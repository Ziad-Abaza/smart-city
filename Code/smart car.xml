import pytest
from autonomous_navigation.safety_monitor import SafetyMonitor
from autonomous_navigation.mission_types import VehicleState, MissionCommand

def test_safety_monitor_permits_activation():
    monitor = SafetyMonitor()
    vs = VehicleState(0.0, 0.0, 0.0, 0.0, True, 1.0)
    
    assert monitor.permits_activation(vs) == True
    
    monitor.pause()
    assert monitor.permits_activation(vs) == False
    
    monitor.resume()
    assert monitor.permits_activation(vs) == True
    
    monitor.trigger_emergency_stop()
    assert monitor.permits_activation(vs) == False

def test_safety_monitor_watchdog():
    monitor = SafetyMonitor(watchdog_timeout_s=2.0)
    
    # New mission starts
    assert monitor.update_mission_health(mission_id=1, current_time=1.0) == True
    
    # 1 second later, still healthy
    assert monitor.update_mission_health(mission_id=1, current_time=2.0) == True
    
    # 2.1 seconds later, watchdog expires
    assert monitor.update_mission_health(mission_id=1, current_time=3.1) == False
    
    # Clear tracking
    monitor.clear_mission_tracking()
    
    # Start fresh
    assert monitor.update_mission_health(mission_id=2, current_time=4.0) == True

def test_safety_monitor_override():
    monitor = SafetyMonitor()
    normal_cmd = MissionCommand(0.5, 0.1, "LANE_FOLLOWING", {"info": "normal"})
    
    # Normal pass-through
    result = monitor.apply_safety_override(normal_cmd)
    assert result.throttle == 0.5
    assert result.steering == 0.1
    assert result.nav_state_label == "LANE_FOLLOWING"
    
    # Paused
    monitor.pause()
    result = monitor.apply_safety_override(normal_cmd)
    assert result.throttle == 0.0
    assert result.steering == 0.0
    assert result.nav_state_label == "PAUSED"
    
    # Emergency stopped
    monitor.resume()
    monitor.trigger_emergency_stop()
    result = monitor.apply_safety_override(normal_cmd)
    assert result.throttle == 0.0
    assert result.steering == 0.0
    assert result.nav_state_label == "EMERGENCY_STOP"
    assert result.debug_annotations == {"info": "normal"} # retains debug info
