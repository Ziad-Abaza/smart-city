import numpy as np
import math
from autonomous_navigation.pose_utils import compute_marker_pose

def test_compute_marker_pose_straight_ahead():
    tvec = np.array([0.0, 0.0, 1.0])
    distance, lat_offset, bearing = compute_marker_pose(tvec)
    
    assert distance == pytest.approx(1.0)
    assert lat_offset == pytest.approx(0.0)
    assert bearing == pytest.approx(0.0)

def test_compute_marker_pose_to_the_right():
    tvec = np.array([1.0, 0.0, 1.0])
    distance, lat_offset, bearing = compute_marker_pose(tvec)
    
    assert distance == pytest.approx(math.sqrt(2))
    assert lat_offset == pytest.approx(1.0)
    assert bearing == pytest.approx(math.pi / 4) # 45 degrees right

def test_compute_marker_pose_to_the_left():
    tvec = np.array([-1.0, 0.0, 1.0])
    distance, lat_offset, bearing = compute_marker_pose(tvec)
    
    assert distance == pytest.approx(math.sqrt(2))
    assert lat_offset == pytest.approx(-1.0)
    assert bearing == pytest.approx(-math.pi / 4) # 45 degrees left

def test_compute_marker_pose_shape_handling():
    # Test column vector shape (3, 1) as output by solvePnP
    tvec = np.array([[2.0], [0.0], [0.0]])
    distance, lat_offset, bearing = compute_marker_pose(tvec)
    
    assert distance == pytest.approx(2.0)
    assert lat_offset == pytest.approx(2.0)
    assert bearing == pytest.approx(math.pi / 2) # 90 degrees right

def test_compute_marker_pose_invalid_shape():
    with pytest.raises(ValueError):
        compute_marker_pose(np.array([1.0, 2.0]))
