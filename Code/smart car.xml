# =============================================================================
# main_auto.py — Hybrid Autonomous Navigation System (v3)
#
# Orchestrates AI Lane Following and ArUco Event Handling.
# =============================================================================

import cv2
import time
import signal
import logging
from camera import Camera
from motor_controller import MotorController
from imu_reader import IMUReader
from autonomous_navigation.ai_driver import AIDriver
from autonomous_navigation.navigator_v2 import NavigatorV2
from autonomous_navigation.telemetry import TelemetryHUD
from ArUco.aruco_detector import ArUcoDetector
from autonomous_navigation.marker_tracker import MarkerTracker
from autonomous_navigation.mission_manager import MissionManager
from autonomous_navigation.safety_monitor import SafetyMonitor
from autonomous_navigation.marker_registry import MarkerRegistry

# Import mission modules so they auto-register with MissionFactory
import autonomous_navigation.trivial_missions
import autonomous_navigation.basic_missions
import autonomous_navigation.complex_missions

from config import ArUcoConfig, DriveConfig

# Configure logging
logging.basicConfig(
    level=logging.INFO,
    format='[%(asctime)s] %(levelname)s — %(message)s',
    datefmt='%H:%M:%S'
)
logger = logging.getLogger(__name__)

def main():
    print("=" * 60)
    print("  HYBRID AUTONOMOUS NAVIGATION SYSTEM V4")
    print("  SPACE=pause  R=resume  Q=quit")
    print("=" * 60)

    # 1. Initialize Hardware
    cam = Camera(publish=True)
    motors = MotorController()
    imu = IMUReader()
    
    # 2. Initialize Navigation Components
    try:
        ai_driver = AIDriver()
        
        # New Mission System stack
        aruco_detector = ArUcoDetector(marker_size_meters=ArUcoConfig.MARKER_SIZE)
        marker_tracker = MarkerTracker()
        safety_monitor = SafetyMonitor()
        registry = MarkerRegistry(config_path='mission_registry.json')
        mission_manager = MissionManager(registry, safety_monitor)
        
        navigator = NavigatorV2(
            ai_driver=ai_driver,
            aruco_detector=aruco_detector,
            marker_tracker=marker_tracker,
            mission_manager=mission_manager,
            safety_monitor=safety_monitor,
            base_speed=DriveConfig.BASE_SPEED
        )
        
        hud = TelemetryHUD()
        logger.info("Navigation components initialized.")
    except Exception as e:
        logger.error(f"Initialization failed: {e}")
        return

    # 3. State Management
    running = [True]
    def shutdown_handler(sig, frame):
        logger.info("Shutdown signal received.")
        running[0] = False
    
    signal.signal(signal.SIGINT,  shutdown_handler)
    signal.signal(signal.SIGTERM, shutdown_handler)

    cam.start()
    imu.start()
    navigator.start()
    
    frame_count = 0
    
    try:
        while running[0]:
            t_loop_start = time.time()

            # A. Capture
            frame = cam.frame
            imu_data = imu.latest
            current_yaw = imu_data.get('yaw', 0.0)

            if frame is None:
                time.sleep(0.01)
                continue

            # B. Keyboard Interaction removed for headless launcher mode

            # D. Update Navigation (The Brain)
            state_name, throttle, steering, aruco_results = navigator.update(
                frame, 
                current_yaw=current_yaw
            )
            
            # D. Actuation
            motors.move(throttle, steering)

            # E. Telemetry & HUD
            fps = 1.0 / (time.time() - t_loop_start)
            frame = hud.draw(frame, state_name, throttle, steering, fps, results=aruco_results)
            
            frame_count += 1
            if frame_count % 50 == 0:
                logger.info(f"State: {state_name} | FPS: {fps:.1f} | Marker Count: {len(aruco_results)}")

    except Exception as e:
        logger.exception(f"Critical error in main loop: {e}")
    finally:
        logger.info("Cleaning up resources...")
        navigator.stop()
        motors.stop()
        motors.close()
        cam.stop()
        imu.stop()
        print("System safely stopped.")

if __name__ == "__main__":
    main()
