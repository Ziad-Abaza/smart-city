import json
from typing import Dict, List, Set
from .mission_types import MissionDefinition, TriggerDirection, RecoveryBehaviour

from .mission_factory import MissionFactory

class ConfigValidationError(Exception):
    """Raised when mission configuration is invalid."""
    pass

def parse_mission_definition(raw: dict) -> MissionDefinition:
    # Validate mission_type
    mission_type = raw.get("mission_type")
    if mission_type not in MissionFactory.get_registered_types():
        raise ConfigValidationError(f"Unknown mission_type '{mission_type}' for marker {raw.get('marker_id')}")

    # Parse enums
    try:
        direction = TriggerDirection(raw.get("trigger_direction", "approach").lower())
    except ValueError:
        raise ConfigValidationError(f"Invalid trigger_direction for marker {raw.get('marker_id')}")

    try:
        recovery = RecoveryBehaviour(raw.get("recovery_behaviour", "return_to_lane_center").lower())
    except ValueError:
        raise ConfigValidationError(f"Invalid recovery_behaviour for marker {raw.get('marker_id')}")

    return MissionDefinition(
        marker_id=int(raw["marker_id"]),
        mission_type=mission_type,
        trigger_distance=float(raw.get("trigger_distance", 1.0)),
        trigger_direction=direction,
        cooldown_s=float(raw.get("cooldown_s", 5.0)),
        priority=int(raw.get("priority", 0)),
        activation_rules=raw.get("activation_rules", []),
        required_vehicle_state=set(raw.get("required_vehicle_state", [])),
        required_mission_state=set(raw.get("required_mission_state", [])),
        repeatable=bool(raw.get("repeatable", True)),
        safety_conditions=raw.get("safety_conditions", []),
        recovery_behaviour=recovery,
        params=raw.get("params", {})
    )

def load_mission_config(filepath: str) -> Dict[int, MissionDefinition]:
    """
    Loads mission definitions from a JSON file.
    Performs load-time validation for missing keys, invalid enums, unknown types, 
    and duplicate marker IDs.
    """
    with open(filepath, 'r') as f:
        data = json.load(f)
        
    if not isinstance(data, list):
        raise ConfigValidationError("Configuration root must be a list of missions.")

    registry = {}
    for raw in data:
        if "marker_id" not in raw:
            raise ConfigValidationError("Mission configuration missing required 'marker_id' field.")
            
        marker_id = int(raw["marker_id"])
        
        if marker_id in registry:
            raise ConfigValidationError(f"Duplicate marker_id found: {marker_id}")
            
        registry[marker_id] = parse_mission_definition(raw)
        
    return registry
