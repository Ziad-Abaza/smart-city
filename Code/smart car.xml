import psutil
import time
from PySide6.QtWidgets import QWidget, QVBoxLayout, QLabel, QFormLayout
from PySide6.QtCore import QTimer

class SystemStatusWidget(QWidget):
    def __init__(self, pm, lm, camera_bridge):
        super().__init__()
        self.pm = pm
        self.lm = lm
        self.camera_bridge = camera_bridge
        
        layout = QVBoxLayout(self)
        layout.setContentsMargins(5, 5, 5, 5)
        form = QFormLayout()
        
        self.lbl_mode = QLabel("Idle")
        self.lbl_uptime = QLabel("00:00")
        self.lbl_cpu = QLabel("0%")
        self.lbl_ram = QLabel("0 MB / 0 MB")
        
        self.lbl_hw_camera = QLabel("Idle")
        self.lbl_hw_gpio = QLabel("Unknown")
        self.lbl_hw_imu = QLabel("Unknown")
        self.lbl_hw_ps4 = QLabel("Unknown")
        
        form.addRow("Current Mode:", self.lbl_mode)
        form.addRow("Uptime:", self.lbl_uptime)
        form.addRow("CPU:", self.lbl_cpu)
        form.addRow("RAM:", self.lbl_ram)
        form.addRow("Camera:", self.lbl_hw_camera)
        form.addRow("GPIO/Motors:", self.lbl_hw_gpio)
        form.addRow("IMU (I2C):", self.lbl_hw_imu)
        form.addRow("PS4 Controller:", self.lbl_hw_ps4)
        
        layout.addLayout(form)
        
        self.update_timer = QTimer(self)
        self.update_timer.timeout.connect(self._update_system_stats)
        self.update_timer.start(1000)
        
        self.current_running_mode = None
        self.mode_start_time = 0
        
        self.pm.processStateChanged.connect(self._on_process_state_changed)
        self.lm.newLine.connect(self._on_log_line)
        self.camera_bridge.statusChanged.connect(self._on_camera_status)
        
        # Initial status updates
        self._update_system_stats()

    def _update_system_stats(self):
        try:
            cpu = psutil.cpu_percent()
            mem = psutil.virtual_memory()
            self.lbl_cpu.setText(f"{cpu}%")
            self.lbl_ram.setText(f"{mem.used // 1048576} MB / {mem.total // 1048576} MB")
        except:
            pass
            
        if self.current_running_mode:
            elapsed = int(time.time() - self.mode_start_time)
            mins, secs = divmod(elapsed, 60)
            self.lbl_uptime.setText(f"{mins:02d}:{secs:02d}")
        else:
            self.lbl_uptime.setText("00:00")

    def _on_process_state_changed(self, mode_name, state):
        if state == "Running":
            self.current_running_mode = mode_name
            self.lbl_mode.setText(mode_name)
            p = self.pm.get_process(mode_name)
            self.mode_start_time = p.start_time
            
            self.lbl_hw_gpio.setText("OK (assumed)")
            self.lbl_hw_gpio.setStyleSheet("color: black;")
            self.lbl_hw_imu.setText("OK (assumed)")
            self.lbl_hw_imu.setStyleSheet("color: black;")
            self.lbl_hw_ps4.setText("Unknown")
            self.lbl_hw_ps4.setStyleSheet("color: black;")
        elif state in ["Stopped", "Crashed"]:
            if self.current_running_mode == mode_name:
                self.current_running_mode = None
                self.lbl_mode.setText("Idle")
                self.lbl_uptime.setText("00:00")

    def _on_camera_status(self, status):
        self.lbl_hw_camera.setText(status)
        if "Error" in status:
            self.lbl_hw_camera.setStyleSheet("color: red;")
        elif "In Use" in status:
            self.lbl_hw_camera.setStyleSheet("color: orange;")
        else:
            self.lbl_hw_camera.setStyleSheet("color: green;")

    def _on_log_line(self, mode_name, stream, formatted_text, color_hint):
        lower = formatted_text.lower()
        if "gpio stack unavailable" in lower or "gpiozero import failed" in lower:
            self.lbl_hw_gpio.setText("Unavailable")
            self.lbl_hw_gpio.setStyleSheet("color: red;")
            
        if "imu" in lower and ("failed" in lower or "error" in lower or "unavailable" in lower):
            self.lbl_hw_imu.setText("Unavailable/Error")
            self.lbl_hw_imu.setStyleSheet("color: red;")
            
        if "joystick connected" in lower:
            self.lbl_hw_ps4.setText("Connected")
            self.lbl_hw_ps4.setStyleSheet("color: green;")
        elif "no joystick" in lower or "joystick disconnected" in lower:
            self.lbl_hw_ps4.setText("Disconnected")
            self.lbl_hw_ps4.setStyleSheet("color: red;")
