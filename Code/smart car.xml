import time
from typing import Optional
from .mission_types import VehicleState, MissionCommand

class SafetyMonitor:
    """
    Cross-cutting safety logic. 
    Always outranks any active mission, can force an abort or emergency stop,
    and enforces overall watchdog timeouts.
    """
    def __init__(self, watchdog_timeout_s: float = 4.0):
        self.watchdog_timeout_s = watchdog_timeout_s
        self._paused = False
        self._emergency_stopped = False
        
        self._active_mission_id = None
        self._active_mission_start_time = 0.0

    def pause(self):
        self._paused = True

    def resume(self):
        self._paused = False
        self._emergency_stopped = False
        self._active_mission_id = None

    def trigger_emergency_stop(self):
        self._emergency_stopped = True

    @property
    def is_paused(self) -> bool:
        return self._paused

    @property
    def is_emergency_stopped(self) -> bool:
        return self._emergency_stopped

    def permits_activation(self, vehicle_state: VehicleState) -> bool:
        """Evaluates if it's currently safe to start a new mission."""
        if self._paused or self._emergency_stopped:
            return False
        # Add future checks here (e.g., speed bounds, lane visibility requirements)
        return True

    def update_mission_health(self, mission_id: int, current_time: float) -> bool:
        """
        Tracks how long a mission has been active.
        Returns True if healthy, False if it should be cancelled (e.g. watchdog expired).
        """
        if self._active_mission_id != mission_id:
            self._active_mission_id = mission_id
            self._active_mission_start_time = current_time
            return True
            
        elapsed = current_time - self._active_mission_start_time
        if elapsed > self.watchdog_timeout_s:
            return False
        return True

    def clear_mission_tracking(self):
        """Called when a mission completes or is aborted normally."""
        self._active_mission_id = None

    def apply_safety_override(self, cmd: MissionCommand) -> MissionCommand:
        """
        Unconditionally forces throttle/steering to zero if safety requires it.
        """
        if self._emergency_stopped:
            return MissionCommand(0.0, 0.0, "EMERGENCY_STOP", cmd.debug_annotations)
        if self._paused:
            return MissionCommand(0.0, 0.0, "PAUSED", cmd.debug_annotations)
        return cmd
