import random
from abc import ABC, abstractmethod

class RouteDecisionStrategy(ABC):
    """
    Interface for deciding whether to take an alternative branch at an intersection.
    """
    @abstractmethod
    def should_branch(self, params: dict) -> bool:
        pass

class RandomRouteStrategy(RouteDecisionStrategy):
    """
    Decides to branch based on a configured probability.
    Used for unpredictable roaming.
    """
    def should_branch(self, params: dict) -> bool:
        probability = float(params.get("branch_probability", 0.5))
        return random.random() < probability
