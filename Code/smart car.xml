from typing import List

@dataclass
class ModeSpec:
    name: str
    command: str
    args: List[str]
    cwd: str
    is_driving_mode: bool
    requires_camera: bool
    
    @property
    def exclusivity_group(self) -> str:
        if self.is_driving_mode:
