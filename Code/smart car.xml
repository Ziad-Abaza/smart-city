# =============================================================================
# imu_reader.py — MPU-6050 IMU Reader with Calibration
# Provides: yaw rate, acceleration, and integrated heading
# =============================================================================

import time
import threading
import logging
import numpy as np

logger = logging.getLogger(__name__)

try:
    import smbus2
    I2C_AVAILABLE = True
except ImportError:
    smbus2 = None
    I2C_AVAILABLE = False

from config import IMUConfig

_WHO_AM_I = 0x75
_MPU6050_DEVICE_ID = 0x68


# ─── MPU-6050 Register Map ───────────────────────────────────────────────────
_PWR_MGMT_1   = 0x6B
_SMPLRT_DIV   = 0x19
_CONFIG_REG   = 0x1A
_GYRO_CONFIG  = 0x1B
_ACCEL_CONFIG = 0x1C
_ACCEL_XOUT   = 0x3B
_GYRO_XOUT    = 0x43
_TEMP_OUT     = 0x41


class IMUReader:
    """
    Reads from MPU-6050 over I2C.

    Provides:
      - Raw accelerometer (ax, ay, az) in g
      - Raw gyroscope (gx, gy, gz) in deg/s
      - Integrated yaw angle (degrees) with bias correction
      - Running in a background thread at SAMPLE_RATE Hz

    Usage:
        imu = IMUReader()
        imu.start()
        ...
        data = imu.latest
        # {'ax':..., 'ay':..., 'az':..., 'gx':..., 'gy':..., 'gz':..., 'yaw':...}
        imu.stop()
    """

    def __init__(self):
        self._bus      = None
        self._addr     = IMUConfig.I2C_ADDRESS
        self._hardware_ready = False
        self._lock     = threading.Lock()
        self._thread   = None
        self._running  = False
        self._dt       = 1.0 / IMUConfig.SAMPLE_RATE

        # Bias offsets (computed during calibration)
        self._gyro_bias  = np.zeros(3)   # [gx, gy, gz] bias in deg/s
        self._accel_bias = np.zeros(3)   # [ax, ay, az] bias in g

        # Integrated yaw (degrees, positive = clockwise when viewed from top)
        self._yaw = 0.0

        # Latest reading
        self._data = {
            'ax': 0.0, 'ay': 0.0, 'az': 1.0,
            'gx': 0.0, 'gy': 0.0, 'gz': 0.0,
            'yaw': 0.0, 'yaw_rate': 0.0,
            'temp_c': 25.0, 'timestamp': time.time()
        }

        self._init_hardware()

    # ──────────────────────────────────────────
    #  Hardware Init
    # ──────────────────────────────────────────

    def _init_hardware(self):
        if not I2C_AVAILABLE:
            raise RuntimeError(
                "[IMU] smbus2 is not installed. "
                "Install with: pip install smbus2 (on Raspberry Pi only)."
            )
        try:
            bus_id = int(getattr(IMUConfig, "I2C_BUS", 1))
            self._bus = smbus2.SMBus(bus_id)
            self._bus.write_byte_data(self._addr, _PWR_MGMT_1, 0x00)   # Wake up
            time.sleep(0.1)
            device_id = self._bus.read_byte_data(self._addr, _WHO_AM_I)
            if device_id != _MPU6050_DEVICE_ID:
                raise RuntimeError(
                    f"WHO_AM_I=0x{device_id:02X}, expected 0x{_MPU6050_DEVICE_ID:02X}"
                )
            self._bus.write_byte_data(self._addr, _SMPLRT_DIV, 0x07)   # 1kHz / 8 = 125Hz
            self._bus.write_byte_data(self._addr, _CONFIG_REG, 0x00)   # No DLPF
            self._bus.write_byte_data(self._addr, _GYRO_CONFIG, 0x00)  # ±250 °/s
            self._bus.write_byte_data(self._addr, _ACCEL_CONFIG, 0x00) # ±2g
            self._hardware_ready = True
            logger.info(
                f"[IMU] MPU-6050 initialized on I2C bus {bus_id} at 0x{self._addr:02X}"
            )
        except Exception as e:
            self._bus = None
            self._hardware_ready = False
            raise RuntimeError(
                f"[IMU] MPU-6050 not available at 0x{self._addr:02X}: {e}. "
                "Check wiring, enable I2C (raspi-config), and run: i2cdetect -y 1"
            ) from e

    # ──────────────────────────────────────────
    #  Background Thread
    # ──────────────────────────────────────────

    def start(self):
        """Start background reading thread and calibrate."""
        if not self._hardware_ready:
            raise RuntimeError("[IMU] Cannot start — MPU-6050 hardware is not ready.")
        self._calibrate()
        self._running = True
        self._thread  = threading.Thread(target=self._run, daemon=True)
        self._thread.start()
        logger.info("[IMU] Background thread started.")

    def stop(self):
        self._running = False
        if self._thread:
            self._thread.join(timeout=2.0)

    def reset_yaw(self):
        """Reset integrated yaw to 0 — call at start of each run."""
        with self._lock:
            self._yaw = 0.0

    # ──────────────────────────────────────────
    #  Calibration
    # ──────────────────────────────────────────

    def _calibrate(self):
        """
        Collect N stationary samples to compute gyro/accel bias.
        Car must be completely still during this phase.
        """
        n = IMUConfig.CALIBRATION_SAMPLES
        logger.info(f"[IMU] Calibrating over {n} samples — keep car still...")

        gyro_acc  = np.zeros(3)
        accel_acc = np.zeros(3)

        for _ in range(n):
            r = self._read_raw()
            gyro_acc  += np.array([r['gx'], r['gy'], r['gz']])
            accel_acc += np.array([r['ax'], r['ay'], r['az']])
            time.sleep(0.005)

        self._gyro_bias  = gyro_acc / n
        self._accel_bias = accel_acc / n
        self._accel_bias[2] -= 1.0   # Keep gravity on Z axis

        logger.info(f"[IMU] Gyro bias:  {self._gyro_bias.round(4)}")
        logger.info(f"[IMU] Accel bias: {self._accel_bias.round(4)}")

    # ──────────────────────────────────────────
    #  Read Loop
    # ──────────────────────────────────────────

    def _run(self):
        interval = self._dt
        while self._running:
            t0 = time.time()

            try:
                raw = self._read_raw()
                gz = raw['gz'] - self._gyro_bias[2]   # Yaw rate (Z-axis)

                with self._lock:
                    self._yaw += gz * interval
                    self._data = {
                        'ax':       raw['ax'] - self._accel_bias[0],
                        'ay':       raw['ay'] - self._accel_bias[1],
                        'az':       raw['az'] - self._accel_bias[2],
                        'gx':       raw['gx'] - self._gyro_bias[0],
                        'gy':       raw['gy'] - self._gyro_bias[1],
                        'gz':       gz,
                        'yaw':      self._yaw,
                        'yaw_rate': gz,
                        'temp_c':   raw['temp_c'],
                        'timestamp': time.time()
                    }
            except Exception as e:
                logger.warning(f"[IMU] Read error: {e}")

            elapsed = time.time() - t0
            sleep_t = max(0.0, interval - elapsed)
            time.sleep(sleep_t)

    # ──────────────────────────────────────────
    #  Raw I2C Read
    # ──────────────────────────────────────────

    def _read_raw(self) -> dict:
        """Read all 6 axes + temperature from MPU-6050 registers."""
        def read_word(reg):
            hi = self._bus.read_byte_data(self._addr, reg)
            lo = self._bus.read_byte_data(self._addr, reg + 1)
            val = (hi << 8) | lo
            return val - 65536 if val >= 32768 else val

        return {
            'ax': read_word(_ACCEL_XOUT)     / IMUConfig.ACCEL_SCALE,
            'ay': read_word(_ACCEL_XOUT + 2) / IMUConfig.ACCEL_SCALE,
            'az': read_word(_ACCEL_XOUT + 4) / IMUConfig.ACCEL_SCALE,
            'gx': read_word(_GYRO_XOUT)      / IMUConfig.GYRO_SCALE,
            'gy': read_word(_GYRO_XOUT + 2)  / IMUConfig.GYRO_SCALE,
            'gz': read_word(_GYRO_XOUT + 4)  / IMUConfig.GYRO_SCALE,
            'temp_c': read_word(_TEMP_OUT) / 340.0 + 36.53,
        }

    # ──────────────────────────────────────────
    #  Public API
    # ──────────────────────────────────────────

    @property
    def hardware_ready(self) -> bool:
        return self._hardware_ready

    @property
    def latest(self) -> dict:
        """Thread-safe access to latest IMU reading."""
        with self._lock:
            return dict(self._data)

    @property
    def yaw(self) -> float:
        with self._lock:
            return self._yaw

    @property
    def yaw_rate(self) -> float:
        with self._lock:
            return self._data['yaw_rate']
</file>

