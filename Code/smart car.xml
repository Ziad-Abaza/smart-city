# =============================================================================
# ps4_controller.py - Direct Linux joystick reader
# Handles analog stick input (Left Y for throttle, Right X for steering)
# and button events (R1 for recording, Circle for pause).
#
# Improvements merged from legacy pygame flow + production safety:
#   - Time-based exponential smoothing (updates every get_commands poll, not
#     only on kernel events) avoids laggy neutral and "stuck" smoothed values.
#   - Stale axis watchdog zeros input if the device goes quiet (disconnect).
#   - Signed power curves soften small stick deflections (stable, controllable).
# =============================================================================

import errno
import logging
import math
import os
import struct
import threading
import time

from config import PS4Config
from led_indicator import LEDIndicator

logger = logging.getLogger(__name__)


class PS4CarController:
    """
    Reads PS4/JS controller events from /dev/input/js0.

    Mapping (Linux Standard):
      Axis 1: Left Stick Y (Up=-32767, Down=32767)
      Axis 3: Right Stick X (Left=-32767, Right=32767)
      Button 5: R1
      Button 1: Circle
    """

    JS_EVENT_BUTTON = 0x01
    JS_EVENT_AXIS = 0x02
    JS_EVENT_INIT = 0x80
    JS_EVENT_FORMAT = "IhBB"
    JS_EVENT_SIZE = struct.calcsize(JS_EVENT_FORMAT)

    # Standard DS4 /dev/input/js0 mappings
    AXIS_LEFT_Y = 1
    AXIS_RIGHT_X = 3

    BUTTON_CIRCLE = 1
    BUTTON_L1 = 4
    BUTTON_R1 = 5

    def __init__(self, motor_controller=None, imu_reader=None, interface="/dev/input/js0", **kwargs):
        self.motors = motor_controller
        self.imu = imu_reader
        self.interface = interface

        self.deadzone = PS4Config.DEADZONE
        self.throttle_limit = PS4Config.THROTTLE_LIMIT
        self.turn_limit = PS4Config.TURN_LIMIT
        self.tau_throttle = PS4Config.TAU_THROTTLE
        self.tau_turn = PS4Config.TAU_TURN
        self.stale_axis_timeout = PS4Config.STALE_AXIS_TIMEOUT
        self.throttle_curve_exp = PS4Config.THROTTLE_CURVE_EXP
        self.turn_curve_exp = PS4Config.TURN_CURVE_EXP

        self._raw_throttle = 0.0
        self._raw_turn = 0.0
        self._throttle = 0.0
        self._turn = 0.0

        self._last_axis_event_time = time.monotonic()
        self._last_poll_time = None

        self._recording_enabled = False
        self._paused = False
        self._recovery_mode = False
        self._quit_flag = False

        self._running = False
        self._thread = None
        self._fd = None
        self._lock = threading.Lock()

        # Hardware status indicators (LEDs)
        self.leds = LEDIndicator()

    @staticmethod
    def _signed_power(x: float, exponent: float) -> float:
        """Preserve sign; |x|<=1; exponent>1 dampens small magnitudes."""
        if exponent <= 0.0:
            return x
        ax = abs(x)
        if ax < 1e-9:
            return 0.0
        return math.copysign(ax ** exponent, x)

    def _normalize_axis(self, value):
        """Map -32767..32767 to -1.0..1.0 with deadzone."""
        normalized = max(-1.0, min(1.0, value / 32767.0))
        if abs(normalized) < self.deadzone:
            return 0.0
        # Renormalize so edge of deadzone maps smoothly to usable range
        span = 1.0 - self.deadzone
        mag = (abs(normalized) - self.deadzone) / span
        return math.copysign(mag, normalized)

    def _handle_axis(self, axis, value):
        normalized = self._normalize_axis(value)
        with self._lock:
            self._last_axis_event_time = time.monotonic()
            # Axis 1 = Vertical (Throttle), Axis 3 = Horizontal (Steering)
            if axis == self.AXIS_LEFT_Y:
                # Up on stick is negative; we want positive for forward
                shaped = self._signed_power(normalized, self.throttle_curve_exp)
                self._raw_throttle = -shaped * self.throttle_limit
            elif axis == self.AXIS_RIGHT_X:
                # Right is positive; steering positive = right turn
                shaped = self._signed_power(normalized, self.turn_curve_exp)
                self._raw_turn = shaped * self.turn_limit

    def _handle_button(self, button, pressed):
        if not pressed:
            return

        with self._lock:
            if button == self.BUTTON_R1:
                self._recording_enabled = not self._recording_enabled
                # LED is ON if recording is enabled AND not paused
                self.leds.set_normal_recording(self._recording_enabled and not self._paused)
                logger.info(
                    "[PS4] Recording %s",
                    "ENABLED" if self._recording_enabled else "DISABLED",
                )
            elif button == self.BUTTON_CIRCLE:
                self._paused = not self._paused
                # Update both LEDs when pause state changes
                self.leds.set_normal_recording(self._recording_enabled and not self._paused)
                self.leds.set_recovery_recording(self._recovery_mode and not self._paused)
                logger.info(
                    "[PS4] %s",
                    "PAUSED" if self._paused else "RESUMED",
                )
            elif button == self.BUTTON_L1:
                self._recovery_mode = not self._recovery_mode
                # LED is ON if recovery mode is enabled AND not paused
                self.leds.set_recovery_recording(self._recovery_mode and not self._paused)
                logger.info(
                    "[PS4] Recovery Mode %s",
                    "ENABLED" if self._recovery_mode else "DISABLED",
                )

    def _open_device(self):
        """Attempt to open the joystick device with retries."""
        if self._fd is not None:
            try:
                os.close(self._fd)
            except OSError:
                pass
            self._fd = None

        if os.path.exists(self.interface):
            try:
                self._fd = os.open(self.interface, os.O_RDONLY | os.O_NONBLOCK)
                logger.info("[PS4] Successfully bound to: %s", self.interface)
                return True
            except OSError as e:
                logger.error("[PS4] Error opening %s: %s", self.interface, e)
        return False

    def _event_loop(self):
        while self._running:
            if self._fd is None:
                if not self._open_device():
                    time.sleep(2.0)
                    continue

            try:
                event = os.read(self._fd, self.JS_EVENT_SIZE)
                if not event or len(event) != self.JS_EVENT_SIZE:
                    time.sleep(0.001)
                    continue

                _, value, event_type, number = struct.unpack(self.JS_EVENT_FORMAT, event)
                actual_type = event_type & ~self.JS_EVENT_INIT

                if actual_type == self.JS_EVENT_AXIS:
                    self._handle_axis(number, value)
                elif actual_type == self.JS_EVENT_BUTTON:
                    self._handle_button(number, bool(value))

            except OSError as e:
                if e.errno in (errno.EAGAIN, errno.EWOULDBLOCK):
                    time.sleep(0.001)
                    continue
                logger.error("[PS4] Joystick disconnected or error: %s", e)
                self._fd = None
                with self._lock:
                    self._raw_throttle = 0.0
                    self._raw_turn = 0.0
            except Exception as e:
                logger.error("[PS4] Unexpected error in event loop: %s", e)
                time.sleep(1.0)

    def listen(self):
        """Start the background thread to read joystick events."""
        if self._running:
            return
        self._running = True
        self._thread = threading.Thread(target=self._event_loop, daemon=True)
        self._thread.start()
        logger.info("[PS4] Listener thread started.")
        return self._thread

    def stop_listening(self):
        self._running = False
        if self._thread is not None:
            self._thread.join(timeout=1.0)
        if self._fd is not None:
            os.close(self._fd)
            self._fd = None
        self.leds.close()

    def _smooth_step(self, target: float, current: float, tau: float, dt: float) -> float:
        """First-order lag toward target; stable for variable dt."""
        if tau <= 1e-6:
            return target
        alpha = 1.0 - math.exp(-dt / tau)
        return alpha * target + (1.0 - alpha) * current

    def get_commands(self):
        """
        Returns smoothed control values. Smoothing runs here on every poll so
        output decays correctly toward neutral even when the kernel sends no
        further axis packets (legacy pygame loop had implicit pump every frame).
        """
        now = time.monotonic()
        with self._lock:
            if self._last_poll_time is None:
                dt = 0.02
            else:
                dt = min(0.12, max(0.0, now - self._last_poll_time))
            self._last_poll_time = now

            # STALE AXIS TIMEOUT REMOVED - Controller input will persist
            # This allows continuous movement without needing repeated events
            
            self._throttle = self._smooth_step(
                self._raw_throttle, self._throttle, self.tau_throttle, dt
            )
            self._turn = self._smooth_step(
                self._raw_turn, self._turn, self.tau_turn, dt
            )

            return {
                "throttle": self._throttle,
                "turn": self._turn,
                "quit": self._quit_flag,
                "reset_imu": False,
                "emergency_stop": False,
                "recording": self._recording_enabled,
                "paused": self._paused,
                "recovery": self._recovery_mode,
            }

    def reset_flags(self):
        """Resets transient flags if needed."""
        pass
