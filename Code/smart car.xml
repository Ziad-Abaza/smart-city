"""
=============================================================================
merge_datasets.py — Autonomous Driving Dataset Consolidation Tool
=============================================================================

This script merges multiple data collection sessions into a single unified 
dataset ready for training. It handles path resolution, image copying, 
name collision prevention, and data validation.

Usage:
    python merge_datasets.py --input DataCollected --output MergedDataset
"""

import os
import shutil
import logging
import argparse
from pathlib import Path
from typing import List, Dict, Any, Optional
from datetime import datetime

import pandas as pd
from tqdm import tqdm

# ─────────────────────────────────────────────
#  Configuration & Logging Setup
# ─────────────────────────────────────────────

def setup_logging(output_dir: Path):
    """Configures logging to both console and a file."""
    output_dir.mkdir(parents=True, exist_ok=True)
    report_path = output_dir / "merge_report.txt"
    
    logging.basicConfig(
        level=logging.INFO,
        format='[%(asctime)s] %(levelname)s: %(message)s',
        handlers=[
            logging.FileHandler(report_path, mode='w', encoding='utf-8'),
            logging.StreamHandler()
        ]
    )
    return report_path

# ─────────────────────────────────────────────
#  Core Dataset Merger
# ─────────────────────────────────────────────

class DatasetMerger:
    def __init__(self, input_root: str, output_root: str):
        self.input_root = Path(input_root)
        self.output_root = Path(output_root)
        self.merged_img_dir = self.output_root / "IMG"
        self.merged_csv_path = self.output_root / "driving_log.csv"
        
        # Stats tracking
        self.stats = {
            "total_sessions": 0,
            "total_rows_found": 0,
            "total_images_copied": 0,
            "skipped_rows": 0,
            "missing_images": 0,
            "duplicate_frame_ids_fixed": 0,
            "errors": 0
        }

    def validate_setup(self, overwrite: bool = False):
        """Checks if input exists and handles output directory safety."""
        if not self.input_root.exists():
            raise FileNotFoundError(f"Input directory not found: {self.input_root}")
        
        if self.output_root.exists():
            if not overwrite:
                confirm = input(f"Output directory '{self.output_root}' already exists. Overwrite? (y/n): ")
                if confirm.lower() != 'y':
                    print("Aborted.")
                    exit(0)
            
            # Create backup before deletion
            backup_name = f"{self.output_root.name}_backup_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
            backup_path = self.output_root.parent / backup_name
            logging.info(f"Creating backup of existing dataset to: {backup_path}")
            shutil.move(str(self.output_root), str(backup_path))

        self.output_root.mkdir(parents=True, exist_ok=True)
        self.merged_img_dir.mkdir(parents=True, exist_ok=True)

    def find_sessions(self) -> List[Path]:
        """Finds all directories containing a driving_log.csv."""
        sessions = []
        for p in self.input_root.rglob("driving_log.csv"):
            sessions.append(p.parent)
        return sorted(sessions)

    def process_session(self, session_path: Path) -> pd.DataFrame:
        """Processes a single session folder."""
        csv_path = session_path / "driving_log.csv"
        session_name = session_path.name
        
        try:
            df = pd.read_csv(csv_path)
        except Exception as e:
            logging.error(f"Failed to read CSV {csv_path}: {e}")
            self.stats["errors"] += 1
            return pd.DataFrame()

        new_rows = []
        session_missing_count = 0
        session_missing_examples = []
        
        # We iterate with a progress bar per session for large files
        for _, row in df.iterrows():
            self.stats["total_rows_found"] += 1
            
            # 1. Resolve original image path
            orig_img_path_str = row['center']
            orig_img_path = Path(orig_img_path_str)
            
            # If path in CSV is relative, try to resolve it against session dir
            if not orig_img_path.is_absolute():
                full_orig_path = session_path / orig_img_path
                # Fallback to checking session/IMG/basename
                if not full_orig_path.exists():
                    full_orig_path = session_path / "IMG" / orig_img_path.name
            else:
                full_orig_path = orig_img_path

            # 2. Validation: check if image exists
            if not full_orig_path.exists():
                session_missing_count += 1
                self.stats["missing_images"] += 1
                self.stats["skipped_rows"] += 1
                if len(session_missing_examples) < 10:
                    session_missing_examples.append(str(full_orig_path))
                continue

            # 3. Deterministic new filename to prevent collisions
            # Format: {session_name}_{original_filename}
            new_filename = f"{session_name}_{full_orig_path.name}"
            new_dest_path = self.merged_img_dir / new_filename
            
            # 4. Copy image
            try:
                # Use symlinks if on Linux for efficiency? No, copy is safer for "unified" requirement.
                shutil.copy2(full_orig_path, new_dest_path)
                self.stats["total_images_copied"] += 1
            except Exception as e:
                logging.error(f"Copy failed: {full_orig_path} -> {new_dest_path}: {e}")
                self.stats["skipped_rows"] += 1
                continue

            # 5. Update row data
            new_row = row.to_dict()
            # Update path to be relative to the new merged root
            new_row['center'] = str(Path("IMG") / new_filename)
            new_rows.append(new_row)

        if session_missing_count > 0:
            example_text = ", ".join(session_missing_examples)
            logging.warning(f"[{session_name}] {session_missing_count} missing images skipped (examples: {example_text})")

        return pd.DataFrame(new_rows)

    def run(self, overwrite: bool = False):
        """Main execution loop."""
        self.validate_setup(overwrite)
        report_path = setup_logging(self.output_root)
        
        sessions = self.find_sessions()
        logging.info(f"Found {len(sessions)} sessions in {self.input_root}")
        self.stats["total_sessions"] = len(sessions)

        all_dataframes = []

        for session in tqdm(sessions, desc="Merging Sessions", unit="session"):
            session_df = self.process_session(session)
            if not session_df.empty:
                all_dataframes.append(session_df)

        if not all_dataframes:
            logging.error("No valid data found to merge.")
            return

        # 1. Concatenate all dataframes
        final_df = pd.concat(all_dataframes, ignore_index=True)

        # 2. Global Validation & Cleaning
        initial_len = len(final_df)
        
        # Check for duplicated frame IDs (optional, but requested)
        if 'frame_id' in final_df.columns:
            final_df = final_df.drop_duplicates(subset=['frame_id'], keep='first')
            self.stats["duplicate_frame_ids_fixed"] = initial_len - len(final_df)

        # 3. Final Save
        final_df.to_csv(self.merged_csv_path, index=False)
        
        self.print_summary(report_path)

    def print_summary(self, report_path: Path):
        """Prints a detailed execution summary."""
        summary = f"""
============================================================
  MERGE SUMMARY
============================================================
  Total Sessions Processed : {self.stats['total_sessions']}
  Total Rows Found         : {self.stats['total_rows_found']}
  Total Images Copied      : {self.stats['total_images_copied']}
  Duplicate Frames Removed : {self.stats['duplicate_frame_ids_fixed']}
  Rows Skipped (Errors/Missing): {self.stats['skipped_rows']}
  
  Final CSV Row Count      : {self.stats['total_images_copied'] - self.stats['duplicate_frame_ids_fixed']}
  Final Dataset Location   : {self.output_root}
  Report Saved to          : {report_path}
============================================================
"""
        print(summary)
        logging.info("Merge process completed successfully.")

# ─────────────────────────────────────────────
#  CLI Entry Point
# ─────────────────────────────────────────────

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Merge autonomous driving datasets.")
    parser.add_argument("--input", type=str, default="DataCollected/56", 
                        help="Root directory containing session folders.")
    parser.add_argument("--output", type=str, default="DataCollected/7", 
                        help="Target directory for the unified dataset.")
    parser.add_argument("--overwrite", action="store_true", 
                        help="Overwrite output directory without asking.")
    
    args = parser.parse_args()

    merger = DatasetMerger(args.input, args.output)
    try:
        merger.run(args.overwrite)
    except KeyboardInterrupt:
        print("\nProcess interrupted by user.")
    except Exception as e:
        print(f"\nCRITICAL ERROR: {e}")
        logging.exception("Stack Trace:")
</file>

