import tensorflow as tf
from tensorflow.keras import layers, models

def create_model(input_shape=(66, 200, 3)):
    """
    PilotNet-style CNN for behavioral cloning.
    Optimized for low-latency inference on Raspberry Pi.
    """
    model = models.Sequential([
        # Input Layer
        layers.Input(shape=input_shape),
        
        # Convolutional Layers
        layers.Conv2D(24, (5, 5), strides=(2, 2), activation='relu'),
        layers.BatchNormalization(),
        
        layers.Conv2D(36, (5, 5), strides=(2, 2), activation='relu'),
        layers.BatchNormalization(),
        
        layers.Conv2D(48, (5, 5), strides=(2, 2), activation='relu'),
        layers.BatchNormalization(),
        
        layers.Conv2D(64, (3, 3), activation='relu'),
        layers.BatchNormalization(),
        
        layers.Conv2D(64, (3, 3), activation='relu'),
        layers.BatchNormalization(),
        
        # Flatten and Dense Layers
        layers.Flatten(),
        layers.Dropout(0.5),
        
        layers.Dense(100, activation='relu'),
        layers.Dropout(0.2),
        
        layers.Dense(50, activation='relu'),
        layers.Dense(10, activation='relu'),
        
        # Output Layer: Steering
        layers.Dense(1, name='steering')
    ])
    
    return model

def create_fusion_model(img_input_shape=(66, 200, 3), imu_input_shape=(6,)):
    """
    Hybrid CNN + IMU fusion model.
    Only used if IMU data is found to be beneficial.
    """
    # Image branch
    img_input = layers.Input(shape=img_input_shape, name='image_input')
    x = layers.Conv2D(24, (5, 5), strides=(2, 2), activation='relu')(img_input)
    x = layers.Conv2D(36, (5, 5), strides=(2, 2), activation='relu')(x)
    x = layers.Conv2D(48, (5, 5), strides=(2, 2), activation='relu')(x)
    x = layers.Conv2D(64, (3, 3), activation='relu')(x)
    x = layers.Conv2D(64, (3, 3), activation='relu')(x)
    x = layers.Flatten()(x)
    
    # IMU branch
    imu_input = layers.Input(shape=imu_input_shape, name='imu_input')
    y = layers.Dense(16, activation='relu')(imu_input)
    y = layers.Dense(16, activation='relu')(y)
    
    # Concatenate branches
    combined = layers.concatenate([x, y])
    
    # Dense head
    z = layers.Dense(100, activation='relu')(combined)
    z = layers.Dropout(0.5)(z)
    z = layers.Dense(50, activation='relu')(z)
    z = layers.Dense(10, activation='relu')(z)
    
    output = layers.Dense(1, name='steering')(z)
    
    model = models.Model(inputs=[img_input, imu_input], outputs=output)
    
    return model

if __name__ == "__main__":
    model = create_model()
    model.summary()
