import pytest
from autonomous_navigation.maneuvers import TimedStraightAdvance, YawTargetTurn, BlendedLaneReturn
from autonomous_navigation.mission_types import VehicleState

def create_vs(yaw: float = 0.0, lane_steering: float = 0.0):
    return VehicleState(1.0, yaw, 0.0, lane_steering, True, 1.0)

def test_timed_straight_advance():
    maneuver = TimedStraightAdvance(duration_s=2.0, speed_scale=0.5)
    vs = create_vs()
    
    maneuver.start(vs, 0.0)
    assert not maneuver.is_complete(vs, 1.0)
    
    cmd = maneuver.update(vs, 1.0)
    assert cmd.throttle == 0.5
    assert cmd.steering == 0.0
    
    assert maneuver.is_complete(vs, 2.1)

def test_yaw_target_turn_success():
    maneuver = YawTargetTurn(target_yaw_delta_deg=-90.0, speed_scale=0.7)
    
    # Start at 0 yaw
    maneuver.start(create_vs(yaw=0.0), 0.0)
    
    # Mid-turn
    assert not maneuver.is_complete(create_vs(yaw=-45.0), 1.0)
    cmd = maneuver.update(create_vs(yaw=-45.0), 1.0)
    assert cmd.steering > 0.0 # Turning left requires positive steering
    assert abs(cmd.steering) <= cmd.throttle * 0.9 # Ackermann limit    
    # Reached target (within tolerance)
    assert maneuver.is_complete(create_vs(yaw=-86.0), 2.0)

def test_yaw_target_turn_watchdog():
    maneuver = YawTargetTurn(target_yaw_delta_deg=90.0, max_duration_s=3.0)
    maneuver.start(create_vs(yaw=0.0), 0.0)
    
    assert not maneuver.is_complete(create_vs(yaw=10.0), 2.9)
    # Trip watchdog
    assert maneuver.is_complete(create_vs(yaw=10.0), 3.1)

def test_blended_lane_return():
    maneuver = BlendedLaneReturn(blend_duration_s=1.0)
    maneuver.start(create_vs(lane_steering=0.5), 0.0)
    
    # At 0s, steering is 0
    cmd = maneuver.update(create_vs(lane_steering=0.5), 0.0)
    assert cmd.steering == 0.0
    
    # At 0.5s, steering is 50%
    cmd = maneuver.update(create_vs(lane_steering=0.5), 0.5)
    assert cmd.steering == 0.25
    
    # At 1.0s, steering is 100%
    cmd = maneuver.update(create_vs(lane_steering=0.5), 1.0)
    assert cmd.steering == 0.5
    
    assert maneuver.is_complete(create_vs(lane_steering=0.5), 1.1)


def test_yaw_target_turn_supports_configurable_steering_scale():
    maneuver = YawTargetTurn(target_yaw_delta_deg=-45.0, speed_scale=0.7, steering_scale=0.25)
    maneuver.start(create_vs(yaw=0.0), 0.0)

    cmd = maneuver.update(create_vs(yaw=0.0), 1.0)

    assert abs(cmd.steering) < 0.3
    assert abs(cmd.steering) <= abs(cmd.throttle) * 0.9
