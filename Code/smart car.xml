import pytest
from typing import Optional
from autonomous_navigation.mission_manager import MissionManager
from autonomous_navigation.safety_monitor import SafetyMonitor
from autonomous_navigation.marker_registry import MarkerRegistry
from autonomous_navigation.mission_factory import MissionFactory
from autonomous_navigation.mission_base import Mission, MissionPhase
from autonomous_navigation.mission_types import (
    MissionDefinition, MarkerSighting, VehicleState, MissionCommand, MissionOutcome,
    TriggerDirection, RecoveryBehaviour
)

class DummyMission(Mission):
    def on_pending(self, v, s): return MissionCommand(0.1, 0.0, "PENDING")
    def on_approach(self, v, s): return MissionCommand(0.2, 0.0, "APPROACH")
    def on_prepare(self, v, s): return MissionCommand(0.3, 0.0, "PREPARE")
    def on_execute(self, v, s): return MissionCommand(0.4, 0.0, "EXECUTE")
    def on_recover(self, v, s): return MissionCommand(0.5, 0.0, "RECOVER")
    def on_abort(self, v): pass
    def on_interrupt(self, v, p): pass
    
    def is_phase_complete(self, phase, vs):
        # Auto-advance for test simplicity
        return True
        
    def report_outcome(self):
        return MissionOutcome.SUCCESS

@pytest.fixture(autouse=True)
def setup_factory():
    MissionFactory.clear_registry()
    MissionFactory.register("dummy", DummyMission)
    yield
    MissionFactory.clear_registry()

def create_def(marker_id: int, priority: int, repeatable: bool = True, cooldown: float = 1.0):
    return MissionDefinition(
        marker_id=marker_id, mission_type="dummy", trigger_distance=2.0, 
        trigger_direction=TriggerDirection.APPROACH, cooldown_s=cooldown, 
        priority=priority, activation_rules=[], required_vehicle_state=set(), 
        required_mission_state=set(), repeatable=repeatable, safety_conditions=[], 
        recovery_behaviour=RecoveryBehaviour.RETURN_TO_LANE_CENTER, params={}
    )

def test_mission_manager_activation_and_lifecycle():
    registry = MarkerRegistry(registry_dict={
        1: create_def(1, 10)
    })
    monitor = SafetyMonitor()
    manager = MissionManager(registry, monitor)
    
    vs = VehicleState(1.0, 0.0, 0.0, 0.0, True, 1.0)
    sighting = MarkerSighting(1, 1, 1.5, 0.0, 0.0, 1.0, 1.0, 1.0)
    
    # Frame 1: Triggers activation. phase=PENDING, completes instantly -> transitions to APPROACH.
    # Wait, the way pump is written, it checks is_phase_complete *before* executing the hook.
    # So PENDING -> complete -> changes to APPROACH -> executes APPROACH.
    cmd = manager.update([sighting], vs, 1.0)
    assert cmd is not None
    assert cmd.nav_state_label == "APPROACH"
    assert manager.active_mission is not None

def test_mission_manager_cooldown():
    registry = MarkerRegistry(registry_dict={
        2: create_def(2, 5, cooldown=5.0)
    })
    monitor = SafetyMonitor()
    manager = MissionManager(registry, monitor)
    vs = VehicleState(1.0, 0.0, 0.0, 0.0, True, 1.0)
    sighting = MarkerSighting(1, 2, 1.5, 0.0, 0.0, 1.0, 1.0, 1.0)
    
    # Triggers activation
    manager.update([sighting], vs, 1.0)
    assert manager.active_mission is not None
    assert 2 in manager.cooldown_ledger
    assert manager.cooldown_ledger[2] == 6.0 # 1.0 + 5.0
    
    # Cancel it
    manager._cancel_active_mission(vs)
    assert manager.active_mission is None
    
    # Try again at t=2.0 (during cooldown)
    manager.update([sighting], vs, 2.0)
    assert manager.active_mission is None # Should be blocked by cooldown

def test_mission_manager_priority_interruption():
    registry = MarkerRegistry(registry_dict={
        1: create_def(1, priority=1),
        2: create_def(2, priority=10)
    })
    monitor = SafetyMonitor()
    manager = MissionManager(registry, monitor)
    vs = VehicleState(1.0, 0.0, 0.0, 0.0, True, 1.0)
    
    sighting_low = MarkerSighting(1, 1, 1.5, 0.0, 0.0, 1.0, 1.0, 1.0)
    sighting_high = MarkerSighting(2, 2, 1.5, 0.0, 0.0, 1.0, 1.0, 1.0)
    
    manager.update([sighting_low], vs, 1.0)
    assert manager.active_mission.definition.marker_id == 1
    
    # Frame 2: higher priority marker appears
    manager.update([sighting_high], vs, 1.1)
    # Should interrupt and switch
    assert manager.active_mission.definition.marker_id == 2

def test_mission_manager_one_time():
    registry = MarkerRegistry(registry_dict={
        3: create_def(3, 5, repeatable=False, cooldown=0.0)
    })
    monitor = SafetyMonitor()
    manager = MissionManager(registry, monitor)
    vs = VehicleState(1.0, 0.0, 0.0, 0.0, True, 1.0)
    sighting = MarkerSighting(1, 3, 1.5, 0.0, 0.0, 1.0, 1.0, 1.0)
    
    # Simulate a completion
    manager.completed_history.add(3)
    
    # Try to trigger
    manager.update([sighting], vs, 1.0)
    assert manager.active_mission is None # blocked by completed_history
