        args=["drive_auto.py"],
        cwd=".",
        is_driving_mode=True,
        requires_camera=True
    ),
    ModeSpec(
        name="Hybrid Auto",
        command="python",
        args=["main_auto.py"],
        cwd=".",
        is_driving_mode=True,
        requires_camera=True
    ),
    ModeSpec(
        name="ArUco Debug",
        command="python",
        args=["aruco_knowledge.py"],
        cwd=".",
        is_driving_mode=False,
        requires_camera=True
    )
]

