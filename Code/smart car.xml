# =============================================================================
# motor_controller.py - Differential DC motor control for L298N/L293D
# Prioritizes stable Raspberry Pi 5 GPIO initialization and legacy-compatible
# signed speed behavior.
# =============================================================================

import logging
import time

logger = logging.getLogger(__name__)

GPIO_AVAILABLE = False
Device = None
Motor = None

try:
    from gpiozero import Device, Motor
    GPIO_AVAILABLE = True
except Exception as e:
    logger.error(f"[Motor] gpiozero import failed: {e}")

from config import DriveConfig, MotorConfig


def _configure_pin_factory():
    """Prefer explicit pin factories on Raspberry Pi 5 for reliability."""
    if not GPIO_AVAILABLE or Device is None:
        return None

    candidates = []
    try:
        from gpiozero.pins.lgpio import LGPIOFactory
        candidates.append(("lgpio", LGPIOFactory))
    except Exception:
        pass

    try:
        from gpiozero.pins.rpigpio import RPiGPIOFactory
        candidates.append(("rpigpio", RPiGPIOFactory))
    except Exception:
        pass

    try:
        from gpiozero.pins.native import NativeFactory
        candidates.append(("native", NativeFactory))
    except Exception:
        pass

    last_error = None
    for name, factory_cls in candidates:
        try:
            Device.pin_factory = factory_cls()
            logger.info(f"[Motor] Using GPIO pin factory: {name}")
            return name
        except Exception as e:
            last_error = e

    if last_error is not None:
        logger.error(f"[Motor] No usable GPIO pin factory found: {last_error}")
    return None


class MotorController:
    """
    Two-motor differential drive controller.
    Legacy behavior preserved:
      left_speed  = speed - turn
      right_speed = speed + turn
    """

    def __init__(self):
        self._left = None
        self._right = None
        self._left_speed = 0.0
        self._right_speed = 0.0
        self._hardware_ready = False

        if not GPIO_AVAILABLE:
            logger.error("[Motor] GPIO stack unavailable. Motors disabled.")
            return

        factory_name = _configure_pin_factory()

        try:
            # On Raspberry Pi 5 with lgpio, frequency is often global or factory-dependent.
            # gpiozero.Motor uses PWM if pwm=True.
            self._left = Motor(
                forward=MotorConfig.LEFT_FORWARD,
                backward=MotorConfig.LEFT_BACKWARD,
                pwm=True,
            )
            self._right = Motor(
                forward=MotorConfig.RIGHT_FORWARD,
                backward=MotorConfig.RIGHT_BACKWARD,
                pwm=True,
            )
            
            # Apply PWM frequency if possible (gpiozero PWM pins have .frequency)
            for m in (self._left, self._right):
                for pin in (m.forward_device, m.backward_device):
                    if hasattr(pin, 'frequency'):
                        try:
                            pin.frequency = MotorConfig.PWM_FREQUENCY
                        except:
                            pass
            
            self._hardware_ready = True
            logger.info(f"[Motor] GPIO motors initialized (Factory: {factory_name}).")
        except Exception as e:
            logger.error(f"[Motor] GPIO init failed: {e}")
            self._left = None
            self._right = None
            self._hardware_ready = False

    @property
    def hardware_ready(self):
        return self._hardware_ready

    @property
    def speeds(self):
        return {"left": self._left_speed, "right": self._right_speed}

    def move(self, speed: float, turn: float = 0.0):
        """
        Drive with signed speed and normalized turn.
        `speed`: +1.0 forward, -1.0 reverse
        `turn`: +1.0 hard right, -1.0 hard left
        """
        # Ensure speed is within hard caps from config
        speed = float(max(-DriveConfig.MAX_SPEED, min(DriveConfig.MAX_SPEED, speed)))
        turn = float(max(-1.0, min(1.0, turn)))

        # Legacy differential mixing
        left_speed = speed - turn
        right_speed = speed + turn

        # drift correction — from motor_cal.json
        left_speed = left_speed * 1.06
        # drift correction — from motor_cal.json
        right_speed = right_speed * 1.0

        # Final clip to hardware range
        left_speed = max(-1.0, min(1.0, left_speed))
        right_speed = max(-1.0, min(1.0, right_speed))

        self._apply(self._left, left_speed)
        self._apply(self._right, right_speed)

        self._left_speed = left_speed
        self._right_speed = right_speed

    def move_from_steering(self, speed: float, steering_normalized: float):
        """Helper for autonomous mode where turn is derived from model output."""
        turn = float(steering_normalized) * DriveConfig.STEERING_SENSITIVITY
        self.move(speed, turn)

    def stop(self, brake_duration: float = 0.0):
        """Stops both motors instantly."""
        if self._left is not None:
            self._left.stop()
        if self._right is not None:
            self._right.stop()

        self._left_speed = 0.0
        self._right_speed = 0.0

        if brake_duration > 0:
            time.sleep(brake_duration)

    def close(self):
        """Cleanup GPIO resources."""
        self.stop()
        for motor in (self._left, self._right):
            if motor is not None:
                try:
                    motor.close()
                except Exception:
                    pass

    def _apply(self, motor, speed: float):
        """Apply speed to a specific gpiozero Motor object."""
        if motor is None:
            return

        # Deadzone to prevent motor hum at very low values
        if abs(speed) < 0.01:
            motor.stop()
        elif speed > 0:
            motor.forward(min(speed, 1.0))
        else:
            motor.backward(min(-speed, 1.0))

    def __repr__(self):
        return (
            f"MotorController(ready={self._hardware_ready}, "
            f"left={self._left_speed:.2f}, right={self._right_speed:.2f})"
        )
