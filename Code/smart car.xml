import time
from typing import Optional
from .mission_base import Mission, MissionPhase
from .mission_types import VehicleState, MarkerSighting, MissionCommand, MissionOutcome
from .mission_factory import MissionFactory

class IgnoreMission(Mission):
    """
    A trivial mission that immediately completes without taking control.
    """
    def on_pending(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, 0.0, "IGNORE:PENDING")

    def on_approach(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, 0.0, "IGNORE:APPROACH")

    def on_prepare(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, 0.0, "IGNORE:PREPARE")

    def on_execute(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, 0.0, "IGNORE:EXECUTE")

    def on_recover(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, 0.0, "IGNORE:RECOVER")

    def on_abort(self, vs: VehicleState):
        pass

    def on_interrupt(self, vs: VehicleState, new_priority: int):
        pass
        
    def is_phase_complete(self, phase: str, vs: VehicleState) -> bool:
        # Instantly burn through all phases
        return True
        
    def report_outcome(self) -> MissionOutcome:
        return MissionOutcome.SUCCESS

class ContinueStraightMission(Mission):
    """
    A mission that represents continuing on the main path.
    For now, acts as a simple pass-through that holds for a short duration.
    """
    def __init__(self, definition, sighting):
        super().__init__(definition, sighting)
        self.start_time = time.time()
        self.advance_duration = float(definition.params.get("advance_duration", 1.0))

    def on_pending(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, 0.0, "STRAIGHT:PENDING")

    def on_approach(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, 0.0, "STRAIGHT:APPROACH")

    def on_prepare(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, 0.0, "STRAIGHT:PREPARE")

    def on_execute(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, 0.0, "STRAIGHT:EXECUTE")

    def on_recover(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, 0.0, "STRAIGHT:RECOVER")

    def on_abort(self, vs: VehicleState):
        pass

    def on_interrupt(self, vs: VehicleState, new_priority: int):
        pass
        
    def is_phase_complete(self, phase: str, vs: VehicleState) -> bool:
        # We simulate a brief execution hold just to test temporal plumbing
        if phase == MissionPhase.EXECUTE:
            elapsed = time.time() - self.start_time
            return elapsed >= self.advance_duration
        return True
        
    def report_outcome(self) -> MissionOutcome:
        return MissionOutcome.SUCCESS

# Auto-register
MissionFactory.register("ignore", IgnoreMission)
MissionFactory.register("continue_straight", ContinueStraightMission)
