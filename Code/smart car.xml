import tensorflow as tf
import os

def export_to_tflite(keras_model_path, tflite_output_path):
    """Convert a Keras model to TensorFlow Lite format."""
    print(f"Loading Keras model from {keras_model_path}...")
    model = tf.keras.models.load_model(keras_model_path)
    
    print("Converting to TFLite...")
    converter = tf.lite.TFLiteConverter.from_keras_model(model)
    
    # Optional: Apply optimizations (e.g., quantization)
    converter.optimizations = [tf.lite.Optimize.DEFAULT]
    
    tflite_model = converter.convert()
    
    print(f"Saving TFLite model to {tflite_output_path}...")
    with open(tflite_output_path, 'wb') as f:
        f.write(tflite_model)
    
    print("Export complete.")

if __name__ == "__main__":
    keras_path = 'models/model_best.keras'
    tflite_path = 'models/model.tflite'
    
    if os.path.exists(keras_path):
        export_to_tflite(keras_path, tflite_path)
    else:
        print(f"Error: {keras_path} not found. Please train the model first.")
