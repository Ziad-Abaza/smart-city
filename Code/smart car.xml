import time
import logging
from typing import Optional, List
from .mission_base import Mission, MissionPhase
from .mission_types import VehicleState, MarkerSighting, MissionCommand, MissionOutcome
from .mission_factory import MissionFactory
from .maneuvers import ManeuverPrimitive, TimedStraightAdvance, YawTargetTurn, BlendedLaneReturn
from .route_strategy import RandomRouteStrategy

logger = logging.getLogger(__name__)

class IntersectionBranchMission(Mission):
    """
    Dynamically composes a sequence of maneuvers based on a routing decision.
    Executes an open-loop advance, a closed-loop IMU turn (if branching), 
    and a smoothed lane-return blend.
    """
    def __init__(self, definition, sighting):
        super().__init__(definition, sighting)
        self.strategy = RandomRouteStrategy()
        self.maneuvers: List[ManeuverPrimitive] = []
        self.current_maneuver_index = 0
        self.current_maneuver_started = False
        self.sequence_built = False

    def on_pending(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, vs.lane_steering, "BRANCH:PENDING")

    def on_approach(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, vs.lane_steering, "BRANCH:APPROACH")

    def on_prepare(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        if not self.sequence_built:
            will_branch = self.strategy.should_branch(self.definition.params)
            logger.info(f"[IntersectionBranchMission] RNG Decision -> Branch: {will_branch}")
            
            # Compose maneuver sequence
            advance_dur = float(self.definition.params.get("pre_turn_advance", 0.8))
            
            if will_branch:
                target_yaw_delta = float(self.definition.params.get("target_yaw_delta", -90.0))
                # 1. Drive into intersection
                self.maneuvers.append(TimedStraightAdvance(duration_s=advance_dur, speed_scale=0.8))
                # 2. Execute turn
                turn_steering_scale = float(self.definition.params.get("turn_steering_scale", 0.5))
                self.maneuvers.append(
                    YawTargetTurn(
                        target_yaw_delta_deg=target_yaw_delta,
                        speed_scale=0.7,
                        steering_scale=turn_steering_scale,
                    )
                )
                # 3. Blend back
                self.maneuvers.append(BlendedLaneReturn(blend_duration_s=1.0))
            else:
                # Drive straight through intersection
                straight_dur = float(self.definition.params.get("advance_duration", 2.0))
                self.maneuvers.append(TimedStraightAdvance(duration_s=straight_dur, speed_scale=0.8))
                self.maneuvers.append(BlendedLaneReturn(blend_duration_s=0.5))
            
            self.sequence_built = True
            
        return MissionCommand(vs.speed, vs.lane_steering, "BRANCH:PREPARE")

    def on_execute(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        if self.current_maneuver_index < len(self.maneuvers):
            current_maneuver = self.maneuvers[self.current_maneuver_index]
            current_time = time.time()
            
            if not self.current_maneuver_started:
                 current_maneuver.start(vs, current_time)
                 self.current_maneuver_started = True
                 
            cmd = current_maneuver.update(vs, current_time)
            
            if current_maneuver.is_complete(vs, current_time):
                self.current_maneuver_index += 1
                self.current_maneuver_started = False
                
            return cmd
            
        return MissionCommand(vs.speed, vs.lane_steering, "BRANCH:EXECUTE_IDLE")

    def on_recover(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, vs.lane_steering, "BRANCH:RECOVER")

    def on_abort(self, vs: VehicleState):
        pass

    def on_interrupt(self, vs: VehicleState, new_priority: int):
        pass

    def is_phase_complete(self, phase: str, vs: VehicleState) -> bool:
        if phase in (MissionPhase.PENDING, MissionPhase.APPROACH, MissionPhase.PREPARE, MissionPhase.RECOVER):
            return True
        if phase == MissionPhase.EXECUTE:
            return self.current_maneuver_index >= len(self.maneuvers)
        return True

    def report_outcome(self) -> MissionOutcome:
        return MissionOutcome.SUCCESS

# Auto-register
MissionFactory.register("intersection_branch", IntersectionBranchMission)
