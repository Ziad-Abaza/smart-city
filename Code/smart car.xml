#!/usr/bin/env python3
# =============================================================================
# analyze_sync_quality.py - Analyze temporal synchronization quality
# Validates that collected data has proper temporal alignment
# =============================================================================

import argparse
import csv
from pathlib import Path

import matplotlib.pyplot as plt
import numpy as np


def analyze_session(log_path: Path):
    """
    Analyze synchronization quality of a collected session.
    
    Checks:
    1. Timestamp consistency (no backwards jumps)
    2. Frame timing regularity
    3. Correlation between sensors
    4. Data completeness
    """
    print(f"\n{'=' * 70}")
    print(f"  Synchronization Quality Analysis")
    print(f"  Session: {log_path.parent.name}")
    print(f"{'=' * 70}\n")
    
    # Load data
    data = []
    with open(log_path, 'r') as f:
        reader = csv.DictReader(f)
        for row in reader:
            data.append(row)
    
    if not data:
        print("❌ No data found in log file")
        return
    
    print(f"✓ Loaded {len(data)} samples\n")
    
    # Extract timestamps
    timestamps = []
    mono_times = []
    frame_ids = []
    
    for row in data:
        try:
            # Parse ISO timestamp
            from datetime import datetime
            ts = datetime.fromisoformat(row['timestamp']).timestamp()
            timestamps.append(ts)
            mono_times.append(float(row['t_mono']))
            
            # Frame ID (if available)
            if 'frame_id' in row:
                frame_ids.append(int(row['frame_id']))
        except (ValueError, KeyError) as e:
            print(f"⚠ Warning: Could not parse row: {e}")
            continue
    
    timestamps = np.array(timestamps)
    mono_times = np.array(mono_times)
    
    # ═══════════════════════════════════════════════════════════
    # 1. Timestamp Consistency
    # ═══════════════════════════════════════════════════════════
    print("1. TIMESTAMP CONSISTENCY")
    print("-" * 70)
    
    # Check for backwards jumps
    time_diffs = np.diff(timestamps)
    backwards = time_diffs < 0
    if np.any(backwards):
        print(f"❌ Found {np.sum(backwards)} backwards time jumps!")
        for idx in np.where(backwards)[0]:
            print(f"   Sample {idx}: {timestamps[idx]:.6f} -> {timestamps[idx+1]:.6f}")
    else:
        print("✓ No backwards time jumps")
    
    # Check for duplicate timestamps
    duplicates = time_diffs == 0
    if np.any(duplicates):
        print(f"⚠ Found {np.sum(duplicates)} duplicate timestamps")
    else:
        print("✓ No duplicate timestamps")
    
    print()
    
    # ═══════════════════════════════════════════════════════════
    # 2. Frame Timing Regularity
    # ═══════════════════════════════════════════════════════════
    print("2. FRAME TIMING REGULARITY")
    print("-" * 70)
    
    # Inter-frame intervals
    intervals_ms = time_diffs * 1000
    
    print(f"Mean interval    : {np.mean(intervals_ms):.2f} ms")
    print(f"Std deviation    : {np.std(intervals_ms):.2f} ms")
    print(f"Min interval     : {np.min(intervals_ms):.2f} ms")
    print(f"Max interval     : {np.max(intervals_ms):.2f} ms")
    print(f"Median interval  : {np.median(intervals_ms):.2f} ms")
    
    # Expected FPS
    expected_fps = 1000.0 / np.median(intervals_ms)
    print(f"Effective FPS    : {expected_fps:.1f}")
    
    # Jitter analysis
    jitter = np.std(intervals_ms)
    if jitter < 5.0:
        print(f"✓ Low jitter ({jitter:.2f}ms) - excellent timing")
    elif jitter < 10.0:
        print(f"✓ Moderate jitter ({jitter:.2f}ms) - acceptable")
    else:
        print(f"⚠ High jitter ({jitter:.2f}ms) - may affect training")
    
    # Large gaps
    large_gaps = intervals_ms > 100
    if np.any(large_gaps):
        print(f"⚠ Found {np.sum(large_gaps)} large gaps (>100ms)")
        print(f"   Max gap: {np.max(intervals_ms):.1f}ms")
    else:
        print("✓ No large timing gaps")
    
    print()
    
    # ═══════════════════════════════════════════════════════════
    # 3. Sensor Data Completeness
    # ═══════════════════════════════════════════════════════════
    print("3. SENSOR DATA COMPLETENESS")
    print("-" * 70)
    
    # Check for missing/zero values
    steering = np.array([float(row['steering']) for row in data])
    throttle = np.array([float(row['throttle']) for row in data])
    
    # IMU data (if available)
    has_imu = 'yaw_rate' in data[0]
    if has_imu:
        yaw_rate = np.array([float(row['yaw_rate']) for row in data])
        print(f"✓ IMU data present")
        print(f"  Yaw rate range: [{np.min(yaw_rate):.2f}, {np.max(yaw_rate):.2f}] deg/s")
    else:
        print("⚠ No IMU data found")
    
    # Enhanced IMU data (new format)
    has_full_imu = 'ax' in data[0]
    if has_full_imu:
        ax = np.array([float(row['ax']) for row in data])
        ay = np.array([float(row['ay']) for row in data])
        az = np.array([float(row['az']) for row in data])
        print(f"✓ Full IMU data (ax, ay, az, gx, gy, gz, yaw)")
        print(f"  Accel X range: [{np.min(ax):.3f}, {np.max(ax):.3f}] g")
        print(f"  Accel Y range: [{np.min(ay):.3f}, {np.max(ay):.3f}] g")
        print(f"  Accel Z range: [{np.min(az):.3f}, {np.max(az):.3f}] g")
    
    # Frame IDs (if available)
    if frame_ids:
        frame_ids = np.array(frame_ids)
        missing_frames = np.sum(np.diff(frame_ids) > 1)
        if missing_frames > 0:
            print(f"⚠ {missing_frames} missing frame IDs (dropped frames)")
        else:
            print("✓ No dropped frames")
    
    print()
    
    # ═══════════════════════════════════════════════════════════
    # 4. Data Quality Metrics
    # ═══════════════════════════════════════════════════════════
    print("4. DATA QUALITY METRICS")
    print("-" * 70)
    
    # Steering distribution
    near_zero = np.abs(steering) < 0.05
    print(f"Steering distribution:")
    print(f"  Mean: {np.mean(steering):+.4f}")
    print(f"  Std:  {np.std(steering):.4f}")
    print(f"  Near-zero (<0.05): {np.mean(near_zero) * 100:.1f}%")
    
    if np.mean(near_zero) > 0.7:
        print(f"  ⚠ Warning: >70% straight driving - add more turns")
    else:
        print(f"  ✓ Good steering diversity")
    
    # Throttle distribution
    print(f"\nThrottle distribution:")
    print(f"  Mean: {np.mean(throttle):+.4f}")
    print(f"  Std:  {np.std(throttle):.4f}")
    
    print()
    
    # ═══════════════════════════════════════════════════════════
    # 5. Synchronization Quality Score
    # ═══════════════════════════════════════════════════════════
    print("5. OVERALL SYNCHRONIZATION QUALITY")
    print("-" * 70)
    
    score = 100.0
    issues = []
    
    # Deduct points for issues
    if np.any(backwards):
        score -= 30
        issues.append("Backwards timestamps (-30)")
    
    if jitter > 10.0:
        score -= 15
        issues.append(f"High jitter ({jitter:.1f}ms) (-15)")
    elif jitter > 5.0:
        score -= 5
        issues.append(f"Moderate jitter ({jitter:.1f}ms) (-5)")
    
    if np.any(large_gaps):
        score -= 10
        issues.append(f"Large timing gaps (-10)")
    
    if not has_full_imu:
        score -= 20
        issues.append("Missing full IMU data (-20)")
    
    if frame_ids and missing_frames > len(data) * 0.05:
        score -= 15
        issues.append(f"Many dropped frames ({missing_frames}) (-15)")
    
    print(f"\nSynchronization Score: {score:.0f}/100")
    
    if score >= 90:
        print("✓ EXCELLENT - Data is well synchronized")
    elif score >= 75:
        print("✓ GOOD - Minor synchronization issues")
    elif score >= 60:
        print("⚠ FAIR - Some synchronization problems")
    else:
        print("❌ POOR - Significant synchronization issues")
    
    if issues:
        print("\nIssues detected:")
        for issue in issues:
            print(f"  - {issue}")
    
    print()
    
    # ═══════════════════════════════════════════════════════════
    # 6. Visualization
    # ═══════════════════════════════════════════════════════════
    print("6. GENERATING PLOTS...")
    print("-" * 70)
    
    fig, axes = plt.subplots(2, 2, figsize=(14, 10))
    fig.suptitle(f'Synchronization Analysis: {log_path.parent.name}', fontsize=14)
    
    # Plot 1: Inter-frame intervals
    ax = axes[0, 0]
    ax.plot(intervals_ms, linewidth=0.5)
    ax.axhline(np.median(intervals_ms), color='r', linestyle='--', label='Median')
    ax.set_xlabel('Sample Index')
    ax.set_ylabel('Interval (ms)')
    ax.set_title('Inter-Frame Timing')
    ax.legend()
    ax.grid(True, alpha=0.3)
    
    # Plot 2: Interval histogram
    ax = axes[0, 1]
    ax.hist(intervals_ms, bins=50, edgecolor='black', alpha=0.7)
    ax.axvline(np.median(intervals_ms), color='r', linestyle='--', label='Median')
    ax.set_xlabel('Interval (ms)')
    ax.set_ylabel('Count')
    ax.set_title('Interval Distribution')
    ax.legend()
    ax.grid(True, alpha=0.3)
    
    # Plot 3: Steering over time
    ax = axes[1, 0]
    ax.plot(timestamps - timestamps[0], steering, linewidth=0.5)
    ax.set_xlabel('Time (s)')
    ax.set_ylabel('Steering')
    ax.set_title('Steering Signal')
    ax.grid(True, alpha=0.3)
    
    # Plot 4: Steering histogram
    ax = axes[1, 1]
    ax.hist(steering, bins=50, edgecolor='black', alpha=0.7)
    ax.set_xlabel('Steering')
    ax.set_ylabel('Count')
    ax.set_title('Steering Distribution')
    ax.grid(True, alpha=0.3)
    
    plt.tight_layout()
    
    # Save plot
    plot_path = log_path.parent / 'sync_analysis.png'
    plt.savefig(plot_path, dpi=150)
    print(f"✓ Saved plot to: {plot_path}")
    
    # Show plot
    plt.show()
    
    print(f"\n{'=' * 70}\n")


def main():
    parser = argparse.ArgumentParser(
        description='Analyze temporal synchronization quality of collected data'
    )
    parser.add_argument(
        'session_dir',
        type=str,
        help='Path to session directory (e.g., DataCollected/session_20240515_123456)'
    )
    
    args = parser.parse_args()
    
    session_path = Path(args.session_dir)
    log_path = session_path / 'driving_log.csv'
    
    if not log_path.exists():
        print(f"❌ Error: Log file not found: {log_path}")
        return
    
    analyze_session(log_path)


if __name__ == '__main__':
    main()
