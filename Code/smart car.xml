import pytest
import numpy as np
from autonomous_navigation.marker_tracker import MarkerTracker

def test_marker_tracker_debounce_confirm():
    tracker = MarkerTracker(confirm_hits=3, drop_misses=3)
    
    det1 = {"id": 10, "tvec": np.array([0.1, 0.0, 1.0])}
    
    # Frame 1: Seen once, not confirmed
    sightings = tracker.process_frame([det1], current_time=1.0)
    assert len(sightings) == 0
    
    # Frame 2: Seen twice, not confirmed
    sightings = tracker.process_frame([det1], current_time=2.0)
    assert len(sightings) == 0
    
    # Frame 3: Seen thrice, confirmed
    sightings = tracker.process_frame([det1], current_time=3.0)
    assert len(sightings) == 1
    assert sightings[0].marker_id == 10
    assert sightings[0].track_id == 1
    assert sightings[0].first_seen_t == 1.0
    assert sightings[0].last_seen_t == 3.0

def test_marker_tracker_flicker_and_drop():
    tracker = MarkerTracker(confirm_hits=2, drop_misses=2)
    det = {"id": 5, "tvec": np.array([0.0, 0.0, 2.0])}
    
    # Frame 1: Hit (1)
    tracker.process_frame([det], 1.0)
    # Frame 2: Hit (2) -> Confirmed
    sightings = tracker.process_frame([det], 2.0)
    assert len(sightings) == 1
    
    # Frame 3: Miss (1) -> Still confirmed due to drop_misses=2
    sightings = tracker.process_frame([], 3.0)
    assert len(sightings) == 1
    assert sightings[0].last_seen_t == 2.0
    
    # Frame 4: Hit (1) -> Misses reset to 0
    sightings = tracker.process_frame([det], 4.0)
    assert len(sightings) == 1
    assert sightings[0].last_seen_t == 4.0
    
    # Frame 5: Miss (1)
    tracker.process_frame([], 5.0)
    # Frame 6: Miss (2) -> Track dropped
    sightings = tracker.process_frame([], 6.0)
    assert len(sightings) == 0

def test_marker_tracker_id_collisions_multiple_markers():
    tracker = MarkerTracker(confirm_hits=1, drop_misses=2)
    det_a = {"id": 1, "tvec": np.array([0.1, 0.0, 1.0])}
    det_b = {"id": 2, "tvec": np.array([-0.1, 0.0, 1.0])}
    
    # Both confirmed instantly
    sightings = tracker.process_frame([det_a, det_b], 1.0)
    assert len(sightings) == 2
    ids = {s.marker_id for s in sightings}
    assert ids == {1, 2}

def test_marker_tracker_new_track_id_after_drop():
    tracker = MarkerTracker(confirm_hits=1, drop_misses=1)
    det = {"id": 42, "tvec": np.array([0.0, 0.0, 1.0])}
    
    sightings = tracker.process_frame([det], 1.0)
    assert sightings[0].track_id == 1
    
    # Drop it
    tracker.process_frame([], 2.0)
    
    # Re-acquire it
    sightings = tracker.process_frame([det], 3.0)
    assert sightings[0].track_id == 2  # New track ID for same marker ID
</file>

