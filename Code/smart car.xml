def analyze():
    print("=== DATASET STRUCTURE ANALYSIS ===")
    if not os.path.exists(csv_path):
        print(f"File {csv_path} not found.")
        return
    
    df = pd.read_csv(csv_path)
    print(f"CSV Columns: {df.columns.tolist()}")
    print(f"Total Rows: {len(df)}")
    
    # Analyze images
    img_files = df.iloc[:, 0].values # First column is center image path
    corrupt_images = 0
    missing_images = 0
    resolutions = set()
    
    print("\nValidating first 1000 images...")
    for idx, img_path in enumerate(img_files[:1000]):
        # Normalize path
        img_path_resolved = img_path
        if not os.path.exists(img_path_resolved):
            # Try appending relative to root
            img_path_resolved = os.path.join(img_dir, os.path.basename(img_path))
        
        if not os.path.exists(img_path_resolved):
            missing_images += 1
            continue
            
        img = cv2.imread(img_path_resolved)
        if img is None:
            corrupt_images += 1
        else:
            resolutions.add(img.shape)
            
