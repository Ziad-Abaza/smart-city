import os
import signal
import sys
import time
from PySide6.QtCore import QObject, QProcess, Signal, QTimer
from launcher.mode_registry import get_mode

class ManagedProcess(QObject):
    stateChanged = Signal(str, str) # mode_name, new_state
    logMessage = Signal(str, str, str) # mode_name, stream_type, text
    
    def __init__(self, mode_name: str):
        super().__init__()
        self.mode_name = mode_name
        self.state = "Stopped"
        self.start_time = 0
        self.restart_count = 0
        
        self.process = QProcess(self)
        self.process.readyReadStandardOutput.connect(self._on_stdout)
        self.process.readyReadStandardError.connect(self._on_stderr)
        self.process.finished.connect(self._on_finished)
        self.process.errorOccurred.connect(self._on_error)
        self.process.started.connect(self._on_started)
        
        self._stop_timer = QTimer(self)
        self._stop_timer.setSingleShot(True)
        self._stop_timer.timeout.connect(self._escalate_stop)
        self._stop_phase = 0

    def start(self):
        mode = get_mode(self.mode_name)
        self.process.setWorkingDirectory(mode.cwd)
        self.process.setProgram(mode.command)
        self.process.setArguments(mode.args)
        
        self.state = "Starting"
        self.stateChanged.emit(self.mode_name, self.state)
        self.process.start()

    def stop(self):
        if self.state in ["Stopped", "Crashed", "Stopping"]:
            return
            
        self.state = "Stopping"
        self.stateChanged.emit(self.mode_name, self.state)
        self._stop_phase = 1
        
        pid = self.process.processId()
        if sys.platform != "win32" and pid > 0:
            try:
                os.kill(pid, signal.SIGINT)
            except ProcessLookupError:
                pass
        else:
            self.process.terminate()
            
        self._stop_timer.start(3000) # 3 seconds

    def _escalate_stop(self):
        if self.process.state() != QProcess.NotRunning:
            if self._stop_phase == 1:
                self._stop_phase = 2
                self.process.terminate() # SIGTERM
                self._stop_timer.start(3000)
            elif self._stop_phase == 2:
                self.process.kill() # SIGKILL

    def _on_started(self):
        self.state = "Running"
        self.start_time = time.time()
        self.stateChanged.emit(self.mode_name, self.state)

    def _on_finished(self, exitCode, exitStatus):
        self._stop_timer.stop()
        if self.state == "Stopping":
            self.state = "Stopped"
        elif exitStatus == QProcess.CrashExit or exitCode != 0:
            self.state = "Crashed"
        else:
            self.state = "Stopped"
            
        self.stateChanged.emit(self.mode_name, self.state)

    def _on_error(self, error):
        self._stop_timer.stop()
        if error == QProcess.FailedToStart:
            self.state = "Crashed"
            self.stateChanged.emit(self.mode_name, self.state)

    def _on_stdout(self):
        data = self.process.readAllStandardOutput().data()
        text = data.decode("utf-8", errors="replace")
        self.logMessage.emit(self.mode_name, "stdout", text)

    def _on_stderr(self):
        data = self.process.readAllStandardError().data()
        text = data.decode("utf-8", errors="replace")
        self.logMessage.emit(self.mode_name, "stderr", text)


class ProcessManager(QObject):
    processStateChanged = Signal(str, str) # mode_name, new_state
    errorOccurred = Signal(str, str) # mode_name, error_message
    logMessage = Signal(str, str, str) # mode_name, stream, text
    processAboutToStart = Signal(str) # mode_name
    
    def __init__(self):
        super().__init__()
        self.processes = {}

    def get_process(self, mode_name: str) -> ManagedProcess:
        if mode_name not in self.processes:
            p = ManagedProcess(mode_name)
            p.stateChanged.connect(self._handle_state_changed)
            p.logMessage.connect(self.logMessage)
            self.processes[mode_name] = p
        return self.processes[mode_name]

    def _handle_state_changed(self, mode_name, state):
        self.processStateChanged.emit(mode_name, state)
        if state == "Crashed":
            self.errorOccurred.emit(mode_name, "Process crashed or failed to start.")

    def _is_exclusivity_conflict(self, target_mode_name: str) -> bool:
        target_mode = get_mode(target_mode_name)
        target_group = target_mode.exclusivity_group
        
        if target_group == "none":
            return False
            
        for name, p in self.processes.items():
            if name != target_mode_name and p.state in ["Starting", "Running", "Stopping"]:
                mode = get_mode(name)
                if mode.exclusivity_group == target_group:
                    return True
        return False

    def start_mode(self, mode_name: str):
        if self._is_exclusivity_conflict(mode_name):
            self.errorOccurred.emit(mode_name, f"Cannot start {mode_name}: mutual exclusion conflict.")
            return
            
        p = self.get_process(mode_name)
        if p.state in ["Starting", "Running", "Stopping"]:
            return
            
        self.processAboutToStart.emit(mode_name)
        p.start()

    def stop_mode(self, mode_name: str):
        p = self.get_process(mode_name)
        p.stop()

    def restart_mode(self, mode_name: str):
        p = self.get_process(mode_name)
        if p.state in ["Starting", "Running", "Stopping"]:
            p.restart_count += 1
            # We must stop, wait for it to be fully stopped, then start again.
            # For phase 1, a simple stop and deferred start can work.
            def on_state_changed(name, state):
                if name == mode_name and state in ["Stopped", "Crashed"]:
                    p.stateChanged.disconnect(on_state_changed)
                    QTimer.singleShot(500, lambda: self.start_mode(mode_name))
            p.stateChanged.connect(on_state_changed)
            p.stop()
        else:
            p.restart_count += 1
            self.start_mode(mode_name)

    def stop_all(self):
        for p in self.processes.values():
            p.stop()
