import os
from datetime import datetime
import tensorflow as tf
from tensorflow.keras.callbacks import ModelCheckpoint, EarlyStopping, ReduceLROnPlateau, TensorBoard
from sklearn.model_selection import train_test_split
from dataset import load_data, batch_generator
from model import create_model

# Hyperparameters
BATCH_SIZE = 32
EPOCHS = 50
# LEARNING_RATE = 1e-3
LEARNING_RATE = 5e-4

CSV_PATH = 'DataCollected/driving_log.csv'
MODEL_DIR = 'models'

def train():
    # 1. Create model directory
    os.makedirs(MODEL_DIR, exist_ok=True)
    
    # 2. Get current date and time
    now = datetime.now()
    today_date = now.strftime("%m_%d_%H%M")
    
    # 3. Load and split data
    df = load_data(CSV_PATH)
    train_df, val_df = train_test_split(df, test_size=0.2, random_state=42)
    
    print(f"Training samples: {len(train_df)}")
    print(f"Validation samples: {len(val_df)}")
    
    # 4. Create generators
    train_gen = batch_generator(train_df, BATCH_SIZE, is_training=True)
    val_gen = batch_generator(val_df, BATCH_SIZE, is_training=False)
    
    # 5. Initialize model
    model = create_model()
    optimizer = tf.keras.optimizers.Adam(learning_rate=LEARNING_RATE)
    
    # Use Huber Loss for better stability against steering outliers
    model.compile(optimizer=optimizer, loss=tf.keras.losses.Huber(), metrics=['mse'])
    
    # 6. Callbacks
    model_name = f"model_{EPOCHS}_{BATCH_SIZE}_{today_date}.keras"
    checkpoint = ModelCheckpoint(
        os.path.join(MODEL_DIR, model_name),
        monitor='val_loss',
        save_best_only=True,
        verbose=1
    )
    
    early_stop = EarlyStopping(
        monitor='val_loss',
        patience=8,
        restore_best_weights=True,
        verbose=1
    )
    
    reduce_lr = ReduceLROnPlateau(
        monitor='val_loss',
        factor=0.2,
        patience=4,
        min_lr=1e-6,
        verbose=1
    )
    
    tensorboard = TensorBoard(log_dir='./logs')
    
    # 7. Training loop
    steps_per_epoch = len(train_df) // BATCH_SIZE
    validation_steps = len(val_df) // BATCH_SIZE
    
    history = model.fit(
        train_gen,
        steps_per_epoch=steps_per_epoch,
        epochs=EPOCHS,
        validation_data=val_gen,
        validation_steps=validation_steps,
        callbacks=[checkpoint, early_stop, reduce_lr, tensorboard],
        verbose=1
    )
    
    # 8. Save final model
    actual_epochs = len(history.history['loss'])
    model_name = f"model_ep{actual_epochs}_{BATCH_SIZE}_{today_date}.keras"
    final_path = os.path.join(MODEL_DIR, model_name)
    model.save(final_path)
    
    # Also save as model_best.keras for easy access
    best_path = os.path.join(MODEL_DIR, 'model_best.keras')
    model.save(best_path)
    
    print(f"Training complete. Model saved as {final_path} and {best_path}")
    
    # 9. Export to TFLite
    print("\nExporting to TFLite...")
    try:
        # Import inside function to avoid circular imports if any
        from export import export_to_tflite
        
        tflite_path = final_path.replace('.keras', '.tflite')
        export_to_tflite(final_path, tflite_path)
        
        # Also update the generic tflite
        export_to_tflite(final_path, os.path.join(MODEL_DIR, 'model.tflite'))
        print("TFLite export successful!")
    except Exception as e:
        print(f"TFLite export failed: {e}")

if __name__ == "__main__":
    train()
