# =============================================================================
# synchronized_sampler.py - Synchronized Multi-Sensor Data Sampling
# Ensures frame, steering, throttle, and IMU are captured at the SAME timestamp
# =============================================================================

import logging
import threading
import time
from dataclasses import dataclass
from typing import Optional

import numpy as np

logger = logging.getLogger(__name__)


@dataclass
class SynchronizedSample:
    """
    A single synchronized sample containing all sensor data at one timestamp.
    
    All fields are captured atomically to ensure temporal alignment.
    """
    # Timing
    timestamp: float        # Wall clock time (time.time())
    mono_time: float        # Monotonic time (time.monotonic())
    
    # Vision
    frame: np.ndarray       # Camera frame (BGR)
    frame_id: int          # Sequential frame counter
    
    # Control inputs
    steering: float        # Normalized steering [-1.0, 1.0]
    throttle: float        # Normalized throttle [-1.0, 1.0]
    state: str             # Driving state (straight, gentle, sharp, recovery)
    
    # IMU data
    ax: float              # Acceleration X (g)
    ay: float              # Acceleration Y (g)
    az: float              # Acceleration Z (g)
    gx: float              # Gyro X (deg/s)
    gy: float              # Gyro Y (deg/s)
    gz: float              # Gyro Z (deg/s)
    yaw: float             # Integrated yaw angle (degrees)
    yaw_rate: float        # Yaw rate (deg/s)
    
    # Derived/estimated
    speed: float           # Estimated speed
    confidence: float      # Lane detection confidence (optional)
    
    def to_dict(self) -> dict:
        """Convert to dictionary for logging/serialization."""
        return {
            'timestamp': self.timestamp,
            'mono_time': self.mono_time,
            'frame_id': self.frame_id,
            'steering': self.steering,
            'throttle': self.throttle,
            'state': self.state,
            'ax': self.ax,
            'ay': self.ay,
            'az': self.az,
            'gx': self.gx,
            'gy': self.gy,
            'gz': self.gz,
            'yaw': self.yaw,
            'yaw_rate': self.yaw_rate,
            'speed': self.speed,
            'confidence': self.confidence,
        }


class SynchronizedSampler:
    """
    Atomic multi-sensor sampler that ensures temporal alignment.
    
    Key principle: All sensor readings are captured within a minimal time window
    (typically <5ms) to ensure they represent the same moment in time.
    
    Usage:
        sampler = SynchronizedSampler(camera, imu, motor_controller)
        sample = sampler.capture(steering, throttle, speed, confidence)
        # sample.frame, sample.steering, sample.yaw_rate are all synchronized
    """
    
    def __init__(self, camera, imu_reader, motor_controller=None):
        """
        Args:
            camera: Camera instance with .frame property
            imu_reader: IMUReader instance with .latest property
            motor_controller: Optional MotorController for motor state
        """
        self._camera = camera
        self._imu = imu_reader
        self._motors = motor_controller
        
        self._sample_count = 0
        self._last_frame_id = -1
        self._skipped_stale_frames = 0
        self._lock = threading.Lock()
        
        # Statistics for monitoring sync quality
        self._capture_times = []
        self._max_capture_time = 0.0
        
        logger.info("[SyncSampler] Initialized")
    
    def capture(
        self,
        steering: float,
        throttle: float,
        state: str = "straight",
        speed: float = 0.0,
        confidence: float = 1.0,
        require_new_frame: bool = True,
    ) -> Optional[SynchronizedSample]:
        """
        Capture a synchronized sample from all sensors.
        
        This method is designed to be FAST (<5ms) to minimize temporal skew.
        
        Args:
            steering: Current steering command [-1.0, 1.0]
            throttle: Current throttle command [-1.0, 1.0]
            state: Driving state (straight, gentle, sharp, recovery)
            speed: Estimated speed
            confidence: Lane detection confidence
            require_new_frame: If True, skip until the camera delivers a new frame
            
        Returns:
            SynchronizedSample if successful, None if any sensor fails or frame is stale
        """
        capture_start = time.perf_counter()
        
        with self._lock:
            # Step 1: Capture timestamps FIRST (reference point)
            timestamp = time.time()
            mono_time = time.monotonic()
            
            # Step 2: Capture frame (typically fastest, ~1-2ms)
            frame = self._camera.frame
            if frame is None:
                logger.warning("[SyncSampler] Camera frame is None")
                return None
            
            frame_id = self._camera.frame_count

            if require_new_frame and frame_id == self._last_frame_id:
                self._skipped_stale_frames += 1
                return None

            # Step 3: Capture IMU data (very fast, <0.5ms)
            imu_data = self._imu.latest
            
            # Step 4: Create synchronized sample
            sample = SynchronizedSample(
                timestamp=timestamp,
                mono_time=mono_time,
                frame=frame.copy(),  # Deep copy to prevent race conditions
                frame_id=frame_id,
                steering=float(steering),
                throttle=float(throttle),
                state=state,
                ax=float(imu_data.get('ax', 0.0)),
                ay=float(imu_data.get('ay', 0.0)),
                az=float(imu_data.get('az', 1.0)),
                gx=float(imu_data.get('gx', 0.0)),
                gy=float(imu_data.get('gy', 0.0)),
                gz=float(imu_data.get('gz', 0.0)),
                yaw=float(imu_data.get('yaw', 0.0)),
                yaw_rate=float(imu_data.get('yaw_rate', 0.0)),
                speed=float(speed),
                confidence=float(confidence),
            )
            
            self._sample_count += 1
            self._last_frame_id = frame_id
            
            # Monitor capture performance
            capture_time = (time.perf_counter() - capture_start) * 1000  # ms
            self._capture_times.append(capture_time)
            if capture_time > self._max_capture_time:
                self._max_capture_time = capture_time
            
            # Keep only recent stats
            if len(self._capture_times) > 1000:
                self._capture_times = self._capture_times[-1000:]
            
            # Warn if capture is too slow (>10ms indicates problem)
            if capture_time > 10.0:
                logger.warning(
                    f"[SyncSampler] Slow capture: {capture_time:.2f}ms "
                    f"(frame_id={frame_id})"
                )
            
            return sample
    
    def get_stats(self) -> dict:
        """Get synchronization quality statistics."""
        if not self._capture_times:
            return {}
        
        times = np.array(self._capture_times)
        return {
            'sample_count': self._sample_count,
            'skipped_stale_frames': self._skipped_stale_frames,
            'avg_capture_time_ms': float(np.mean(times)),
            'max_capture_time_ms': float(self._max_capture_time),
            'std_capture_time_ms': float(np.std(times)),
            'p95_capture_time_ms': float(np.percentile(times, 95)),
            'p99_capture_time_ms': float(np.percentile(times, 99)),
        }
    
    def print_stats(self):
        """Print synchronization quality report."""
        stats = self.get_stats()
        if not stats:
            print("[SyncSampler] No samples captured yet")
            return
        
        print("\n" + "=" * 60)
        print("  Synchronization Quality Report")
        print("=" * 60)
        print(f"  Total samples      : {stats['sample_count']}")
        print(f"  Stale frames skipped: {stats.get('skipped_stale_frames', 0)}")
        print(f"  Avg capture time   : {stats['avg_capture_time_ms']:.2f} ms")
        print(f"  Max capture time   : {stats['max_capture_time_ms']:.2f} ms")
        print(f"  Std capture time   : {stats['std_capture_time_ms']:.2f} ms")
        print(f"  P95 capture time   : {stats['p95_capture_time_ms']:.2f} ms")
        print(f"  P99 capture time   : {stats['p99_capture_time_ms']:.2f} ms")
        
        if stats['avg_capture_time_ms'] < 5.0:
            print("  ✓ Excellent synchronization (<5ms)")
        elif stats['avg_capture_time_ms'] < 10.0:
            print("  ✓ Good synchronization (<10ms)")
        else:
            print("  ⚠ Warning: Slow capture (>10ms) - check sensor performance")
        
        print("=" * 60)
    
    @property
    def sample_count(self) -> int:
        return self._sample_count


class TimestampValidator:
    """
    Validates temporal consistency of samples.
    
    Detects issues like:
    - Timestamps going backwards
    - Large gaps between samples
    - Duplicate timestamps
    """
    
    def __init__(self, max_gap_ms: float = 100.0):
        self._last_timestamp = None
        self._last_mono = None
        self._max_gap_ms = max_gap_ms
        self._issues = []
    
    def validate(self, sample: SynchronizedSample) -> bool:
        """
        Validate timestamp consistency.
        
        Returns:
            True if sample is valid, False if issues detected
        """
        valid = True
        
        if self._last_timestamp is not None:
            # Check for backwards time
            if sample.timestamp < self._last_timestamp:
                self._issues.append(
                    f"Timestamp went backwards: "
                    f"{sample.timestamp} < {self._last_timestamp}"
                )
                valid = False
            
            # Check for large gaps
            gap_ms = (sample.timestamp - self._last_timestamp) * 1000
            if gap_ms > self._max_gap_ms:
                self._issues.append(
                    f"Large time gap: {gap_ms:.1f}ms "
                    f"(frame {sample.frame_id})"
                )
                # Don't mark as invalid - gaps are expected during pauses
            
            # Check for duplicate timestamps
            if abs(sample.timestamp - self._last_timestamp) < 0.0001:
                self._issues.append(
                    f"Duplicate timestamp: {sample.timestamp} "
                    f"(frame {sample.frame_id})"
                )
                valid = False
        
        self._last_timestamp = sample.timestamp
        self._last_mono = sample.mono_time
        
        return valid
    
    def get_issues(self) -> list:
        """Get list of detected issues."""
        return self._issues.copy()
    
    def clear_issues(self):
        """Clear issue history."""
        self._issues.clear()


def classify_steering_state(steering: float, is_recovery: bool = False) -> str:
    """
    Helper to classify driving state based on magnitude and manual flags.
    
    Args:
        steering: Current steering value [-1.0, 1.0]
        is_recovery: Manual recovery mode toggle from controller
        
    Returns:
        One of: 'straight', 'gentle', 'sharp', 'recovery'
    """
    if is_recovery:
        return 'recovery'
    
    s = abs(steering)
    if s < 0.05:
        return 'straight'
    elif s < 0.20:
        return 'gentle'
    else:
        return 'sharp'
