# =============================================================================
# drive_auto.py — Autonomous Driving Script (v2)
#
# Optimized for models/model.tflite
# Using the AutonomousDriver class from training/inference.py
#
# Controls during autonomous run:
#   SPACE      → Pause
#   R          → Resume after pause
#   Q / ESC    → Quit
# =============================================================================

import cv2
import time
import signal
import logging
import numpy as np
from datetime import datetime

# Local imports
from camera            import Camera
from motor_controller  import MotorController
from training.inference import AutonomousDriver

# Configuration
MODEL_PATH = 'models/model.tflite'
FIXED_THROTTLE = 0.25  # The car runs at fixed speed
STEERING_SENSITIVITY = 0.8  # Adjust based on track behavior
INVERT_STEERING = True  # Set to True if the car turns opposite to predicted direction

logging.basicConfig(
    level=logging.INFO,
    format='[%(asctime)s] %(levelname)s — %(message)s',
    datefmt='%H:%M:%S'
)
logger = logging.getLogger(__name__)

def main():
    print("=" * 60)
    print("  Self-Driving Car — Autonomous Mode V2")
    print("  SPACE=pause  R=resume  Q=quit")
    print("  Model: " + MODEL_PATH)
    print("=" * 60)

    # 1. Initialize Hardware
    cam = Camera(publish=True)
    motors = MotorController()
    
    # 2. Initialize Model
    try:
        driver = AutonomousDriver(MODEL_PATH)
        logger.info(f"[Model] TFLite model loaded successfully.")
    except Exception as e:
        logger.error(f"[Model] Failed to load model: {e}")
        return

    cam.start()
    
    # 3. State Management
    paused = False
    running = [True]
    frame_count = 0
    
    def shutdown(sig=None, frame=None):
        running[0] = False

    signal.signal(signal.SIGINT,  shutdown)
    signal.signal(signal.SIGTERM, shutdown)

    print("\n[Auto] Starting in 2 seconds...")
    time.sleep(2.0)

    try:
        while running[0]:
            t_start = time.time()

            # Capture frame
            frame = cam.frame
            if frame is None:
                time.sleep(0.01)
                continue

            # Keyboard Controls removed for headless launcher mode
            
            if paused:
                continue

            # 4. Inference
            try:
                # Get raw steering prediction from model
                raw_steering = driver.predict(frame)
                
                # Apply inversion if needed
                if INVERT_STEERING:
                    raw_steering = -raw_steering
                
                # Apply sensitivity and clip
                final_steering = float(np.clip(raw_steering * STEERING_SENSITIVITY, -1.0, 1.0))
                
                # 5. Motor Control
                # We use fixed throttle as requested
                motors.move(FIXED_THROTTLE, final_steering)
                
            except Exception as e:
                logger.error(f"Inference error: {e}")
                motors.stop()
                break

            # 6. HUD drawing (telemetry generated but not shown in OpenCV window)
            frame_count += 1
            fps = 1.0 / (time.time() - t_start)
            _draw_hud(frame, raw_steering, final_steering, FIXED_THROTTLE, fps)

            if frame_count % 50 == 0:
                logger.info(f"Step: {frame_count} | Steer: {final_steering:+.3f} | FPS: {fps:.1f}")

    finally:
        logger.info("Cleaning up...")
        motors.stop()
        cam.stop()
        print("[Auto] Stopped.")

def _draw_hud(frame, raw_steer, final_steer, throttle, fps):
    """Draw telemetry HUD on display."""
    h, w = frame.shape[:2]
    lines = [
        f"V2 AUTONOMOUS MODE",
        f"Raw Steer : {raw_steer:+.3f}",
        f"Final Steer: {final_steer:+.3f}",
        f"Throttle   : {throttle:.2f}",
        f"FPS        : {fps:.1f}",
    ]
    
    # Simple semi-transparent overlay
    for i, line in enumerate(lines):
        cv2.putText(frame, line, (10, 25 + i * 25),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 0), 2)

    # Visual steering bar
    bar_y = h - 30
    bar_x = w // 2
    bar_w = 120
    cv2.line(frame, (bar_x - bar_w, bar_y), (bar_x + bar_w, bar_y), (255, 255, 255), 2)
    marker_x = int(bar_x + (final_steer * bar_w))
    cv2.circle(frame, (marker_x, bar_y), 8, (0, 0, 255), -1)

if __name__ == '__main__':
    main()
