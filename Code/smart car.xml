import cv2
import numpy as np
import os
import matplotlib.pyplot as plt
try:
    from .aruco_config import ArucoType
except (ImportError, ValueError):
    from aruco_config import ArucoType

class ArUcoGenerator:
    """
    Handles generation of ArUco markers and saving them to disk.
    """
    def __init__(self, output_dir=None):
        if output_dir is None:
            base_dir = os.path.dirname(os.path.abspath(__file__))
            self.output_dir = os.path.join(base_dir, 'aruco_markers')
        else:
            self.output_dir = output_dir
        
        os.makedirs(self.output_dir, exist_ok=True)

    def generate_marker(self, marker_id, aruco_type=ArucoType.DICT_6X6_250, size=200, border_width=5):
        """
        Generate a single ArUco marker.
        """
        aruco_dict = cv2.aruco.getPredefinedDictionary(aruco_type.value)
        marker_image = np.zeros((size, size), dtype=np.uint8)
        marker_image = cv2.aruco.generateImageMarker(aruco_dict, marker_id, size, marker_image, 1)

        # Add white border for better detection
        if border_width > 0:
            marker_image = cv2.copyMakeBorder(
                marker_image,
                border_width, border_width, border_width, border_width,
                cv2.BORDER_CONSTANT,
                value=[255, 255, 255]
            )

        filename = os.path.join(self.output_dir, f'aruco_marker_{marker_id}.png')
        cv2.imwrite(filename, marker_image)
        print(f"Generated marker ID {marker_id} -> {filename}")
        return marker_image

    def generate_batch(self, start_id, count, aruco_type=ArucoType.DICT_6X6_250, size=200):
        """
        Generate multiple ArUco markers.
        """
        print(f"Generating {count} markers starting from ID {start_id}...")
        for i in range(start_id, start_id + count):
            self.generate_marker(i, aruco_type, size)
        print("Batch generation complete.")

if __name__ == "__main__":
    generator = ArUcoGenerator()
    # Example: Generate first 10 markers
    generator.generate_batch(start_id=0, count=10)
