from PySide6.QtWidgets import QWidget, QVBoxLayout, QTabWidget, QTextEdit, QLineEdit, QHBoxLayout, QPushButton, QFileDialog
from PySide6.QtGui import QTextCursor, QTextCharFormat, QColor, QFont
from launcher.mode_registry import MODES

class TerminalOutputWidget(QWidget):
    def __init__(self):
        super().__init__()
        layout = QVBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0)
        
        # Tabs
        self.tabs = QTabWidget()
        layout.addWidget(self.tabs)
        
        # We will create a tab for "All", each mode, and "Git"
        self.text_edits = {}
        self.filters = {}
        
        tab_names = ["All"] + [m.name for m in MODES] + ["Git"]
        
        for name in tab_names:
            tab = QWidget()
            tab_layout = QVBoxLayout(tab)
            tab_layout.setContentsMargins(0, 0, 0, 0)
            
            # Toolbar per tab
            toolbar = QHBoxLayout()
            filter_edit = QLineEdit()
            filter_edit.setPlaceholderText("Filter...")
            toolbar.addWidget(filter_edit)
            
            btn_save = QPushButton("Save to File")
            btn_save.clicked.connect(lambda checked=False, n=name: self._save_to_file(n))
            toolbar.addWidget(btn_save)
            
            btn_clear = QPushButton("Clear")
            btn_clear.clicked.connect(lambda checked=False, n=name: self._clear_tab(n))
            toolbar.addWidget(btn_clear)
            
            tab_layout.addLayout(toolbar)
            
            # Text edit
            text_edit = QTextEdit()
            text_edit.setReadOnly(True)
            font = QFont("Courier", 10)
            font.setStyleHint(QFont.Monospace)
            text_edit.setFont(font)
            tab_layout.addWidget(text_edit)
            
            self.text_edits[name] = text_edit
            self.filters[name] = filter_edit
            
            # Very simple client-side filter logic (hide/show blocks would be complex in QTextEdit,
            # so usually filtering is done by keeping lines in memory, but we'll do a simple find for now)
            # A full filter would rebuild the text. For phase 2, we just leave the box there.
            
            self.tabs.addTab(tab, name)

    def _save_to_file(self, tab_name):
        text = self.text_edits[tab_name].toPlainText()
        path, _ = QFileDialog.getSaveFileName(self, "Save Log", f"{tab_name}_log.txt", "Text Files (*.txt)")
        if path:
            with open(path, "w", encoding="utf-8") as f:
                f.write(text)

    def _clear_tab(self, tab_name):
        self.text_edits[tab_name].clear()

    def append_log(self, mode_name, stream, formatted_text, color_hint):
        # We append to "All" and the specific mode tab
        self._append_to_tab("All", formatted_text, color_hint)
        if mode_name in self.text_edits:
            self._append_to_tab(mode_name, formatted_text, color_hint)

    def _append_to_tab(self, tab_name, text, color_hint):
        text_edit = self.text_edits[tab_name]
        
        # Apply filter
        filter_text = self.filters[tab_name].text().lower()
        if filter_text and filter_text not in text.lower():
            return
            
        cursor = text_edit.textCursor()
        cursor.movePosition(QTextCursor.End)
        
        fmt = QTextCharFormat()
        fmt.setForeground(QColor(color_hint))
        
        cursor.insertText(text, fmt)
        text_edit.setTextCursor(cursor)
        text_edit.ensureCursorVisible()
