import cv2
import time
import logging

class TelemetryHUD:
    """
    Handles HUD drawing and telemetry logging for Autonomous Mode.
    """
    def __init__(self):
        self.font = cv2.FONT_HERSHEY_SIMPLEX
        self.color_main = (0, 255, 0) # Green
        self.color_alert = (0, 0, 255) # Red
        self.color_info = (0, 255, 255) # Yellow

    def draw(self, frame, state, throttle, steering, fps, results=None):
        """Draw HUD on the frame."""
        h, w = frame.shape[:2]
        
        # 1. Basic Telemetry
        lines = [
            f"STATE    : {state.upper()}",
            f"THROTTLE : {throttle:.2f}",
            f"STEERING : {steering:+.3f}",
            f"FPS      : {fps:.1f}",
        ]
        
        for i, line in enumerate(lines):
            cv2.putText(frame, line, (10, 25 + i * 25),
                        self.font, 0.6, self.color_main, 2)

        # 2. ArUco Marker Overlay
        if results:
            for res in results:
                corner = res["corners"][0][0]
                text_pos = (int(corner[0]), int(corner[1]) - 10)
                # Try getting distance from metadata, else show N/A
                dist = res.get('distance', 0.0)
                cv2.putText(frame, f"ID:{res['id']} ({dist:.1f}m)", 
                            text_pos, self.font, 0.5, self.color_info, 2)

        # 3. Steering Bar Visual
        bar_y = h - 30
        bar_x = w // 2
        bar_w = 100
        cv2.line(frame, (bar_x - bar_w, bar_y), (bar_x + bar_w, bar_y), (255, 255, 255), 1)
        marker_x = int(bar_x + (steering * bar_w))
        cv2.circle(frame, (marker_x, bar_y), 6, self.color_alert, -1)
        
        # 4. State Alert (if paused or stopping)
        state_upper = state.upper()
        if "PAUSE" in state_upper or "STOP" in state_upper or "EMERGENCY" in state_upper:
            cv2.putText(frame, f"!!! {state_upper} !!!", (w//2 - 80, h//2),
                        self.font, 1.0, self.color_alert, 3)

        return frame
