from typing import Dict, Type, Set
from .mission_base import Mission
from .mission_types import MissionDefinition, MarkerSighting

class MissionFactory:
    """
    Registry and factory for all Mission subclasses.
    Allows new mission types to be added by registering a class, 
    without modifying dispatcher code.
    """
    _registry: Dict[str, Type[Mission]] = {}

    @classmethod
    def register(cls, mission_type: str, mission_class: Type[Mission]):
        """Registers a Mission subclass under a string name."""
        if not issubclass(mission_class, Mission):
            raise TypeError(f"Class {mission_class.__name__} must inherit from Mission")
        cls._registry[mission_type] = mission_class

    @classmethod
    def create(cls, mission_type: str, definition: MissionDefinition, sighting: MarkerSighting) -> Mission:
        """Instantiates a registered Mission subclass."""
        if mission_type not in cls._registry:
            raise ValueError(f"Unknown mission type: {mission_type}")
            
        mission_class = cls._registry[mission_type]
        return mission_class(definition, sighting)

    @classmethod
    def get_registered_types(cls) -> Set[str]:
        """Returns the set of registered mission type strings."""
        return set(cls._registry.keys())

    @classmethod
    def clear_registry(cls):
        """Clears the registry (useful for testing)."""
        cls._registry.clear()
