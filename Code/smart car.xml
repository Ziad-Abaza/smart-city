import time
from typing import List, Dict, Optional
from .mission_types import MarkerSighting
from .pose_utils import compute_marker_pose

class Track:
    def __init__(self, track_id: int, marker_id: int, current_time: float):
        self.track_id = track_id
        self.marker_id = marker_id
        self.first_seen_t = current_time
        self.last_seen_t = current_time
        self.consecutive_hits = 1
        self.consecutive_misses = 0
        self.is_confirmed = False
        
        self.distance = 0.0
        self.lateral_offset = 0.0
        self.bearing_angle = 0.0
        self.confidence = 0.0

class MarkerTracker:
    """
    Consumes raw per-frame ArUco detections and produces temporally-stable MarkerSightings.
    Debounces flicker (requires N consecutive detections to confirm) and handles temporary 
    marker loss (M consecutive misses to drop a track).
    """
    def __init__(self, confirm_hits: int = 3, drop_misses: int = 5):
        self.confirm_hits = confirm_hits
        self.drop_misses = drop_misses
        self.next_track_id = 1
        self.active_tracks: Dict[int, Track] = {}

    def process_frame(self, detections: List[dict], current_time: float) -> List[MarkerSighting]:
        """
        Process a new frame's detections.
        
        Args:
            detections: List of dicts, each containing 'id', 'tvec', and optionally 'rvec'.
            current_time: The monotonic timestamp of this frame.
            
        Returns:
            A list of confirmed MarkerSighting objects currently visible/tracked.
        """
        seen_ids = set()
        
        for det in detections:
            marker_id = det["id"]
            seen_ids.add(marker_id)
            
            # Extract pose if available
            tvec = det.get("tvec")
            rvec = det.get("rvec")
            if tvec is not None:
                dist, lat, bearing = compute_marker_pose(tvec, rvec)
            else:
                dist, lat, bearing = 0.0, 0.0, 0.0
                
            if marker_id not in self.active_tracks:
                # New track starts
                new_track = Track(self.next_track_id, marker_id, current_time)
                self.next_track_id += 1
                new_track.distance = dist
                new_track.lateral_offset = lat
                new_track.bearing_angle = bearing
                new_track.confidence = min(1.0, 1.0 / self.confirm_hits)
                if self.confirm_hits <= 1:
                    new_track.is_confirmed = True
                self.active_tracks[marker_id] = new_track
            else:
                # Update existing track
                track = self.active_tracks[marker_id]
                track.consecutive_hits += 1
                track.consecutive_misses = 0
                track.last_seen_t = current_time
                track.distance = dist
                track.lateral_offset = lat
                track.bearing_angle = bearing
                track.confidence = min(1.0, track.consecutive_hits / self.confirm_hits)
                
                if track.consecutive_hits >= self.confirm_hits:
                    track.is_confirmed = True

        # Process misses
        lost_ids = []
        for marker_id, track in self.active_tracks.items():
            if marker_id not in seen_ids:
                track.consecutive_misses += 1
                track.consecutive_hits = 0  # Reset consecutive hits on a miss
                if track.consecutive_misses >= self.drop_misses:
                    lost_ids.append(marker_id)

        for marker_id in lost_ids:
            del self.active_tracks[marker_id]

        # Return confirmed sightings
        sightings = []
        for track in self.active_tracks.values():
            if track.is_confirmed:
                sightings.append(MarkerSighting(
                    track_id=track.track_id,
                    marker_id=track.marker_id,
                    distance=track.distance,
                    lateral_offset=track.lateral_offset,
                    bearing_angle=track.bearing_angle,
                    confidence=track.confidence,
                    first_seen_t=track.first_seen_t,
                    last_seen_t=track.last_seen_t
                ))
                
        return sightings
