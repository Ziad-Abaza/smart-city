import numpy as np
import cv2
import time

try:
    # Try importing tflite_runtime (for Raspberry Pi)
    import tflite_runtime.interpreter as tflite
except ImportError:
    # Fallback to full tensorflow
    import tensorflow.lite as tflite

class AutonomousDriver:
    def __init__(self, model_path, input_shape=(66, 200)):
        """Initialize the TFLite interpreter and preprocessing parameters."""
        self.interpreter = tflite.Interpreter(model_path=model_path)
        self.interpreter.allocate_tensors()
        
        self.input_details = self.interpreter.get_input_details()
        self.output_details = self.interpreter.get_output_details()
        
        self.input_shape = input_shape # (height, width)
        self.crop_top = 100
        self.crop_bottom = 260
        
    def preprocess(self, img_bgr):
        """Prepare raw BGR image from camera for the model."""
        # Convert to RGB
        img_rgb = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2RGB)
        
        # Crop (ROI)
        img_cropped = img_rgb[self.crop_top:self.crop_bottom, :, :]
        
        # Resize to model input size
        img_resized = cv2.resize(img_cropped, (self.input_shape[1], self.input_shape[0]))
        
        # Normalize to [0.0, 1.0]
        img_normalized = img_resized.astype(np.float32) / 255.0
        
        # Add batch dimension
        img_batch = np.expand_dims(img_normalized, axis=0)
        
        return img_batch
        
    def predict(self, img_bgr):
        """Run inference and return steering value."""
        start_time = time.time()
        
        # 1. Preprocess
        input_data = self.preprocess(img_bgr)
        
        # 2. Set input tensor
        self.interpreter.set_tensor(self.input_details[0]['index'], input_data)
        
        # 3. Run inference
        self.interpreter.invoke()
        
        # 4. Get output
        steering = self.interpreter.get_tensor(self.output_details[0]['index'])[0][0]
        
        inference_time = (time.time() - start_time) * 1000
        # print(f"Inference time: {inference_time:.2f}ms")
        
        return float(steering)

if __name__ == "__main__":
    # Example usage (testing with a dummy image)
    import os
    model_path = 'models/model.tflite'
    
    if os.path.exists(model_path):
        driver = AutonomousDriver(model_path)
        dummy_img = np.zeros((288, 352, 3), dtype=np.uint8)
        steering = driver.predict(dummy_img)
        print(f"Predicted steering: {steering}")
    else:
        print(f"Model {model_path} not found.")
