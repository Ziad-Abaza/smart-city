import time
import numpy as np
import cv2
from PySide6.QtCore import QObject, Signal, QTimer
from PySide6.QtGui import QImage

class CameraBridge(QObject):
    frameReady = Signal(QImage)
    statusChanged = Signal(str) # "Idle", "Active", "Error", "In Use By <mode>"
    
    def __init__(self, pm):
        super().__init__()
        self.pm = pm
        self.camera = None
        self.timer = QTimer(self)
        self.timer.timeout.connect(self._update_frame)
        
        self._zmq_ctx = None
        self._zmq_sub = None
        self._init_zmq()
        
        self.pm.processAboutToStart.connect(self._on_process_about_to_start)
        self.pm.processStateChanged.connect(self._on_process_state_changed)
        self.active_mode = None
        
        # Start immediately if no camera mode is running
        QTimer.singleShot(0, self._check_and_start)

    def _init_zmq(self):
        try:
            import zmq
            self._zmq_ctx = zmq.Context()
            self._zmq_sub = self._zmq_ctx.socket(zmq.SUB)
            self._zmq_sub.setsockopt(zmq.SUBSCRIBE, b'')
            self._zmq_sub.setsockopt(zmq.CONFLATE, 1)
            self._zmq_sub.connect("tcp://127.0.0.1:5555")
        except Exception as e:
            print(f"Failed to init ZMQ subscriber in camera_bridge: {e}")

    def _check_and_start(self):
        from launcher.mode_registry import get_mode
        for name, p in self.pm.processes.items():
            if p.state in ["Starting", "Running", "Stopping"]:
                mode = get_mode(name)
                if mode.requires_camera:
                    self.active_mode = name
                    self.statusChanged.emit(f"In Use By {name}")
                    return
                    
        self.start()

    def start(self):
        if self.camera is not None:
            return
        self.statusChanged.emit("Starting...")
        try:
            from camera import Camera
            self.camera = Camera()
            self.camera.start()
            self.timer.start(100) # 10 FPS
            self.statusChanged.emit("Active")
        except Exception as e:
            self.statusChanged.emit(f"Error: {e}")
            self.camera = None

    def stop(self):
        self.timer.stop()
        if self.camera is not None:
            self.camera.stop()
            self.camera = None

    def _update_frame(self):
        if self.camera is not None:
            # Local camera
            frame = getattr(self.camera, 'frame', None)
            if frame is not None:
                self._emit_frame(frame)
                return
                
        # Subscribed camera
        if self.active_mode is not None and self._zmq_sub is not None:
            import zmq
            try:
                # drain until empty to get the latest
                latest = None
                while True:
                    try:
                        latest = self._zmq_sub.recv(flags=zmq.NOBLOCK)
                    except zmq.Again:
                        break
                if latest is not None:
                    np_arr = np.frombuffer(latest, np.uint8)
                    frame = cv2.imdecode(np_arr, cv2.IMREAD_COLOR)
                    if frame is not None:
                        self._emit_frame(frame)
            except Exception:
                pass

    def _emit_frame(self, frame):
        h, w, ch = frame.shape
        bytes_per_line = ch * w
        qimg = QImage(frame.data, w, h, bytes_per_line, QImage.Format_BGR888)
        self.frameReady.emit(qimg)

    def _on_process_about_to_start(self, mode_name):
        from launcher.mode_registry import get_mode
        mode = get_mode(mode_name)
        if mode.requires_camera:
            self.stop()
            self.active_mode = mode_name
            self.statusChanged.emit(f"In Use By {mode_name} (Live)")
            # Keep timer running for ZMQ polling
            self.timer.start(100)

    def _on_process_state_changed(self, mode_name, state):
        from launcher.mode_registry import get_mode
        mode = get_mode(mode_name)
        if not mode.requires_camera:
            return
            
        if state in ["Stopped", "Crashed"]:
            if self.active_mode == mode_name:
                self.active_mode = None
                # Give the OS a moment to release the camera device node
                QTimer.singleShot(1000, self._check_and_start)
