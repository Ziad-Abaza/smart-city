import numpy as np
import math

def compute_marker_pose(tvec, rvec=None):
    """
    Computes distance, lateral offset, and bearing angle to a marker from its translation vector.
    
    Args:
        tvec: Translation vector from cv2.solvePnP (shape (3, 1) or (3,))
              Assuming standard OpenCV camera coordinate system:
              X is right, Y is down, Z is forward.
        rvec: Rotation vector (currently unused, included for future orientation needs)
        
    Returns:
        tuple: (distance, lateral_offset, bearing_angle)
            - distance (float): Euclidean distance to the marker in meters.
            - lateral_offset (float): X-axis translation (positive is to the right).
            - bearing_angle (float): Angle in radians from the camera's optical axis 
                                     to the marker (positive is to the right).
    """
    tvec = np.asarray(tvec).flatten()
    
    if len(tvec) != 3:
        raise ValueError("tvec must have exactly 3 elements")
        
    x, y, z = tvec
    
    distance = float(np.linalg.norm(tvec))
    lateral_offset = float(x)
    
    # Bearing angle is atan2(x, z). 
    # If z is 0, this will handle it safely (returns pi/2 or -pi/2).
    bearing_angle = float(math.atan2(x, z))
    
    return distance, lateral_offset, bearing_angle
