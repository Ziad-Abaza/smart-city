from abc import ABC, abstractmethod
from typing import Optional
from .mission_types import (
    MissionDefinition, 
    MarkerSighting, 
    VehicleState, 
    MissionCommand, 
    MissionOutcome
)

class MissionPhase:
    """Standard phases every mission progresses through."""
    PENDING = "pending"
    APPROACH = "approach"
    PREPARE = "prepare"
    EXECUTE = "execute"
    RECOVER = "recover"
    COMPLETE = "complete"
    ABORTED = "aborted"

class Mission(ABC):
    """
    Abstract base class for all mission types.
    Defines the standard lifecycle interface driven by the MissionManager.
    """
    def __init__(self, definition: MissionDefinition, initial_sighting: MarkerSighting):
        self.definition = definition
        self.initial_sighting = initial_sighting
        self.current_phase = MissionPhase.PENDING

    @abstractmethod
    def on_pending(self, vehicle_state: VehicleState, sighting: Optional[MarkerSighting]) -> MissionCommand:
        pass

    @abstractmethod
    def on_approach(self, vehicle_state: VehicleState, sighting: Optional[MarkerSighting]) -> MissionCommand:
        pass

    @abstractmethod
    def on_prepare(self, vehicle_state: VehicleState, sighting: Optional[MarkerSighting]) -> MissionCommand:
        pass

    @abstractmethod
    def on_execute(self, vehicle_state: VehicleState, sighting: Optional[MarkerSighting]) -> MissionCommand:
        pass

    @abstractmethod
    def on_recover(self, vehicle_state: VehicleState, sighting: Optional[MarkerSighting]) -> MissionCommand:
        pass

    @abstractmethod
    def on_abort(self, vehicle_state: VehicleState) -> MissionCommand:
        """Called when the mission is cancelled forcefully."""
        pass

    @abstractmethod
    def on_interrupt(self, vehicle_state: VehicleState, new_priority: int) -> MissionCommand:
        """Called when a higher-priority mission attempts to interrupt."""
        pass

    @abstractmethod
    def is_phase_complete(self, phase: str, vehicle_state: VehicleState) -> bool:
        """Evaluates if the current phase has finished its work."""
        pass

    @abstractmethod
    def report_outcome(self) -> MissionOutcome:
        """Returns the final outcome of the mission."""
        pass
