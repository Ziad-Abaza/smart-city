import pandas as pd
import numpy as np
import os
import matplotlib.pyplot as plt

def analyze_and_optimize():
    csv_path = 'DataCollected/driving_log.csv'
    
    if not os.path.exists(csv_path):
        print(f"Error: {csv_path} not found!")
        return

    # Load the dataset
    df = pd.read_csv(csv_path)
    total_samples = len(df)
    
    print("="*50)
    print("  DATASET ANALYSIS REPORT")
    print("="*50)
    print(f"Total Samples: {total_samples}")

    # 1. State Distribution (using the 'state' column)
    if 'state' in df.columns:
        state_counts = df['state'].value_counts()
        print("\nDriving State Distribution:")
        for state, count in state_counts.items():
            percentage = (count / total_samples) * 100
            print(f"  - {state:10}: {count:6} ({percentage:.2f}%)")
    
    # 2. Steering Analysis (Manual classification for more detail)
    steering = df['steering'].values
    straight = df[np.abs(df['steering']) < 0.05]
    gentle = df[(np.abs(df['steering']) >= 0.05) & (np.abs(df['steering']) < 0.15)]
    sharp = df[np.abs(df['steering']) >= 0.15]

    print("\nSteering Angle Classification:")
    print(f"  - Straight (<0.05) : {len(straight):6} ({len(straight)/total_samples*100:.2f}%)")
    print(f"  - Gentle   (0.05-0.15): {len(gentle):6} ({len(gentle)/total_samples*100:.2f}%)")
    print(f"  - Sharp    (>0.15) : {len(sharp):6} ({len(sharp)/total_samples*100:.2f}%)")
    print("="*50)

    # 3. Optimization / Pruning
    try:
        prune_pct = float(input("\nEnter the percentage of 'Straight' data to REMOVE (0 to 100): "))
    except ValueError:
        print("Invalid input. Skipping pruning.")
        return

    if prune_pct > 0:
        # We prune from the 'straight' category (steering < 0.05)
        # Randomly shuffle the straight indices and drop a portion
        straight_indices = straight.index.tolist()
        np.random.shuffle(straight_indices)
        
        num_to_remove = int(len(straight_indices) * (prune_pct / 100.0))
        indices_to_remove = straight_indices[:num_to_remove]
        
        df_optimized = df.drop(indices_to_remove)
        
        new_total = len(df_optimized)
        print(f"\nOptimization Complete:")
        print(f"  - Samples removed: {num_to_remove}")
        print(f"  - New total samples: {new_total}")
        
        # New distribution
        new_straight_count = len(df_optimized[np.abs(df_optimized['steering']) < 0.05])
        print(f"  - New Straight percentage: {new_straight_count/new_total*100:.2f}%")
        
        save_choice = input("\nSave optimized CSV as 'driving_log_optimized.csv'? (y/n): ")
        if save_choice.lower() == 'y':
            output_path = 'DataCollected/driving_log_optimized.csv'
            df_optimized.to_csv(output_path, index=False)
            print(f"Saved to {output_path}")
    else:
        print("No samples removed.")

if __name__ == "__main__":
    analyze_and_optimize()
