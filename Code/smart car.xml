import cv2
import numpy as np
import time
try:
    from .aruco_config import ArucoType, DEFAULT_CAMERA_MATRIX, DEFAULT_DIST_COEFFS
except (ImportError, ValueError):
    from aruco_config import ArucoType, DEFAULT_CAMERA_MATRIX, DEFAULT_DIST_COEFFS

class ArUcoDetector:
    """
    Unified ArUco marker detector and pose estimator.
    """
    def __init__(self, 
                 aruco_type=ArucoType.DICT_6X6_250, 
                 camera_matrix=None, 
                 dist_coeffs=None,
                 marker_size_meters=0.05):
        
        self.aruco_dict = cv2.aruco.getPredefinedDictionary(aruco_type.value)
        self.aruco_params = cv2.aruco.DetectorParameters()
        self.detector = cv2.aruco.ArucoDetector(self.aruco_dict, self.aruco_params)
        
        self.camera_matrix = np.array(camera_matrix if camera_matrix is not None else DEFAULT_CAMERA_MATRIX)
        self.dist_coeffs = np.array(dist_coeffs if dist_coeffs is not None else DEFAULT_DIST_COEFFS)
        self.marker_size = marker_size_meters

        # Define 3D points of the marker in its own coordinate system
        # Assuming the marker is on the Z=0 plane
        s = self.marker_size / 2
        self.obj_points = np.array([
            [-s,  s, 0],
            [ s,  s, 0],
            [ s, -s, 0],
            [-s, -s, 0]
        ], dtype=np.float32)

    def detect(self, frame, estimate_pose=True):
        """
        Detect markers in a frame and optionally estimate their pose.
        """
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        corners, ids, rejected = self.detector.detectMarkers(gray)
        
        results = []
        if ids is not None:
            for i, corner in enumerate(corners):
                marker_id = ids[i][0]
                result = {
                    "id": marker_id,
                    "corners": corner
                }
                
                if estimate_pose:
                    # solvePnP returns rotation and translation vectors
                    ret, rvec, tvec = cv2.solvePnP(self.obj_points, corner, self.camera_matrix, self.dist_coeffs)
                    if ret:
                        result["rvec"] = rvec
                        result["tvec"] = tvec
                        result["distance"] = np.linalg.norm(tvec)
                
                results.append(result)
        
        return results, ids

    def draw_detections(self, frame, results, show_axes=True, show_info=True):
        """
        Draw detected markers, IDs, distances, and axes on the frame.
        """
        for res in results:
            # Draw marker boundary
            cv2.aruco.drawDetectedMarkers(frame, [res["corners"]], np.array([[res["id"]]]))
            
            if show_info:
                corner = res["corners"][0][0]
                text_pos = (int(corner[0]), int(corner[1]) - 10)
                cv2.putText(frame, f"ID: {res['id']}", text_pos, 
                            cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 255, 0), 2)
                
                if "distance" in res:
                    dist_pos = (int(corner[0]), int(corner[1]) - 30)
                    cv2.putText(frame, f"Dist: {res['distance']:.2f}m", dist_pos, 
                                cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 255, 255), 2)
            
            if show_axes and "rvec" in res and "tvec" in res:
                cv2.drawFrameAxes(frame, self.camera_matrix, self.dist_coeffs, 
                                  res["rvec"], res["tvec"], self.marker_size)
        
        return frame

def run_live_detection(camera_index=0, aruco_type=ArucoType.DICT_6X6_250):
    detector = ArUcoDetector(aruco_type=aruco_type)
    cap = cv2.VideoCapture(camera_index)
    
    if not cap.isOpened():
        print(f"Error: Could not open camera {camera_index}")
        return

    print("Starting ArUco detection. Press 'q' to quit.")
    
    prev_time = 0
    while True:
        ret, frame = cap.read()
        if not ret:
            break
            
        # Calculate FPS
        curr_time = time.time()
        fps = 1 / (curr_time - prev_time) if prev_time > 0 else 0
        prev_time = curr_time
        
        # Detect and estimate pose
        results, ids = detector.detect(frame)
        
        # Visualize
        frame = detector.draw_detections(frame, results)
        cv2.putText(frame, f"FPS: {fps:.1f}", (10, 30), 
                    cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 0, 255), 2)
        
        cv2.imshow("ArUco Detection", frame)
        
        if cv2.waitKey(1) & 0xFF == ord('q'):
            break
            
    cap.release()
    cv2.destroyAllWindows()

if __name__ == "__main__":
    run_live_detection()
