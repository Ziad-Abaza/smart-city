import os
import time
from PySide6.QtCore import QObject, Signal
from launcher.settings import MAX_LOG_FILES_PER_MODE
from launcher.mode_registry import MODES

class LogManager(QObject):
    newLine = Signal(str, str, str, str) # mode_name, stream, formatted_text, color_hint
    
    def __init__(self, pm):
        super().__init__()
        self.pm = pm
        self.pm.logMessage.connect(self._on_log_message)
        
        self.log_dir = "logs"
        os.makedirs(self.log_dir, exist_ok=True)
        self.files = {}
        
        self.pm.processStateChanged.connect(self._on_state_changed)
        self._cleanup_old_logs()

    def _cleanup_old_logs(self):
        for mode in MODES:
            mode_files = []
            for f in os.listdir(self.log_dir):
                if f.startswith(f"{mode.name}_") and f.endswith(".log"):
                    mode_files.append(f)
            mode_files.sort()
            if len(mode_files) > MAX_LOG_FILES_PER_MODE:
                to_delete = mode_files[:-MAX_LOG_FILES_PER_MODE]
                for f in to_delete:
                    try:
                        os.remove(os.path.join(self.log_dir, f))
                    except:
                        pass

    def _on_state_changed(self, mode_name, state):
        if state == "Starting":
            ts = time.strftime("%Y%m%d_%H%M%S")
            filename = os.path.join(self.log_dir, f"{mode_name}_{ts}.log")
            if mode_name in self.files:
                self.files[mode_name].close()
            self.files[mode_name] = open(filename, "w", encoding="utf-8")

    def _on_log_message(self, mode_name, stream, text):
        # Text can contain multiple lines
        lines = text.splitlines(keepends=True)
        ts = time.strftime("%H:%M:%S")
        for line in lines:
            formatted = f"[{ts}] [{stream}] {line}"
            color = "black"
            lower_line = line.lower()
            if "error" in lower_line or "traceback" in lower_line:
                color = "red"
            elif "warn" in lower_line:
                color = "orange"
            elif stream == "stderr":
                color = "darkred"
                
            f = self.files.get(mode_name)
            if f:
                f.write(formatted)
                f.flush()
                
            self.newLine.emit(mode_name, stream, formatted, color)
