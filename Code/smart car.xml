import sys
import time
from PySide6.QtWidgets import (
    QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,
    QPushButton, QLabel, QTableWidget, QTableWidgetItem, QHeaderView, QMessageBox
)
from PySide6.QtCore import Qt, QTimer
from launcher.mode_registry import MODES, get_mode
from launcher.process_manager import ProcessManager
from launcher.log_manager import LogManager
from launcher.ui_widgets.terminal import TerminalOutputWidget
from launcher.git_updater import GitUpdater
from launcher.ui_widgets.git_panel import GitUpdatePanel
from launcher.camera_bridge import CameraBridge
from launcher.ui_widgets.camera_preview import CameraPreviewWidget
from launcher.ui_widgets.system_status import SystemStatusWidget

class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Smart Car Launcher")
        self.resize(1024, 768)
        
        self.pm = ProcessManager()
        self.pm.processStateChanged.connect(self._on_process_state_changed)
        self.pm.errorOccurred.connect(self._on_error_occurred)
        
        self.lm = LogManager(self.pm)
        
        self.git_updater = GitUpdater()
        self.git_updater.logMessage.connect(self.lm._on_log_message)
        self.git_updater.stateChanged.connect(self.lm._on_state_changed)
        
        self.camera_bridge = CameraBridge(self.pm)
        
        main_widget = QWidget()
        self.setCentralWidget(main_widget)
        layout = QVBoxLayout(main_widget)
        
        # Toolbar
        self.toolbar_layout = QHBoxLayout()
        self.mode_buttons = {}
        for mode in MODES:
            btn = QPushButton(mode.name)
            btn.clicked.connect(lambda checked=False, m=mode.name: self.pm.start_mode(m))
            self.toolbar_layout.addWidget(btn)
            self.mode_buttons[mode.name] = btn
        
        self.btn_stop = QPushButton("Stop All")
        self.btn_stop.clicked.connect(self.pm.stop_all)
        self.toolbar_layout.addWidget(self.btn_stop)
        
        layout.addLayout(self.toolbar_layout)
        
        # Mid Section
        mid_layout = QHBoxLayout()
        self.camera_preview = CameraPreviewWidget(self.camera_bridge)
        mid_layout.addWidget(self.camera_preview)
        
        # System Status Panel
        self.system_status = SystemStatusWidget(self.pm, self.lm, self.camera_bridge)
        mid_layout.addWidget(self.system_status)
        layout.addLayout(mid_layout)
        
        # Process Status Table
        self.table = QTableWidget(len(MODES), 6)
        self.table.setHorizontalHeaderLabels(["Mode", "State", "PID", "Started", "Restart Count", "Actions"])
        self.table.horizontalHeader().setSectionResizeMode(QHeaderView.Stretch)
        
        self.row_map = {}
        for i, mode in enumerate(MODES):
            self.row_map[mode.name] = i
            self.table.setItem(i, 0, QTableWidgetItem(mode.name))
            self.table.setItem(i, 1, QTableWidgetItem("Stopped"))
            self.table.setItem(i, 2, QTableWidgetItem("-"))
            self.table.setItem(i, 3, QTableWidgetItem("-"))
            self.table.setItem(i, 4, QTableWidgetItem("0"))
            
            action_widget = QWidget()
            action_layout = QHBoxLayout(action_widget)
            action_layout.setContentsMargins(0, 0, 0, 0)
            btn_stop_row = QPushButton("Stop")
            btn_stop_row.clicked.connect(lambda checked=False, m=mode.name: self.pm.stop_mode(m))
            btn_restart_row = QPushButton("Restart")
            btn_restart_row.clicked.connect(lambda checked=False, m=mode.name: self.pm.restart_mode(m))
            action_layout.addWidget(btn_stop_row)
            action_layout.addWidget(btn_restart_row)
            self.table.setCellWidget(i, 5, action_widget)
            
        layout.addWidget(self.table)
        
        # Error Notification Bar
        self.error_bar = QLabel("")
        self.error_bar.setStyleSheet("background-color: #f8d7da; color: #721c24; padding: 5px; border: 1px solid #f5c6cb; border-radius: 3px;")
        self.error_bar.hide()
        layout.addWidget(self.error_bar)
        
        # Git Update Panel
        self.git_panel = GitUpdatePanel(self.git_updater)
        layout.addWidget(self.git_panel)
        
        # Terminal Output
        self.terminal = TerminalOutputWidget()
        layout.addWidget(self.terminal)
        self.lm.newLine.connect(self.terminal.append_log)
        
        # Timer for UI updates
        self.update_timer = QTimer(self)
        self.update_timer.timeout.connect(self._update_table_dynamic_data)
        self.update_timer.start(1000)

    def _on_process_state_changed(self, mode_name, state):
        row = self.row_map.get(mode_name)
        if row is not None:
            self.table.setItem(row, 1, QTableWidgetItem(state))
            
            p = self.pm.get_process(mode_name)
            pid = str(p.process.processId()) if p.process.processId() > 0 else "-"
            self.table.setItem(row, 2, QTableWidgetItem(pid))
            self.table.setItem(row, 4, QTableWidgetItem(str(p.restart_count)))
            
        self._update_button_states()

    def _on_error_occurred(self, mode_name, error_msg):
        self.error_bar.setText(f"Error in {mode_name}: {error_msg}")
        self.error_bar.show()
        # Auto-hide after 10 seconds
        QTimer.singleShot(10000, self.error_bar.hide)

    def _update_button_states(self):
        # Exclusivity group check
        driving_running = False
        camera_running = False
        for name, p in self.pm.processes.items():
            if p.state in ["Starting", "Running"]:
                mode = get_mode(name)
                if mode.exclusivity_group == "driving":
                    driving_running = True
                if mode.exclusivity_group == "camera":
                    camera_running = True
                    
        for mode in MODES:
            btn = self.mode_buttons.get(mode.name)
            if not btn:
                continue
            p = self.pm.processes.get(mode.name)
            is_running = p and p.state in ["Starting", "Running"]
            if is_running:
                btn.setEnabled(False)
            else:
                if mode.exclusivity_group == "driving" and driving_running:
                    btn.setEnabled(False)
                elif mode.exclusivity_group == "camera" and camera_running:
                    btn.setEnabled(False)
                else:
                    btn.setEnabled(True)

    def _update_table_dynamic_data(self):
        now = time.time()
        for mode_name, p in self.pm.processes.items():
            if p.state == "Running" and p.start_time > 0:
                elapsed = int(now - p.start_time)
                mins, secs = divmod(elapsed, 60)
                row = self.row_map.get(mode_name)
                if row is not None:
                    self.table.setItem(row, 3, QTableWidgetItem(f"{mins:02d}:{secs:02d}"))
            elif p.state in ["Stopped", "Crashed"]:
                row = self.row_map.get(mode_name)
                if row is not None:
                    self.table.setItem(row, 3, QTableWidgetItem("-"))

    def closeEvent(self, event):
        self.pm.stop_all()
        # Wait a brief moment for processes to stop
        event.accept()

def main():
    app = QApplication(sys.argv)
    window = MainWindow()
    window.show()
    sys.exit(app.exec())

if __name__ == "__main__":
    main()
