import pandas as pd
import numpy as np
import cv2
import os
from sklearn.model_selection import train_test_split
from sklearn.utils import shuffle

# Configuration
IMG_WIDTH, IMG_HEIGHT = 200, 66
CROP_TOP, CROP_BOTTOM = 100, 260

def preprocess_image(img_path):
    """Load, crop, resize, and normalize an image."""
    # Load image (OpenCV loads as BGR)
    img = cv2.imread(img_path)
    if img is None:
        raise FileNotFoundError(f"Image not found at {img_path}")
    
    # Convert to RGB
    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
    
    # Crop (ROI)
    img = img[CROP_TOP:CROP_BOTTOM, :, :]
    
    # Resize
    img = cv2.resize(img, (IMG_WIDTH, IMG_HEIGHT))
    
    # Normalize
    img = img.astype(np.float32) / 255.0
    
    return img

def augment_image(img, steering):
    """Apply random augmentations: Flip and Brightness."""
    # 1. Random Brightness
    hsv = cv2.cvtColor(img, cv2.COLOR_RGB2HSV)
    ratio = 1.0 + 0.4 * (np.random.rand() - 0.5)
    hsv[:, :, 2] = np.clip(hsv[:, :, 2] * ratio, 0, 1.0)
    img = cv2.cvtColor(hsv, cv2.COLOR_HSV2RGB)
    
    # 2. Random Flip
    if np.random.rand() < 0.5:
        img = cv2.flip(img, 1)
        steering = -steering
        
    return img, steering

def load_data(csv_path, base_dir='DataCollected'):
    """Load CSV and apply balancing."""
    df = pd.read_csv(csv_path)
    
    # Mandatory: Ignore speed
    if 'speed' in df.columns:
        df = df.drop(columns=['speed'])
    
    # Path correction
    df['center'] = df['center'].apply(lambda x: os.path.join(base_dir, x))
    
    # Fill NaN states based on steering (if steering is low, assume straight)
    df['state'] = df['state'].fillna('straight')
    
    # Balancing strategy
    # 1. Straight driving (state=='straight' and low steering)
    straight_mask = (df['state'] == 'straight') & (df['steering'].abs() < 0.02)
    df_straight = df[straight_mask]
    df_other = df[~straight_mask]
    
    # Downsample straight driving by 85% (keep only 15%)
    df_straight_downsampled = df_straight.sample(frac=0.15, random_state=42)
    
    # 2. Sharp/Recovery driving (upsample to emphasize importance)
    sharp_mask = (df['state'] == 'sharp') | (df['state'] == 'recovery')
    df_sharp = df[sharp_mask]
    
    # Combine (Triple sharp/recovery samples)
    df_balanced = pd.concat([df_other, df_straight_downsampled, df_sharp, df_sharp]) 
    df_balanced = shuffle(df_balanced).reset_index(drop=True)
    
    print(f"Original size: {len(df)}")
    print(f"Balanced size: {len(df_balanced)}")
    print("State distribution after balancing:")
    print(df_balanced['state'].value_counts(dropna=False))
    
    return df_balanced

def batch_generator(df, batch_size, is_training):
    """Generator for Keras training."""
    while True:
        df = shuffle(df)
        for i in range(0, len(df), batch_size):
            batch_df = df.iloc[i : i + batch_size]
            
            images = []
            steerings = []
            
            for _, row in batch_df.iterrows():
                try:
                    img = preprocess_image(row['center'])
                    steer = row['steering']
                    
                    if is_training:
                        img, steer = augment_image(img, steer)
                        
                    images.append(img)
                    steerings.append(steer)
                except Exception as e:
                    print(f"Error processing {row['center']}: {e}")
                    continue
            
            yield np.array(images), np.array(steerings)

if __name__ == "__main__":
    # Test loader
    df = load_data('DataCollected/driving_log.csv')
    gen = batch_generator(df, 32, True)
    imgs, steers = next(gen)
    print(f"Batch shape: {imgs.shape}, Steer shape: {steers.shape}")
