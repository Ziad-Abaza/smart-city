import logging
from config import LEDConfig

logger = logging.getLogger(__name__)

class DummyLED:
    """Mock object that does nothing, avoiding constant 'if leds:' checks."""
    def on(self):
        pass
    def off(self):
        pass
    def close(self):
        pass

class LEDIndicator:
    """
    Decoupled hardware controller for status LEDs.
    Uses gpiozero.LED with safe fallback to DummyLED if hardware is unavailable.
    """
    def __init__(self):
        self.normal_led = DummyLED()
        self.recovery_led = DummyLED()

        if not LEDConfig.ENABLED:
            logger.info("[LED] Indicators disabled in configuration.")
            return

        try:
            from gpiozero import LED
            self.normal_led = LED(LEDConfig.PIN_RECORD_NORMAL)
            self.recovery_led = LED(LEDConfig.PIN_RECORD_RECOVERY)
            logger.info("[LED] Hardware initialized (Normal: BCM %d, Recovery: BCM %d)", 
                        LEDConfig.PIN_RECORD_NORMAL, LEDConfig.PIN_RECORD_RECOVERY)
        except (ImportError, Exception) as e:
            logger.warning("[LED] Could not initialize GPIO LEDs: %s. Falling back to dummy mode.", e)

    def set_normal_recording(self, active: bool):
        """Turn Normal Record LED ON or OFF."""
        if active:
            self.normal_led.on()
        else:
            self.normal_led.off()

    def set_recovery_recording(self, active: bool):
        """Turn Recovery Record LED ON or OFF."""
        if active:
            self.recovery_led.on()
        else:
            self.recovery_led.off()

    def close(self):
        """Cleanly release GPIO resources and turn off LEDs."""
        try:
            self.normal_led.off()
            self.recovery_led.off()
            self.normal_led.close()
            self.recovery_led.close()
        except Exception:
            pass
