from abc import ABC, abstractmethod
from .mission_types import VehicleState, MissionCommand

class ManeuverPrimitive(ABC):
    """Base class for reusable, composable open/closed-loop maneuvers."""
    @abstractmethod
    def start(self, vehicle_state: VehicleState, current_time: float):
        pass

    @abstractmethod
    def update(self, vehicle_state: VehicleState, current_time: float) -> MissionCommand:
        pass

    @abstractmethod
    def is_complete(self, vehicle_state: VehicleState, current_time: float) -> bool:
        pass

class TimedStraightAdvance(ManeuverPrimitive):
    """Drives straight for a fixed duration."""
    def __init__(self, duration_s: float, speed_scale: float = 1.0):
        self.duration_s = duration_s
        self.speed_scale = speed_scale
        self.start_time = 0.0

    def start(self, vehicle_state: VehicleState, current_time: float):
        self.start_time = current_time

    def update(self, vehicle_state: VehicleState, current_time: float) -> MissionCommand:
        return MissionCommand(vehicle_state.speed * self.speed_scale, 0.0, "MANEUVER:STRAIGHT")

    def is_complete(self, vehicle_state: VehicleState, current_time: float) -> bool:
        return (current_time - self.start_time) >= self.duration_s

class YawTargetTurn(ManeuverPrimitive):
    """Turns using IMU feedback until a target yaw delta is reached, bounded by a watchdog."""
    def __init__(self, target_yaw_delta_deg: float, speed_scale: float = 0.7, max_duration_s: float = 4.0, steering_scale: float = 1.0):
        self.target_yaw_delta = target_yaw_delta_deg
        self.speed_scale = speed_scale
        self.max_duration_s = max_duration_s
        self.steering_scale = steering_scale
        self.start_time = 0.0
        self.start_yaw = 0.0
        self.tolerance_deg = 5.0

    def start(self, vehicle_state: VehicleState, current_time: float):
        self.start_time = current_time
        self.start_yaw = vehicle_state.yaw

    def update(self, vehicle_state: VehicleState, current_time: float) -> MissionCommand:
        throttle = vehicle_state.speed * self.speed_scale
        # Ackermann limit: turn must not exceed throttle to prevent inner wheel reversal
        # We use a factor of 0.9 to ensure forward motion on both wheels
        ackermann_limit = abs(throttle) * 0.9
        steering_mag = min(1.0, ackermann_limit * self.steering_scale)
        steering = -steering_mag if self.target_yaw_delta > 0 else steering_mag
        return MissionCommand(throttle, steering, "MANEUVER:TURN")

    def is_complete(self, vehicle_state: VehicleState, current_time: float) -> bool:
        if (current_time - self.start_time) >= self.max_duration_s:
            return True # Watchdog trip
            
        current_delta = vehicle_state.yaw - self.start_yaw
        if self.target_yaw_delta > 0:
            if current_delta >= self.target_yaw_delta - self.tolerance_deg:
                return True
        else:
            if current_delta <= self.target_yaw_delta + self.tolerance_deg:
                return True
        return False

class BlendedLaneReturn(ManeuverPrimitive):
    """Ramps steering from straight-ahead smoothly into AIDriver's lane following output."""
    def __init__(self, blend_duration_s: float = 1.0):
        self.blend_duration_s = blend_duration_s
        self.start_time = 0.0

    def start(self, vehicle_state: VehicleState, current_time: float):
        self.start_time = current_time

    def update(self, vehicle_state: VehicleState, current_time: float) -> MissionCommand:
        elapsed = current_time - self.start_time
        alpha = min(1.0, max(0.0, elapsed / self.blend_duration_s))
        blended_steering = vehicle_state.lane_steering * alpha
        
        # Enforce Ackermann limit during recovery to prevent physical spin
        ackermann_limit = abs(vehicle_state.speed) * 0.9
        blended_steering = max(-ackermann_limit, min(ackermann_limit, blended_steering))
        
        return MissionCommand(vehicle_state.speed, blended_steering, "MANEUVER:RECOVER")

    def is_complete(self, vehicle_state: VehicleState, current_time: float) -> bool:
        return (current_time - self.start_time) >= self.blend_duration_s
