#!/usr/bin/env python3
# =============================================================================
# motor_calibration.py — Motor Drift Calibration System
#
# SSH-safe: uses select() + non-blocking reads to avoid terminal freeze.
# =============================================================================

import json
import logging
import os
import select
import sys
import termios
import time
import tty
from pathlib import Path

logger = logging.getLogger(__name__)

CAL_FILE = Path(__file__).parent / "motor_cal.json"

TRIM_MIN = 0.70
TRIM_MAX = 1.30

STEP_FINE   = 0.005
STEP_MEDIUM = 0.015
STEP_COARSE = 0.030


# =============================================================================
#  MotorCalibration
# =============================================================================
class MotorCalibration:
    """
    Independent trim correction factors for each motor.

        left_actual  = commanded_speed * left_trim
        right_actual = commanded_speed * right_trim

    Range: [0.70 .. 1.30]   Default: 1.0 (no correction)
    """

    def __init__(self):
        self.left_trim:  float = 1.0
        self.right_trim: float = 1.0
        self._loaded = False
        self.load()

    # ── Persistence ──────────────────────────────────────────────────────────

    def save(self) -> None:
        data = {
            "left_trim":  round(self.left_trim,  4),
            "right_trim": round(self.right_trim, 4),
            "timestamp":  time.strftime("%Y-%m-%d %H:%M:%S"),
            "note":       "Motor calibration — drift correction factors",
        }
        with open(CAL_FILE, "w") as f:
            json.dump(data, f, indent=2)
        logger.info(
            f"[Cal] Saved  L={self.left_trim:.4f}  R={self.right_trim:.4f}"
        )

    def load(self) -> bool:
        if not CAL_FILE.exists():
            logger.info("[Cal] No calibration file found; using defaults (1.0 / 1.0).")
            return False
        try:
            with open(CAL_FILE) as f:
                data = json.load(f)
            self.left_trim  = float(data.get("left_trim",  1.0))
            self.right_trim = float(data.get("right_trim", 1.0))
            self._clip()
            self._loaded = True
            logger.info(
                f"[Cal] Loaded  L={self.left_trim:.4f}  R={self.right_trim:.4f}"
                f"  ({data.get('timestamp', '?')})"
            )
            return True
        except Exception as e:
            logger.warning(f"[Cal] Load failed: {e}")
            return False

    def reset(self) -> None:
        self.left_trim  = 1.0
        self.right_trim = 1.0
        if CAL_FILE.exists():
            CAL_FILE.unlink()
        logger.info("[Cal] Reset to defaults.")

    # ── Adjustment ───────────────────────────────────────────────────────────

    def adjust(self, side: str, delta: float) -> None:
        if side == "left":
            self.left_trim  = round(self.left_trim  + delta, 4)
        elif side == "right":
            self.right_trim = round(self.right_trim + delta, 4)
        else:
            raise ValueError(f"side must be 'left' or 'right', got: {side!r}")
        self._clip()

    # ── Apply ─────────────────────────────────────────────────────────────────

    def apply(self, left_speed: float, right_speed: float):
        """Returns (left_corrected, right_corrected) clamped to [-1, 1]."""
        l = max(-1.0, min(1.0, left_speed  * self.left_trim))
        r = max(-1.0, min(1.0, right_speed * self.right_trim))
        return l, r

    # ── Info ─────────────────────────────────────────────────────────────────

    @property
    def info(self) -> dict:
        return {
            "left_trim":        self.left_trim,
            "right_trim":       self.right_trim,
            "balance":          round(self.right_trim - self.left_trim, 4),
            "loaded_from_file": self._loaded,
        }

    def __repr__(self):
        return (
            f"MotorCalibration("
            f"left={self.left_trim:.4f}, "
            f"right={self.right_trim:.4f}, "
            f"balance={self.right_trim - self.left_trim:+.4f})"
        )

    def _clip(self):
        self.left_trim  = max(TRIM_MIN, min(TRIM_MAX, self.left_trim))
        self.right_trim = max(TRIM_MIN, min(TRIM_MAX, self.right_trim))


# =============================================================================
#  SSH-safe non-blocking key reader
# =============================================================================
def _read_key(fd: int, timeout: float = 0.05) -> str:
    """
    Return one character if a key was pressed within `timeout` seconds,
    otherwise return ''.

    Uses select() instead of a plain blocking read so the event loop
    stays alive over SSH without hanging on stdin.
    """
    ready, _, _ = select.select([fd], [], [], timeout)
    if ready:
        return os.read(fd, 1).decode("utf-8", errors="ignore")
    return ""


# =============================================================================
#  Interactive Calibrator
# =============================================================================
class InteractiveCalibrator:
    """
    SSH-safe interactive calibration session.

    Uses tty.setcbreak() instead of tty.setraw() so that:
      - Keys are delivered immediately (no Enter needed)
      - SIGINT (Ctrl-C) still works over SSH
      - The terminal does not freeze between keystrokes

    Key map
    -------
    a / A   vehicle drifts LEFT   → increase right motor  (fine / medium)
    d / D   vehicle drifts RIGHT  → increase left  motor  (fine / medium)
    z / Z   decrease right motor                          (fine / medium)
    c / C   decrease left  motor                          (fine / medium)
    s       save calibration to motor_cal.json
    r       reset both trims to 1.0
    p       reprint current status line
    q / Q   quit (motors stop immediately)
    """

    def __init__(self, motor_controller=None):
        self.cal    = MotorCalibration()
        self.mc     = motor_controller
        self._speed = 0.28          # constant forward speed used during test

    # ── Public ───────────────────────────────────────────────────────────────

    def run(self):
        self._print_header()
        self._print_status()

        fd           = sys.stdin.fileno()
        old_settings = termios.tcgetattr(fd)

        try:
            # setcbreak: immediate key delivery, no echo, keeps SIGINT alive
            tty.setcbreak(fd)

            if self.mc:
                self._drive(self._speed)

            while True:
                ch = _read_key(fd, timeout=0.05)
                if not ch:
                    # No keypress this tick — motors keep running undisturbed
                    continue
                if self._handle_key(ch):
                    break               # quit requested

        except KeyboardInterrupt:
            pass

        finally:
            # Always restore terminal before exiting
            termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
            if self.mc:
                self.mc.stop()

        print("\n")
        print("[Cal] Session ended.")
        print(f"[Cal] Final: {self.cal}")

    # ── Key handler ───────────────────────────────────────────────────────────

    def _handle_key(self, ch: str) -> bool:
        """Process one keypress. Returns True when the user wants to quit."""

        acted = True

        if ch in ("q", "Q", "\x03"):            # q / Q / Ctrl-C
            return True

        elif ch == "a":                          # drift left  → boost right (fine)
            self.cal.adjust("right", +STEP_FINE)
        elif ch == "A":                          # drift left  → boost right (medium)
            self.cal.adjust("right", +STEP_MEDIUM)

        elif ch == "d":                          # drift right → boost left (fine)
            self.cal.adjust("left",  +STEP_FINE)
        elif ch == "D":                          # drift right → boost left (medium)
            self.cal.adjust("left",  +STEP_MEDIUM)

        elif ch == "z":                          # reduce right fine
            self.cal.adjust("right", -STEP_FINE)
        elif ch == "Z":                          # reduce right medium
            self.cal.adjust("right", -STEP_MEDIUM)

        elif ch == "c":                          # reduce left fine
            self.cal.adjust("left",  -STEP_FINE)
        elif ch == "C":                          # reduce left medium
            self.cal.adjust("left",  -STEP_MEDIUM)

        elif ch == "s":
            self.cal.save()
            print("\n[Cal] Saved!")
        elif ch == "r":
            self.cal.reset()
            print("\n[Cal] Reset to 1.0 / 1.0")
        elif ch == "p":
            pass                                 # just reprint status
        else:
            acted = False

        if acted:
            if self.mc:
                self._drive(self._speed)
            self._print_status()

        return False

    # ── Motor helper ──────────────────────────────────────────────────────────

    def _drive(self, speed: float):
        """Apply calibrated forward drive directly to both motors."""
        l, r = self.cal.apply(speed, speed)
        self.mc._apply(self.mc._left,  l)
        self.mc._apply(self.mc._right, r)
        self.mc._left_speed  = l
        self.mc._right_speed = r

    # ── Display ───────────────────────────────────────────────────────────────

    def _print_header(self):
        print()
        print("=" * 62)
        print("  MOTOR CALIBRATION — Drift Correction  (SSH safe)")
        print("=" * 62)
        print("  Place the vehicle on a flat surface with clear space ahead.")
        print()
        print("  a / A   drifts LEFT   → boost right   fine(+.005) / med(+.015)")
        print("  d / D   drifts RIGHT  → boost left    fine(+.005) / med(+.015)")
        print("  z / Z   reduce right  motor            fine / medium")
        print("  c / C   reduce left   motor            fine / medium")
        print("  s       save  →  motor_cal.json")
        print("  r       reset → 1.0 / 1.0")
        print("  p       refresh status")
        print("  q       quit  (motors stop)")
        print("-" * 62)

    def _print_status(self):
        info = self.cal.info
        l    = info["left_trim"]
        r    = info["right_trim"]
        bal  = info["balance"]
        bar  = _balance_bar(bal)
        sign = "+" if bal >= 0 else ""
        print(
            f"\r  L={l:.4f}  R={r:.4f}  {bar}  bal={sign}{bal:.4f}  ",
            end="",
            flush=True,
        )


def _balance_bar(balance: float, width: int = 21) -> str:
    """
    Horizontal ASCII bar showing relative motor balance.

    L [----------|---------] R   center mark = equal
    L [---█------|----------] R  marker left  = left motor heavier
    L [----------|---------█] R  marker right = right motor heavier
    """
    center = width // 2
    pos    = int(round(center + balance * center))
    pos    = max(0, min(width - 1, pos))

    bar         = ["-"] * width
    bar[center] = "|"
    bar[pos]    = chr(0x2588)       # █

    return "L [" + "".join(bar) + "] R"


# =============================================================================
#  Patch existing MotorController instance
# =============================================================================
def patch_motor_controller(mc, cal: MotorCalibration = None):
    """
    Inject drift correction into an existing MotorController without
    modifying its source file.

    Usage
    -----
        from motor_calibration import patch_motor_controller
        mc = MotorController()
        patch_motor_controller(mc)

    After patching, every mc.move() call applies trim correction.
    """
    if cal is None:
        cal = MotorCalibration()

    def move_with_cal(speed: float, turn: float = 0.0):
        from config import DriveConfig
        speed = float(max(-DriveConfig.MAX_SPEED, min(DriveConfig.MAX_SPEED, speed)))
        turn  = float(max(-1.0, min(1.0, turn)))

        left_raw  = max(-1.0, min(1.0, speed - turn))
        right_raw = max(-1.0, min(1.0, speed + turn))

        left_cal, right_cal = cal.apply(left_raw, right_raw)

        mc._apply(mc._left,  left_cal)
        mc._apply(mc._right, right_cal)
        mc._left_speed  = left_cal
        mc._right_speed = right_cal

    mc.move        = move_with_cal
    mc.calibration = cal
    logger.info(f"[Cal] MotorController patched: {cal}")
    return cal


# =============================================================================
#  Entry Point
# =============================================================================
if __name__ == "__main__":
    logging.basicConfig(level=logging.INFO, format="%(message)s")

    import argparse

    parser = argparse.ArgumentParser(description="Motor drift calibration tool")
    parser.add_argument("--no-motors", action="store_true",
                        help="Dry-run: no GPIO / no real motors")
    parser.add_argument("--show",      action="store_true",
                        help="Print current calibration and exit")
    parser.add_argument("--reset",     action="store_true",
                        help="Reset calibration to defaults")
    parser.add_argument("--set-left",  type=float, metavar="TRIM",
                        help="Set left  trim directly  (e.g. 0.95)")
    parser.add_argument("--set-right", type=float, metavar="TRIM",
                        help="Set right trim directly  (e.g. 1.05)")
    args = parser.parse_args()

    cal = MotorCalibration()

    if args.reset:
        cal.reset()
        print("[Cal] Calibration reset to defaults.")

    if args.set_left is not None:
        cal.left_trim = args.set_left
        cal._clip()
        cal.save()
        print(f"[Cal] Left trim  → {cal.left_trim:.4f}")

    if args.set_right is not None:
        cal.right_trim = args.set_right
        cal._clip()
        cal.save()
        print(f"[Cal] Right trim → {cal.right_trim:.4f}")

    if args.show or args.reset or args.set_left or args.set_right:
        print(f"\nCurrent calibration:\n  {cal}")
        sys.exit(0)

    # ── Start interactive session ─────────────────────────────────────────────
    mc = None
    if not args.no_motors:
        try:
            from motor_controller import MotorController
            mc = MotorController()
            if not mc.hardware_ready:
                print("[Cal] GPIO not ready — dry-run mode.")
                mc = None
        except Exception as e:
            print(f"[Cal] Could not load MotorController: {e}")
            print("[Cal] Dry-run mode (no motors).")

    InteractiveCalibrator(motor_controller=mc).run()
