# =============================================================================
# config.py — Central Configuration
# Real Self-Driving Car Kit: RPi + Camera + IMU + DC Motors
# =============================================================================

# ─────────────────────────────────────────────
#  HARDWARE — GPIO Pin Assignments
# ─────────────────────────────────────────────
class MotorConfig:
    LEFT_FORWARD  = 17      # GPIO BCM IN1
    LEFT_BACKWARD = 27      # IN2
    RIGHT_FORWARD = 5       # IN3
    RIGHT_BACKWARD = 6      # IN4
    PWM_FREQUENCY = 1000    # Hz — for PWM speed control via L298N/L293D

class IMUConfig:
    ENABLED       = True
    I2C_BUS       = 1       # Raspberry Pi I2C bus (typically 1)
