import argparse
import logging
from pathlib import Path
from typing import Optional

import pandas as pd


def setup_logging(log_dir: Path, log_name: str = "clean_missing_images.log") -> Path:
    log_dir.mkdir(parents=True, exist_ok=True)
    log_path = log_dir / log_name
    logging.basicConfig(
        level=logging.INFO,
        format='[%(asctime)s] %(levelname)s: %(message)s',
        handlers=[
            logging.FileHandler(log_path, mode='w', encoding='utf-8'),
            logging.StreamHandler(),
        ],
    )
    return log_path


def clean_dataset(csv_path: Optional[Path] = None, output_path: Optional[Path] = None, log_dir: Optional[Path] = None):
    if csv_path is None:
        csv_path = Path('DataCollected') / 'driving_log.csv'
    if output_path is None:
        output_path = csv_path.with_name('driving_log_cleaned.csv')
    if log_dir is None:
        log_dir = csv_path.parent

    log_path = setup_logging(log_dir)
    logger = logging.getLogger('clean_missing_images')

    logger.info('Starting dataset cleanup')
    logger.info('Input CSV: %s', csv_path)
    logger.info('Output CSV: %s', output_path)
    logger.info('Log file: %s', log_path)

    if not csv_path.exists():
        logger.error('CSV file not found: %s', csv_path)
        print(f"Error: {csv_path} not found!")
        return

    logger.info('Reading dataset: %s', csv_path)
    df = pd.read_csv(csv_path)
    total_rows = len(df)

    logger.info('Total entries in CSV: %d', total_rows)
    logger.info('Checking for missing images...')

    base_dir = csv_path.parent
    missing_paths = []
    exists_mask = []

    for _, row in df.iterrows():
        img_rel_path = row['center']
        full_path = base_dir / img_rel_path
        exists = full_path.exists()
        exists_mask.append(exists)
        if not exists:
            missing_paths.append(str(full_path))

    df_cleaned = df[exists_mask]
    removed_count = total_rows - len(df_cleaned)

    logger.info('Rows removed due to missing images: %d', removed_count)
    logger.info('Rows remaining: %d', len(df_cleaned))

    if removed_count > 0:
        logger.warning('Missing images found: %d', removed_count)
        if missing_paths:
            logger.warning('Sample missing paths: %s', ', '.join(missing_paths[:10]))

        print(f"\n--- RESULTS ---")
        print(f"Missing images found: {removed_count}")
        print(f"Rows remaining: {len(df_cleaned)}")

        save_choice = input(f"\nSave cleaned CSV to '{output_path}'? (y/n): ")
        if save_choice.lower() == 'y':
            df_cleaned.to_csv(output_path, index=False)
            logger.info('Cleaned dataset saved successfully: %s', output_path)
            print('Cleaned dataset saved successfully!')
    else:
        logger.info('Great! All images are present. No cleaning needed.')
        print('Great! All images are present. No cleaning needed.')


if __name__ == '__main__':
    parser = argparse.ArgumentParser(description='Clean a driving dataset by removing rows with missing images.')
    parser.add_argument('--csv', type=str, default='DataCollected/driving_log.csv', help='Path to the input CSV file')
    parser.add_argument('--output', type=str, default=None, help='Path to the output cleaned CSV file')
    parser.add_argument('--log-dir', type=str, default=None, help='Directory where the log file will be written')
    args = parser.parse_args()

    clean_dataset(
        csv_path=Path(args.csv),
        output_path=Path(args.output) if args.output else None,
        log_dir=Path(args.log_dir) if args.log_dir else None,
    )
