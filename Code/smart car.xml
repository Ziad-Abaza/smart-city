import time
import logging
from ArUco.aruco_detector import ArUcoDetector
from .ai_driver import AIDriver
from .marker_tracker import MarkerTracker
from .mission_manager import MissionManager
from .safety_monitor import SafetyMonitor
from .mission_types import VehicleState, MissionCommand

logger = logging.getLogger(__name__)

class NavigatorV2:
    """
    Top-level navigation wrapper replacing the old Navigator.
    Retains identical output shape for main_auto.py but internally delegates
    to the Mission System.
    """
    def __init__(self, ai_driver: AIDriver, aruco_detector: ArUcoDetector, 
                 marker_tracker: MarkerTracker, mission_manager: MissionManager, 
                 safety_monitor: SafetyMonitor, base_speed: float = 0.25):
        self.ai = ai_driver
        self.aruco_detector = aruco_detector
        self.tracker = marker_tracker
        self.manager = mission_manager
        self.safety = safety_monitor
        self.base_speed = base_speed
        self.is_running = False

    def start(self):
        self.is_running = True

    def stop(self):
        self.is_running = False
        self.safety.trigger_emergency_stop()

    def set_paused(self, paused: bool):
        if paused:
            self.safety.pause()
            logger.info("Navigator PAUSED")
        else:
            self.safety.resume()
            logger.info("Navigator RESUMED")

    def update(self, frame, current_yaw=None):
        current_time = time.time()
        
        # 1. Perception
        # (Assuming aruco_detector.detect returns (results, ids) as per existing code)
        results, ids = self.aruco_detector.detect(frame, estimate_pose=True)
        sightings = self.tracker.process_frame(results, current_time)
        
        steering, raw_steering = self.ai.get_steering(frame)
        
        vehicle_state = VehicleState(
            speed=self.base_speed,
            yaw=current_yaw if current_yaw is not None else 0.0,
            yaw_rate=0.0,  # Simplification for now
            lane_steering=steering,
            is_lane_visible=True,  # Simplification
            steering_confidence=1.0 # Simplification
        )
        
        # 2. Status check
        if not self.is_running:
            return "IDLE", 0.0, 0.0, results
            
        # 3. Mission Orchestration
        command = self.manager.update(sightings, vehicle_state, current_time)
        
        # 4. Default to Lane Following
        if not command:
            command = MissionCommand(
                throttle=self.base_speed,
                steering=steering,
                nav_state_label="LANE_FOLLOWING"
            )
            
        # 5. Safety Monitor Override
        safe_cmd = self.safety.apply_safety_override(command)
        
        # Format the label per spec
        final_label = safe_cmd.nav_state_label
        if self.manager.active_mission and safe_cmd.nav_state_label not in ("PAUSED", "EMERGENCY_STOP"):
            final_label = f"MISSION_ACTIVE:{safe_cmd.nav_state_label}"
            
        return final_label, safe_cmd.throttle, safe_cmd.steering, results
