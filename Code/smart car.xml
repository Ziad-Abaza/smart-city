# =============================================================================
# lane_detector.py — Lane Detection + PD Steering Controller
# Based on test3.py / test5.py / test7.py from the original repo
# =============================================================================

import cv2
import math
import logging
import numpy as np
from dataclasses import dataclass, field
from typing import Optional, List, Tuple

from config import LaneConfig, DriveConfig

logger = logging.getLogger(__name__)


@dataclass
class LaneResult:
    """Output of one frame's lane detection."""
    steering_angle: float = 90.0      # degrees, 90 = straight
    turn_value:     float = 0.0       # normalized [-1, 1]
    lane_error:     float = 0.0       # pixels from center
    lane_lines:     list  = field(default_factory=list)
    frame_annotated: Optional[np.ndarray] = None
    confidence:     float = 0.0       # 0=no lanes, 1=both lanes found


class LaneDetector:
    """
    Full lane detection pipeline for a physical track.

    Pipeline per frame:
      1. HSV color segmentation (white left / yellow right lane lines)
      2. ROI masking (trapezoid)
      3. Hough line detection
      4. Line averaging → single left & right lane line
      5. Lane center computation → error from frame center
      6. PD controller → steering angle → normalized turn value

    The PD controller eliminates the oscillation problem by damping
    rapid steering changes using the derivative of the error signal.
    """

    def __init__(self):
        # Color thresholds from config
        self._lower_left  = np.array(LaneConfig.LOWER_LEFT,  np.uint8)
        self._upper_left  = np.array(LaneConfig.UPPER_LEFT,  np.uint8)
        self._lower_right = np.array(LaneConfig.LOWER_RIGHT, np.uint8)
        self._upper_right = np.array(LaneConfig.UPPER_RIGHT, np.uint8)
        self._lower_red   = np.array(LaneConfig.LOWER_RED,   np.uint8)
        self._upper_red   = np.array(LaneConfig.UPPER_RED,   np.uint8)

        # PD controller state
        self._last_error  = 0.0
        self._last_time   = None

        # Smoothing for steering angle output
        self._smooth_angle = 90.0   # degrees

    # ──────────────────────────────────────────
    #  Main Entry Point
    # ──────────────────────────────────────────

    def process(self, frame: np.ndarray, annotate: bool = True) -> LaneResult:
        """
        Run full lane detection pipeline on one BGR frame.

        Args:
            frame    : BGR image from camera
            annotate : if True, draw lane lines on frame

        Returns:
            LaneResult with all computed values
        """
        h, w = frame.shape[:2]
        result = LaneResult()

        # ── Step 1: Edge detection in HSV color space ──
        edges = self._detect_edges(frame)

        # ── Step 2: Region of interest ──
        roi = self._region_of_interest(edges, h, w)

        # ── Step 3–4: Hough lines → averaged lane lines ──
        segments   = self._detect_segments(roi)
        lane_lines = self._average_slope_intercept(frame, segments)
        result.lane_lines = lane_lines

        # ── Step 5: Lane center error ──
        lane_center, error, confidence = self._compute_error(frame, lane_lines)
        result.lane_error  = error
        result.confidence  = confidence

        # ── Step 6: PD controller → steering angle ──
        steering_angle = self._pd_controller(error)
        # Smooth the angle to reduce jitter
        self._smooth_angle = (0.6 * steering_angle +
                              0.4 * self._smooth_angle)
        result.steering_angle = self._smooth_angle

        # Normalize to [-1, +1] for motor controller
        deviation = self._smooth_angle - 90.0     # deviation from straight
        result.turn_value = float(np.clip(deviation / 60.0, -1.0, 1.0))

        # ── Annotation ──
        if annotate:
            result.frame_annotated = self._annotate(
                frame.copy(), lane_lines,
                self._smooth_angle, lane_center
            )

        return result

    # ──────────────────────────────────────────
    #  Detection Pipeline Steps
    # ──────────────────────────────────────────

    def _detect_edges(self, frame: np.ndarray) -> np.ndarray:
        """HSV color segmentation → binary edge mask."""
        hsv = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)

        left_mask  = cv2.inRange(hsv, self._lower_left,  self._upper_left)
        right_mask = cv2.inRange(hsv, self._lower_right, self._upper_right)
        combined   = cv2.bitwise_or(left_mask, right_mask)

        blurred = cv2.GaussianBlur(combined, (5, 5), 0)
        edges   = cv2.Canny(blurred, 50, 150)
        return edges

    def _region_of_interest(self, edges: np.ndarray,
                             h: int, w: int) -> np.ndarray:
        """Mask edges to lower-trapezoid ROI (road area only)."""
        vertices = np.array([[
            (0,         h),
            (w // 3,    int(h * LaneConfig.ROI_TOP_FRAC)),
            (w * 2 // 3, int(h * LaneConfig.ROI_TOP_FRAC)),
            (w,         h),
        ]], dtype=np.int32)

        mask   = np.zeros_like(edges)
        cv2.fillPoly(mask, vertices, 255)
        return cv2.bitwise_and(edges, mask)

    def _detect_segments(self, roi: np.ndarray) -> Optional[np.ndarray]:
        """Probabilistic Hough transform to find line segments."""
        return cv2.HoughLinesP(
            roi,
            LaneConfig.HOUGH_RHO,
            LaneConfig.HOUGH_THETA,
            LaneConfig.HOUGH_THRESHOLD,
            np.array([]),
            minLineLength=LaneConfig.HOUGH_MIN_LENGTH,
            maxLineGap=LaneConfig.HOUGH_MAX_GAP,
        )

    def _average_slope_intercept(self, frame: np.ndarray,
                                  segments) -> List:
        """
        Fit left and right lane lines from raw Hough segments.
        Returns list of 0, 1, or 2 averaged lines: [[x1,y1,x2,y2], ...]
        """
        if segments is None:
            return []

        h, w = frame.shape[:2]
        boundary      = 1.0 / 3.0
        left_boundary = w * (1.0 - boundary)
        right_boundary = w * boundary

        left_fit  = []
        right_fit = []

        for seg in segments:
            x1, y1, x2, y2 = seg[0]
            if x1 == x2:
                continue  # skip vertical lines

            slope     = (y2 - y1) / (x2 - x1)
            intercept = y1 - slope * x1

            if abs(slope) < 0.1:
                continue   # skip near-horizontal segments

            if slope < 0 and x1 < left_boundary and x2 < left_boundary:
                left_fit.append((slope, intercept))
            elif slope > 0 and x1 > right_boundary and x2 > right_boundary:
                right_fit.append((slope, intercept))

        lanes = []
        if left_fit:
            lanes.append(self._make_line(frame, np.mean(left_fit, axis=0)))
        if right_fit:
            lanes.append(self._make_line(frame, np.mean(right_fit, axis=0)))

        return lanes

    def _make_line(self, frame: np.ndarray,
                   line: Tuple[float, float]) -> List[int]:
        """Convert (slope, intercept) to pixel coordinates [x1,y1,x2,y2]."""
        h    = frame.shape[0]
        slope, intercept = line

        y1 = h
        y2 = int(h * 0.5)

        if abs(slope) < 1e-6:
            slope = 0.1

        x1 = int((y1 - intercept) / slope)
        x2 = int((y2 - intercept) / slope)

        # Clamp to frame width
        w  = frame.shape[1]
        x1 = max(0, min(w, x1))
        x2 = max(0, min(w, x2))

        return [x1, y1, x2, y2]

    def _compute_error(self, frame: np.ndarray,
                        lane_lines: List) -> Tuple[int, float, float]:
        """
        Compute pixel offset of lane center from frame center.

        Returns:
            (lane_center_x, error_pixels, confidence)
        """
        w = frame.shape[1]
        mid = w // 2

        if len(lane_lines) == 2:
            # Both lanes found — use midpoint of top endpoints
            lx = (lane_lines[0][0] + lane_lines[0][2]) // 2
            rx = (lane_lines[1][0] + lane_lines[1][2]) // 2
            center = (lx + rx) // 2
            confidence = 1.0
        elif len(lane_lines) == 1:
            # Only one lane — estimate center from that line
            center = (lane_lines[0][0] + lane_lines[0][2]) // 2
            confidence = 0.5
        else:
            center = mid   # no detection — assume center
            confidence = 0.0

        error = float(mid - center)   # positive = car is right of lane center
        return center, error, confidence

    # ──────────────────────────────────────────
    #  PD Controller
    # ──────────────────────────────────────────

    def _pd_controller(self, error: float) -> float:
        """
        PD controller: converts lane error (pixels) to steering angle (degrees).

        Steering angle convention: 90° = straight, <90 = left, >90 = right

        D-term dampens oscillation: when error is correcting quickly,
        the derivative is opposite sign → reduces overshoot.
        """
        now = cv2.getTickCount() / cv2.getTickFrequency()

        if self._last_time is None:
            dt = 0.033   # assume ~30fps on first frame
        else:
            dt = max(0.001, now - self._last_time)

        d_error = (error - self._last_error) / dt

        # PD formula
        correction = (DriveConfig.KP * error +
                      DriveConfig.KD * d_error)

        self._last_error = error
        self._last_time  = now

        steering_angle = 90.0 + correction
        return float(np.clip(steering_angle, 40.0, 140.0))

    # ──────────────────────────────────────────
    #  Annotation
    # ──────────────────────────────────────────

    def _annotate(self, frame, lane_lines, angle_deg,
                  lane_center) -> np.ndarray:
        """Draw lane lines and heading arrow on frame."""
        h, w = frame.shape[:2]

        # Draw lane lines
        for line in lane_lines:
            x1, y1, x2, y2 = line
            length = math.hypot(x2 - x1, y2 - y1)
            color  = (0, 255, 255) if length >= 200 else (0, 255, 0)
            cv2.line(frame, (x1, y1), (x2, y2), color, 3)

        # Draw heading arrow
        try:
            angle_rad = angle_deg / 180.0 * math.pi
            cx = w // 2
            cy = h
            ex = int(cx - h * 0.3 / math.tan(angle_rad))
            ey = int(h * 0.5)
            cv2.arrowedLine(frame, (cx, cy), (ex, ey),
                            (0, 0, 255), 3, tipLength=0.3)
        except ZeroDivisionError:
            pass

        # Lane center dot
        cv2.circle(frame, (lane_center, h // 2), 6, (255, 0, 255), -1)
        cv2.circle(frame, (w // 2, h // 2), 6, (255, 255, 0), -1)

        # Text overlay
        cv2.putText(frame, f"Angle: {angle_deg:.1f}",
                    (10, 25), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 255), 2)

        return frame
