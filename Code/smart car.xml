import os
import numpy as np
import logging
from training.inference import AutonomousDriver
from config import ModelConfig, DriveConfig

logger = logging.getLogger(__name__)

class AIDriver:
    """
    Wraps the TFLite lane-following model.
    Handles inference, steering smoothing, and sensitivity.
    """
    def __init__(self, model_path=None):
        self.model_path = model_path or ModelConfig.TFLITE_PATH
        if not os.path.exists(self.model_path):
            raise FileNotFoundError(f"Model not found at {self.model_path}")
            
        self.driver = AutonomousDriver(self.model_path)
        self.steering_sensitivity = DriveConfig.STEERING_SENSITIVITY
        self.invert_steering = getattr(DriveConfig, 'INVERT_STEERING', False)
        self.smoothing_alpha = ModelConfig.STEERING_SMOOTH
        self.last_steering = 0.0
        
        logger.info(f"AIDriver initialized with model: {self.model_path}")

    def get_steering(self, frame):
        """
        Run inference and return a smoothed, scaled steering value.
        """
        try:
            # 1. Get raw prediction (-1.0 to 1.0)
            raw_steering = self.driver.predict(frame)
            
            # 2. Apply inversion if configured
            if self.invert_steering:
                raw_steering = -raw_steering
            
            # 3. Apply sensitivity
            scaled_steering = raw_steering * self.steering_sensitivity
            
            # 4. Smoothing (EMA)
            # smoothed = alpha * current + (1 - alpha) * previous
            # if alpha=1.0, it's just raw scaled_steering
            final_steering = (self.smoothing_alpha * scaled_steering) + \
                             ((1.0 - self.smoothing_alpha) * self.last_steering)
            
            # 5. Clip to hard range
            final_steering = float(np.clip(final_steering, -1.0, 1.0))
            self.last_steering = final_steering
            
            return final_steering, raw_steering
            
        except Exception as e:
            logger.error(f"AI Inference error: {e}")
            return 0.0, 0.0
