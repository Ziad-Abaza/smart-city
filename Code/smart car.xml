import time
from typing import Optional
from .mission_base import Mission, MissionPhase
from .mission_types import VehicleState, MarkerSighting, MissionCommand, MissionOutcome
from .mission_factory import MissionFactory

class StopMission(Mission):
    """
    Stops the vehicle completely for a configurable duration.
    """
    def __init__(self, definition, sighting):
        super().__init__(definition, sighting)
        self.stop_duration = float(definition.params.get("stop_duration", 2.0))
        self.stop_start_time = 0.0

    def on_pending(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, vs.lane_steering, "STOP:PENDING")
        
    def on_approach(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        # Decelerate linearly or step down
        return MissionCommand(vs.speed * 0.5, vs.lane_steering, "STOP:APPROACH")
        
    def on_prepare(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(0.0, 0.0, "STOP:PREPARE")
    
    def on_execute(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        if self.stop_start_time == 0.0:
            self.stop_start_time = time.time()
        return MissionCommand(0.0, 0.0, "STOP:EXECUTE")
        
    def on_recover(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, vs.lane_steering, "STOP:RECOVER")
        
    def on_abort(self, vs: VehicleState):
        pass
        
    def on_interrupt(self, vs: VehicleState, p: int):
        pass

    def is_phase_complete(self, phase: str, vs: VehicleState) -> bool:
        if phase in (MissionPhase.PENDING, MissionPhase.APPROACH, MissionPhase.PREPARE, MissionPhase.RECOVER):
            return True
        if phase == MissionPhase.EXECUTE:
            if self.stop_start_time > 0 and (time.time() - self.stop_start_time) >= self.stop_duration:
                return True
            return False
        return True

    def report_outcome(self) -> MissionOutcome:
        return MissionOutcome.SUCCESS

class SlowDownMission(Mission):
    """
    Slows down the vehicle for a configurable duration while continuing to steer.
    """
    def __init__(self, definition, sighting):
        super().__init__(definition, sighting)
        self.slow_duration = float(definition.params.get("slow_duration", 3.0))
        self.speed_scale = float(definition.params.get("speed_scale", 0.5))
        self.start_time = 0.0

    def on_pending(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, vs.lane_steering, "SLOW:PENDING")
        
    def on_approach(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, vs.lane_steering, "SLOW:APPROACH")
        
    def on_prepare(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, vs.lane_steering, "SLOW:PREPARE")
    
    def on_execute(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        if self.start_time == 0.0:
            self.start_time = time.time()
        return MissionCommand(vs.speed * self.speed_scale, vs.lane_steering, "SLOW:EXECUTE")
        
    def on_recover(self, vs: VehicleState, s: Optional[MarkerSighting]) -> MissionCommand:
        return MissionCommand(vs.speed, vs.lane_steering, "SLOW:RECOVER")
        
    def on_abort(self, vs: VehicleState):
        pass
        
    def on_interrupt(self, vs: VehicleState, p: int):
        pass

    def is_phase_complete(self, phase: str, vs: VehicleState) -> bool:
        if phase in (MissionPhase.PENDING, MissionPhase.APPROACH, MissionPhase.PREPARE, MissionPhase.RECOVER):
            return True
        if phase == MissionPhase.EXECUTE:
            if self.start_time > 0 and (time.time() - self.start_time) >= self.slow_duration:
                return True
            return False
        return True

    def report_outcome(self) -> MissionOutcome:
        return MissionOutcome.SUCCESS

# Clean old mock in case it exists, then register real implementations
if "stop" in MissionFactory.get_registered_types():
    del MissionFactory._registry["stop"]
if "slow_down" in MissionFactory.get_registered_types():
    del MissionFactory._registry["slow_down"]

MissionFactory.register("stop", StopMission)
MissionFactory.register("slow_down", SlowDownMission)
