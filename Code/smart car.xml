import os
import time
from PySide6.QtCore import QObject, Signal, QProcess

class GitUpdater(QObject):
    logMessage = Signal(str, str, str) # mode_name="Git", stream, text
    updateFinished = Signal(bool, str) # success, message
    stateChanged = Signal(str, str) # mode_name, state
    
    def __init__(self):
        super().__init__()
        self.process = QProcess(self)
        self.process.readyReadStandardOutput.connect(self._on_stdout)
        self.process.readyReadStandardError.connect(self._on_stderr)
        self.process.finished.connect(self._on_finished)
        self.process.errorOccurred.connect(self._on_error)
        
        self.cwd = "." # repo root
        self.process.setWorkingDirectory(self.cwd)

    def run_update(self):
        if self.process.state() != QProcess.NotRunning:
            return
            
        self.stateChanged.emit("Git", "Starting")
        self.logMessage.emit("Git", "stdout", "=== Starting Git Pull ===\n")
        self.process.start("git", ["pull"])

    def _on_stdout(self):
        data = self.process.readAllStandardOutput().data()
        text = data.decode("utf-8", errors="replace")
        self.logMessage.emit("Git", "stdout", text)

    def _on_stderr(self):
        data = self.process.readAllStandardError().data()
        text = data.decode("utf-8", errors="replace")
        self.logMessage.emit("Git", "stderr", text)

    def _on_finished(self, exitCode, exitStatus):
        if exitStatus == QProcess.CrashExit or exitCode != 0:
            msg = f"Git update failed with exit code {exitCode}."
            self.logMessage.emit("Git", "stderr", f"=== {msg} ===\n")
            self.updateFinished.emit(False, msg)
        else:
            msg = "Git update successful."
            self.logMessage.emit("Git", "stdout", f"=== {msg} ===\n")
            self.updateFinished.emit(True, msg)
        self.stateChanged.emit("Git", "Stopped")

    def _on_error(self, error):
        msg = f"Git process error occurred."
        self.logMessage.emit("Git", "stderr", f"=== {msg} ===\n")
        self.updateFinished.emit(False, msg)
        self.stateChanged.emit("Git", "Crashed")
