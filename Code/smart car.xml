# =============================================================================
# data_collector.py - Asynchronous dataset collection
# Saves images and synchronized control metadata without blocking the drive loop.
# Now uses SynchronizedSample for perfect temporal alignment.
# =============================================================================

import csv
import logging
import queue
import threading
import time
from datetime import datetime
from pathlib import Path

import cv2
import numpy as np

from config import DataConfig
from synchronized_sampler import SynchronizedSample

logger = logging.getLogger(__name__)


class DataCollector:
    """
    Save frames and control signals to disk in a background writer thread.

    Output:
      DataCollected/session_YYYYMMDD_HHMMSS/IMG/frame_xxxxxxx.jpg
      DataCollected/session_YYYYMMDD_HHMMSS/driving_log.csv
    """

    def __init__(self, session_name: str = None):
        if session_name is None:
            session_name = f"session_{datetime.now().strftime('%Y%m%d_%H%M%S')}"

        self._session_dir = Path(DataConfig.OUTPUT_DIR) / session_name
        self._img_dir = self._session_dir / DataConfig.IMG_SUBDIR
        self._log_path = self._session_dir / DataConfig.LOG_FILENAME

        self._session_dir.mkdir(parents=True, exist_ok=True)
        self._img_dir.mkdir(parents=True, exist_ok=True)

        self._csv_file = open(self._log_path, "w", newline="")
        self._csv_writer = csv.writer(self._csv_file)
        # Enhanced CSV header with full IMU data for better training
        self._csv_writer.writerow(
            ["center", "steering", "throttle", "speed", "state",
             "ax", "ay", "az", "gx", "gy", "gz", "yaw", "yaw_rate",
             "confidence", "frame_id", "timestamp", "t_mono"]
        )

        self._frame_count = 0
        self._last_saved_frame_id = -1
        self._skipped_duplicate_frames = 0
        self._saved_count = 0
        self._rows_since_flush = 0
        self._steering_history = []
        self._lock = threading.Lock()
        self._queue = queue.Queue(maxsize=256)
        self._writer_thread = threading.Thread(target=self._writer_loop, daemon=True)
        self._writer_thread.start()

        logger.info(f"[Collector] Session started: {self._session_dir}")
        print(f"[Collector] Saving to: {self._session_dir}")

    def save_sample(self, sample: SynchronizedSample) -> bool:
        """
        Save a synchronized sample to disk.
        
        This is the NEW preferred method that ensures perfect temporal alignment.
        All data in the sample was captured at the same moment.
        
        Args:
            sample: SynchronizedSample containing all sensor data
            
        Returns:
            True if saved, False if skipped
        """
        if sample.frame_id == self._last_saved_frame_id:
            self._skipped_duplicate_frames += 1
            return False

        self._frame_count += 1

        if self._frame_count % DataConfig.SAVE_INTERVAL != 0:
            return False

        if sample.frame is None or sample.frame.size == 0:
            logger.warning("[Collector] Skipping empty frame.")
            return False

        try:
            ts_iso = datetime.fromtimestamp(sample.timestamp).isoformat(timespec="milliseconds")
        except (OverflowError, OSError, ValueError):
            ts_iso = datetime.now().isoformat(timespec="milliseconds")

        with self._lock:
            filename = f"frame_{self._saved_count:07d}.jpg"
            img_path = self._img_dir / filename
            
            # Enhanced row with full IMU data
            row = [
                str(img_path),
                float(sample.steering),
                float(sample.throttle),
                float(sample.speed),
                sample.state,
                float(sample.ax),
                float(sample.ay),
                float(sample.az),
                float(sample.gx),
                float(sample.gy),
                float(sample.gz),
                float(sample.yaw),
                float(sample.yaw_rate),
                float(sample.confidence),
                int(sample.frame_id),
                ts_iso,
                f"{sample.mono_time:.6f}",
            ]
            self._saved_count += 1
            self._last_saved_frame_id = int(sample.frame_id)
            self._steering_history.append(float(sample.steering))

        item = (str(img_path), sample.frame.copy(), row)
        try:
            self._queue.put_nowait(item)
        except queue.Full:
            logger.warning("[Collector] Writer queue full. Dropping frame.")
            return False
        return True

    def save(
        self,
        frame: np.ndarray,
        steering: float,
        throttle: float,
        speed: float = 0.0,
        yaw_rate: float = 0.0,
        confidence: float = 1.0,
        sample_time: float = None,
        mono_time: float = None,
    ) -> bool:
        """
        LEGACY method for backward compatibility.
        
        WARNING: This method does NOT guarantee temporal alignment!
        Use save_sample() with SynchronizedSampler instead.
        """
        self._frame_count += 1

        if self._frame_count % DataConfig.SAVE_INTERVAL != 0:
            return False

        if frame is None or frame.size == 0:
            logger.warning("[Collector] Skipping empty frame.")
            return False

        wall = sample_time if sample_time is not None else time.time()
        mono = mono_time if mono_time is not None else time.monotonic()
        try:
            ts_iso = datetime.fromtimestamp(wall).isoformat(timespec="milliseconds")
        except (OverflowError, OSError, ValueError):
            ts_iso = datetime.now().isoformat(timespec="milliseconds")

        with self._lock:
            filename = f"frame_{self._saved_count:07d}.jpg"
            img_path = self._img_dir / filename
            row = [
                str(img_path),
                float(steering),
                float(throttle),
                float(speed),
                float(yaw_rate),
                ts_iso,
                f"{mono:.6f}",
            ]
            self._saved_count += 1
            self._steering_history.append(float(steering))

        item = (str(img_path), frame.copy(), row)
        try:
            self._queue.put_nowait(item)
        except queue.Full:
            logger.warning("[Collector] Writer queue full. Dropping frame.")
            return False
        return True

    def _writer_loop(self):
        encode_params = [cv2.IMWRITE_JPEG_QUALITY, DataConfig.JPEG_QUALITY]
        while True:
            item = self._queue.get()
            if item is None:
                self._queue.task_done()
                break

            img_path, frame, row = item
            ok = cv2.imwrite(img_path, frame, encode_params)
            if not ok:
                logger.error(f"[Collector] Failed to write image: {img_path}")
            else:
                self._csv_writer.writerow(row)
                self._rows_since_flush += 1
                if self._rows_since_flush >= DataConfig.FLUSH_INTERVAL:
                    self._csv_file.flush()
                    self._rows_since_flush = 0

            self._queue.task_done()

    def finish(self):
        self._queue.put(None)
        self._queue.join()
        self._csv_file.flush()
        self._csv_file.close()
        self._print_stats()
        logger.info(f"[Collector] Session saved: {self._saved_count} frames")

    def _print_stats(self):
        if not self._steering_history:
            return

        arr = np.array(self._steering_history, dtype=np.float32)
        print("\n" + "=" * 50)
        print("  Data Collection Summary")
        print("=" * 50)
        print(f"  Session dir : {self._session_dir}")
        print(f"  Frames saved: {self._saved_count}")
        print(f"  Frames skipped: {self._frame_count - self._saved_count}")
        if self._skipped_duplicate_frames:
            print(f"  Duplicate frame_id skipped: {self._skipped_duplicate_frames}")
        print(
            f"  Steering - mean: {arr.mean():+.4f} "
            f"std: {arr.std():.4f} "
            f"min: {arr.min():+.4f} "
            f"max: {arr.max():+.4f}"
        )

        near_zero = (np.abs(arr) < 0.05).mean() * 100.0
        print(f"  Near-zero steering (|s|<0.05): {near_zero:.1f}%")
        if near_zero > 70:
            print("  WARNING: >70% straight driving.")
            print("  Add more turns or rebalance during training.")
        print("=" * 50)

    @property
    def saved_count(self) -> int:
        return self._saved_count

    @property
    def frame_count(self) -> int:
        return self._frame_count
