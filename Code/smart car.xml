# =============================================================================
# collect_data.py - Manual driving data collection
# Stable runtime path for Raspberry Pi 5 + USB webcam + L298N + PS4 controller.
# =============================================================================

import logging
import signal
import time

import cv2
import numpy as np

logging.basicConfig(
    level=logging.INFO,
    format='[%(asctime)s] %(levelname)s - %(message)s',
    datefmt='%H:%M:%S'
)
logger = logging.getLogger(__name__)

from camera import Camera
from config import DataConfig, DriveConfig, IMUConfig
from data_collector import DataCollector
from imu_reader import IMUReader
from lane_detector import LaneDetector
from motor_controller import MotorController
from ps4_controller import PS4CarController
from synchronized_sampler import SynchronizedSampler, TimestampValidator, classify_steering_state

try:
    import pygame
    pygame.init()
    pygame.display.set_mode((320, 240))
    pygame.display.set_caption("Data Collection")
    PYGAME_AVAILABLE = True
except Exception:
    PYGAME_AVAILABLE = False
    logger.warning("[Input] pygame not available - using PS4/OpenCV input only.")


def get_keyboard_commands():
    commands = {
        "throttle": 0.0,
        "turn": 0.0,
        "quit": False,
        "reset_imu": False,
        "emergency_stop": False,
    }

    if not PYGAME_AVAILABLE:
        return commands

    pygame.event.pump()
    keys = pygame.key.get_pressed()

    if keys[pygame.K_w] or keys[pygame.K_UP]:
        commands["throttle"] = DriveConfig.COLLECT_SPEED
    elif keys[pygame.K_s] or keys[pygame.K_DOWN]:
        commands["throttle"] = -DriveConfig.COLLECT_SPEED

    if keys[pygame.K_a] or keys[pygame.K_LEFT]:
        commands["turn"] = -0.6
    elif keys[pygame.K_d] or keys[pygame.K_RIGHT]:
        commands["turn"] = 0.6

    if keys[pygame.K_SPACE]:
        commands["emergency_stop"] = True

    if keys[pygame.K_r]:
        commands["reset_imu"] = True

    if keys[pygame.K_q] or keys[pygame.K_ESCAPE]:
        commands["quit"] = True

    return commands


def estimate_speed(throttle: float, prev_speed: float, accel_magnitude: float = 0.0) -> float:
    """
    Lightweight speed estimate aligned with manual input.
    Keeps sign from throttle so logs distinguish forward/reverse.
    """
    target_speed = throttle * 10.0 * DriveConfig.BASE_SPEED
    return 0.85 * prev_speed + 0.15 * target_speed + 0.02 * np.sign(throttle) * accel_magnitude


def main(use_ps4: bool = False):
    print("=" * 60)
    print("  Self-Driving Car - Data Collection")
    print("  ✓ SYNCHRONIZED SAMPLING ENABLED")
    print("  ✓ SOFTWARE-LEVEL LABELING ENABLED (Straight/Gentle/Sharp/Recovery)")
    print("  All sensors captured at same timestamp (<5ms window)")
    if use_ps4:
        print("  Controls: PS4 Controller")
        print("    Left Stick Y  = Throttle")
        print("    Right Stick X = Steering")
        print("    R1            = Toggle Recording")
        print("    L1            = Toggle Recovery Mode (MANUAL LABELING)")
        print("    Circle        = Pause/Resume")
    else:
        print("  Controls: WASD = drive | R = reset IMU | Q = quit")
    print("=" * 60)

    cam = Camera(publish=True)
    motors = MotorController()
    try:
        imu = IMUReader()
    except RuntimeError as e:
        if IMUConfig.ENABLED:
            print(f"\n[ERROR] {e}")
            print("[ERROR] Data collection requires a working MPU-6050 (no simulation).")
            return
        imu = None
    detector = LaneDetector()
    collector = DataCollector()
    
    # NEW: Synchronized sampler for perfect temporal alignment
    sampler = SynchronizedSampler(cam, imu, motors) if imu is not None else None
    validator = TimestampValidator(max_gap_ms=100.0)

    ps4_ctrl = None
    if use_ps4:
        ps4_ctrl = PS4CarController(motor_controller=motors, imu_reader=imu)
        ps4_ctrl.listen()

    cam.start()
    if IMUConfig.ENABLED and imu is not None:
        imu.start()
        print(f"[IMU] Hardware ready: {imu.hardware_ready}")

    running = [True]

    def shutdown(sig=None, frame=None):
        running[0] = False

    signal.signal(signal.SIGINT, shutdown)
    signal.signal(signal.SIGTERM, shutdown)

    prev_speed = 0.0
    frame_count = 0
    save_count = 0
    sync_errors = 0
    loop_times = []
    display_scale = 0.35
    recording_enabled = False
    paused = False

    print("\n[Collection] Ready. Start driving!")
    print("[SyncSampler] Monitoring temporal alignment...\n")

    try:
        while running[0]:
            loop_start = time.time()

            if use_ps4 and ps4_ctrl is not None:
                cmds = ps4_ctrl.get_commands()
                ps4_ctrl.reset_flags()
            else:
                cmds = get_keyboard_commands()
                recording_enabled = True
                paused = False

            if cmds["quit"]:
                break

            if use_ps4 and ps4_ctrl is not None:
                recording_enabled = bool(cmds.get("recording", False))
                paused = bool(cmds.get("paused", False))

            frame = cam.frame
            if frame is None:
                time.sleep(0.01)
                continue

            if cmds["reset_imu"] and imu is not None:
                imu.reset_yaw()
                logger.info("[Main] IMU yaw reset.")

            throttle = float(cmds["throttle"])
            turn = float(cmds["turn"])
            is_recovery = bool(cmds.get("recovery", False))
            
            # Real-time state classification
            drive_state = classify_steering_state(turn, is_recovery)

            if cmds.get("emergency_stop", False) or paused:
                motors.stop()
                throttle = 0.0
                turn = 0.0
            else:
                motors.move(throttle, -turn)

            # Lane detection for confidence
            lane_result = detector.process(frame, annotate=True)
            vis_frame = lane_result.frame_annotated

            # ═══════════════════════════════════════════════════════════
            # SYNCHRONIZED SAMPLING - All sensors captured atomically
            # IMU is read ONCE inside sampler.capture() to guarantee
            # the same reading is used for both speed estimation and CSV.
            # ═══════════════════════════════════════════════════════════
            sample = None
            if sampler is not None:
                sample = sampler.capture(
                    steering=turn,
                    throttle=throttle,
                    state=drive_state,
                    speed=prev_speed,
                    confidence=lane_result.confidence,
                    require_new_frame=True,
                )

            # Update speed estimate using the IMU values already in the sample
            if sample is not None:
                accel_mag = np.sqrt(sample.ax ** 2 + sample.ay ** 2)
                prev_speed = estimate_speed(throttle, prev_speed, accel_mag)
                # Patch speed into sample so the saved value is up-to-date
                sample.speed = prev_speed

                if recording_enabled and not paused:
                    if validator.validate(sample):
                        saved = collector.save_sample(sample)
                        if saved:
                            save_count += 1
                    else:
                        sync_errors += 1
                        logger.warning(
                            f"[Main] Timestamp validation failed "
                            f"(errors={sync_errors})"
                        )
            elif imu is not None:
                # Stale camera frame — update speed only, do not log duplicate frame_id
                imu_data = imu.latest
                accel_mag = np.sqrt(
                    float(imu_data.get("ax", 0.0)) ** 2 +
                    float(imu_data.get("ay", 0.0)) ** 2
                )
                prev_speed = estimate_speed(throttle, prev_speed, accel_mag)

            if vis_frame is not None:
                # Use IMU values from the sample when available
                yaw_rate = float(sample.yaw_rate) if sample is not None else 0.0
                
                _draw_hud(
                    vis_frame,
                    steering=turn,
                    throttle=throttle,
                    speed=prev_speed,
                    yaw_rate=yaw_rate,
                    save_count=save_count,
                    lane_confidence=lane_result.confidence,
                    motor_ready=motors.hardware_ready,
                    recording_enabled=recording_enabled,
                    paused=paused,
                    drive_state=drive_state,
                )
                h, w = vis_frame.shape[:2]
                display = cv2.resize(vis_frame, (int(w * display_scale), int(h * display_scale)))
                cv2.imshow("Data Collection", display)

            key = cv2.waitKey(1) & 0xFF
            if key in (ord("q"), 27):
                break
            elif key == ord(" "):
                motors.stop()

            frame_count += 1
            elapsed = time.time() - loop_start
            loop_times.append(elapsed)

            if frame_count % 100 == 0 and loop_times:
                fps = 1.0 / (sum(loop_times[-30:]) / min(30, len(loop_times)))
                sync_stats = sampler.get_stats() if sampler is not None else {}
                avg_sync_ms = sync_stats.get('avg_capture_time_ms', 0.0)
                
                print(
                    f"[Collection] frames={frame_count} "
                    f"saved={save_count} fps={fps:.1f} "
                    f"sync={avg_sync_ms:.2f}ms "
                    f"errors={sync_errors} "
                    f"recording={recording_enabled} paused={paused} "
                    f"throttle={throttle:+.2f} turn={turn:+.2f} "
                    f"speed={prev_speed:+.2f}"
                )
    finally:
        motors.stop()
        motors.close()
        cam.stop()
        if IMUConfig.ENABLED and imu is not None:
            imu.stop()
        if ps4_ctrl is not None:
            ps4_ctrl.stop_listening()
        
        # Print synchronization quality report
        print("\n")
        if sampler is not None:
            sampler.print_stats()
        
        # Print timestamp validation issues
        issues = validator.get_issues()
        if issues:
            print("\n⚠ Timestamp Validation Issues:")
            for issue in issues[-10:]:  # Show last 10 issues
                print(f"  - {issue}")
        else:
            print("\n✓ No timestamp validation issues detected")
        
        collector.finish()
        cv2.destroyAllWindows()
        if PYGAME_AVAILABLE:
            pygame.quit()

        print(f"\n[Done] Collected {save_count} synchronized frames.")
        print(f"[Done] Sync errors: {sync_errors}")
        print(f"[Done] Log: {collector._log_path}")


def _draw_hud(frame, steering, throttle, speed, yaw_rate, save_count, lane_confidence, motor_ready,
              recording_enabled, paused, drive_state="straight"):
    lines = [
        f"Steering   : {steering:+.3f} ({drive_state.upper()})",
        f"Throttle   : {throttle:+.3f}",
        f"Speed est  : {speed:+.2f}",
        f"Yaw Rate   : {yaw_rate:+.1f} deg/s",
        f"Lane conf  : {lane_confidence:.2f}",
        f"Saved      : {save_count}",
        f"Recording  : {'ON' if recording_enabled else 'OFF'}",
        f"Paused     : {'YES' if paused else 'NO'}",
        f"Motor GPIO : {'READY' if motor_ready else 'FAILED'}",
    ]

    # Special highlighting for Recovery Mode
    if drive_state == "recovery":
        cv2.putText(frame, "RECOVERY MODE ACTIVE", (frame.shape[1] // 2 - 120, 40),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 0, 255), 2)

    overlay = frame.copy()
    cv2.rectangle(overlay, (0, 0), (250, len(lines) * 22 + 16), (0, 0, 0), -1)
    cv2.addWeighted(overlay, 0.55, frame, 0.45, 0, frame)

    for idx, line in enumerate(lines):
        cv2.putText(
            frame,
            line,
            (8, 22 + idx * 22),
            cv2.FONT_HERSHEY_SIMPLEX,
            0.55,
            (255, 255, 255),
            1,
        )

    h, w = frame.shape[:2]
    cy = h - 20
    cx = w // 2
    bw = int(w * 0.35)
    cv2.line(frame, (cx - bw, cy), (cx + bw, cy), (70, 70, 70), 4)
    ix = cx + int(steering * bw)
    cv2.circle(frame, (ix, cy), 8, (0, 200, 255), -1)
    cv2.circle(frame, (cx, cy), 4, (255, 255, 255), -1)


if __name__ == "__main__":
    import sys

    use_ps4 = "--ps4" in sys.argv or "-p" in sys.argv
    main(use_ps4=use_ps4)
