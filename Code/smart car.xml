import logging
import threading
import time

import numpy as np

logger = logging.getLogger(__name__)

try:
    from picamera2 import Picamera2
    PICAM_AVAILABLE = True
except ImportError:
    PICAM_AVAILABLE = False
    logger.warning("[Camera] Picamera2 not available - using OpenCV fallback.")

from config import CameraConfig


class Camera:
    """Background camera capture with latest-frame semantics."""

    def __init__(self, publish=False):
        self._backend = None
        self._frame = None
        self._frame_count = 0
        self._lock = threading.Lock()
        self._running = False
        self._thread = None
        self._use_picam = False
        
        self.publish = publish
        self._zmq_ctx = None
        self._zmq_socket = None

    @property
    def frame(self) -> np.ndarray:
        with self._lock:
            return self._frame.copy() if self._frame is not None else None

    @property
    def frame_count(self) -> int:
        return self._frame_count

    def start(self):
        self._init_camera()
        
        if self.publish:
            try:
                import zmq
                self._zmq_ctx = zmq.Context()
                self._zmq_socket = self._zmq_ctx.socket(zmq.PUB)
                self._zmq_socket.setsockopt(zmq.CONFLATE, 1)
                self._zmq_socket.bind("tcp://127.0.0.1:5555")
            except Exception as e:
                logger.warning(f"[Camera] ZMQ publisher init failed: {e}")
                self.publish = False
                
        self._running = True
        self._thread = threading.Thread(target=self._capture_loop, daemon=True)
        self._thread.start()

        deadline = time.time() + 5.0
        while time.time() < deadline:
            if self.frame is not None:
                logger.info(f"[Camera] Started. Frame shape: {self.frame.shape}")
                return
            time.sleep(0.03)

        raise RuntimeError("[Camera] No frame received within timeout.")

    def stop(self):
        self._running = False
        if self._thread is not None:
            self._thread.join(timeout=2.0)

        if self._zmq_socket is not None:
            self._zmq_socket.close()
            self._zmq_socket = None
        if self._zmq_ctx is not None:
            self._zmq_ctx.term()
            self._zmq_ctx = None

        if self._backend is not None:
            try:
                if self._use_picam:
                    self._backend.stop()
                    if hasattr(self._backend, "close"):
                        self._backend.close()
                else:
                    self._backend.release()
            except Exception as e:
                logger.warning(f"[Camera] Cleanup error: {e}")

        self._backend = None
        logger.info("[Camera] Stopped.")

    def _init_camera(self):
        if PICAM_AVAILABLE and CameraConfig.USE_PICAM2:
            cam = None
            try:
                cam = Picamera2()
                config = cam.create_preview_configuration(
                    main={
                        "size": (CameraConfig.WIDTH, CameraConfig.HEIGHT),
                        "format": "RGB888",
                    }
                )
                cam.configure(config)

                # Fix FPS and disable auto-exposure for consistent frames
                controls = {"FrameRate": float(CameraConfig.FPS)}
                if not CameraConfig.AUTO_EXPOSURE:
                    controls["AeEnable"]       = False          # disable auto-exposure
                    controls["ExposureTime"]   = int(CameraConfig.PICAM_SHUTTER_US)
                    controls["AnalogueGain"]   = float(CameraConfig.PICAM_ANALOGUE_GAIN)
                    controls["AwbEnable"]      = False          # disable auto white-balance too
                cam.set_controls(controls)
                cam.start()

                for _ in range(CameraConfig.WARMUP_FRAMES):
                    cam.capture_array()

                self._backend = cam
                self._use_picam = True
                logger.info(
                    f"[Camera] PiCamera2 {CameraConfig.WIDTH}x{CameraConfig.HEIGHT} "
                    f"@ {CameraConfig.FPS}fps  AE={'on' if CameraConfig.AUTO_EXPOSURE else 'off'}"
                )
                return
            except Exception as e:
                logger.warning(f"[Camera] Picamera2 init failed: {e}")
                if cam is not None:
                    try:
                        cam.stop()
                        cam.close()
                    except Exception:
                        pass
                time.sleep(0.5)

        self._init_opencv_camera()

    def _init_opencv_camera(self):
        import cv2

        backends = [cv2.CAP_V4L2, cv2.CAP_ANY]
        indices = [CameraConfig.INDEX]
        for fallback_index in (0, 1, 2):
            if fallback_index not in indices:
                indices.append(fallback_index)

        last_error = None
        for index in indices:
            for backend in backends:
                cap = None
                try:
                    cap = cv2.VideoCapture(index, backend)
                    if not cap.isOpened():
                        raise RuntimeError("open failed")

                    cap.set(cv2.CAP_PROP_FRAME_WIDTH,  CameraConfig.WIDTH)
                    cap.set(cv2.CAP_PROP_FRAME_HEIGHT, CameraConfig.HEIGHT)
                    cap.set(cv2.CAP_PROP_FPS,          CameraConfig.FPS)
                    cap.set(cv2.CAP_PROP_BUFFERSIZE,   1)
                    cap.set(cv2.CAP_PROP_FOURCC, cv2.VideoWriter_fourcc(*"MJPG"))

                    # ── Disable auto-exposure ──────────────────────────────
                    # V4L2: CAP_PROP_AUTO_EXPOSURE values:
                    #   0.25 = manual mode  |  0.75 = aperture-priority (auto)
                    # Some drivers use integer 1 (manual) / 3 (auto) instead.
                    if not CameraConfig.AUTO_EXPOSURE:
                        cap.set(cv2.CAP_PROP_AUTO_EXPOSURE, 0.25)   # manual
                        cap.set(cv2.CAP_PROP_EXPOSURE, CameraConfig.EXPOSURE)
                        # Disable auto white-balance for consistent colour
                        cap.set(cv2.CAP_PROP_AUTO_WB, 0)

                    # Warm up and prove the device returns frames.
                    ok = False
                    for _ in range(max(5, CameraConfig.WARMUP_FRAMES)):
                        ret, frame = cap.read()
                        if ret and frame is not None and frame.size > 0:
                            ok = True
                            break
                        time.sleep(0.03)

                    if not ok:
                        raise RuntimeError("camera opened but returned no frames")

                    # Log what the driver actually accepted
                    actual_w   = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
                    actual_h   = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
                    actual_fps = cap.get(cv2.CAP_PROP_FPS)
                    actual_exp = cap.get(cv2.CAP_PROP_EXPOSURE)
                    logger.info(
                        f"[Camera] OpenCV index={index} backend={backend} "
                        f"{actual_w}x{actual_h} @ {actual_fps:.0f}fps  "
                        f"AE={'on' if CameraConfig.AUTO_EXPOSURE else 'off'}  "
                        f"exposure={actual_exp}"
                    )

                    self._backend = cap
                    self._use_picam = False
                    return
                except Exception as e:
                    last_error = e
                    if cap is not None:
                        try:
                            cap.release()
                        except Exception:
                            pass

        raise RuntimeError(f"[Camera] No camera available after retries: {last_error}")

    def _capture_loop(self):
        import cv2

        while self._running:
            try:
                if self._use_picam:
                    raw = self._backend.capture_array()
                    frame = cv2.cvtColor(raw, cv2.COLOR_RGB2BGR)
                else:
                    # Drain USB driver buffer (legacy WebcamModule pattern: always "fresh" frame).
                    extra = max(0, int(getattr(CameraConfig, "BUFFER_GRABS", 0)))
                    for _ in range(extra):
                        self._backend.grab()
                    ret, frame = self._backend.retrieve()
                    if not ret or frame is None:
                        ret, frame = self._backend.read()
                    if not ret or frame is None:
                        time.sleep(0.01)
                        continue

                if CameraConfig.FLIP:
                    frame = cv2.flip(frame, -1)

                with self._lock:
                    self._frame = frame
                    self._frame_count += 1
                    
                if self.publish and self._zmq_socket is not None:
                    _, encoded = cv2.imencode(".jpg", frame, [cv2.IMWRITE_JPEG_QUALITY, 80])
                    self._zmq_socket.send(encoded.tobytes())
                    
            except Exception as e:
                logger.warning(f"[Camera] Capture error: {e}")
                time.sleep(0.02)
