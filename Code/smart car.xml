from typing import List, Optional, Tuple
from .mission_types import MarkerSighting, VehicleState, MissionCommand, MissionOutcome
from .mission_base import Mission, MissionPhase
from .marker_registry import MarkerRegistry
from .mission_factory import MissionFactory
from .safety_monitor import SafetyMonitor
import logging

logger = logging.getLogger(__name__)

class MissionManager:
    """
    Orchestrates mission execution. Arbitrates priority, validates triggers, 
    tracks cooldowns/history, and pumps the active mission state machine.
    """
    def __init__(self, registry: MarkerRegistry, safety_monitor: SafetyMonitor):
        self.registry = registry
        self.safety_monitor = safety_monitor
        self.active_mission: Optional[Mission] = None
        
        self.cooldown_ledger = {}  # marker_id -> expiry timestamp
        self.completed_history = set()  # marker_ids of successful one-time missions

    def update(self, sightings: List[MarkerSighting], vehicle_state: VehicleState, current_time: float) -> Optional[MissionCommand]:
        """
        Called every frame. Returns the controlling MissionCommand, or None if no mission is active.
        """
        # 1. Validation & Candidate Selection
        candidate = self._select_best_candidate(sightings, vehicle_state, current_time)
        
        # 2. Interruption or Activation
        if candidate:
            definition, sighting = candidate
            self._activate_candidate(definition, sighting, vehicle_state, current_time)

        # 3. Active Mission Execution
        if not self.active_mission:
            return None

        # Check safety/watchdog limits
        if not self.safety_monitor.update_mission_health(self.active_mission.definition.marker_id, current_time):
            self._cancel_active_mission(vehicle_state)
            return None
            
        if self.safety_monitor.is_paused or self.safety_monitor.is_emergency_stopped:
            self._cancel_active_mission(vehicle_state)
            return None

        # Run phase machine
        command = self._pump_active_mission(vehicle_state, sightings)
        return command

    def _select_best_candidate(self, sightings: List[MarkerSighting], vehicle_state: VehicleState, current_time: float):
        best_candidate = None
        highest_priority = -1
        
        if self.active_mission:
            highest_priority = self.active_mission.definition.priority

        for sighting in sightings:
            definition = self.registry.get_definition(sighting.marker_id)
            if not definition:
                continue
                
            # Priority must be strictly higher to interrupt
            if definition.priority <= highest_priority:
                continue
                
            # Cooldown check
            if sighting.marker_id in self.cooldown_ledger:
                if current_time < self.cooldown_ledger[sighting.marker_id]:
                    continue
                    
            # One-time check
            if not definition.repeatable and sighting.marker_id in self.completed_history:
                continue
                
            # Trigger distance check
            if sighting.distance > definition.trigger_distance:
                continue
                
            # Safety Monitor check
            if not self.safety_monitor.permits_activation(vehicle_state):
                continue
                
            best_candidate = (definition, sighting)
            highest_priority = definition.priority
            
        return best_candidate

    def _activate_candidate(self, definition, sighting, vehicle_state, current_time):
        if self.active_mission:
            logger.info(f"[MissionManager] Interrupting current mission for Marker {definition.marker_id} (Priority {definition.priority})")
            self.active_mission.on_interrupt(vehicle_state, definition.priority)
            
        logger.info(f"[MissionManager] Activating Mission '{definition.mission_type}' for Marker {definition.marker_id}")
        self.active_mission = MissionFactory.create(definition.mission_type, definition, sighting)
        # Start cooldown block immediately upon activation
        self.cooldown_ledger[definition.marker_id] = current_time + definition.cooldown_s

    def _cancel_active_mission(self, vehicle_state):
        if self.active_mission:
            self.active_mission.on_abort(vehicle_state)
            self.active_mission = None
            self.safety_monitor.clear_mission_tracking()

    def _pump_active_mission(self, vehicle_state: VehicleState, sightings: List[MarkerSighting]) -> Optional[MissionCommand]:
        m = self.active_mission
        phase = m.current_phase
        matching_sighting = next((s for s in sightings if s.marker_id == m.definition.marker_id), None)
        
        # Advance phase if complete
        if m.is_phase_complete(phase, vehicle_state):
            transitions = {
                MissionPhase.PENDING: MissionPhase.APPROACH,
                MissionPhase.APPROACH: MissionPhase.PREPARE,
                MissionPhase.PREPARE: MissionPhase.EXECUTE,
                MissionPhase.EXECUTE: MissionPhase.RECOVER,
                MissionPhase.RECOVER: MissionPhase.COMPLETE
            }
            if phase in transitions:
                new_phase = transitions[phase]
                logger.info(f"[MissionManager] Mission phase transition: {phase} -> {new_phase}")
                m.current_phase = new_phase
                phase = m.current_phase
        
        # Handle completion
        if phase == MissionPhase.COMPLETE:
            outcome = m.report_outcome()
            logger.info(f"[MissionManager] Mission Complete. Outcome: {outcome.name}")
            if outcome == MissionOutcome.SUCCESS:
                # Add to history if successful (for one-time enforcement)
                self.completed_history.add(m.definition.marker_id)
            self.active_mission = None
            self.safety_monitor.clear_mission_tracking()
            return None

        # Execute hook based on current phase
        if phase == MissionPhase.PENDING:
            return m.on_pending(vehicle_state, matching_sighting)
        elif phase == MissionPhase.APPROACH:
            return m.on_approach(vehicle_state, matching_sighting)
        elif phase == MissionPhase.PREPARE:
            return m.on_prepare(vehicle_state, matching_sighting)
        elif phase == MissionPhase.EXECUTE:
            return m.on_execute(vehicle_state, matching_sighting)
        elif phase == MissionPhase.RECOVER:
            return m.on_recover(vehicle_state, matching_sighting)
            
        return None
