/**
 * Liquid Blob renderer — preserved visual identity from Liquid_Blob.html
 * Extended with thinking state and external state-machine integration.
 */
import { lerp, smooth } from '../core/easing.js';
import { STATES } from '../core/state-machine.js';

export function createNoise() {
  const hash = (n) => {
    n = (n << 13) ^ n;
    return ((n * (n * n * 15731 + 789221) + 1376312589) & 0x7fffffff) / 0x7fffffff;
  };

  return function noise(x, y, z) {
    const X = Math.floor(x) & 255;
    const Y = Math.floor(y) & 255;
    const Z = Math.floor(z) & 255;
    const xf = x - Math.floor(x);
    const yf = y - Math.floor(y);
    const zf = z - Math.floor(z);
    const u = xf * xf * (3 - 2 * xf);
    const v = yf * yf * (3 - 2 * yf);
    const w = zf * zf * (3 - 2 * zf);

    const n000 = hash(X + Y * 57 + Z * 131);
    const n001 = hash(X + Y * 57 + (Z + 1) * 131);
    const n010 = hash(X + (Y + 1) * 57 + Z * 131);
    const n011 = hash(X + (Y + 1) * 57 + (Z + 1) * 131);
    const n100 = hash((X + 1) + Y * 57 + Z * 131);
    const n101 = hash((X + 1) + Y * 57 + (Z + 1) * 131);
    const n110 = hash((X + 1) + (Y + 1) * 57 + Z * 131);
    const n111 = hash((X + 1) + (Y + 1) * 57 + (Z + 1) * 131);

    const x00 = lerp(n000, n100, u);
    const x10 = lerp(n010, n110, u);
    const x01 = lerp(n001, n101, u);
    const x11 = lerp(n011, n111, u);
    const y0 = lerp(x00, x10, v);
    const y1 = lerp(x01, x11, v);
    return lerp(y0, y1, w);
  };
}

export class LiquidBlob {
  constructor(canvas, { stateMachine, audioAnalyzer }) {
    this.canvas = canvas;
    this.ctx = canvas.getContext('2d', { alpha: false });
    this.stateMachine = stateMachine;
    this.audio = audioAnalyzer;
    this.noise = createNoise();

    this.numPoints = 200;
    this.baseRadius = 160;
    this.angles = Array.from({ length: this.numPoints }, (_, i) => (i / this.numPoints) * Math.PI * 2);
    this.radii = new Float32Array(this.numPoints).fill(this.baseRadius);

    this.clock = { t: 0, delta: 0 };
    this.lastTimestamp = 0;
    this._running = false;

    this._initParticles();
    this._resize();
    window.addEventListener('resize', () => this._resize());
  }

  _initParticles() {
    const w = 800, h = 800, baseRadius = this.baseRadius;

    this.bgParticles = Array.from({ length: 120 }, () => ({
      x: Math.random() * w,
      y: Math.random() * h,
      size: 0.5 + Math.random() * 1.5,
      speedX: (Math.random() - 0.5) * 0.1,
      speedY: (Math.random() - 0.5) * 0.1,
      alpha: 0.1 + Math.random() * 0.3,
      phase: Math.random() * Math.PI * 2,
    }));

    this.waveParticles = Array.from({ length: 250 }, (_, i) => ({
      angle: (i / 250) * Math.PI * 2,
      radius: baseRadius + 30 + Math.random() * 80,
      speed: 0.001 + Math.random() * 0.003,
      size: 0.8 + Math.random() * 1.5,
      alpha: 0.3 + Math.random() * 0.5,
      yOffset: (Math.random() - 0.5) * 50,
      phase: Math.random() * Math.PI * 2,
      idx: i,
    }));

    this.ringParticles = Array.from({ length: 80 }, (_, i) => ({
      angle: (i / 80) * Math.PI * 2 + Math.random() * 0.5,
      radius: baseRadius + 40 + Math.random() * 30,
      speed: 0.003 + Math.random() * 0.002,
      size: 1 + Math.random() * 2,
      alpha: 0.4 + Math.random() * 0.4,
      orbitSpeed: (Math.random() - 0.5) * 0.01,
    }));

    this.thinkingOrbits = Array.from({ length: 12 }, (_, i) => ({
      angle: (i / 12) * Math.PI * 2,
      speed: 0.15 + Math.random() * 0.1,
      radius: baseRadius * (0.55 + Math.random() * 0.25),
    }));
  }

  _resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = this.canvas.getBoundingClientRect();
    const size = Math.max(rect.width, rect.height, 400);
    this.canvas.width = size * dpr;
    this.canvas.height = size * dpr;
    this.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    this.w = rect.width || size;
    this.h = rect.height || size;
    this.cx = this.w / 2;
    this.cy = this.h / 2;
    this.scale = Math.min(this.w, this.h) / 800;
    this.baseRadius = 160 * this.scale;
    if (this.radii) this.radii.fill(this.baseRadius);
  }

  start() {
    if (this._running) return;
    this._running = true;
    this.lastTimestamp = 0;
    requestAnimationFrame((t) => this._render(t));
  }

  stop() {
    this._running = false;
  }

  _computeRadii(time, weights, smoothed) {
    const { noise } = this;
    const baseRadius = this.baseRadius;

    for (let i = 0; i < this.numPoints; i++) {
      const angle = this.angles[i];
      let radiusOffset = 0;

      const dormantNoise = noise(
        Math.cos(angle) * 2.0,
        Math.sin(angle) * 2.0,
        time * 0.2
      ) * 0.025;
      radiusOffset += dormantNoise;
      radiusOffset += 0.015 * Math.sin(angle * 2.0 + time * 0.5);

      const listeningWave =
        0.06 * Math.sin(angle * 3.0 + time * 1.0) * Math.cos(time * 0.6) +
        0.04 * Math.cos(angle * 5.0 - time * 0.8);

      const thinkingFlow =
        0.04 * noise(Math.cos(angle) * 4 + time * 0.15, Math.sin(angle) * 4, time * 0.25) +
        0.03 * Math.sin(angle * 2 + time * 0.35) * Math.cos(time * 0.2) +
        0.02 * Math.sin(time * 0.8 + angle * 3);

      const spikeNoise1 = noise(Math.cos(angle) * 3.0 + time * 0.4, Math.sin(angle) * 3.0, time * 0.6);
      const spikeNoise2 = noise(Math.cos(angle) * 6.0 - time * 1.0, Math.sin(angle) * 6.0 + time * 0.2, time * 1.2);
      const spikeNoise3 = noise(Math.cos(angle) * 12.0 + time * 1.5, Math.sin(angle) * 12.0 - time * 0.8, time * 2.5);
      const spikeNoise4 = noise(Math.cos(angle) * 24.0 + time * 3.0, Math.sin(angle) * 24.0 - time * 2.0, time * 5.0);

      const activeSpike =
        spikeNoise1 * 0.3 + spikeNoise2 * 0.25 + spikeNoise3 * 0.2 + spikeNoise4 * 0.1;

      const audioSpike =
        smoothed.low * 0.45 * (1 + 0.7 * Math.sin(angle * 4.0 + time * 2.0)) +
        smoothed.mid * 0.35 * Math.cos(angle * 8.0 - time * 3.5) +
        smoothed.high * 0.25 * Math.sin(angle * 18.0 + time * 12.0) +
        smoothed.rms * 0.55 * Math.sin(angle * 6.0 + time * 5.0);

      const { dormant, listening, thinking, speaking } = weights;

      let finalOffset =
        dormant * radiusOffset +
        listening * (radiusOffset + listeningWave * 0.6) +
        thinking * (radiusOffset + thinkingFlow + 0.02 * Math.sin(time * 1.2)) +
        speaking * (activeSpike + audioSpike);

      if (listening > 0.2) {
        finalOffset += smoothed.rms * 0.12 * Math.sin(angle * 7.0 + time * 2.5);
      }

      finalOffset = Math.max(-0.4, finalOffset);
      const targetR = baseRadius * (0.88 + finalOffset);
      this.radii[i] = smooth(this.radii[i], targetR, 0.1);
    }
  }

  _drawBlob(time, blend, weights, smoothed) {
    const ctx = this.ctx;
    const { cx, cy, baseRadius } = this;
    const points = [];

    for (let i = 0; i < this.numPoints; i++) {
      const r = this.radii[i];
      points.push({
        x: cx + r * Math.cos(this.angles[i]),
        y: cy + r * Math.sin(this.angles[i]),
        angle: this.angles[i],
      });
    }

    const speakingW = weights.speaking;
    const dynamicBloom = 35 + blend * 8 + smoothed.rms * 100 + speakingW * 15;

    ctx.shadowColor = speakingW > 0.3
      ? `rgba(200, 235, 255, ${0.25 + smoothed.rms * 0.35})`
      : `rgba(100, 200, 255, ${0.15 + blend * 0.04})`;
    ctx.shadowBlur = dynamicBloom;

    ctx.beginPath();
    for (let i = 0; i < points.length; i++) {
      const curr = points[i];
      const next = points[(i + 1) % points.length];
      const midX = (curr.x + next.x) / 2;
      const midY = (curr.y + next.y) / 2;
      if (i === 0) ctx.moveTo(midX, midY);
      else ctx.quadraticCurveTo(curr.x, curr.y, midX, midY);
    }
    ctx.closePath();

    const gradShiftX = -35 + blend * 4 + smoothed.low * 15;
    const gradShiftY = -45 + blend * 2;
    const fillGrad = ctx.createRadialGradient(
      cx + gradShiftX, cy + gradShiftY, 10,
      cx, cy, baseRadius * (1.35 + smoothed.low * 0.35)
    );

    if (blend < 0.8) {
      fillGrad.addColorStop(0, '#e8f6ff');
      fillGrad.addColorStop(0.12, '#c0e8ff');
      fillGrad.addColorStop(0.35, '#78c8ff');
      fillGrad.addColorStop(0.65, '#2f8ed9');
      fillGrad.addColorStop(0.85, '#0f4b7a');
      fillGrad.addColorStop(1, '#031f33');
    } else if (blend < 1.8) {
      fillGrad.addColorStop(0, '#d8fbff');
      fillGrad.addColorStop(0.12, '#88f0ff');
      fillGrad.addColorStop(0.35, '#48d8e8');
      fillGrad.addColorStop(0.65, '#2088a8');
      fillGrad.addColorStop(0.85, '#0a4058');
      fillGrad.addColorStop(1, '#021828');
    } else if (blend < 2.5) {
      fillGrad.addColorStop(0, '#e0f4ff');
      fillGrad.addColorStop(0.15, '#90d8f0');
      fillGrad.addColorStop(0.4, '#50b8d8');
      fillGrad.addColorStop(0.7, '#1a6890');
      fillGrad.addColorStop(0.9, '#0a3048');
      fillGrad.addColorStop(1, '#021420');
    } else {
      fillGrad.addColorStop(0, `rgba(245, 252, 255, ${0.92 + smoothed.rms * 0.08})`);
      fillGrad.addColorStop(0.12, `rgba(190, 235, 255, ${0.88 + smoothed.rms * 0.12})`);
      fillGrad.addColorStop(0.35, `rgba(110, 205, 255, ${0.75 + smoothed.rms * 0.15})`);
      fillGrad.addColorStop(0.65, `rgba(45, 145, 225, ${0.65 + smoothed.rms * 0.15})`);
      fillGrad.addColorStop(0.85, `rgba(18, 80, 130, ${0.55 + smoothed.rms * 0.15})`);
      fillGrad.addColorStop(1, `rgba(4, 35, 55, ${0.45 + smoothed.rms * 0.15})`);
    }

    ctx.fillStyle = fillGrad;
    ctx.fill();

    ctx.shadowBlur = 12 + blend * 4 + smoothed.high * 40;
    ctx.shadowColor = speakingW > 0.3
      ? `rgba(220, 245, 255, ${0.35 + smoothed.rms * 0.45})`
      : `rgba(160, 220, 255, ${0.25 + blend * 0.05})`;
    ctx.strokeStyle = speakingW > 0.3
      ? `rgba(210, 245, 255, ${0.35 + smoothed.rms * 0.55})`
      : `rgba(150, 215, 255, ${0.25 + blend * 0.05})`;
    ctx.lineWidth = 1.8 + blend * 0.4 + smoothed.high * 2.5;
    ctx.stroke();

    const hl1Size = baseRadius * (0.22 + blend * 0.03);
    const hl1X = cx - 55 * this.scale + blend * 6;
    const hl1Y = cy - 65 * this.scale + blend * 4;
    ctx.shadowBlur = 40 + smoothed.rms * 60;
    ctx.shadowColor = 'rgba(255, 255, 255, 0.35)';
    const hl1Grad = ctx.createRadialGradient(hl1X, hl1Y, 2, hl1X, hl1Y, hl1Size);
    hl1Grad.addColorStop(0, `rgba(255, 255, 255, ${0.55 + smoothed.rms * 0.25})`);
    hl1Grad.addColorStop(0.4, `rgba(210, 245, 255, ${0.25 + smoothed.rms * 0.15})`);
    hl1Grad.addColorStop(1, 'rgba(150, 220, 255, 0)');
    ctx.beginPath();
    ctx.arc(hl1X, hl1Y, hl1Size, 0, Math.PI * 2);
    ctx.fillStyle = hl1Grad;
    ctx.fill();

    const hl2Size = baseRadius * 0.15;
    const hl2X = cx + 45 * this.scale;
    const hl2Y = cy + 55 * this.scale;
    const hl2Grad = ctx.createRadialGradient(hl2X, hl2Y, 2, hl2X, hl2Y, hl2Size);
    hl2Grad.addColorStop(0, `rgba(180, 225, 255, ${0.2 + smoothed.rms * 0.1})`);
    hl2Grad.addColorStop(1, 'rgba(100, 200, 255, 0)');
    ctx.beginPath();
    ctx.arc(hl2X, hl2Y, hl2Size, 0, Math.PI * 2);
    ctx.fillStyle = hl2Grad;
    ctx.fill();

    if (weights.thinking > 0.15) {
      for (const orbit of this.thinkingOrbits) {
        orbit.angle += orbit.speed * 0.016;
        const ox = cx + Math.cos(orbit.angle) * orbit.radius;
        const oy = cy + Math.sin(orbit.angle) * orbit.radius * 0.4;
        const spot = 2 + weights.thinking * 3;
        ctx.beginPath();
        ctx.arc(ox, oy, spot, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(180, 230, 255, ${0.15 + weights.thinking * 0.25})`;
        ctx.fill();
      }
    }

    if (speakingW > 0.2) {
      for (let i = 0; i < 8; i++) {
        const spotAngle = (i / 8) * Math.PI * 2 + time * 0.5 + smoothed.rms * 3;
        const spotR = baseRadius * (0.9 + smoothed.high * 0.3);
        const sx = cx + Math.cos(spotAngle) * spotR;
        const sy = cy + Math.sin(spotAngle) * spotR;
        ctx.beginPath();
        ctx.arc(sx, sy, 3 + smoothed.high * 8, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(200, 240, 255, ${0.3 + smoothed.high * 0.4})`;
        ctx.fill();
      }
    }

    ctx.shadowBlur = 0;
    ctx.shadowColor = 'transparent';
  }

  _drawBgParticles(time, blend, smoothed) {
    const ctx = this.ctx;
    const { cx, cy, w, h } = this;
    const speedMult = 1 + smoothed.rms * 6 * (blend / 3);

    for (const p of this.bgParticles) {
      const dx = p.x / 800 * w - cx;
      const dy = p.y / 800 * h - cy;
      const dist = Math.sqrt(dx * dx + dy * dy) || 1;
      const pushForce = smoothed.rms * 2.5 * (blend / 3);
      p.x += (p.speedX * speedMult) + (dx / dist) * pushForce + 0.012 * Math.sin(time * 0.2 + p.y * 0.01);
      p.y += (p.speedY * speedMult) + (dy / dist) * pushForce + 0.012 * Math.cos(time * 0.15 + p.x * 0.01);
      if (p.x < 0) p.x = w;
      if (p.x > w) p.x = 0;
      if (p.y < 0) p.y = h;
      if (p.y > h) p.y = 0;

      const baseAlpha = p.alpha * (0.5 + 0.5 * Math.sin(time * 0.5 + p.x * 0.02 + p.phase));
      const activeAlpha = Math.min(1, baseAlpha + smoothed.rms * 0.25 * (blend / 3));
      ctx.beginPath();
      ctx.arc(p.x / 800 * w, p.y / 800 * h, p.size * (1 + smoothed.rms * 1.2), 0, Math.PI * 2);
      ctx.fillStyle = `rgba(160, 215, 255, ${activeAlpha * 0.28})`;
      ctx.fill();
    }
  }

  _drawWaveParticles(time, weights, smoothed) {
    const ctx = this.ctx;
    const { cx, cy } = this;
    const listeningIntensity = weights.listening;
    const speakingIntensity = weights.speaking;
    if (listeningIntensity < 0.05 && speakingIntensity < 0.05) return;

    for (const p of this.waveParticles) {
      p.angle += p.speed * (1 + smoothed.rms * 4);
      const waveY = Math.sin(p.angle * 3.0 + time * 1.8) * 25 * listeningIntensity * this.scale;
      const waveX = Math.cos(p.angle * 2.0 - time * 1.2) * 18 * listeningIntensity * this.scale;
      const expansion = 1 + smoothed.rms * 2.5 * listeningIntensity + smoothed.low * 1.8 * speakingIntensity;
      const currentRadius = p.radius * this.scale * expansion;
      const px = cx + Math.cos(p.angle) * currentRadius + waveX;
      const py = cy + Math.sin(p.angle) * currentRadius * 0.35 + waveY + p.yOffset * this.scale;

      const stateAlpha = listeningIntensity > 0.5 ? listeningIntensity : speakingIntensity * 0.4;
      const activeAlpha = Math.min(1, p.alpha * stateAlpha + smoothed.rms * 0.35);
      let r = 90, g = 205, b = 255;
      if (speakingIntensity > 0.3) {
        r = 210 + smoothed.rms * 45;
        g = 235 + smoothed.rms * 20;
        b = 255;
      }

      ctx.beginPath();
      ctx.arc(px, py, p.size * (1 + smoothed.rms * 1.8), 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${r | 0}, ${g | 0}, ${b | 0}, ${activeAlpha * 0.35})`;
      ctx.fill();
    }
  }

  _drawRingParticles(time, weights, smoothed) {
    const ctx = this.ctx;
    const { cx, cy } = this;
    const listeningIntensity = weights.listening;
    if (listeningIntensity < 0.1) return;

    for (const p of this.ringParticles) {
      p.angle += p.orbitSpeed + smoothed.rms * 0.02;
      const ringRadius = (p.radius + Math.sin(time * 2.0 + p.angle * 3) * 15 * listeningIntensity) * this.scale;
      const px = cx + Math.cos(p.angle) * ringRadius;
      const py = cy + Math.sin(p.angle) * ringRadius * 0.3;
      const alpha = p.alpha * listeningIntensity * (0.6 + 0.4 * Math.sin(time * 3 + p.angle * 5));
      ctx.beginPath();
      ctx.arc(px, py, p.size * (1 + smoothed.rms * 1.5), 0, Math.PI * 2);
      ctx.fillStyle = `rgba(120, 220, 255, ${alpha * 0.4})`;
      ctx.fill();
    }
  }

  _drawWaveLines(time, weights, smoothed) {
    const ctx = this.ctx;
    const { cx, cy } = this;
    const listeningIntensity = weights.listening;
    if (listeningIntensity < 0.1) return;

    ctx.save();
    ctx.globalAlpha = listeningIntensity * 0.25;
    ctx.strokeStyle = 'rgba(100, 230, 255, 0.5)';
    ctx.lineWidth = 1.2;

    for (let y = -80; y <= 80; y += 20) {
      ctx.beginPath();
      for (let x = -250; x <= 250; x += 4) {
        const waveHeight = Math.sin(x * 0.025 + time * 1.8) * 20 * listeningIntensity;
        const waveHeight2 = Math.cos(x * 0.04 - time * 1.2) * 10 * listeningIntensity;
        const audioBoost = smoothed.rms * 15 * listeningIntensity;
        const py = cy + y * this.scale + waveHeight + waveHeight2 + audioBoost * Math.sin(x * 0.015);
        const px = cx + x * this.scale;
        if (x === -250) ctx.moveTo(px, py);
        else ctx.lineTo(px, py);
      }
      ctx.stroke();
    }
    ctx.restore();
  }

  _drawBackground(blend, smoothed) {
    const ctx = this.ctx;
    const { cx, cy, w, h } = this;

    const bgGrad = ctx.createRadialGradient(cx, cy, 40, cx, cy, Math.max(w, h) * 0.85);
    if (blend < 0.8) {
      bgGrad.addColorStop(0, '#0e151c');
      bgGrad.addColorStop(0.6, '#030608');
      bgGrad.addColorStop(1, '#000000');
    } else if (blend < 1.8) {
      bgGrad.addColorStop(0, '#0a1e2a');
      bgGrad.addColorStop(0.6, '#020c14');
      bgGrad.addColorStop(1, '#000000');
    } else if (blend < 2.5) {
      bgGrad.addColorStop(0, '#0c1a28');
      bgGrad.addColorStop(0.6, '#040e18');
      bgGrad.addColorStop(1, '#000000');
    } else {
      bgGrad.addColorStop(0, `rgba(10, 28, 45, ${0.85 + smoothed.rms * 0.15})`);
      bgGrad.addColorStop(0.6, `rgba(5, 18, 30, ${0.92 + smoothed.rms * 0.08})`);
      bgGrad.addColorStop(1, '#000000');
    }
    ctx.fillStyle = bgGrad;
    ctx.fillRect(0, 0, w, h);
  }

  _drawAmbientGlow(blend, smoothed) {
    const ctx = this.ctx;
    const { cx, cy, baseRadius, w, h } = this;
    const glowIntensity = (blend / 3 * 0.025) + smoothed.low * 0.07;
    const glow = ctx.createRadialGradient(cx, cy, 15, cx, cy, baseRadius * 3.2);
    if (blend < 2) {
      glow.addColorStop(0, `rgba(60, 185, 255, ${glowIntensity})`);
      glow.addColorStop(0.5, `rgba(20, 105, 205, ${glowIntensity * 0.5})`);
    } else {
      glow.addColorStop(0, `rgba(70, 210, 255, ${glowIntensity * 1.5})`);
      glow.addColorStop(0.5, `rgba(35, 160, 225, ${glowIntensity})`);
    }
    glow.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = glow;
    ctx.fillRect(0, 0, w, h);
  }

  _render(now) {
    if (!this._running) return;

    const delta = this.lastTimestamp ? Math.min((now - this.lastTimestamp) / 1000, 0.04) : 0.016;
    this.lastTimestamp = now;
    this.clock.t += delta;
    this.clock.delta = delta;

    this.stateMachine.tick();
    const blend = this.stateMachine.blend;
    const weights = this.stateMachine.getBlendWeights();
    const isSpeaking = this.stateMachine.state === STATES.SPEAKING;
    this.audio.process(isSpeaking);
    const smoothed = this.audio.smoothed;

    const ctx = this.ctx;
    ctx.clearRect(0, 0, this.w, this.h);

    this._drawBackground(blend, smoothed);
    this._drawBgParticles(this.clock.t, blend, smoothed);
    this._drawWaveLines(this.clock.t, weights, smoothed);
    this._drawRingParticles(this.clock.t, weights, smoothed);
    this._drawWaveParticles(this.clock.t, weights, smoothed);
    this._computeRadii(this.clock.t, weights, smoothed);
    this._drawBlob(this.clock.t, blend, weights, smoothed);
    this._drawAmbientGlow(blend, smoothed);

    requestAnimationFrame((t) => this._render(t));
  }
}
