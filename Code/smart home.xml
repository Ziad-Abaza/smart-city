import cv2
import mediapipe as mp
from mediapipe.tasks import python
from mediapipe.tasks.python import vision
import numpy as np
from sklearn.neighbors import NearestNeighbors
from collections import Counter
from core.config_manager import config_manager
from face_recognition.aligner import align_face

class FaceRecognition:
    def __init__(self, enrolled_faces_dir=None, 
                 unknown_faces_dir=None, threshold=None):
        fr_config = config_manager.get("face_recognition_server", {})
        
        self.enrolled_faces_dir = enrolled_faces_dir or fr_config.get("enrolled_faces_dir", "face_recognition/enrolled_faces")
        self.unknown_faces_dir = unknown_faces_dir or fr_config.get("unknown_faces_dir", "face_recognition/unknown_faces")
        self.threshold = threshold if threshold is not None else fr_config.get("threshold", 0.5)
        
        # Resolve to absolute paths
        self.enrolled_faces_dir = config_manager.resolve_path(self.enrolled_faces_dir)
        self.unknown_faces_dir = config_manager.resolve_path(self.unknown_faces_dir)
        
        model_relative_path = fr_config.get("model_path", "face_recognition/models/face_landmarker.task")
        model_absolute_path = config_manager.resolve_path(model_relative_path)
        
        # Initialize MediaPipe FaceLandmarker
        det_conf = fr_config.get("detection_min_confidence", 0.6)
        trk_conf = fr_config.get("tracking_min_confidence", 0.6)

        base_options = python.BaseOptions(
            model_asset_path=model_absolute_path)
        options = vision.FaceLandmarkerOptions(
            base_options=base_options,
            num_faces=1,
            min_face_detection_confidence=det_conf,
            min_tracking_confidence=trk_conf)
            
        self.face_landmarker = vision.FaceLandmarker.create_from_options(options)
        
        sface_model_path = config_manager.resolve_path(fr_config.get("sface_model_path", "face_recognition/models/face_recognition_sface_2021dec.onnx"))
        self.sface = cv2.FaceRecognizerSF.create(sface_model_path, "")

        self.known_embeddings = []
        self.known_labels = []
        self.nn = NearestNeighbors(n_neighbors=3, metric='cosine')
        self.load_known_faces()

        # Announcement cooldown: track last announcement time per name.
        # Prevents the same greeting from firing on every video frame.
        import time as _time
        self._time = _time
        self._last_announced: dict = {}          # name -> timestamp
        self.announcement_cooldown: float = fr_config.get("announcement_cooldown_s", 30.0)

    def get_face_embedding(self, image):
        """Convert face image to embedding using SFace"""
        if image.shape[:2] == (112, 112):
            aligned_face = image
        else:
            rgb_image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)
            mp_image = mp.Image(image_format=mp.ImageFormat.SRGB, data=rgb_image)
            detection_result = self.face_landmarker.detect(mp_image)
            
            if not detection_result.face_landmarks:
                return None
                
            landmarks = detection_result.face_landmarks[0]
            aligned_face = align_face(image, landmarks)
            if aligned_face is None:
                return None
                
        feature = self.sface.feature(aligned_face)
        feature = feature[0]
        feature = feature / np.linalg.norm(feature)
        return feature

    def load_known_faces(self):
        """Load both known and unknown faces"""
        # Create directories if they don't exist
        os.makedirs(self.enrolled_faces_dir, exist_ok=True)
        os.makedirs(self.unknown_faces_dir, exist_ok=True)

        # Load known faces
        for person_name in os.listdir(self.enrolled_faces_dir):
            if person_name == "Unknown":
                continue
            person_dir = os.path.join(self.enrolled_faces_dir, person_name)
            if os.path.isdir(person_dir):
                self.process_directory(person_dir, person_name)

        if not self.known_embeddings:
            raise ValueError("No faces found in enrolled or unknown directories")
        
        n_neighbors = min(3, len(self.known_embeddings))
        self.nn.n_neighbors = n_neighbors
        self.nn.fit(self.known_embeddings)

    def process_directory(self, directory_path, label):
        """Process all images in a directory"""
        for image_file in os.listdir(directory_path):
            image_path = os.path.join(directory_path, image_file)
            if not image_path.lower().endswith(('.png', '.jpg', '.jpeg')):
                continue
            
            cache_path = image_path + ".npy"
            embedding = None
            
            # Use cached embedding if available and newer than the image
            if os.path.exists(cache_path) and os.path.getmtime(cache_path) >= os.path.getmtime(image_path):
                embedding = np.load(cache_path)
            else:
                image = cv2.imread(image_path)
                if image is None:
                    continue
                
                embedding = self.get_face_embedding(image)
                if embedding is not None:
                    np.save(cache_path, embedding)
                    
            if embedding is not None:
                self.known_embeddings.append(embedding)
                self.known_labels.append(label)
                
    def recognize_face(self, frame):
        rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        mp_image = mp.Image(image_format=mp.ImageFormat.SRGB, data=rgb_frame)
        detection_result = self.face_landmarker.detect(mp_image)
        
        if not detection_result.face_landmarks:
            return frame, "Unknown", False

        # Process the first detected face (or modify for multiple faces)
        landmarks = detection_result.face_landmarks[0]
        
        aligned_face = align_face(frame, landmarks)
        if aligned_face is None:
            return frame, "Unknown", False
            
        embedding = self.sface.feature(aligned_face)
        embedding = embedding[0]
        embedding = embedding / np.linalg.norm(embedding)

        # Get face bounding box
        xs = [lm.x * frame.shape[1] for lm in landmarks]
        ys = [lm.y * frame.shape[0] for lm in landmarks]
        x_min, x_max = int(min(xs)), int(max(xs))
        y_min, y_max = int(min(ys)), int(max(ys))

        # Find closest matches
        k_neighbors = config_manager.get("face_recognition_server", {}).get("nn_k_neighbors", 3)
        n_neighbors = min(k_neighbors, len(self.known_embeddings))
        distances, indices = self.nn.kneighbors([embedding], n_neighbors=n_neighbors)
        
        dist_list = distances[0]
        neighbor_labels = [self.known_labels[i] for i in indices[0]]

        unique, counts = np.unique(neighbor_labels, return_counts=True)
        best_label = unique[np.argmax(counts)]
        
        avg_best_dist = np.mean([d for d, lbl in zip(dist_list, neighbor_labels) if lbl == best_label])
        other_dists = [d for d, lbl in zip(dist_list, neighbor_labels) if lbl != best_label]
        min_other_dist = min(other_dists) if other_dists else float('inf')
        
        margin_min = config_manager.get("face_recognition_server", {}).get("match_margin_min", 0.05)

        # Determine label
        if avg_best_dist > self.threshold or (min_other_dist - avg_best_dist < margin_min):
            label = "Unknown"
            color = (0, 0, 255)  # Red for unknown
        else:
            label = best_label
            color = (0, 255, 0)  # Green for known

        # Draw results on the frame
        cv2.rectangle(frame, (x_min, y_min), (x_max, y_max), color, 2)
        cv2.putText(frame, label, (x_min, y_min - 10),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.7, color, 2)

        return frame, label, True

    def _should_announce(self, name: str) -> bool:
        """Return True only if the name has not been announced within cooldown_time seconds.
        Maintains a per-name timestamp to avoid repeating greetings on every frame."""
        if name == "Unknown":
            return False
        now = self._time.time()
        last = self._last_announced.get(name, 0.0)
        if now - last >= self.announcement_cooldown:
            self._last_announced[name] = now
            return True
        return False
# Usage
if __name__ == "__main__":
    recognizer = FaceRecognition()
    
    cap = cv2.VideoCapture(0)
    while cap.isOpened():
        ret, frame = cap.read()
        if not ret:
            break
        
        frame, name, _ = recognizer.recognize_face(frame)
        cv2.imshow('Face Recognition', frame)
        
        if cv2.waitKey(1) & 0xFF == ord('q'):
            break
    
    cap.release()
    cv2.destroyAllWindows()
