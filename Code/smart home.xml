from typing import Dict, Any, Tuple, Optional
from voice_assistant.memory_retriever import memory_retriever

def detect_duplicate_or_conflict(candidate: Dict[str, Any]) -> Tuple[str, Optional[Dict[str, Any]]]:
    """
    Returns (status, existing_item)
    status can be: 'new', 'duplicate', 'conflict'
    """
    # 1. Scope search to the same category
    results = memory_retriever.search(candidate["content"], top_k=3, category_filter=candidate["category"])
    
    if not results:
        return "new", None
        
    best_match = results[0]
    score = best_match["score"]
    
    # 2. Check thresholds
    # Score > 0.90 -> Extremely similar -> Duplicate
    if score > 0.90:
        return "duplicate", best_match
        
    # Score between 0.70 and 0.90 -> Similar context, possibly conflicting values
    # For a real implementation, we'd use LLM to decide if it's a conflict or just related.
    # For this phase, we treat it as a conflict.
    if score > 0.70:
        return "conflict", best_match
        
    return "new", None
