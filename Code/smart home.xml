class ToolExecutor:
    def __init__(self, api_endpoints: Dict[str, Any], api_base_url: str = ""):
        self.registry = ToolRegistry()
        self.api_endpoints = api_endpoints
        self.api_base_url = api_base_url

    def validate_parameters(self, tool_name: str, parameters: Dict[str, Any]) -> bool:
        tool = self.registry.get_tool(tool_name)
        if not tool:
            return False
        
        required = tool.parameters.get("required", [])
        for req in required:
            if req not in parameters:
                return False
                
        props = tool.parameters.get("properties", {})
        for key, val in parameters.items():
            if key not in props:
                return False
            expected_enum = props[key].get("enum")
            if expected_enum and val not in expected_enum:
                return False
        return True

    def execute(self, tool_name: str, parameters: Dict[str, Any]) -> Dict[str, Any]:
        """
        Validates parameters and maps the normalized tool to the legacy API endpoint strings,
        then calls the hardware bridge.
        """
        if not self.validate_parameters(tool_name, parameters):
            return {"status": "error", "message": "Invalid parameters for tool."}
            
        tool = self.registry.get_tool(tool_name)
        if tool and tool.handler:
            return tool.handler(parameters)

        # Map to legacy endpoint keys
        endpoint_key = None
        
        if tool_name == "control_light":
            room = parameters["room"]
            state = parameters["state"]
            if room == "all":
                endpoint_key = f"lights_{state}_command"
            else:
                endpoint_key = f"light_{room}_{state}_command"
                
        elif tool_name == "control_fan":
            state = parameters["state"]
            endpoint_key = f"fan_{state}_command"
            
        elif tool_name == "control_door":
            action = parameters["action"]
            # "open" is high risk and usually intercepted before this point for face recognition
            # but if it reaches here, we execute it.
            if action == "open":
                endpoint_key = "open_door_command"
            else:
                endpoint_key = "close_door_command"
                
        elif tool_name == "read_sensor":
            sensor = parameters["sensor"]
            if sensor == "temperature":
                endpoint_key = "READ_TEMP"
            elif sensor == "humidity":
                endpoint_key = "READ_HUM"
            elif sensor == "environment":
                endpoint_key = "get_environment"

        if not endpoint_key:
            return {"status": "error", "message": "Could not map tool to hardware endpoint."}

        return self._call_api(endpoint_key)

    def _call_api(self, endpoint_key: str, method="POST") -> Dict[str, Any]:
        endpoint_config = self.api_endpoints.get(endpoint_key)
        if not endpoint_config:
            print(f"❌ API endpoint '{endpoint_key}' not found in config.")
            return {"status": "error", "message": "Endpoint not configured."}

        if isinstance(endpoint_config, str):
            url = endpoint_config
            method = "POST"
            body = None
            timeout = 5
        else:
            url = endpoint_config.get("url")
            if url and url.startswith("/") and self.api_base_url:
                url = f"{self.api_base_url.rstrip('/')}{url}"
            method = endpoint_config.get("method", method).upper()
            body = endpoint_config.get("body", None)
            timeout = endpoint_config.get("timeout", 5)

        try:
            print(f"🔗 Executing Tool API: {url} ({method})")
            response = requests.request(method, url, json=body, timeout=timeout)
            if response.status_code == 200:
                try:
                    return response.json()
                except json.JSONDecodeError:
                    return {"status": "success", "message": "Command executed successfully."}
            return {"status": "error", "message": f"Hardware bridge returned {response.status_code}"}
        except requests.exceptions.ConnectionError:
            print(f"❌ API unreachable: {url}")
            return {"status": "error", "message": "Hardware bridge is offline."}
        except requests.exceptions.Timeout:
            print(f"❌ API timed out: {url}")
            return {"status": "error", "message": "Hardware bridge timed out."}
        except Exception as e:
            print(f"❌ API error: {e}")
            return {"status": "error", "message": "Could not execute hardware command."}
