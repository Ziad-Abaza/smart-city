import nltk
from pydub import AudioSegment
from pydub.silence import split_on_silence
from nltk.tokenize import sent_tokenize

# Add project root to sys.path
root_path = Path(__file__).resolve().parent.parent
if str(root_path) not in sys.path:
    sys.path.insert(0, str(root_path))

from core.config_manager import config_manager

# Download NLTK data (run once)
nltk.download('punkt', quiet=True)

# Configuration
input_audio = config_manager.resolve_path("data/rawan_voice.wav")
output_folder = config_manager.resolve_path("data/split_audio")
transcript_file = config_manager.resolve_path("data/transcripts/transcript.txt")
metadata_file = "metadata.csv"

min_silence_len = 500  # Minimum silence length in milliseconds
silence_thresh = -40   # Silence threshold in dBFS
keep_silence = 200     # Keep some silence at boundaries

if not os.path.exists(input_audio):
    print(f"Error: Input audio file not found at {input_audio}")
    sys.exit(1)

if not os.path.exists(transcript_file):
    print(f"Error: Transcript file not found at {transcript_file}")
    sys.exit(1)

# Create output directory
os.makedirs(output_folder, exist_ok=True)

# Load and process audio
audio = AudioSegment.from_wav(input_audio)

# Split audio on silence
chunks = split_on_silence(
    audio,
    min_silence_len=min_silence_len,
    silence_thresh=silence_thresh,
    keep_silence=keep_silence
)

# Split transcript into sentences
with open(transcript_file, "r") as f:
    parts = f.read().split("|", 1)
    if len(parts) > 1:
        transcript = parts[1].strip()
    else:
        transcript = parts[0].strip()
    
sentences = sent_tokenize(transcript)

# Verify alignment
if len(chunks) != len(sentences):
    print(f"Warning: {len(chunks)} audio chunks found but {len(sentences)} sentences in transcript")

# Save segments and create metadata
metadata = []
for i, (chunk, sentence) in enumerate(zip(chunks, sentences)):
    filename = f"segment_{i+1:03d}.wav"
    chunk.export(os.path.join(output_folder, filename), format="wav")
    metadata.append(f"{filename}|{sentence}")

# Save metadata
with open(os.path.join(output_folder, metadata_file), "w") as f:
    f.write("audio_path|text\n")
    f.write("\n".join(metadata))

print(f"Successfully created {len(metadata)} segments in '{output_folder}'")
