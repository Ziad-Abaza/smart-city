def handle_system_info(params: Dict[str, Any]) -> Dict[str, Any]:
    metric = params.get("metric", "all")
    data = {}
    
    try:
        if metric in ["os", "all"]:
            data["os"] = f"{platform.system()} {platform.release()}"
            data["hostname"] = platform.node()
            
        if metric in ["cpu", "all"]:
            data["cpu_percent"] = psutil.cpu_percent(interval=0.1)
            
        if metric in ["ram", "all"]:
            mem = psutil.virtual_memory()
            data["ram_used_gb"] = round(mem.used / (1024**3), 2)
            data["ram_total_gb"] = round(mem.total / (1024**3), 2)
            
        if metric in ["disk", "all"]:
            try:
                disk = psutil.disk_usage('/')
                data["disk_used_gb"] = round(disk.used / (1024**3), 2)
                data["disk_total_gb"] = round(disk.total / (1024**3), 2)
            except Exception:
                data["disk_used_gb"] = None
                data["disk_total_gb"] = None
                
        if metric in ["uptime", "all"]:
            boot_time = psutil.boot_time()
            data["uptime_seconds"] = int(time.time() - boot_time)
            
    except Exception as e:
        return {"status": "error", "message": f"Could not retrieve system info: {str(e)}"}
        
