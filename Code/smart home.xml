        # Common errors and system messages
        "Sorry, something went wrong. Please try again.",
        "Sorry, I had trouble processing that. Please try again.",
        "Access denied. Service is offline. Please start the server first.",
        "Service unavailable. Please try again.",
        "Goodbye!",
        "Please look at the camera for face recognition.",
    })
    fixed_phrases = [p for p in fixed_phrases if p and len(p.strip()) > 2]
    recognizer.tts.warm_cache(fixed_phrases)

    print("\n\U0001f916 Voice Assistant is running.")
    print(f"   Wake words : {', '.join(WAKE_WORDS)}")
    print(f"   Say a wake word followed by your command.")
    print(f"   Say 'exit' or 'stop' to quit.")
    print(f"   UI         : http://localhost:{HTTP_PORT}/ui/\n")

    while True:
        UIBridge.set_state("dormant")
        print("\U0001f7e2 Voice Assistant ready. Awaiting next command...")
        user_input = recognizer.listen_for_wake_and_command().strip()

        if not user_input:
            # Nothing heard or no wake word — just loop back silently
            continue

        if user_input.lower() in ["exit", "stop"]:
            print("\U0001f44b Exiting voice assistant...")
            recognizer.tts.speak("Goodbye!")
            if recognizer.wake_detector is not None:
                recognizer.wake_detector.cleanup()
            recognizer.tts.close()
            break

        try:
            response_buffer = ""
            def _stream_cb(word, is_final=False):
                nonlocal response_buffer
                response_buffer += word
                UIBridge.set_response(response_buffer)
