// Renders the warning alarm overlay (covers display instantly on state shift)
void displayAlert(const char* message, uint16_t color) {
  tft.fillScreen(color);
  tft.setTextSize(2);
  tft.setTextColor(ST77XX_BLACK);
  
  // Centered Alert Screen Layout
  tft.setCursor(26, 30);
  tft.print("EMERGENCY");
  
  int len = strlen(message);
  int x = (160 - (len * 12)) / 2;
  if (x < 0) x = 0;
  tft.setCursor(x, 60);
  tft.print(message);
  
  tft.setTextSize(1);
  tft.setCursor(20, 100);
  tft.print("EVACUATE IMMEDIATELY");
}

void setToast(const char* message, unsigned long durationMs) {
  currentToast = message;
  toastExpireTime = millis() + durationMs;
  lastDisplayUpdateTime = 0; // Trigger immediate UI refresh to draw the toast header
}

// Drives room motion evaluation with EMI software debounce
void motion_detector(
  int pirPin, int relayPin, 
  unsigned long &motionLastSeen, int &motionState, 
  unsigned long &lastDebounceTime, int &lastRawState,
  bool manualControl, bool &lightState
) {
  if (manualControl) return;  

  int currentRawState = digitalRead(pirPin);

  // If the raw state changed (due to noise, bounce, or actual motion), reset the debounce timer
  if (currentRawState != lastRawState) {
    lastDebounceTime = millis();
    lastRawState = currentRawState;
  }

  // Check if the raw state has been stable longer than our 200ms threshold
  if ((millis() - lastDebounceTime) >= 200) {
    // The state is stable. If it differs from our logical motionState, validate the transition.
    if (currentRawState != motionState) {
      motionState = currentRawState;
      
      // Telemetry: Log only on validated, debounced state transitions
      if (motionState == HIGH) {
        Serial.print("LOG:PIR_PIN_");
        Serial.print(pirPin);
        Serial.println(":HIGH");
      } else {
        Serial.print("LOG:PIR_PIN_");
        Serial.print(pirPin);
        Serial.println(":LOW");
      }
    }
  }

  // Execute asynchronous hold logic based on the validated motionState
  if (motionState == HIGH) {
    // Constantly refresh the 5-second hold timer while motion is actively HIGH
    motionLastSeen = millis();
    
    if (!lightState) {
      Serial.print("LOG:RELAY_PIN_");
      Serial.print(relayPin);
      Serial.println(":ON");
      digitalWrite(relayPin, RELAY_ON);
      lightState = true;
    }
  } else {
    // If validated motion is LOW, check if 5000ms have passed since the last seen motion
    if (motionLastSeen != 0 && (millis() - motionLastSeen <= 5000)) {
      if (!lightState) {
        Serial.print("LOG:RELAY_PIN_");
        Serial.print(relayPin);
        Serial.println(":ON");
        digitalWrite(relayPin, RELAY_ON);
        lightState = true;
      }
    } else {
      // 5 seconds have officially elapsed, safe to turn off
      if (lightState) {
        Serial.print("LOG:RELAY_PIN_");
        Serial.print(relayPin);
        Serial.println(":OFF");
        digitalWrite(relayPin, RELAY_OFF);
        lightState = false;
        motionLastSeen = 0; // Prevent edge-case overflow triggering
      }
    }
  }
}

// Sets manual test alarm sequence (5000ms warning state)
void warning() {
  manualWarningExpireTime = millis() + ALARM_DURATION;
  allLight(RELAY_OFF);
}

void allLight(bool state) {
  digitalWrite(LIGHT_ROOM_A, state);
  digitalWrite(LIGHT_ROOM_B, state);
  digitalWrite(LIGHT_ROOM_C, state);
}

void controlLight(String room, bool state) {
  if (room == "A") digitalWrite(LIGHT_ROOM_A, state);
  else if (room == "B") digitalWrite(LIGHT_ROOM_B, state);
  else if (room == "C") digitalWrite(LIGHT_ROOM_C, state);
  else if (room == "ALL") allLight(state);
}

void controlFan(bool state) {
  digitalWrite(FAN_PIN, state);
}

void controlServo(int targetAngle) {
  targetServoAngle = constrain(targetAngle, 0, 180);
}

void openWindow() {
  targetServoAngle = 70;
}

void closeWindow() {
  targetServoAngle = 0;
}

// Process serial commands and assign feedback toast messages
void processCommand(String command) {
  if (command == "LIGHT_A_ON") {
    digitalWrite(LIGHT_ROOM_A, RELAY_ON);
    manualControlA = true;
    lightStateA = true;
    setToast("LIGHT A: ON");
  } else if (command == "LIGHT_A_OFF") {
    digitalWrite(LIGHT_ROOM_A, RELAY_OFF);
    manualControlA = true;
    lightStateA = false;
    setToast("LIGHT A: OFF");
  } else if (command == "LIGHT_B_ON") {
    digitalWrite(LIGHT_ROOM_B, RELAY_ON);
    manualControlB = true;
    lightStateB = true;
    setToast("LIGHT B: ON");
  } else if (command == "LIGHT_B_OFF") {
    digitalWrite(LIGHT_ROOM_B, RELAY_OFF);
    manualControlB = true;
    lightStateB = false;
    setToast("LIGHT B: OFF");
  } else if (command == "LIGHT_C_ON") {
    digitalWrite(LIGHT_ROOM_C, RELAY_ON);
    manualControlC = true;
    lightStateC = true;
    setToast("LIGHT C: ON");
  } else if (command == "LIGHT_C_OFF") {
    digitalWrite(LIGHT_ROOM_C, RELAY_OFF);
    manualControlC = true;
    lightStateC = false;
    setToast("LIGHT C: OFF");
  } else if (command == "LIGHTS_ON") {
    allLight(RELAY_ON);
    manualControlA = manualControlB = manualControlC = true;
    lightStateA = lightStateB = lightStateC = true;
    setToast("ALL LIGHTS: ON");
  } else if (command == "LIGHTS_OFF") {
    allLight(RELAY_OFF);
    manualControlA = manualControlB = manualControlC = true;
    lightStateA = lightStateB = lightStateC = false;
    setToast("ALL LIGHTS: OFF");
  } else if (command == "FAN_ON") {
    digitalWrite(FAN_PIN, RELAY_ON);
    setToast("FAN: ON");
  } else if (command == "FAN_OFF") {
    digitalWrite(FAN_PIN, RELAY_OFF);
    setToast("FAN: OFF");
  } else if (command == "AUTO_A") {
    manualControlA = false; 
    setToast("LIGHT A: AUTO");
  } else if (command == "AUTO_B") {
    manualControlB = false;
    setToast("LIGHT B: AUTO");
  } else if (command == "AUTO_C") {
    manualControlC = false;
    setToast("LIGHT C: AUTO");
  } else if (command == "WINDOW_OPEN") {
    openWindow();
    setToast("WINDOW: OPENING");
  } else if (command == "WINDOW_CLOSE") {
    closeWindow();
    setToast("WINDOW: CLOSING");
  } else if (command == "READ_TEMP") {
    if (!isnan(currentTemperature)) {
      Serial.println("Temperature: " + String(currentTemperature) + " C");
    } else {
      Serial.println("Error reading temperature");
    }
  } else if (command == "READ_HUM") {
    if (!isnan(currentHumidity)) {
      Serial.println("Humidity: " + String(currentHumidity) + " %");
    } else {
      Serial.println("Error reading humidity");
    }
  } else if (command == "WARNING") {
    warning();
    setToast("MANUAL ALERT!");
  } else {
    Serial.println("Unknown command: " + command);
    setToast("UNKNOWN CMD!");
  }
}
