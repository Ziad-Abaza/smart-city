import cv2
import time
import threading
import base64
from core.config_manager import config_manager

class CameraManager:
    _instance = None
    _lock = threading.Lock()

    def __new__(cls):
        with cls._lock:
            if cls._instance is None:
                cls._instance = super(CameraManager, cls).__new__(cls)
                cls._instance._init()
            return cls._instance

    def _init(self):
        self.camera = None
        self.camera_active = False
        self.camera_lock = threading.Lock()
        
        self.frame_data = {"frame": None, "timestamp": 0}
        self.frame_lock = threading.Lock()
        
        self.stop_capture = threading.Event()
        
        # Load config logic exactly like face_recognition/app.py
        video_url = config_manager.get("face_recognition_server", {}).get("video_feed_url", 0)
        try:
            if isinstance(video_url, str) and video_url.isdigit():
                video_url = int(video_url)
        except Exception:
            pass
        self.video_url = video_url
        self.capture_fps = 10

    def start_camera(self):
        """Activates the camera in a background thread if not already running."""
        with self.camera_lock:
            if self.camera_active:
                return True
                
            print("👁️ Activating centralized vision system...")
            
            # Try to open the configured camera
            cap = cv2.VideoCapture(self.video_url)
            if not cap.isOpened():
                print(f"❌ Failed to access configured video feed at {self.video_url}")
                return False
                    
            print(f"✅ Camera opened successfully on feed: {self.video_url}")
            
            # Warm up and stabilize the camera by throwing away first unstable frames
            # This solves Issue 1 where the first request fails due to unready frames
            warmup_frames = 5
            valid_frames_read = 0
            
            start_wait = time.time()
            # Wait up to 5 seconds to get warmup_frames
            while valid_frames_read < warmup_frames and time.time() - start_wait < 5.0:
                ret, frame = cap.read()
                if ret and frame is not None:
                    valid_frames_read += 1
                else:
                    time.sleep(0.05)
                    
            if valid_frames_read == 0:
                print("❌ Camera opened but failed to capture any valid frames during warmup.")
                cap.release()
                return False
                
            self.camera = cap
            self.camera_active = True
            self.stop_capture.clear()
            
            # Reset frame data
            with self.frame_lock:
                self.frame_data["frame"] = None
                self.frame_data["timestamp"] = 0
                
            threading.Thread(target=self._capture_frames, daemon=True, name="central_vision_capture").start()
            
        # Wait until background thread populates at least one frame (MUST be outside camera_lock)
        wait_start = time.time()
        while time.time() - wait_start < 3.0:
            with self.frame_lock:
                if self.frame_data["frame"] is not None:
                    return True
            time.sleep(0.05)
            
        print("⚠️ Background thread failed to capture frames in time.")
        return False

    def stop_camera(self):
        """Deactivates the camera and releases resources."""
        with self.camera_lock:
            if not self.camera_active:
                return
            print("👁️ Deactivating centralized vision system...")
            self.camera_active = False
            self.stop_capture.set()
            if self.camera is not None:
                self.camera.release()
                self.camera = None
                
        with self.frame_lock:
            self.frame_data["frame"] = None
            self.frame_data["timestamp"] = 0

    def _capture_frames(self):
        """Background thread that continuously reads frames and caches the latest one."""
        while not self.stop_capture.is_set():
            with self.camera_lock:
                cam = self.camera
                
            if cam is None or not cam.isOpened():
                time.sleep(0.1)
                continue
                
            success, frame = cam.read()
            if not success or frame is None:
                time.sleep(0.05)
                continue
                
            with self.frame_lock:
                self.frame_data["frame"] = frame.copy()
                self.frame_data["timestamp"] = time.time()
                
            # Limit background capture rate to reduce CPU
            time.sleep(1.0 / self.capture_fps)

    def get_latest_frame(self):
        """Return the latest frame as a BGR numpy array."""
        with self.frame_lock:
            if self.frame_data["frame"] is not None:
                return self.frame_data["frame"].copy()
        return None

    def get_latest_frame_b64(self, downscale=True):
        """Return the latest frame encoded as a base64 JPEG string."""
        frame = self.get_latest_frame()
        if frame is None:
            return None
            
        if downscale:
            # Resize for LLM to reduce payload and latency (e.g. 320x240)
            h, w = frame.shape[:2]
            target_w = 320
            target_h = int((target_w / w) * h)
            frame = cv2.resize(frame, (target_w, target_h), interpolation=cv2.INTER_AREA)
            
        success, buffer = cv2.imencode('.jpg', frame, [cv2.IMWRITE_JPEG_QUALITY, 75])
        if not success:
            return None
            
        return base64.b64encode(buffer).decode('utf-8')

