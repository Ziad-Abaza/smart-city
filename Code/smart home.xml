import os
import json
import uuid
import time
from datetime import datetime
from typing import Dict, Any, List, Optional

# Base directory for memory store
MEMORY_ROOT = "memory_store"

CATEGORIES = {
    "user_identity": "profile",
    "personal_information": "profile",
    "preference": "preferences",
    "smart_home_preference": "preferences",
    "appointment_event": "events",
    "task": "tasks",
    "long_term_fact": "facts",
}

# Subdirectories
DIRS = list(set(CATEGORIES.values())) + ["archive", "index", "runtime", "runtime/temp", "runtime/cache", "runtime/task_state"]

def init_store():
    for d in DIRS:
        os.makedirs(os.path.join(MEMORY_ROOT, d), exist_ok=True)

def _get_path(category: str, item_id: str) -> str:
    folder = CATEGORIES.get(category)
    if not folder:
        raise ValueError(f"Unknown category {category}")
    return os.path.join(MEMORY_ROOT, folder, f"{item_id}.json")

def _get_archive_path(item_id: str, version: int) -> str:
    return os.path.join(MEMORY_ROOT, "archive", f"{item_id}_v{version}.json")

def create_item(
    content: str,
    category: str,
    source: str = "explicit_statement",
    confidence: float = 1.0,
    importance: str = "medium",
    lifetime: str = "permanent",
    tags: List[str] = None,
    expiration_date: Optional[str] = None,
    confirmation_status: str = "confirmed",
    sensitivity_level: str = "standard"
) -> Dict[str, Any]:
    
    if tags is None:
        tags = []
        
    if category == "personal_information":
        sensitivity_level = "sensitive"
        
    now_iso = datetime.utcnow().isoformat() + "Z"
    
    item = {
        "id": str(uuid.uuid4()),
        "content": content,
        "creation_time": now_iso,
        "last_updated": now_iso,
        "source": source,
        "confidence": confidence,
        "importance": importance,
        "lifetime": lifetime,
        "category": category,
        "tags": tags,
        "access_frequency": 0,
        "expiration_date": expiration_date,
        "version": 1,
        "schema_version": 1,
        "confirmation_status": confirmation_status,
        "sensitivity_level": sensitivity_level
    }
    
    path = _get_path(category, item["id"])
    with open(path, "w", encoding="utf-8") as f:
        json.dump(item, f, indent=4)
        
    return item

def get_item(category: str, item_id: str) -> Optional[Dict[str, Any]]:
    path = _get_path(category, item_id)
    if os.path.exists(path):
        with open(path, "r", encoding="utf-8") as f:
            item = json.load(f)
            
        # Phase 8: Audit Logging for sensitive items
        if item.get("sensitivity_level") == "sensitive" or category == "personal_information":
            audit_path = os.path.join(MEMORY_ROOT, "audit.log")
            now_iso = datetime.utcnow().isoformat() + "Z"
            with open(audit_path, "a", encoding="utf-8") as audit_f:
                audit_f.write(f"[{now_iso}] ACCESS: Sensitive memory '{item_id}' (Category: {category}) was read.\n")
                
        return item
    return None

def update_item(category: str, item_id: str, updates: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    item = get_item(category, item_id)
    if not item:
        return None
        
    # Archive current version
    arch_path = _get_archive_path(item_id, item["version"])
    with open(arch_path, "w", encoding="utf-8") as f:
        json.dump(item, f, indent=4)
        
    # Apply updates
    item.update(updates)
    item["version"] += 1
    item["last_updated"] = datetime.utcnow().isoformat() + "Z"
    
    path = _get_path(category, item_id)
    with open(path, "w", encoding="utf-8") as f:
        json.dump(item, f, indent=4)
        
    return item

def record_access(category: str, item_id: str):
    item = get_item(category, item_id)
    if item:
        item["access_frequency"] += 1
        path = _get_path(category, item_id)
        with open(path, "w", encoding="utf-8") as f:
            json.dump(item, f, indent=4)

def delete_item(category: str, item_id: str, purge_sensitive_archive: bool = True):
    path = _get_path(category, item_id)
    if os.path.exists(path):
        with open(path, "r", encoding="utf-8") as f:
            item = json.load(f)
            
        os.remove(path)
        
        # Tombstone it
        tomb_path = os.path.join(MEMORY_ROOT, "archive", f"{item_id}_tombstone.json")
        with open(tomb_path, "w", encoding="utf-8") as f:
            json.dump({"id": item_id, "deleted_at": datetime.utcnow().isoformat() + "Z"}, f)
            
        # Purge sensitive history if requested
        if purge_sensitive_archive and item.get("sensitivity_level") == "sensitive":
            for i in range(1, item["version"] + 1):
                arch_path = _get_archive_path(item_id, i)
                if os.path.exists(arch_path):
                    os.remove(arch_path)
                    
        return True
    return False

def list_items(category: str) -> List[Dict[str, Any]]:
    folder = CATEGORIES.get(category)
    if not folder:
        return []
        
    dir_path = os.path.join(MEMORY_ROOT, folder)
    items = []
    if os.path.exists(dir_path):
        for fname in os.listdir(dir_path):
            if fname.endswith(".json"):
                with open(os.path.join(dir_path, fname), "r", encoding="utf-8") as f:
                    try:
                        item = json.load(f)
                        if item.get("category") == category:
                            items.append(item)
                    except json.JSONDecodeError:
                        pass
    return items

# Initialize store on import
init_store()

def get_user_identity_context() -> str:
    items = list_items("user_identity")
    if not items:
        return ""
    facts = [item["content"] for item in items]
    return "\nUser Identity:\n- " + "\n- ".join(facts) + "\n"


# ----------------------------------------------------
# Phase 6: Temporary Memory Architecture
# ----------------------------------------------------

def _is_expired(expires_at: Optional[str]) -> bool:
    if not expires_at:
        return False
    try:
        exp = datetime.fromisoformat(expires_at.replace("Z", "+00:00"))
        # Using simple utcnow for comparison assuming UTC is used
        now = datetime.utcnow()
        now = now.replace(tzinfo=exp.tzinfo) if exp.tzinfo else now
        return now > exp
    except ValueError:
        return True

def create_temp_item(content: str, expires_at: str, context: Dict[str, Any] = None) -> Dict[str, Any]:
    if context is None:
        context = {}
        
    item = {
        "id": str(uuid.uuid4()),
        "content": content,
        "created_at": datetime.utcnow().isoformat() + "Z",
        "expires_at": expires_at,
        "context": context,
        "lifetime": "ttl_bounded"
    }
    
    path = os.path.join(MEMORY_ROOT, "runtime", "temp", f"{item['id']}.json")
    with open(path, "w", encoding="utf-8") as f:
        json.dump(item, f, indent=4)
        
    return item

def get_temp_item(item_id: str) -> Optional[Dict[str, Any]]:
    path = os.path.join(MEMORY_ROOT, "runtime", "temp", f"{item_id}.json")
    if os.path.exists(path):
        with open(path, "r", encoding="utf-8") as f:
            item = json.load(f)
            if _is_expired(item.get("expires_at")):
                return None
            return item
    return None

def list_temp_items() -> List[Dict[str, Any]]:
    dir_path = os.path.join(MEMORY_ROOT, "runtime", "temp")
    items = []
    if os.path.exists(dir_path):
        for fname in os.listdir(dir_path):
            if fname.endswith(".json"):
                with open(os.path.join(dir_path, fname), "r", encoding="utf-8") as f:
                    try:
                        item = json.load(f)
                        if not _is_expired(item.get("expires_at")):
                            items.append(item)
                    except json.JSONDecodeError:
                        pass
    return items
