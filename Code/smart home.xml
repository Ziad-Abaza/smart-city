import os
import json
import time
import glob
from datetime import datetime
from voice_assistant.memory_store import MEMORY_ROOT, _is_expired, get_item, CATEGORIES
from voice_assistant.memory_retriever import memory_retriever

def cleanup_temp_memory():
    temp_dir = os.path.join(MEMORY_ROOT, "runtime", "temp")
    if not os.path.exists(temp_dir):
        return
        
    deleted = 0
    for fname in os.listdir(temp_dir):
        if fname.endswith(".json"):
            path = os.path.join(temp_dir, fname)
            try:
                with open(path, "r", encoding="utf-8") as f:
                    item = json.load(f)
                if _is_expired(item.get("expires_at")):
                    os.remove(path)
                    deleted += 1
            except Exception as e:
                print(f"⚠️ Error cleaning up {fname}: {e}")
                
    if deleted > 0:
        print(f"🧹 Maintenance: Cleaned up {deleted} expired temporary memories.")

def prune_archive():
    archive_dir = os.path.join(MEMORY_ROOT, "archive")
    if not os.path.exists(archive_dir):
        return
        
    # Find all versioned files: {item_id}_v{version}.json
    # We want to prune history exceeding 10 revisions.
    # Group by item_id
    versions = {}
    for fname in os.listdir(archive_dir):
        if fname.endswith(".json") and "_v" in fname:
            parts = fname.replace(".json", "").split("_v")
            if len(parts) == 2:
                item_id, ver = parts[0], parts[1]
                try:
                    ver = int(ver)
                    if item_id not in versions:
                        versions[item_id] = []
                    versions[item_id].append((ver, fname))
                except ValueError:
                    pass
                    
    pruned = 0
    for item_id, vers in versions.items():
        if len(vers) > 10:
            # Sort by version ascending
            vers.sort(key=lambda x: x[0])
            # Remove all but the last 10
            for ver, fname in vers[:-10]:
                try:
                    os.remove(os.path.join(archive_dir, fname))
                    pruned += 1
                except Exception:
                    pass
                    
    if pruned > 0:
        print(f"🧹 Maintenance: Pruned {pruned} old archive versions.")

def rebuild_index():
    # Rebuild index from valid permanent items
    # We don't want to embed everything again, so we'll just check existing items in memory_retriever
    # and remove any that are no longer on disk.
    valid_ids = set()
    
    # Collect all valid IDs from storage
    for cat, folder in CATEGORIES.items():
        dir_path = os.path.join(MEMORY_ROOT, folder)
        if os.path.exists(dir_path):
            for fname in os.listdir(dir_path):
                if fname.endswith(".json"):
                    item_id = fname.replace(".json", "")
                    valid_ids.add(item_id)
                    
    # Remove from retriever items that aren't in valid_ids
    # But since memory_retriever is global and stateful, we should do it through its API
    ids_in_index = [item["id"] for item in memory_retriever.items]
    removed = 0
    
    for idx_id in ids_in_index:
        if idx_id not in valid_ids:
            memory_retriever.remove_item(idx_id)
            removed += 1
            
    if removed > 0:
        print(f"🧹 Maintenance: Removed {removed} tombstoned items from semantic index.")

def run_maintenance():
    print("🧹 Running Background Memory Maintenance...")
    cleanup_temp_memory()
    prune_archive()
    rebuild_index()
    print("🧹 Maintenance complete.")
