import unittest
from unittest.mock import MagicMock, patch, mock_open
import numpy as np
import pyaudio
import os

from voice_assistant.wakeword.base import BaseWakeWordEngine
from voice_assistant.wakeword.models import resolve_model_path, BUILTIN_MODELS
from voice_assistant.wakeword.openwakeword_engine import OpenWakeWordEngine
from voice_assistant.wakeword.detector import WakeWordDetector
from voice_assistant.wakeup import WakeUpDetector

class TestWakeWordModels(unittest.TestCase):
    """Unit tests for the model resolution logic in models.py."""
    
    def test_builtin_model_resolution(self):
        """Verify that standard built-in model names are resolved correctly."""
        for model in BUILTIN_MODELS:
            self.assertEqual(resolve_model_path(model), model)
            
        # Case-insensitive / fuzzy match checks
        self.assertEqual(resolve_model_path("Jarvis"), "hey_jarvis")
        self.assertEqual(resolve_model_path("hey jarvis"), "hey_jarvis")
        self.assertEqual(resolve_model_path("mycroft"), "hey_mycroft")

    @patch('os.path.exists')
    @patch('core.config_manager.config_manager.resolve_path')
    def test_custom_model_resolution(self, mock_resolve, mock_exists):
        """Verify that custom model file paths are resolved if the file exists."""
        mock_resolve.return_value = "/absolute/path/to/custom.onnx"
        mock_exists.return_value = True
        
        resolved = resolve_model_path("custom.onnx")
        self.assertEqual(resolved, "/absolute/path/to/custom.onnx")
        mock_resolve.assert_called_with("custom.onnx")

    @patch('os.path.exists')
    @patch('core.config_manager.config_manager.resolve_path')
    def test_missing_model_resolution_error(self, mock_resolve, mock_exists):
        """Verify that a FileNotFoundError is raised if a custom file path is missing."""
        mock_resolve.return_value = "/absolute/path/to/missing.onnx"
        mock_exists.return_value = False
        
        with self.assertRaises(FileNotFoundError):
            resolve_model_path("missing.onnx")


class TestOpenWakeWordEngine(unittest.TestCase):
    """Unit tests for the OpenWakeWordEngine wrapper."""

    @patch('voice_assistant.wakeword.openwakeword_engine.Model')
    @patch('voice_assistant.wakeword.openwakeword_engine.resolve_model_path')
    def test_engine_initialization(self, mock_resolve, mock_model_cls):
        """Test engine loads successfully with the target model."""
        mock_resolve.return_value = "hey_jarvis"
        mock_model = MagicMock()
        mock_model.models = {"hey_jarvis": {}}
        mock_model_cls.return_value = mock_model
        
        engine = OpenWakeWordEngine(model_name="hey_jarvis")
        
        self.assertEqual(engine.get_model_names(), ["hey_jarvis"])
        self.assertEqual(engine.get_required_sample_rate(), 16000)
        self.assertEqual(engine.get_required_chunk_size(), 1280)
        mock_model_cls.assert_called_once_with(wakeword_models=["hey_jarvis"], inference_framework="onnx")

    @patch('voice_assistant.wakeword.openwakeword_engine.Model')
    @patch('voice_assistant.wakeword.openwakeword_engine.resolve_model_path')
    def test_engine_prediction(self, mock_resolve, mock_model_cls):
        """Test that engine prediction propagates inputs and returns correct format."""
        mock_resolve.return_value = "hey_jarvis"
        mock_model = MagicMock()
        mock_model.models = {"hey_jarvis": {}}
        mock_model.predict.return_value = {"hey_jarvis": 0.85}
        mock_model_cls.return_value = mock_model
        
        engine = OpenWakeWordEngine(model_name="hey_jarvis")
        pcm = np.zeros(1280, dtype=np.int16)
        scores = engine.predict(pcm)
        
        self.assertEqual(scores, {"hey_jarvis": 0.85})
        mock_model.predict.assert_called_once_with(pcm)


class TestWakeWordDetector(unittest.TestCase):
    """Unit and failure handling tests for the WakeWordDetector class."""

    @patch('voice_assistant.wakeword.detector.pyaudio.PyAudio')
    @patch('voice_assistant.wakeword.detector.WakeWordDetector._get_engine_class')
    def test_detector_initialization_success(self, mock_engine_cls, mock_pyaudio):
        """Verify detector initializes engine and audio streams correctly under normal conditions."""
        mock_engine = MagicMock()
        mock_engine.get_required_sample_rate.return_value = 16000
        mock_engine.get_required_chunk_size.return_value = 1280
        mock_engine_cls.return_value = lambda model_name: mock_engine
        
        detector = WakeWordDetector()
        
        self.assertTrue(detector.enabled)
        self.assertIsNotNone(detector.engine)
        self.assertIsNotNone(detector.pa)
