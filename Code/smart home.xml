import numpy as np
from typing import Dict, List

class BaseWakeWordEngine(ABC):
    """Abstract Base Class for Wake Word detection engines to ensure plug-and-play capability."""
    
    @abstractmethod
    def __init__(self, **kwargs) -> None:
