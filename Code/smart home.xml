<file path="ui/js/core/state-machine.js">
/**
 * Assistant state machine — drives UI, blob, and overlay transitions.
 *
 * States: dormant | listening | thinking | speaking
 */
import { bus } from './event-bus.js';
import { smooth } from './easing.js';

export const STATES = Object.freeze({
  DORMANT: 'dormant',
  LISTENING: 'listening',
  THINKING: 'thinking',
  SPEAKING: 'speaking',
});

const STATE_INDEX = {
  [STATES.DORMANT]: 0,
  [STATES.LISTENING]: 1,
  [STATES.THINKING]: 2,
  [STATES.SPEAKING]: 3,
};

const STATUS_LABELS = {
  [STATES.DORMANT]: 'Idle',
  [STATES.LISTENING]: 'Listening...',
  [STATES.THINKING]: 'Thinking...',
  [STATES.SPEAKING]: 'Speaking',
};

export class StateMachine {
  constructor() {
    this.state = STATES.DORMANT;
    this.previousState = STATES.DORMANT;
    this.blend = 0;
    this._targetBlend = 0;
    this.faceActive = false;
    this.user = null;
    this.faceStatus = null;
  }

  get statusLabel() {
    return STATUS_LABELS[this.state] ?? 'Idle';
  }

  /** Backend sync — always applies, even when state is unchanged. */
  syncState(next) {
    if (!Object.values(STATES).includes(next)) return;
    const changed = next !== this.state;
    this.previousState = this.state;
    this.state = next;
    this._targetBlend = STATE_INDEX[next];
    bus.emit('state:change', {
      state: next,
      previous: this.previousState,
      label: this.statusLabel,
      changed,
    });
  }

  setState(next) {
    this.syncState(next);
  }

  setFaceActive(active, meta = {}) {
    this.faceActive = !!active;
    if (meta.user !== undefined) this.user = meta.user;
    if (meta.faceStatus !== undefined) this.faceStatus = meta.faceStatus;
    bus.emit('face:change', {
      active: this.faceActive,
      user: this.user,
      faceStatus: this.faceStatus,
      ...meta,
    });
  }

  tick() {
    this.blend = smooth(this.blend, this._targetBlend, 0.06);
  }

  getBlendWeights() {
    const s = this.blend;
    return {
      dormant: Math.max(0, 1 - s),
      listening: s < 1 ? s : Math.max(0, 2 - s),
      thinking: s >= 1 && s < 2 ? Math.min(1, s - 1) : s >= 2 ? Math.max(0, 3 - s) : 0,
      speaking: s > 2 ? s - 2 : 0,
    };
  }
}

export const stateMachine = new StateMachine();
</file>

