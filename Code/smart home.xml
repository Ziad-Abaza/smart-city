    def warm_cache(self, phrases: list, language: str = "en"):
        """
        Pre-synthesize a list of phrases in the background.
        Called once after startup — assistant remains fully available.
        """
        print(f"\U0001f504 Warming audio cache ({len(phrases)} phrases in background)...")
        self._cache.warm(phrases, self._synthesize_chunk, language)

    @staticmethod
    def _split_sentences(text: str, limit: int):
        """
        Split text into chunks that respect the XTTS character limit.
        Tries to break on sentence boundaries (. ! ?) then on commas,
        falling back to hard word-boundary splits.
        """
        import re
        text = " ".join(text.split())
        if len(text) <= limit:
            return [text]

        chunks = []
        sentences = re.split(r'(?<=[.!?])\s+', text)
        current = ""
        for sent in sentences:
            if len(sent) > limit:
                parts = re.split(r'(?<=,)\s+', sent)
                for part in parts:
                    if len(current) + len(part) + 1 <= limit:
                        current = (current + " " + part).strip()
                    else:
                        if current:
                            chunks.append(current)
                        while len(part) > limit:
                            cut = part.rfind(" ", 0, limit)
                            cut = cut if cut > 0 else limit
                            chunks.append(part[:cut].strip())
                            part = part[cut:].strip()
                        current = part
            elif len(current) + len(sent) + 1 <= limit:
                current = (current + " " + sent).strip()
            else:
                if current:
                    chunks.append(current)
                current = sent
        if current:
            chunks.append(current)
        return [c for c in chunks if c.strip()]

    def _synthesize_chunk(self, text: str, language: str):
        """Synthesise one chunk and return the wav numpy array, or None on error."""
        try:
            with self._synth_lock, torch.inference_mode():
                result = self.model.inference(
                    text,
                    language=language,
                    gpt_cond_latent=self.gpt_cond_latent,
                    speaker_embedding=self.speaker_embedding,
                    temperature=0.65,
                    top_p=0.85,
                    top_k=50,
                    speed=1.0,
                    enable_text_splitting=False,
                )
            return result.get("wav") if isinstance(result, dict) else None
        except Exception as e:
            print(f"\u274c Chunk synthesis error: {e}")
            return None

    def _iter_stream_chunks(self, text: str, language: str):
        """Yield audio chunks from XTTS streaming inference, with non-streaming fallback."""
        if not text or not text.strip() or self.model is None:
            return
        if self._streaming_supported:
            try:
                with self._synth_lock, torch.inference_mode():
                    stream = self.model.inference_stream(
                        text,
                        language,
                        self.gpt_cond_latent,
                        self.speaker_embedding,
                        temperature=0.65,
                        top_p=0.85,
                        top_k=50,
                        speed=1.0,
                        enable_text_splitting=False,
                    )
                    for chunk in stream:
                        yield _AudioPlayer._to_float32(chunk)
                return
            except Exception as e:
                print(f"\u26a0\ufe0f Streaming synthesis failed ({e}), falling back to standard inference.")
                self._streaming_supported = False

        wav = self._synthesize_chunk(text, language)
        if wav is not None:
            yield _AudioPlayer._to_float32(wav)

    def _speak_streaming(self, text: str, language: str = "en", play: bool = True) -> list:
        """Synthesize and play text via inference_stream; return collected chunks."""
        chunks = []
        for chunk in self._iter_stream_chunks(text, language):
            chunks.append(chunk)
            if play:
                self._player.write(chunk)
        return chunks

    def speak(self, text, language="en"):
        """
        Speak text. Cache hit → plays instantly from pre-generated wav.
        Cache miss → full XTTS synthesis (split into sentences).
        Fully synchronous — main loop blocked until all audio done.
        """
        if not text or not text.strip():
            return
        if self.model is None:
            print("\u26a0\ufe0f TTS model not available.")
            return
        UIBridge.set_state("speaking")
        try:
            text = text.strip()

            # --- Cache fast path ---
            cached = self._cache.get(text)
            if cached is not None:
                print(f"\u26a1 Speaking (cached): {text[:60]}{'...' if len(text)>60 else ''}")
                self._player.play(cached)
                print("\u2705 Speech complete!")
                return

            # --- Smart threaded streaming synthesis path ---
            import queue
            chunks = self._split_sentences(text, self._XTTS_CHAR_LIMIT)
            all_wav = []
            
            if len(chunks) == 1:
                # Fast path for a single chunk - Stream audio immediately!
                print(f"🔊 Synthesizing and Playing: {chunks[0][:60]}{'...' if len(chunks[0])>60 else ''}")
                stream_chunks = self._speak_streaming(chunks[0], language, play=True)
                if stream_chunks:
                    wav = np.concatenate(stream_chunks) if len(stream_chunks) > 1 else stream_chunks[0]
                    self._cache.put(text, wav)
                    write(self.output_wav, self.SAMPLE_RATE, wav)
            else:
                audio_queue = queue.Queue()
                
                def producer():
                    for i, chunk in enumerate(chunks):
                        print(f"🔊 Synthesizing ({i+1}/{len(chunks)}): {chunk[:60]}{'...' if len(chunk)>60 else ''}")
                        stream_chunks = self._speak_streaming(chunk, language, play=False)
                        if stream_chunks:
                            wav = np.concatenate(stream_chunks) if len(stream_chunks) > 1 else stream_chunks[0]
                            audio_queue.put(wav)
                    audio_queue.put(None)  # Sentinel to indicate completion
                
                # Start synthesis in the background
                t = threading.Thread(target=producer, daemon=True)
                t.start()
                
                # Play audio chunks as soon as they are ready
                print("🔊 Playing seamlessly while synthesizing in background...")
                while True:
                    wav = audio_queue.get()
                    if wav is None:
                        break
                    self._player.play(wav)
                    all_wav.append(wav)
                
                if all_wav:
                    full = np.concatenate(all_wav)
                    write(self.output_wav, self.SAMPLE_RATE, full)
                    
            print("✅ Speech complete!")
        except Exception as e:
            print(f"\u274c Speech synthesis error: {e}")

    def play_audio_file(self, file_path):
        UIBridge.set_state("speaking")
        try:
            sample_rate, audio_data = read(file_path)
            if audio_data.dtype != np.float32:
                if np.issubdtype(audio_data.dtype, np.integer):
                    audio_data = audio_data.astype(np.float32) / np.iinfo(audio_data.dtype).max
                else:
                    audio_data = audio_data.astype(np.float32)
            self._player.play(audio_data)
            print("\u2705 Audio played successfully!")
        except Exception as e:
            print(f"\u274c Error playing audio: {e}")



