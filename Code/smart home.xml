"""Quick bridge diagnostics — run while clone_main.py or ui/server.py is up."""
from __future__ import annotations

import asyncio
import json
import os
import sys
import urllib.request

ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if ROOT not in sys.path:
    sys.path.insert(0, ROOT)

WS_URL = "ws://127.0.0.1:8765"
HEALTH_URL = "http://127.0.0.1:8766/ui/api/health"


def check_health() -> dict:
    
    try:
        with urllib.request.urlopen(HEALTH_URL, timeout=3) as resp:
            return json.loads(resp.read().decode())
    except Exception as exc:
        return {"error": str(exc)}


async def listen_ws(seconds: float = 8.0):
    try:
        import websockets
    except ImportError:
        print("pip install websockets")
        return

    print(f"Connecting to {WS_URL} for {seconds}s...")
    try:
        async with websockets.connect(WS_URL) as ws:
            print("WebSocket connected.")
            await ws.send(json.dumps({"type": "ping"}))
            end = asyncio.get_event_loop().time() + seconds
            while asyncio.get_event_loop().time() < end:
                try:
                    raw = await asyncio.wait_for(ws.recv(), timeout=1.0)
                    msg = json.loads(raw)
                    print("  <-", json.dumps(msg, ensure_ascii=False)[:200])
                except asyncio.TimeoutError:
                    pass
    except Exception as exc:
        print(f"WebSocket error: {exc}")


def pulse():
    from ui.server import UIBridge, ensure_bridge

    if not ensure_bridge(timeout=5):
        print("Bridge not available")
        sys.exit(1)
    print("Sending debug pulse...")
    UIBridge.debug_pulse()
    print("Done — check the UI blob/status.")


if __name__ == "__main__":
    cmd = sys.argv[1] if len(sys.argv) > 1 else "check"
    if cmd == "pulse":
        pulse()
    elif cmd == "listen":
        health = check_health()
        print("Health:", json.dumps(health, indent=2))
        asyncio.run(listen_ws())
    else:
        health = check_health()
        print(json.dumps(health, indent=2))
        if health.get("bridge_ready") and not health.get("bridge_error"):
            print("\nBridge OK. Run: python ui/test_bridge.py pulse")
        else:
            print("\nBridge NOT ready. Start: python clone_main.py")
