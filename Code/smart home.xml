/**
 * Application entry — production UI wired to clone_main.py bridge
 */
import { stateMachine, STATES } from './core/state-machine.js';
import { audioAnalyzer } from './audio/audio-analyzer.js';
import { LiquidBlob } from './blob/liquid-blob.js';
import { BackgroundLayer } from './components/background.js';
import { StatusDisplay } from './components/status-display.js';
import { CameraOverlay } from './components/camera-overlay.js';
import { bridge } from './bridge/assistant-bridge.js';
import { DebugPanel } from './components/debug-panel.js';

class App {
  constructor() {
    this.appEl = document.querySelector('.app');
    this.bgCanvas = document.getElementById('bgCanvas');
    this.blobCanvas = document.getElementById('blobCanvas');

    this.background = new BackgroundLayer(this.bgCanvas);
    this.blob = new LiquidBlob(this.blobCanvas, { stateMachine, audioAnalyzer });
    this.status = new StatusDisplay(document.querySelector('.status-display'), bridge);
    this.camera = new CameraOverlay(document.querySelector('.camera-overlay'));

    bridge.exposeAPI();
    bridge.connect();
    this.debug = new DebugPanel();

    this._startRenderLoop();
    this.blob.start();

    this.appEl.dataset.state = STATES.DORMANT;
    this.appEl.dataset.bridge = 'connecting';
  }

  _startRenderLoop() {
    let last = 0;
    const loop = (now) => {
      const t = now * 0.001;
      const intensity = stateMachine.blend / 3;
      if (now - last > 32) {
        this.background.render(t, intensity);
        last = now;
      }
      requestAnimationFrame(loop);
    };
    requestAnimationFrame(loop);
  }
}

document.addEventListener('DOMContentLoaded', () => new App());
