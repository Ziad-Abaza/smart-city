.camera-overlay {
  position: fixed;
  right: clamp(1.5rem, 5vw, 4rem);
  top: 50%;
  transform: translate(120%, -50%);
  width: var(--camera-panel-width);
  opacity: 0;
  pointer-events: none;
  transition:
    transform var(--duration-slow) var(--ease-out-soft),
    opacity var(--duration-normal) var(--ease-fluid);
  z-index: 8;
}

.camera-overlay.is-active {
  transform: translate(0, -50%);
  opacity: 1;
  pointer-events: auto;
}

.camera-panel {
  position: relative;
  border-radius: 24px;
  overflow: hidden;
  background: var(--color-glass-bg);
  backdrop-filter: blur(var(--blur-glass));
  border: 1px solid var(--color-glass-border);
  box-shadow: var(--shadow-panel);
}

.camera-panel::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 1px;
  background: linear-gradient(
    135deg,
    rgba(120, 210, 255, 0.25) 0%,
    rgba(80, 180, 255, 0.05) 50%,
    rgba(120, 210, 255, 0.15) 100%
  );
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  z-index: 2;
}

.camera-feed-wrap {
  position: relative;
  aspect-ratio: 4 / 3;
  background: #050a10;
  overflow: hidden;
}

.camera-feed {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform: scaleX(-1);
}

.camera-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.camera-meta {
  padding: 1.1rem 1.25rem 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
}

.camera-status {
  font-size: var(--font-size-status);
  font-weight: var(--font-weight-thin);
  letter-spacing: 0.08em;
  color: var(--color-text-primary);
  transition: color var(--duration-fast) var(--ease-fluid);
}

.camera-status[data-status="verified"] { color: var(--color-success); }
.camera-status[data-status="recognizing"],
.camera-status[data-status="scanning"],
.camera-status[data-status="liveness"] { color: var(--color-cyan); }
.camera-status[data-status="unknown"] { color: var(--color-warning); }
.camera-status[data-status="error"] { color: var(--color-error); }

.camera-user {
  font-size: clamp(0.85rem, 1.4vw, 1rem);
  font-weight: var(--font-weight-light);
  color: var(--color-text-secondary);
  letter-spacing: 0.06em;
}

.camera-confidence {
  font-size: var(--font-size-label);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}

.camera-confidence-bar {
  height: 2px;
  margin-top: 0.35rem;
  background: rgba(80, 180, 255, 0.12);
  border-radius: 2px;
  overflow: hidden;
}

.camera-confidence-fill {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, var(--color-cyan), var(--color-ice));
  border-radius: 2px;
  transition: width var(--duration-normal) var(--ease-fluid);
  box-shadow: 0 0 12px rgba(80, 200, 255, 0.4);
}

@media (max-width: 900px) {
  .camera-overlay {
    right: 50%;
    top: auto;
    bottom: clamp(1rem, 4vh, 2rem);
    transform: translate(50%, 120%);
    width: min(92vw, 380px);
  }

  .camera-overlay.is-active {
    transform: translate(50%, 0);
  }
}
