import os
import sys
from pathlib import Path
import torch
from transformers import SpeechT5Processor, SpeechT5ForTextToSpeech
from speechbrain.inference.speaker import EncoderClassifier
import torchaudio

# Add project root to sys.path
root_path = Path(__file__).resolve().parent.parent
if str(root_path) not in sys.path:
    sys.path.insert(0, str(root_path))

from core.config_manager import config_manager

# Configuration
device = "cuda" if torch.cuda.is_available() else "cpu"
audio_path = config_manager.resolve_path("data/rawan_voice.wav")
transcript = "Hello, my name is Rawan Magdy and I'm currently a third year information technology student.  I'm passionate about technology and continually seeking opportunities to learn and grow in  this field.  I have participated in various volunteer activities, such as the OBD and Haya Karima, where I had  the chance to contribute to meaningful community projects.  In addition, I have hands-on experience working in the field of UI UX design and I have also  gained skills in marketing.  At the moment, I'm working as a freelancer, combining my passion for design and technology  to deliver innovative solutions.  I believe that participating in this forum will allow me to expand my knowledge with  like-minded individuals and further my professional journey.  I'm excited about the opportunity and I hope to contribute positively.  That's it and thank you so much for your time."

if not os.path.exists(audio_path):
    print(f"Error: Audio file not found at {audio_path}")
    sys.exit(1)

# Initialize models with proper input dimensions
processor = SpeechT5Processor.from_pretrained("microsoft/speecht5_tts")
model = SpeechT5ForTextToSpeech.from_pretrained("microsoft/speecht5_tts").to(device)
classifier = EncoderClassifier.from_hparams(
    source="speechbrain/spkrec-ecapa-voxceleb",
    run_opts={"device": device}
)

def train_aligned_chunks():
    # Load and preprocess audio
    waveform, sr = torchaudio.load(audio_path)
    if sr != 16000:
        waveform = torchaudio.transforms.Resample(sr, 16000)(waveform)
    
    # Split into 3-second chunks (48k samples)
    chunk_size = 16000 * 3
    audio_chunks = [waveform[:, i:i+chunk_size] for i in range(0, waveform.size(1), chunk_size)]
    
    # Split text by sentences
    sentences = [s.strip() for s in transcript.split('.') if s.strip()]
    
    # Align chunks
    pairs = list(zip(sentences, audio_chunks))[:min(len(sentences), len(audio_chunks))]
    
    # Training setup
    optimizer = torch.optim.AdamW(model.parameters(), lr=1e-6)
    
    for epoch in range(100):
        total_loss = 0
        for text, audio in pairs:
            # Process text
            inputs = processor(
                text=text,
                return_tensors="pt",
                max_length=200,
                padding="max_length",
                truncation=True
            ).to(device)
            
            # Process audio
            if audio.size(1) < 48000:  # Pad short chunks
                audio = torch.nn.functional.pad(audio, (0, 48000 - audio.size(1)))
            audio = audio[:, :48000]  # Truncate to exact size
            
            # Extract embeddings
            with torch.no_grad():
                embeddings = classifier.encode_batch(audio.to(device))
            
            # Forward pass
            optimizer.zero_grad()
            outputs = model(
                input_ids=inputs.input_ids,
                attention_mask=inputs.attention_mask,
                speaker_embeddings=embeddings,
                labels=audio.to(device),
                return_dict=True
            )
            
            loss = outputs.loss
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            optimizer.step()
            
            total_loss += loss.item()
        
        print(f"Epoch {epoch+1} Loss: {total_loss/len(pairs):.4f}")

# Run training
train_aligned_chunks()
