import os
import json
import numpy as np
import ollama
from typing import List, Dict, Any, Optional

INDEX_PATH = "memory_store/index/memory_index.json"

class MemoryRetriever:
    def __init__(self, embed_model: str = "nomic-embed-text"):
        self.embed_model = embed_model
        self.items: List[Dict[str, Any]] = []
        self.embeddings: np.ndarray = np.array([])
        self._load_index()

    def _load_index(self):
        os.makedirs(os.path.dirname(INDEX_PATH), exist_ok=True)
        if os.path.exists(INDEX_PATH):
            with open(INDEX_PATH, "r", encoding="utf-8") as f:
                data = json.load(f)
                self.items = data.get("items", [])
                emb_list = data.get("embeddings", [])
                if emb_list:
                    self.embeddings = np.array(emb_list, dtype=np.float32)
                else:
                    self.embeddings = np.array([])

    def _save_index(self):
        with open(INDEX_PATH, "w", encoding="utf-8") as f:
            json.dump({
                "items": self.items,
                "embeddings": self.embeddings.tolist() if isinstance(self.embeddings, np.ndarray) else []
            }, f)

    def _get_embedding(self, text: str) -> List[float]:
        response = ollama.embeddings(model=self.embed_model, prompt=text)
        return response["embedding"]

    def index_item(self, item_id: str, content: str, category: str, tags: List[str]):
        # Remove old version of item if exists
        idx_to_remove = [i for i, item in enumerate(self.items) if item["id"] == item_id]
        if idx_to_remove:
            idx = idx_to_remove[0]
            self.items.pop(idx)
            self.embeddings = np.delete(self.embeddings, idx, axis=0)

        emb = self._get_embedding(content)
        
        self.items.append({
            "id": item_id,
            "category": category,
            "tags": tags,
            "content": content
        })
        
        if len(self.embeddings) == 0:
            self.embeddings = np.array([emb], dtype=np.float32)
        else:
            self.embeddings = np.vstack([self.embeddings, emb])
            
        self._save_index()

    def remove_item(self, item_id: str):
        idx_to_remove = [i for i, item in enumerate(self.items) if item["id"] == item_id]
        if idx_to_remove:
            idx = idx_to_remove[0]
            self.items.pop(idx)
            self.embeddings = np.delete(self.embeddings, idx, axis=0)
            self._save_index()

    def search(self, query: str, top_k: int = 3, category_filter: Optional[str] = None) -> List[Dict[str, Any]]:
        if len(self.items) == 0:
            return []

        query_emb = np.array(self._get_embedding(query), dtype=np.float32)
        
        # Calculate cosine similarities
        norms_db = np.linalg.norm(self.embeddings, axis=1)
        norm_q = np.linalg.norm(query_emb)
        norms = norms_db * norm_q
        norms[norms == 0] = 1e-10
        similarities = np.dot(self.embeddings, query_emb) / norms
        
        results = []
        for i, item in enumerate(self.items):
            if category_filter and item["category"] != category_filter:
                continue
            
            score = float(similarities[i])
            results.append({
                "id": item["id"],
                "content": item["content"],
                "category": item["category"],
                "score": score
            })
            
        # Sort by score descending
        results.sort(key=lambda x: x["score"], reverse=True)
        return results[:top_k]

# Global instance
memory_retriever = MemoryRetriever()
