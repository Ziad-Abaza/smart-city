import os
import sys
from pathlib import Path

# Add project root to sys.path
root_path = Path(__file__).resolve().parent.parent
if str(root_path) not in sys.path:
    sys.path.insert(0, str(root_path))

import cv2
import mediapipe as mp
from mediapipe.tasks import python
from mediapipe.tasks.python import vision
import numpy as np
import time
from core.config_manager import config_manager
from face_recognition.aligner import align_face
from face_recognition.quality import check_image_quality

class FaceEnrollment:
    def __init__(self, user_name, save_path=None):
        self.user_name = user_name
        
        # Load from config or use default
        default_save_path = config_manager.get("face_recognition_server", {}).get("enrolled_faces_dir", "face_recognition/enrolled_faces")
        self.save_path = save_path or default_save_path
        self.save_path = config_manager.resolve_path(self.save_path)
        
        self.circle_center = None
        self.circle_radius = None
        self.saved_images = 0
        self.max_images = config_manager.get("face_recognition_server", {}).get("enrollment_sample_count", 20)
        self.saved_embeddings = []

        # Initialize Mediapipe FaceLandmarker
        fr_config = config_manager.get("face_recognition_server", {})
        model_relative_path = fr_config.get("model_path", "face_recognition/models/face_landmarker.task")
        model_absolute_path = config_manager.resolve_path(model_relative_path)
        
        det_conf = fr_config.get("detection_min_confidence", 0.6)
        trk_conf = fr_config.get("tracking_min_confidence", 0.6)

        base_options = python.BaseOptions(model_asset_path=model_absolute_path)
        options = vision.FaceLandmarkerOptions(
            base_options=base_options,
            num_faces=1,
            min_face_detection_confidence=det_conf,
            min_tracking_confidence=trk_conf,
            output_facial_transformation_matrixes=True
        )
        self.face_landmarker = vision.FaceLandmarker.create_from_options(options)

        sface_model_path = config_manager.resolve_path(fr_config.get("sface_model_path", "face_recognition/models/face_recognition_sface_2021dec.onnx"))
        self.sface = cv2.FaceRecognizerSF.create(sface_model_path, "")

        # Create directory if it doesn't exist
        os.makedirs(os.path.join(self.save_path, self.user_name), exist_ok=True)

        # Open Webcam
        video_source = config_manager.get("face_recognition_server", {}).get("video_feed_url", 0)
        try:
            if isinstance(video_source, str) and video_source.isdigit():
                video_source = int(video_source)
        except Exception:
            pass
        self.cap = cv2.VideoCapture(video_source)
        self.screen_width = int(self.cap.get(3))
        self.screen_height = int(self.cap.get(4))

        # Define Circle Position
        self.circle_center = (self.screen_width // 2, self.screen_height // 2 )
        self.circle_radius = min(self.screen_width, self.screen_height) // 3

    def enroll_face(self):
        delay_time = time.time()

        while self.cap.isOpened():
            ret, frame = self.cap.read()
            if not ret:
                break
            
            frame = cv2.flip(frame, 1)  # Mirror the frame
            rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)

            # Face Detection
            mp_image = mp.Image(image_format=mp.ImageFormat.SRGB, data=rgb_frame)
            detection_result = self.face_landmarker.detect(mp_image)
            
            face_inside = False
            has_landmarks = False
            if detection_result.face_landmarks:
                has_landmarks = True
                face_landmarks = detection_result.face_landmarks[0]
                # Get nose tip position
                nose_x = int(face_landmarks[1].x * self.screen_width)
                nose_y = int(face_landmarks[1].y * self.screen_height)
                face_center = (nose_x, nose_y)

                if detection_result.facial_transformation_matrixes:
                    face_matrix = detection_result.facial_transformation_matrixes[0]
                else:
                    face_matrix = None

                # Quality check
                fr_config = config_manager.get("face_recognition_server", {})
                passed_quality, metrics, reason = check_image_quality(frame, face_landmarks, face_matrix, fr_config)

                # Check if nose is inside the circle
                if np.linalg.norm(np.array(self.circle_center) - np.array(face_center)) < self.circle_radius:
                    face_inside = True
                    if passed_quality and time.time() - delay_time > 0.5:  # Check quality and time
                        aligned_crop = align_face(frame, face_landmarks)
                        if aligned_crop is not None:
                            embedding = self.sface.feature(aligned_crop)[0]
                            embedding = embedding / np.linalg.norm(embedding)
                            
                            # Duplicate rejection
                            is_duplicate = False
                            duplicate_threshold = fr_config.get("duplicate_reject_similarity", 0.97)
                            for saved_emb in self.saved_embeddings:
                                sim = np.dot(embedding, saved_emb)
                                if sim > duplicate_threshold:
                                    is_duplicate = True
                                    break
                                    
                            if not is_duplicate:
                                self.save_face(aligned_crop)
                                self.saved_embeddings.append(embedding)
                                delay_time = time.time()
                            else:
                                cv2.putText(frame, "Too similar, move slightly", (50, 50), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 165, 255), 2)
                    elif not passed_quality:
                        cv2.putText(frame, f"Quality: {reason}", (50, 50), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 0, 255), 2)


                # Draw face mesh points for a modern look
                for lm in face_landmarks:
                    x, y = int(lm.x * self.screen_width), int(lm.y * self.screen_height)
                    cv2.circle(frame, (x, y), 1, (0, 255, 0), -1)

            # Change circle color based on face alignment
            if not has_landmarks:
                circle_color = (100, 100, 100)  # Gray (no face detected)
            elif face_inside:
                circle_color = (0, 255, 0)  # Green (aligned correctly)
            else:
                circle_color = (0, 0, 255)  # Red (misaligned)

            # Draw radial lines around the circle
            num_lines = 72  # Increased number of segments
            for i in range(num_lines):
                angle = i * (360 / num_lines)
                x1 = int(self.circle_center[0] + (self.circle_radius + 20) * np.cos(np.radians(angle)))
                y1 = int(self.circle_center[1] + (self.circle_radius + 20) * np.sin(np.radians(angle)))
                x2 = int(self.circle_center[0] + (self.circle_radius + 30) * np.cos(np.radians(angle)))
                y2 = int(self.circle_center[1] + (self.circle_radius + 30) * np.sin(np.radians(angle)))
                cv2.line(frame, (x1, y1), (x2, y2), circle_color, 2)

            # Draw Face ID Circle
            cv2.circle(frame, self.circle_center, self.circle_radius + 10, circle_color, 10, cv2.LINE_AA)
            
            # Show completion message
            if self.saved_images >= self.max_images:
                cv2.putText(frame, "Face Enrollment Complete!", (50, 100), cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 255, 0), 3)

            cv2.imshow("Face Enrollment", frame)

            if cv2.waitKey(1) & 0xFF == ord('q') or self.saved_images >= self.max_images:
                break

        self.cap.release()
        cv2.destroyAllWindows()

    def save_face(self, frame):
        """Save the captured face image."""
        if self.saved_images < self.max_images:
            img_path = os.path.join(self.save_path, self.user_name, f"{self.saved_images}.jpg")
            cv2.imwrite(img_path, frame)
            print(f"Saved {img_path}")
            self.saved_images += 1
