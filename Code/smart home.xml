import os
import sys
from pathlib import Path

# Add project root to sys.path
root_path = Path(__file__).resolve().parent.parent
if str(root_path) not in sys.path:
    sys.path.insert(0, str(root_path))

import cv2
import mediapipe as mp
from mediapipe.tasks import python
from mediapipe.tasks.python import vision

def main():
    print("Initializing test_camera.py...")
    print(f"OpenCV version: {cv2.__version__}")
    print(f"MediaPipe version: {mp.__version__}")

    # Check for model file
    model_path = root_path / "face_recognition" / "models" / "face_landmarker.task"
    if not model_path.exists():
        print(f"ERROR: Model file not found at {model_path}")
        sys.exit(1)
    print(f"Model file found at {model_path}")

    # Initialize MediaPipe FaceLandmarker
    print("Initializing MediaPipe FaceLandmarker...")
    base_options = python.BaseOptions(model_asset_path=str(model_path))
    options = vision.FaceLandmarkerOptions(
        base_options=base_options,
        num_faces=1,
        min_face_detection_confidence=0.5,
        min_tracking_confidence=0.5
    )
    face_landmarker = vision.FaceLandmarker.create_from_options(options)
    print("MediaPipe FaceLandmarker initialized successfully!")

    # Check for camera
    print("Attempting to open camera index 0...")
    cap = cv2.VideoCapture(0)
    
    if not cap.isOpened():
        print("ERROR: Could not open camera index 0.")
        sys.exit(1)
        
    print("Camera successfully opened! Capturing 30 frames to test...")
    
    face_detected_count = 0
    frames_captured = 0
    
    for i in range(30):
        ret, frame = cap.read()
        if not ret:
            print(f"Frame {i}: Failed to read frame from camera.")
            continue
            
        frames_captured += 1
        # Convert the BGR image to RGB
        rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        mp_image = mp.Image(image_format=mp.ImageFormat.SRGB, data=rgb_frame)
        
        detection_result = face_landmarker.detect(mp_image)
        
        if detection_result.face_landmarks:
            face_detected_count += 1
            print(f"Frame {i}: Frame captured. Face landmarks detected!")
            # Save a debug image of the first detected face
            if face_detected_count == 1:
                debug_path = root_path / "tests" / "debug_face.jpg"
                cv2.imwrite(str(debug_path), frame)
                print(f"  Saved debug image to {debug_path}")
        else:
            print(f"Frame {i}: Frame captured. No face detected.")
            
        # Sleep slightly to simulate real frame rate
        cv2.waitKey(33)
        
    cap.release()
    print("\n--- Test Summary ---")
    print(f"Total frames processed: {frames_captured}/30")
    print(f"Total frames with face detected: {face_detected_count}")
    
    if frames_captured == 0:
        print("FAIL: No frames could be read from the camera.")
        sys.exit(1)
    elif face_detected_count > 0:
        print("SUCCESS: Camera works and MediaPipe FaceLandmarker works!")
    else:
        print("WARNING: Camera works, but no face was detected in any frame. Make sure you are in front of the camera and there is good lighting.")

if __name__ == "__main__":
    main()
