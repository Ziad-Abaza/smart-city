/**
 * On-screen bridge diagnostics (?debug=1 or always-minimal strip)
 */
import { bus } from '../core/event-bus.js';
import { bridge } from '../bridge/assistant-bridge.js';
import { stateMachine } from '../core/state-machine.js';

const SHOW_PANEL = new URLSearchParams(location.search).has('debug');

export class DebugPanel {
  constructor() {
    this.el = document.createElement('aside');
    this.el.className = 'debug-panel';
    this.el.setAttribute('aria-hidden', SHOW_PANEL ? 'false' : 'true');
    document.body.appendChild(this.el);

    this._healthTimer = null;
    bus.on('bridge:debug', () => this._render());
    bus.on('bridge:connected', () => this._render());
    bus.on('bridge:disconnected', () => this._render());
    bus.on('bridge:ready', () => this._render());
    bus.on('state:change', () => this._render());

    this._render();
    this._healthTimer = setInterval(() => this._pollHealth(), 5000);
    if (SHOW_PANEL) this._pollHealth();
  }

  async _pollHealth() {
    this._health = await bridge.fetchHealth();
    this._render();
  }

  _render() {
    const h = this._health || {};
    const last = bridge.messageLog[0];
    const lines = [
      `WS: ${bridge.connected ? 'connected' : 'offline'} | Backend: ${bridge.backendReady ? 'ready' : 'waiting'}`,
      `State: ${stateMachine.state} | Clients: ${h.clients ?? '?'}`,
      `Sent: ${h.emit_stats?.sent ?? 0} remote:${h.emit_stats?.remote_sent ?? 0} dropped:${(h.emit_stats?.dropped_no_clients ?? 0) + (h.emit_stats?.dropped_no_loop ?? 0)}`,
      h.bridge_error ? `ERROR: ${h.bridge_error}` : (last ? `Last: ${last.kind} ${JSON.stringify(last).slice(0, 90)}` : 'Waiting for messages...'),
    ];

    if (SHOW_PANEL) {
      const log = bridge.messageLog.slice(0, 12).map((e) =>
        `${e.ts.slice(11, 19)} ${e.kind} ${JSON.stringify(e).slice(0, 100)}`
      ).join('\n');
      this.el.innerHTML = `
        <header>Bridge Debug <a href="?" style="color:#8cf;float:right">hide</a></header>
        <pre class="debug-panel__summary">${lines.join('\n')}</pre>
        <pre class="debug-panel__log">${log || '(no events yet)'}</pre>
        <p class="debug-panel__hint">Health: /ui/api/health · Test: python ui/test_bridge.py pulse</p>
      `;
      this.el.classList.add('is-expanded');
    } else {
      this.el.innerHTML = `<pre class="debug-panel__strip">${lines[0]} · ${lines[3]}</pre>`;
      this.el.classList.remove('is-expanded');
    }
  }
}
