import re
import json
import ollama
from typing import Dict, Any, Optional
from datetime import datetime

def _extract_after(text: str, prefix: str) -> str:
    idx = text.lower().find(prefix)
    if idx == -1:
        return text
    return text[idx + len(prefix):].strip()

def fast_path_classify(text: str) -> Optional[Dict[str, Any]]:
    lower_text = text.lower()
    
    if lower_text.startswith("my name is "):
        return {"category": "user_identity", "content": f"User's name is {_extract_after(text, 'my name is ')}", "lifetime": "permanent", "importance": "high", "tags": ["name"]}
    if lower_text.startswith("call me "):
        return {"category": "user_identity", "content": f"User's preferred name is {_extract_after(text, 'call me ')}", "lifetime": "permanent", "importance": "high", "tags": ["nickname"]}
        
    if "prefer metric" in lower_text or "use celsius" in lower_text:
        return {"category": "preference", "content": "User prefers metric units (Celsius)", "lifetime": "permanent", "importance": "medium", "tags": ["units", "metric"]}
    if "prefer imperial" in lower_text or "use fahrenheit" in lower_text:
        return {"category": "preference", "content": "User prefers imperial units (Fahrenheit)", "lifetime": "permanent", "importance": "medium", "tags": ["units", "imperial"]}

    return None

def classify_memory(text: str) -> Dict[str, Any]:
    res = fast_path_classify(text)
    if res:
        res["source"] = "explicit_statement"
        res["confidence"] = 1.0
        return res
        
    # Phase 5: LLM Classification for remaining categories
    prompt = f"""
You are a memory classifier for a Smart Voice Assistant.
Classify the following statement into one of these categories:
1. user_identity: Name, pronouns, contact info.
2. user_preferences: Preferred units, language, style.
3. personal_information: Birthday, address, phone number. (Highly sensitive).
4. smart_home_preference: Preferred temperature, lighting.
5. appointment_event: Meetings, birthdays, scheduled reminders.
6. task: To-do items, shopping lists.
7. long_term_fact: Catch-all for durable facts (e.g. allergies, car model).

Today's date is: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}

Respond ONLY with valid JSON matching this schema:
{{
    "category": "category_name_here",
    "content": "A clear, 3rd person statement of the fact to remember",
    "lifetime": "permanent", "until_date", or "ttl_bounded" (for temporary things like "remind me later today" or cached context),
    "expiration_date": "YYYY-MM-DD" or null (if lifetime is permanent),
    "importance": "low", "medium", or "high",
    "confidence": 0.0 to 1.0 (float representing your certainty),
    "tags": ["tag1", "tag2"]
}}

Statement to classify: "{text}"
"""
    
    try:
        response = ollama.chat(
            model="minicpm-v:latest",
            messages=[{"role": "user", "content": prompt}],
            options={"temperature": 0.0}
        )
        
        reply = response["message"]["content"].strip()
        # Find JSON block if wrapped
        if "```json" in reply:
            reply = reply.split("```json")[1].split("```")[0].strip()
        elif "```" in reply:
            reply = reply.split("```")[1].split("```")[0].strip()
            
        data = json.loads(reply)
        
        # Validation fallbacks
        if data.get("category") not in ["user_identity", "user_preferences", "personal_information", "smart_home_preference", "appointment_event", "task", "long_term_fact"]:
            data["category"] = "long_term_fact"
            
        data["source"] = "explicit_statement"
        if "confidence" not in data:
            data["confidence"] = 0.8
            
        # Map user_preferences to preference to match our taxonomy internal name
        if data["category"] == "user_preferences":
            data["category"] = "preference"
            
        return data
        
    except Exception as e:
        print(f"⚠️ Memory Classification Error: {e}")
        return {
            "category": "long_term_fact",
            "content": text.replace("remember that ", "").replace("remember ", "").strip(),
            "lifetime": "permanent",
            "importance": "medium",
            "tags": [],
            "source": "explicit_statement",
            "confidence": 0.5
        }
