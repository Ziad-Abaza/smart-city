        self.tts = recognizer.tts
        self.vision_manager = camera_manager
        try:
            with open(config_path, "r") as f:
                config_data = json.load(f)
            # Load separate prompt keys
            self.general_prompt    = config_data.get("general_prompt", "")
            self.doctor_prompt     = config_data.get("doctor_prompt", "")
            self.job_prompt        = config_data.get("job_prompt", "")
            self.smart_city_prompt = config_data.get("smart_city_prompt", "")
            self.open_door_command = config_data.get("open_door_command", "")
            self.api_instructions  = config_data.get("api_instructions", "")
            self.lights_on_command = config_data.get("lights_on_command", "")
            self.lights_off_command= config_data.get("lights_off_command", "")
            self.api_endpoints     = config_data.get("api_endpoints", {})
            self.api_base_url      = config_data.get("api", "")
            print("✅ Configuration loaded successfully!")
        except Exception as e:
            print(f"❌ Error loading configuration: {e}")
            self.general_prompt    = ""
            self.doctor_prompt     = ""
            self.job_prompt        = ""
            self.smart_city_prompt = ""
            self.api_instructions  = ""
            self.lights_on_command  = ""
            self.lights_off_command = ""
            self.api_endpoints     = {}
        print(f"🤖 Using Ollama model: {self.model_name}")
        self.tool_executor = ToolExecutor(self.api_endpoints, getattr(self, "api_base_url", ""))
        self.conversation_history = []
        self.pending_confirmation = None
    def get_full_system_prompt(self):
        # Combine the separate prompt parts in a specific order
        parts = [
            self.general_prompt,
            self.doctor_prompt,
            self.job_prompt,
            self.smart_city_prompt,
            self.api_instructions,
            self.lights_on_command,
            self.lights_off_command,
            self.open_door_command
        ]
        # Only join non-empty parts
        return "\n".join(part for part in parts if part)

    def call_api(self, command_key):
        endpoint_config = self.api_endpoints.get(command_key)
        if not endpoint_config:
            print(f"❌ API endpoint not found for command: {command_key}")
            return {"status": "error", "message": "Invalid command key"}

        # If it's a string, treat it as a direct POST URL
        if isinstance(endpoint_config, str):
            url = endpoint_config
            method = "POST"
            body = None
            timeout = 5
        else:
            url = endpoint_config.get("url")
            
            # Combine with base API URL if it's a relative path
            if url and url.startswith("/") and hasattr(self, "api_base_url") and self.api_base_url:
                url = f"{self.api_base_url.rstrip('/')}{url}"
                
            method = endpoint_config.get("method", "POST").upper()
            body = endpoint_config.get("body", None)
            timeout = endpoint_config.get("timeout", 5)  # per-endpoint override

        try:
            print(f"🔗 Calling API: {url} ({method}, timeout={timeout}s)")
            response = requests.request(method, url, json=body, timeout=timeout)
            print(f"API call response: {response.text}")
            try:
                return response.json()
            except json.JSONDecodeError:
                return {"status": "success"}
        except requests.exceptions.ConnectionError:
            print(f"❌ API unreachable: {url}")
            return {"status": "error", "message": "Service is offline. Please start the server first."}
        except requests.exceptions.Timeout:
            print(f"❌ API timed out: {url}")
            return {"status": "error", "message": "Service took too long to respond."}
        except Exception as e:
            print(f"❌ API error: {e}")
            return {"status": "error", "message": "Could not reach the service."}


    def get_response(self, user_input: Union[str, UserInput], stream_callback=None):
        if isinstance(user_input, str):
            user_input = UserInput(text=user_input)
            
        text_input = user_input.text
        
        if not text_input.strip() or text_input.strip() == ".":
            response = random.choice(WAKE_RESPONSES)
            print(response)
            self.tts.speak(response)
            return response

        if "morsi" in text_input.lower():
            text_input = text_input.replace("morsi", "smart city")

        UIBridge.set_state("thinking")

        # ------------------------------------------------------------------
        # Fast path: fuzzy-match known device control commands — no LLM call
        # ------------------------------------------------------------------
        # Route the intent
        route_result = self.router.route(text_input)
        route = route_result.route
        appended_memory_msg = ""
        
        # Phase 7: Implicit Intent Memory Processing
        if getattr(route_result, "memorable", False) and route != "memory_operation":
            from voice_assistant.memory_classifier import classify_memory
            from voice_assistant import memory_store
            from voice_assistant.memory_retriever import memory_retriever
            from voice_assistant.memory_lifecycle import detect_duplicate_or_conflict
            
            classification = classify_memory(text_input)
            status, existing = detect_duplicate_or_conflict(classification)
            classification["source"] = "implicit_confirmed"
            
            if status == "new" and classification["confidence"] >= 0.8 and classification["category"] != "personal_information":
                if classification.get("lifetime") == "ttl_bounded":
                    from datetime import datetime, timedelta
                    exp = datetime.utcnow() + timedelta(hours=2)
                    item = memory_store.create_temp_item(
                        content=classification["content"],
                        expires_at=exp.isoformat() + "Z",
                        context={"category": classification["category"]}
                    )
                else:
                    item = memory_store.create_item(
                        content=classification["content"], category=classification["category"],
                        source=classification["source"], confidence=classification["confidence"],
                        importance=classification["importance"], lifetime=classification["lifetime"],
                        tags=classification["tags"], expiration_date=classification.get("expiration_date")
                    )
                    memory_retriever.index_item(item["id"], item["content"], item["category"], item["tags"])
            elif status != "duplicate":
                action_type = "conflict" if status == "conflict" else "low_confidence"
                self.pending_confirmation = {"action": action_type, "candidate": classification, "conflict": existing}
                
                if status == "conflict":
                    appended_memory_msg = f" By the way, you previously told me: '{existing['content']}'. Should I update it to '{classification['content']}'?"
                else:
                    appended_memory_msg = f" By the way, should I remember that {classification['content']}?"
        
        # ------------------------------------------------------------------
        # Fast path / Hardware Tool Execution
        # ------------------------------------------------------------------
        if route_result.route == "tool_execution" and route_result.tool:
            tool_name = route_result.tool
            params = route_result.parameters or {}
            spoken = route_result.spoken_confirmation or "Executing command."
            
            tool_def = self.tool_executor.registry.get_tool(tool_name)
            
            is_high_risk = (tool_name == "control_door" and params.get("action") == "open") or (tool_name == "manage_filesystem" and params.get("action") == "write")
            if tool_def and tool_def.risk_tier == "high" and is_high_risk:
