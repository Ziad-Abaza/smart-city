import torch
import numpy as np
import sounddevice as sd
import noisereduce as nr
from faster_whisper import WhisperModel
from core.config_manager import config_manager
from voice_assistant.wakeword.detector import WakeWordDetector
from voice_assistant.tts_engine import TextToSpeech
try:
    from ui.server import UIBridge
except ImportError:
    class UIBridge:
        @classmethod
        def set_state(cls, state: str): pass
        @classmethod
        def set_transcript(cls, text: str): pass
# Configuration Constants for Speech Recognition (loaded from config)
# ---------------------------------------------------------------------
SAMPLE_RATE = 16000
_va_cfg = config_manager.get("voice_assistant", {})
WAKE_WORDS        = _va_cfg.get("wake_words",        ["jarvis", "hey assistant", "hello", "wake up"])
WAKE_RESPONSES    = _va_cfg.get("wake_responses",    ["Yes?", "I'm listening.", "How can I help you?"])
SILENCE_THRESHOLD = _va_cfg.get("silence_threshold", 0.02)
SILENCE_DURATION  = _va_cfg.get("silence_duration",  2)
FUZZY_SCORE_CUTOFF = _va_cfg.get("fuzzy_score_cutoff", 85)

# Phrases each built-in OpenWakeWord model can actually detect.
_OWW_MODEL_PHRASES = {
    "hey_jarvis": ("jarvis", "hey jarvis"),
    "hey_mycroft": ("mycroft", "hey mycroft"),
    "hey_rhasspy": ("rhasspy", "hey rhasspy"),
    "alexa": ("alexa",),
    "timer": ("timer",),
    "weather": ("weather",),
}


def _openwakeword_matches_wake_words(model_name: str, wake_words: list) -> bool:
    """True only when the OWW model can detect at least one configured wake word."""
    model = (model_name or "").lower().strip()
    detectable = _OWW_MODEL_PHRASES.get(model, (model.replace("hey_", ""),))
    for wake_word in wake_words:
        ww = wake_word.lower().strip()
        for phrase in detectable:
            if phrase in ww or ww in phrase:
                return True
    return False


# ---------------------------------------------------------------------
# AudioTranscriber Class (Optional, for file-based transcription)
# ---------------------------------------------------------------------
class AudioTranscriber:
    print("🔄 Initializing FasterWhisper for transcription...")
    def __init__(self):
        device = "cuda" if torch.cuda.is_available() else "cpu"
        print(f"🔹 Initializing faster-whisper on device: {device}")
        self.model = WhisperModel("large-v2", device=device)

    def transcribe(self, audio_path):
        try:
            segments, _ = self.model.transcribe(audio_path)
            transcript = " ".join([segment.text for segment in segments])
            return transcript
        except Exception as e:
            print(f"❌ Error during transcription: {e}")
            return ""

# ---------------------------------------------------------------------
# Chatbot Class that Loads Configuration and Uses Ollama
# ---------------------------------------------------------------------
# SpeechRecognizer Class with Combined Wake Word & Command Capture
# ---------------------------------------------------------------------
class SpeechRecognizer:
    def __init__(self):
        print("🔄 Loading FasterWhisper model for speech recognition...")
        device = "cuda" if torch.cuda.is_available() else "cpu"
        print(f"🖥️ Using device: {device}")

        # Load model name from config (default to "small" for fast execution)
        whisper_model_name = config_manager.get("speech_recognition", {}).get("whisper_model", "small")
        compute_type = "float16" if device == "cuda" else "int8"
        print(f"📦 Loading Whisper Model size: {whisper_model_name} (compute_type={compute_type})")
        self.model = WhisperModel(whisper_model_name, device=device, compute_type=compute_type)
        self.tts = TextToSpeech()
        self.listening = True

        # OpenWakeWord: only when explicitly enabled AND model matches wake words
        self.wake_detector = None
        self.use_wake_detector = False
        ww_cfg = config_manager.get("wakeword", {})
        oww_enabled = ww_cfg.get("enabled", True)
        oww_model = ww_cfg.get("model", "hey_jarvis")
        oww_compatible = _openwakeword_matches_wake_words(oww_model, WAKE_WORDS)

        if not oww_enabled:
            print("\u2139\ufe0f OpenWakeWord disabled in config — using Whisper wake-word detection.")
        elif not oww_compatible:
            print(
                f"\u26a0\ufe0f OpenWakeWord model '{oww_model}' does not match wake words "
                f"{WAKE_WORDS} — using Whisper wake-word detection."
            )
        else:
            try:
                self.wake_detector = WakeWordDetector()
                if self.wake_detector.enabled:
                    self.use_wake_detector = True
                    print(f"\u2705 OpenWakeWord active (model: {oww_model}).")
                else:
                    print("\u26a0\ufe0f OpenWakeWord unavailable — using Whisper wake-word detection.")
                    self.wake_detector = None
            except Exception as e:
                print(f"\u26a0\ufe0f OpenWakeWord init failed ({e}) — using Whisper wake-word detection.")

    def record_audio(self):
        """Two-phase audio recording:
        Phase 1 – wait silently for speech to begin (up to pre_speech_timeout seconds).
        Phase 2 – record until silence_duration of quiet is detected after speech.
        This prevents the silence timer from expiring before the user has spoken.
        """
        if not self.listening:
            return None

        chunk_duration   = 0.1   # seconds per read chunk
        chunk_size       = int(SAMPLE_RATE * chunk_duration)
        silence_chunks   = int(SILENCE_DURATION / chunk_duration)  # chunks of silence before stopping
        pre_speech_limit = int(10.0 / chunk_duration)              # wait up to 10 s for speech to start

        print("\U0001f3a4 Listening... Speak now.")
        buffer          = []
        silence_counter = 0
        pre_counter     = 0
        speech_started  = False

        with sd.InputStream(samplerate=SAMPLE_RATE, channels=1, dtype="float32") as stream:
            while True:
                chunk, _ = stream.read(chunk_size)
                chunk = chunk.flatten()
                volume = np.sqrt(np.mean(chunk ** 2))

                if not speech_started:
                    # Phase 1: waiting for the user to start speaking
                    if volume >= SILENCE_THRESHOLD:
                        speech_started = True
                        buffer.append(chunk)
                    else:
                        pre_counter += 1
                        if pre_counter >= pre_speech_limit:
                            # Nobody spoke within the timeout window
                            return None
                else:
                    # Phase 2: recording — stop only after sustained post-speech silence
                    buffer.append(chunk)
                    if volume < SILENCE_THRESHOLD:
                        silence_counter += 1
                        if silence_counter >= silence_chunks:
                            print("\U0001f6d1 Silence detected, stopping recording.")
                            break
                    else:
                        silence_counter = 0

        if not buffer:
            return None

        audio = np.concatenate(buffer)
        use_nr = config_manager.get("speech_recognition", {}).get("use_noise_reduction", True)
        if use_nr:
            try:
                audio = nr.reduce_noise(y=audio, sr=SAMPLE_RATE, prop_decrease=0.5)
            except Exception as e:
                print(f"\u26a0\ufe0f Noise reduction skipped: {e}")
        return audio

    def transcribe_audio(self, audio):
        if audio is None or audio.size == 0:
            return ""
        try:
            segments, _ = self.model.transcribe(audio, beam_size=5, language="en")
            return " ".join(segment.text for segment in segments).strip()
        except Exception as e:
            print(f"❌ Error during transcription: {e}")
            return ""

    def extract_command(self, text):
        """
        Look for any wake word in the recognized text and remove it.
        Return the remaining text as the command.
        """
        # Lowercase the text to simplify matching
        text = text.lower()
        for wake_word in WAKE_WORDS:
            if wake_word in text:
                # Remove the wake word from the text.
                command = text.replace(wake_word, "").strip(" ,:;")
                if command:
                    print(f"✅ Extracted command: {command}")
                    return command
                else:
                    # Wake word found but no command tail.
                    print("⚠️ Wake word detected but no command found.")
                    return ""
        # If no wake word is detected, return empty
        return ""

    def listen_for_wake_and_command(self):
        """
        Listens for the wake word and command.
        When OpenWakeWord is available, gates recording behind lightweight detection.
        Returns the extracted command string, or empty string if nothing heard.
        """
        UIBridge.set_state("wake_word")
        UIBridge.set_state("listening")
        if self.use_wake_detector and self.wake_detector is not None:
            print("\U0001f442 Listening for wake word (OpenWakeWord)...")
            try:
                self.wake_detector.listen_for_wake_word()
            except KeyboardInterrupt:
                raise
            except Exception as e:
                print(f"\u26a0\ufe0f Wake-word detection error: {e}")
                return ""

            print("\U0001f3a4 Wake word detected — listening for command...")
            try:
                self.wake_detector.release_microphone()
                audio = self.record_audio()
            finally:
                self.wake_detector.resume_microphone()
            text = self.transcribe_audio(audio)
            UIBridge.set_transcript(text)
            if text:
                print(f"\U0001f50d Heard: {text}")
            return text.strip()

        # Fallback: single recording + Whisper-based wake-word extraction
        print("\U0001f3a4 Listening for wake word and command...")
        audio = self.record_audio()
        if audio is None:
            return ""
        text = self.transcribe_audio(audio)
        UIBridge.set_transcript(text)
        if text:
            print(f"\U0001f50d Heard: {text}")
        command = self.extract_command(text)
        return command

    def pause(self):
        self.listening = False

    def resume(self):
        self.listening = True

# ---------------------------------------------------------------------
# Main Function: Integrated Voice Assistant Loop
</file>

