import json
import ollama
from dataclasses import dataclass
from typing import Optional, Dict, Any, Tuple
from fuzzywuzzy import process, fuzz
from core.config_manager import config_manager

@dataclass
class RouteResult:
    route: str  # 'tool_execution', 'knowledge_rag', 'general_chat', 'hybrid', 'clarify'
    confidence: float
    tool: Optional[str] = None
    parameters: Optional[Dict[str, Any]] = None
    vision_needed: bool = False
    spoken_confirmation: Optional[str] = None

class IntentRouter:
    # ------------------------------------------------------------------
    # Fuzzy command map: phrase -> (api_key, spoken_response)
    # The router bypasses Ollama for confident device control matches.
    # ------------------------------------------------------------------
    COMMAND_PHRASES = {
        # All lights
        "turn on the lights":  ("control_light", {"room": "all", "state": "on"}, "Turning on the lights."),
        "open the lights":     ("control_light", {"room": "all", "state": "on"}, "Turning on the lights."),
        "lights up":           ("control_light", {"room": "all", "state": "on"}, "Turning on the lights."),
        "turn off the lights": ("control_light", {"room": "all", "state": "off"}, "Turning off the lights."),
        "close the lights":    ("control_light", {"room": "all", "state": "off"}, "Turning off the lights."),
        "lights down":         ("control_light", {"room": "all", "state": "off"}, "Turning off the lights."),
        # Room A
        "turn on lights in room a":       ("control_light", {"room": "a", "state": "on"}, "Turning on light A."),
        "open lights a":                  ("control_light", {"room": "a", "state": "on"}, "Turning on light A."),
        "turn on the lights for room a":  ("control_light", {"room": "a", "state": "on"}, "Turning on light A."),
        "turn off lights in room a":      ("control_light", {"room": "a", "state": "off"}, "Turning off light A."),
        "close lights a":                 ("control_light", {"room": "a", "state": "off"}, "Turning off light A."),
        # Room B
        "turn on lights in room b":  ("control_light", {"room": "b", "state": "on"}, "Turning on light B."),
        "open lights b":             ("control_light", {"room": "b", "state": "on"}, "Turning on light B."),
        "turn off lights in room b": ("control_light", {"room": "b", "state": "off"}, "Turning off light B."),
        "close lights b":            ("control_light", {"room": "b", "state": "off"}, "Turning off light B."),
        # Room C
        "turn on lights in room c":  ("control_light", {"room": "c", "state": "on"}, "Turning on light C."),
        "open lights c":             ("control_light", {"room": "c", "state": "on"}, "Turning on light C."),
        "turn off lights in room c": ("control_light", {"room": "c", "state": "off"}, "Turning off light C."),
        "close lights c":            ("control_light", {"room": "c", "state": "off"}, "Turning off light C."),
        # Fan
        "turn on the fan":  ("control_fan", {"state": "on"},  "Turning on the fan."),
        "start the fan":    ("control_fan", {"state": "on"},  "Turning on the fan."),
        "fan up":           ("control_fan", {"state": "on"},  "Turning on the fan."),
        "turn off the fan": ("control_fan", {"state": "off"}, "Turning off the fan."),
        "stop the fan":     ("control_fan", {"state": "off"}, "Turning off the fan."),
        "fan down":         ("control_fan", {"state": "off"}, "Turning off the fan."),
        # Door
        "open the door": ("control_door", {"action": "open"}, "Please face the camera for recognition."),
        "let me in":     ("control_door", {"action": "open"}, "Please face the camera for recognition."),
        "unlock":        ("control_door", {"action": "open"}, "Please face the camera for recognition."),
        "close the door":("control_door", {"action": "close"}, "Closing the door."),
        "shut the door": ("control_door", {"action": "close"}, "Closing the door."),
        "lock the door": ("control_door", {"action": "close"}, "Closing the door."),
        # Sensors
        "what is the temperature": ("read_sensor", {"sensor": "temperature"}, "Checking temperature..."),
        "what is the weather":     ("read_sensor", {"sensor": "temperature"}, "Checking temperature..."),
        "what is the humidity":    ("read_sensor", {"sensor": "humidity"}, "Checking humidity..."),
        "environment status":      ("read_sensor", {"sensor": "environment"}, "Checking environment status..."),
        # Real-World Facts
        "what time is it": ("get_current_time", {}, "Checking the time..."),
        "what is the time": ("get_current_time", {}, "Checking the time..."),
        "what is the date": ("get_calendar_date", {"operation": "today"}, "Checking the date..."),
        "what's today": ("get_calendar_date", {"operation": "today"}, "Checking the date..."),
        "what day is it": ("get_calendar_date", {"operation": "today"}, "Checking the date..."),
        "what is tomorrow": ("get_calendar_date", {"operation": "tomorrow"}, "Checking the date..."),
        "what is yesterday": ("get_calendar_date", {"operation": "yesterday"}, "Checking the date..."),
        # Stateful Tools
        "start the stopwatch": ("control_stopwatch", {"action": "start"}, "Starting stopwatch."),
        "stop the stopwatch": ("control_stopwatch", {"action": "stop"}, "Stopping stopwatch."),
        "pause the stopwatch": ("control_stopwatch", {"action": "pause"}, "Pausing stopwatch."),
        "resume the stopwatch": ("control_stopwatch", {"action": "resume"}, "Resuming stopwatch."),
        "what are my active timers": ("control_timer", {"action": "list"}, "Checking active timers."),
        "what are my alarms": ("control_alarm", {"action": "list"}, "Checking alarms."),
        "what is the weather": ("get_weather", {}, "Checking the weather..."),
        "how is the weather": ("get_weather", {}, "Checking the weather..."),
        "where am i": ("get_location", {}, "Checking location..."),
        "what city is this": ("get_location", {}, "Checking location..."),
    }
    

    def __init__(self, model_name: str, wake_words: list):
        self.model_name = model_name
        self.wake_words = wake_words
        self.fuzzy_cutoff = config_manager.get("voice_assistant", {}).get("fuzzy_score_cutoff", 85)

    def _fuzzy_route(self, text_input: str) -> Tuple[Optional[str], Optional[Dict[str, Any]], Optional[str]]:
        cleaned = text_input.lower().strip()
        for ww in self.wake_words:
            if cleaned.startswith(ww):
                cleaned = cleaned[len(ww):].strip(" ,:;")
                break
        if not cleaned:
            return None, None, None
            
        # ----------------------------------------------------
        # Memory Operations Fast Path
        # ----------------------------------------------------
        mem_keywords = ["remember", "remind me", "call me ", "my name is", "my phone number", "my email", "my address", "my birthday", "save this"]
        if any(cleaned.startswith(kw) or (kw in cleaned and len(cleaned) < 100) for kw in mem_keywords):
            return "memory_operation", {"statement": text_input}, "Got it."
            
        if "prefer metric" in cleaned or "prefer imperial" in cleaned or "use celsius" in cleaned or "use fahrenheit" in cleaned:
            return "memory_operation", {"statement": text_input}, "I've noted your preference."
        
        choices = list(self.COMMAND_PHRASES.keys())
        best = process.extractOne(cleaned, choices, scorer=fuzz.token_sort_ratio)
        if best and best[1] >= self.fuzzy_cutoff:
            print(f"🎯 Fuzzy Match: '{best[0]}' ({best[1]}%)")
            return self.COMMAND_PHRASES[best[0]]
        return None, None, None

    def analyze_intent(self, text: str) -> dict:
        text_lower = text.lower()
        vision_keywords = ["see", "look", "watch", "monitor", "describe", "find", "search", "camera", "in front", "where is"]
        vision_needed = any(k in text_lower for k in vision_keywords)
        continuous = any(k in text_lower for k in ["keep", "watch", "monitor", "continuous"])
        return {"vision_needed": vision_needed, "continuous": continuous}

    def route(self, text_input: str) -> RouteResult:
        # 1. Fast Path
        tool_name, params, spoken = self._fuzzy_route(text_input)
        if tool_name is not None:
            if tool_name == "memory_operation":
                return RouteResult(
                    route="memory_operation",
                    confidence=1.0,
                    tool=None,
                    parameters=params,
                    spoken_confirmation=spoken
                )
            return RouteResult(
                route="tool_execution",
                confidence=1.0,
                tool=tool_name,
                parameters=params,
                spoken_confirmation=spoken
            )

        # 2. Vision Check
        intent = self.analyze_intent(text_input)
        
        # 3. LLM Router with JSON output constraint
        prompt = f"""
You are an intent router for a smart city voice assistant.
Classify the user's input into one of these routes:
- "tool_execution": User wants to control a smart device, read sensors, OR asks about real-world facts like time, date, weather, system state, timers, or alarms. NEVER route time/date to general_chat.
- "knowledge_rag": User asks about the smart city project documentation (parking, charging, localization).
- "general_chat": Casual conversation ONLY. Do not guess facts.
- "clarify": The request is ambiguous or nonsensical.

Respond in strictly valid JSON format matching this schema:
{{
    "route": "<route_name>",
    "tool": "<tool_name_if_known>",
    "parameters": {{}},
    "confidence": <float_between_0_and_1>
}}

User Input: "{text_input}"
"""
        print("🧠 Routing intent via LLM...")
        try:
            response = ollama.chat(
                model=self.model_name,
                messages=[{"role": "user", "content": prompt}],
                format="json",
                options={"temperature": 0.0, "num_predict": 100}
            )
            content = response.get('message', {}).get('content', '{}')
            data = json.loads(content)
            
            route_val = data.get('route', 'general_chat')
            if route_val not in ['tool_execution', 'knowledge_rag', 'general_chat', 'hybrid', 'clarify']:
                route_val = 'general_chat'
                
            return RouteResult(
                route=route_val,
                confidence=float(data.get('confidence', 0.5)),
                tool=data.get('tool'),
                parameters=data.get('parameters'),
                vision_needed=intent.get('vision_needed', False)
            )
        except Exception as e:
            print(f"⚠️ Router Error: {e}. Falling back to general_chat.")
            return RouteResult(
                route='general_chat',
                confidence=0.0,
                vision_needed=intent.get('vision_needed', False)
            )
