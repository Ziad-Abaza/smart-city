import os
from pathlib import Path
from typing import List
from core.config_manager import config_manager

BUILTIN_MODELS = {"alexa", "hey_mycroft", "hey_jarvis", "hey_rhasspy", "timer", "weather"}

def resolve_model_path(model_name_or_path: str) -> str:
    """Resolves the model name or file path for the wake-word engine.
    
    If the name is a built-in model (e.g. "hey_jarvis"), it returns the name as-is.
    If it is a custom path, it resolves it relative to the project root.
    
    Args:
        model_name_or_path: The name of a built-in model or path to a custom ONNX file.
        
    Returns:
        The resolved model identifier (name or absolute path).
        
    Raises:
        FileNotFoundError: If a custom file path is specified but does not exist.
    """
    if not model_name_or_path:
        raise ValueError("Model name or path cannot be empty.")

    # 1. Check if it's one of the known built-in models
    if model_name_or_path in BUILTIN_MODELS:
        return model_name_or_path

    # 2. Treat as a custom file path
    resolved_path = config_manager.resolve_path(model_name_or_path)
    if os.path.exists(resolved_path):
        return resolved_path
    
    # 3. Fallback check: check if it's a built-in model without matching case
    lower_name = model_name_or_path.lower().strip()
    for bm in BUILTIN_MODELS:
        normalized_bm = bm.replace("hey_", "")
        if lower_name == bm or lower_name.replace(" ", "_") == bm or normalized_bm == lower_name or normalized_bm == lower_name.replace("hey_", ""):
            return bm
            
    # If not found anywhere, raise exception
    raise FileNotFoundError(
        f"Wake-word model '{model_name_or_path}' could not be resolved. "
        f"It is neither a built-in model {list(BUILTIN_MODELS)} nor a valid file path: {resolved_path}"
    )
