import json
import os
import numpy as np
import ollama

class LocalRAG:
    def __init__(self, vector_store_path="data/vector_store.json", embed_model="nomic-embed-text"):
        self.vector_store_path = vector_store_path
        self.embed_model = embed_model
        self.chunks = []
        self.embeddings = []
        self._load_store()

    def _load_store(self):
        if os.path.exists(self.vector_store_path):
            try:
                with open(self.vector_store_path, 'r', encoding='utf-8') as f:
                    data = json.load(f)
                    self.chunks = data.get("chunks", [])
                    self.embeddings = np.array(data.get("embeddings", []), dtype=np.float32)
                print(f"📦 Loaded {len(self.chunks)} vectors from {self.vector_store_path}")
            except Exception as e:
                print(f"❌ Failed to load vector store: {e}")

    def save_store(self):
        os.makedirs(os.path.dirname(self.vector_store_path), exist_ok=True)
        data = {
            "chunks": self.chunks,
            "embeddings": self.embeddings.tolist() if isinstance(self.embeddings, np.ndarray) else self.embeddings
        }
        with open(self.vector_store_path, 'w', encoding='utf-8') as f:
            json.dump(data, f)
        print(f"💾 Saved {len(self.chunks)} vectors to {self.vector_store_path}")

    def get_embedding(self, text: str):
        response = ollama.embeddings(model=self.embed_model, prompt=text)
        return response["embedding"]

    def ingest_xml(self, xml_path: str):
        print(f"📚 Ingesting {xml_path}...")
        with open(xml_path, 'r', encoding='utf-8') as f:
            content = f.read()

        files = content.split('<file path="')
        new_chunks = []
        
        for file_data in files[1:]:
            idx = file_data.find('">')
            if idx == -1:
                continue
            file_name = file_data[:idx]
            file_content = file_data[idx+2:].split('</file>')[0].strip()

            # Heading-aware chunking
            sections = file_content.split('\n## ')
            for i, section in enumerate(sections):
                if not section.strip(): continue
                text = section if i == 0 else "## " + section
                if len(text.split()) < 15: continue
                
                chunk_dict = {
                    "source": file_name,
                    "text": text.strip()
                }
                new_chunks.append(chunk_dict)

        print(f"🧩 Created {len(new_chunks)} chunks. Generating embeddings...")
        
        embeddings = []
        for i, chunk in enumerate(new_chunks):
            if i % 10 == 0:
                print(f"Embedding chunk {i+1}/{len(new_chunks)}...")
            emb = self.get_embedding(chunk["text"])
            embeddings.append(emb)
        print("✅ Embeddings generated.")

        self.chunks = new_chunks
        self.embeddings = np.array(embeddings, dtype=np.float32)
        self.save_store()

    def search(self, query: str, top_k=3) -> list:
        if len(self.chunks) == 0:
            return []
            
        query_emb = np.array(self.get_embedding(query), dtype=np.float32)
        norm_q = np.linalg.norm(query_emb)
        norms_db = np.linalg.norm(self.embeddings, axis=1)
        
        norms = norms_db * norm_q
        norms[norms == 0] = 1e-10
        
        similarities = np.dot(self.embeddings, query_emb) / norms
        
        top_indices = np.argsort(similarities)[-top_k:][::-1]
        
        results = []
        for idx in top_indices:
            results.append({
                "source": self.chunks[idx]["source"],
                "text": self.chunks[idx]["text"],
                "score": float(similarities[idx])
            })
            
        return results

if __name__ == "__main__":
    rag = LocalRAG()
    if len(rag.chunks) == 0:
        rag.ingest_xml("smart city.xml")
    
    res = rag.search("how does the smart parking system detect available spots?")
    for i, r in enumerate(res):
        print(f"--- Top {i+1} (Score: {r['score']:.4f}) [{r['source']}] ---")
        print(r['text'][:200].replace('\n', ' ') + "...\n")
