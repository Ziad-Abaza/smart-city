/**
 * Face recognition camera overlay — glassmorphism panel with live feed
 */
import { bus } from '../core/event-bus.js';

const STATUS_LABELS = {
  scanning: 'Scanning...',
  recognizing: 'Recognizing',
  liveness: 'Liveness Check',
  verified: 'Verified',
  unknown: 'Unknown Face',
  error: 'Error',
};

export class CameraOverlay {
  constructor(root) {
    this.root = root;
    this.panel = root.querySelector('.camera-panel');
    this.video = root.querySelector('.camera-feed');
    this.canvas = root.querySelector('.camera-canvas');
    this.ctx = this.canvas.getContext('2d');
    this.statusEl = root.querySelector('.camera-status');
    this.userEl = root.querySelector('.camera-user');
    this.confidenceEl = root.querySelector('.camera-confidence');
    this.confidenceFill = root.querySelector('.camera-confidence-fill');

    this.stream = null;
    this._animFrame = null;
    this._faceBox = null;
    this._confidence = 0;

    bus.on('face:change', (meta) => this._onFaceChange(meta));
    bus.on('face:frame', (data) => this._onRemoteFrame(data));
  }

  async _onFaceChange({ active, faceStatus, user, confidence, landmarks, bbox }) {
    this.root.classList.toggle('is-active', active);
    this.root.setAttribute('aria-hidden', active ? 'false' : 'true');

    if (!active) {
      this._stopCamera();
      return;
    }

    const status = faceStatus || 'scanning';
    this._setStatus(status, user, confidence);

    if (bbox) this._faceBox = bbox;
    if (landmarks) this._landmarks = landmarks;
    if (confidence != null) this._confidence = confidence;

    if (!this.stream) {
      await this._startCamera();
    }
  }

  _setStatus(status, user, confidence) {
    const label = STATUS_LABELS[status] || status;
    this.statusEl.textContent = label;
    this.statusEl.dataset.status = status;
    this.userEl.textContent = user || '—';
    const pct = confidence != null ? Math.round(confidence * 100) : 0;
    this.confidenceEl.textContent = confidence != null ? `Confidence ${pct}%` : '';
    if (this.confidenceFill) this.confidenceFill.style.width = `${pct}%`;
  }

  async _startCamera() {
    try {
      this.stream = true;
      this.video.src = "http://192.168.43.167:5002/stream";
      this._drawLoop();
    } catch (err) {
      console.warn('Camera unavailable, using placeholder', err);
      this._setStatus('error');
      this.userEl.textContent = 'Camera unavailable';
    }
  }

  _stopCamera() {
    if (this._animFrame) cancelAnimationFrame(this._animFrame);
    this._animFrame = null;
    this.stream = null;
    this.video.src = "";
    this._faceBox = null;
    this._landmarks = null;
  }

  _onRemoteFrame({ imageData, bbox, landmarks, confidence, user, status }) {
    if (!this.root.classList.contains('is-active')) return;
    if (bbox) this._faceBox = bbox;
    if (landmarks) this._landmarks = landmarks;
    if (confidence != null) this._confidence = confidence;
    if (user) this.userEl.textContent = user;
    if (status) this._setStatus(status, user, confidence);
    if (imageData) {
      this.ctx.putImageData(imageData, 0, 0);
    }
  }

  _drawLoop() {
    const draw = () => {
      if (!this.stream) return;
      const { video, canvas, ctx } = this;
      if (video.complete && video.naturalWidth > 0) {
        canvas.width = video.naturalWidth;
        canvas.height = video.naturalHeight;
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        if (this._faceBox) {
          const { x, y, w, h } = this._faceBox;
          ctx.strokeStyle = 'rgba(100, 220, 255, 0.85)';
          ctx.lineWidth = 2;
          ctx.shadowColor = 'rgba(80, 200, 255, 0.5)';
          ctx.shadowBlur = 12;
          ctx.strokeRect(x, y, w, h);
          ctx.shadowBlur = 0;
        }

        if (this._landmarks?.length) {
          ctx.fillStyle = 'rgba(180, 230, 255, 0.7)';
          for (const pt of this._landmarks) {
            ctx.beginPath();
            ctx.arc(pt.x, pt.y, 2, 0, Math.PI * 2);
            ctx.fill();
          }
        }
      }
      this._animFrame = requestAnimationFrame(draw);
    };
    draw();
  }
}
