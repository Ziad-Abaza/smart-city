from pathlib import Path

# Add project root to sys.path
root_path = Path(__file__).resolve().parent.parent
if str(root_path) not in sys.path:
    sys.path.insert(0, str(root_path))

import requests
import cv2
import numpy as np
import threading
import time
from core.config_manager import config_manager

class VideoStream:
    def __init__(self, stream_url, window_size):
        self.stream_url = stream_url
        self.window_size = window_size
        self.frame = None
        self.frame_lock = threading.Lock()  # Lock for thread-safe frame updates
        self.running = False
        self.thread = None

    def start(self):
        """Start the video streaming thread."""
        self.running = True
        self.thread = threading.Thread(target=self._video_stream, daemon=True)
        self.thread.start()

    def stop(self):
        """Stop the video streaming thread."""
        self.running = False
        if self.thread:
            self.thread.join()

    def _video_stream(self):
        """Internal method to handle the video streaming."""
        while self.running:
            try:
                # Open stream connection
                stream = requests.get(self.stream_url, stream=True, timeout=0.5)
                if not stream.status_code == 200:
                    print("Error: Could not open ESP32-CAM stream. Retrying...")
                    time.sleep(1)  # Wait before retrying
                    continue

                bytes_data = b""
                for chunk in stream.iter_content(chunk_size=512):
                    bytes_data += chunk

                    # Look for the boundary of the JPEG frame (MJPEG boundary)
                    a = bytes_data.find(b"\xff\xd8")  # Start of the JPEG frame
                    b = bytes_data.find(b"\xff\xd9")  # End of the JPEG frame

                    if a != -1 and b != -1:
                        jpg = bytes_data[a:b+2]  # Extract the complete JPEG frame
                        bytes_data = bytes_data[b+2:]  # Keep the remaining data
                        
                    # Bound the MJPEG parser buffer to prevent OOM
                    max_buffer_size = config_manager.get("face_recognition_server", {}).get("mjpeg_max_buffer_bytes", 5 * 1024 * 1024)
                    if len(bytes_data) > max_buffer_size:
                        print("Warning: MJPEG buffer exceeded limit. Dropping corrupted data.")
                        bytes_data = b""

                        # Ensure jpg is not empty before decoding
                        if len(jpg) == 0:
                            continue

                        # Convert the JPEG frame to an image
                        img = cv2.imdecode(np.frombuffer(jpg, dtype=np.uint8), cv2.IMREAD_COLOR)

                        if img is not None:
                            # Apply transformations to the frame
                            img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)  # Convert frame to RGB
                            img = cv2.resize(img, self.window_size)  # Resize the frame to fit the window

                            # Update the frame safely
                            with self.frame_lock:
                                self.frame = img

            except Exception as e:
                print(f"Error with video stream: {e}. Reconnecting...")
                time.sleep(1)  # Wait before retrying
                continue

    def get_frame(self):
        """Get the current frame in a thread-safe manner."""
        with self.frame_lock:
            return self.frame
        
if __name__ == "__main__":
    # Configuration for testing
    video_url = config_manager.get("face_recognition_server", {}).get("video_feed_url", "http://192.168.1.97:81/stream")
    WINDOW_SIZE = (360, 360)

    # Initialize VideoStream
    video_stream = VideoStream(video_url, WINDOW_SIZE)
    video_stream.start()  # Start the video streaming thread

    try:
        while True:
            # Get the current frame
            frame = video_stream.get_frame()
            if frame is not None:
                # Display the frame using OpenCV (for testing purposes)
                cv2.imshow("Video Stream", cv2.cvtColor(frame, cv2.COLOR_RGB2BGR))
                if cv2.waitKey(1) & 0xFF == ord('q'):  # Press 'q' to quit
                    break
    except KeyboardInterrupt:
        print("Exiting...")
    finally:
        # Cleanup
        video_stream.stop()
        cv2.destroyAllWindows()
