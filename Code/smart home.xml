from flask import Flask, Response
import cv2

app = Flask(__name__)

# Use the default camera (0). Based on your lsusb output, this is the desired camera.
camera = cv2.VideoCapture(0)

# Optimize streaming settings (adjust as needed to reduce network usage)
camera.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
camera.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)
camera.set(cv2.CAP_PROP_FPS, 15)


def gen_frames():
    while True:
        success, frame = camera.read()
        if not success:
            break
        else:
            # Encode the frame as a JPEG image
            ret, buffer = cv2.imencode(".jpg", frame)
            frame = buffer.tobytes()

            # Prepare the MJPEG stream headers
            yield (
                b"--frame\r\n"
                b"Content-Type: image/jpeg\r\n\r\n" + frame + b"\r\n"
            )


@app.route("/stream")
def video_feed():
    # Return the continuous MJPEG stream
    return Response(
        gen_frames(),
        mimetype="multipart/x-mixed-replace; boundary=frame"
    )


@app.route("/")
def index():
    return "Camera Stream Server is running. Access /stream to view the live video feed."


if __name__ == "__main__":
    # Run the server on a port different from the Arduino service (e.g., 5002)
    app.run(host="0.0.0.0", port=5002, threaded=True)
