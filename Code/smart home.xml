"""
WebSocket bridge + static UI server for clone_main.py.

Usage (production — single entry point):
    python clone_main.py

Standalone UI only (no assistant state):
    python ui/server.py
"""
from __future__ import annotations

import asyncio
import json
import logging
import os
import socket
import threading
import time
from functools import partial
from http.server import ThreadingHTTPServer, SimpleHTTPRequestHandler
from typing import Any

import sys, os
# Ensure the project root is on PYTHONPATH for relative imports
sys.path.append(os.path.abspath(os.path.join(os.path.dirname(__file__), '..')))
from core.ui_config import HTTP_PORT, WS_PORT

PROJECT_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
try:
    import websockets
    from websockets.server import serve
except ImportError:
    websockets = None  # type: ignore

logger = logging.getLogger(__name__)

_clients: set = set()
_loop: asyncio.AbstractEventLoop | None = None
_ws_thread: threading.Thread | None = None
_http_thread: threading.Thread | None = None
_bridge_ready = threading.Event()
_bridge_error: str | None = None
_remote_publish_loop: asyncio.AbstractEventLoop | None = None
_remote_publish_thread: threading.Thread | None = None
_remote_ws = None
_emit_stats = {"sent": 0, "dropped_no_loop": 0, "dropped_no_clients": 0, "remote_sent": 0}

_snapshot: dict[str, Any] = {
    "state": "dormant",
    "status": "Starting assistant...",
    "transcript": "",
    "response": "",
    "ready": False,
    "face": {"active": False, "status": None, "user": None, "confidence": None},
}


def _apply_payload_to_snapshot(payload: dict[str, Any]) -> None:
    """Keep snapshot in sync for new UI connections."""
    msg_type = payload.get("type")
    if msg_type == "state":
        _snapshot["state"] = payload.get("value", _snapshot["state"])
    elif msg_type == "status":
        _snapshot["status"] = payload.get("text", "")
    elif msg_type == "transcript":
        _snapshot["transcript"] = payload.get("text", "")
    elif msg_type == "response":
        _snapshot["response"] = payload.get("text", "")
    elif msg_type == "ready":
        _snapshot["ready"] = bool(payload.get("value"))
    elif msg_type == "face":
        _snapshot["face"] = {
            "active": bool(payload.get("active")),
            "status": payload.get("status"),
            "user": payload.get("user"),
            "confidence": payload.get("confidence"),
        }
    elif msg_type == "user":
        _snapshot["face"]["user"] = payload.get("name")


async def _handler(websocket):
    _clients.add(websocket)
    logger.info("UI client connected (%d total)", len(_clients))
    try:
        await websocket.send(json.dumps({"type": "snapshot", **_snapshot}))
        async for raw in websocket:
            if not raw:
                continue
            try:
                payload = json.loads(raw)
            except json.JSONDecodeError:
                continue
            if payload.get("type") == "ping":
                await websocket.send(json.dumps({"type": "pong", "ts": time.time()}))
                continue
            _apply_payload_to_snapshot(payload)
            await _broadcast(json.dumps(payload), exclude=websocket)
    finally:
        _clients.discard(websocket)
        logger.info("UI client disconnected (%d remaining)", len(_clients))


async def _broadcast(message: str, exclude=None):
    if not _clients:
        return
    targets = [c for c in list(_clients) if c is not exclude]
    if not targets:
        return
    await asyncio.gather(*[c.send(message) for c in targets], return_exceptions=True)


def _run_server():
    global _loop, _bridge_error
    _loop = asyncio.new_event_loop()
    asyncio.set_event_loop(_loop)

    async def main():
        global _bridge_error
        try:
            async with serve(_handler, "127.0.0.1", WS_PORT):
                logger.info("UI bridge listening on ws://127.0.0.1:%d", WS_PORT)
                _bridge_ready.set()
                await asyncio.Future()
        except OSError as exc:
            _bridge_error = f"Port {WS_PORT} in use — stop other ui/server.py processes ({exc})"
            logger.error(_bridge_error)
            _bridge_ready.set()

    try:
        _loop.run_until_complete(main())
    except Exception as exc:
        _bridge_error = str(exc)
        logger.exception("UI bridge crashed: %s", exc)
        _bridge_ready.set()
    finally:
        if _bridge_error:
            _loop = None


class _HealthHandler(SimpleHTTPRequestHandler):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, directory=PROJECT_ROOT, **kwargs)

    def log_message(self, format, *args):
        if args and str(args[0]).startswith("GET /ui/api/"):
            return
        super().log_message(format, *args)

    def do_GET(self):
        if self.path.rstrip("/") == "/ui/api/health":
            body = json.dumps({
                "bridge_ready": bridge_is_ready(),
                "bridge_error": _bridge_error,
                "ws_port": WS_PORT,
                "http_port": HTTP_PORT,
                "clients": len(_clients),
                "emit_stats": dict(_emit_stats),
                "snapshot": _snapshot,
                "remote_publisher": _remote_ws is not None,
            }).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        super().do_GET()


def _run_static_server():
    server = ThreadingHTTPServer(("127.0.0.1", HTTP_PORT), _HealthHandler)
    logger.info("UI static server at http://127.0.0.1:%d/ui/", HTTP_PORT)
    server.serve_forever()


def start_static_server_background():
    global _http_thread
    if _http_thread and _http_thread.is_alive():
        return
    _http_thread = threading.Thread(target=_run_static_server, daemon=True, name="ui-static")
    _http_thread.start()

def start_bridge_background():
    global _ws_thread
    if websockets is None:
        _bridge_error = "websockets not installed (pip install websockets)"
        logger.warning(_bridge_error)
        _bridge_ready.set()
        return
    if _ws_thread and _ws_thread.is_alive():
        return
    _bridge_ready.clear()
    _ws_thread = threading.Thread(target=_run_server, daemon=True, name="ui-bridge")
    _ws_thread.start()

def bridge_is_ready() -> bool:
    return _bridge_ready.is_set() and _bridge_error is None and _loop is not None


def wait_for_bridge(timeout: float = 15.0) -> bool:
    start_bridge_background()
    if not _bridge_ready.wait(timeout):
        logger.error("UI bridge did not start within %.1fs", timeout)
        return False
    if _bridge_error:
        logger.error("UI bridge error: %s", _bridge_error)
        return False
    return True


def port_in_use(port: int) -> bool:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.settimeout(0.5)
        return sock.connect_ex(("127.0.0.1", port)) == 0


def _run_remote_publisher():
    global _remote_publish_loop, _remote_ws

    async def _publisher():
        global _remote_ws
        uri = f"ws://127.0.0.1:{WS_PORT}"
        while True:
            try:
                async with websockets.connect(uri) as ws:
                    _remote_ws = ws
                    logger.info("UIBridge remote publisher connected to %s", uri)
                    while True:
                        await asyncio.sleep(3600)
            except Exception as exc:
                _remote_ws = None
                logger.warning("Remote publisher disconnected: %s — retrying", exc)
                await asyncio.sleep(2)

    _remote_publish_loop = asyncio.new_event_loop()
    asyncio.set_event_loop(_remote_publish_loop)
    _remote_publish_loop.run_until_complete(_publisher())


def start_remote_publisher_background():
    """Connect to an existing bridge when this process could not bind the port."""
    global _remote_publish_thread
    if _remote_publish_thread and _remote_publish_thread.is_alive():
        return
    _remote_publish_thread = threading.Thread(
        target=_run_remote_publisher, daemon=True, name="ui-remote-publisher"
    )
    _remote_publish_thread.start()


def ensure_bridge(timeout: float = 15.0) -> bool:
    """Start in-process bridge or fallback to remote publisher.
    Returns True when UI updates can be delivered.
    """
    start_static_server_background()
    if wait_for_bridge(timeout=3.0):
        logger.info("UI bridge ready (in-process)")
        return True

    if _bridge_error and port_in_use(WS_PORT):
        logger.info(
            "Port %d already in use — using remote publisher to existing bridge. "
            "For production, stop standalone ui/server.py and run only clone_main.py.",
            WS_PORT,
        )
        start_remote_publisher_background()
        deadline = time.time() + timeout
        while time.time() < deadline:
            if _remote_ws is not None:
                logger.info("UI remote publisher ready")
                return True
            time.sleep(0.2)
        logger.error("Remote publisher failed to connect within %.1fs", timeout)
        return False

    logger.error("UI bridge unavailable: %s", _bridge_error or "unknown error")
    return False


class UIBridge:
    """Thread-safe API for pushing UI state from the voice assistant."""

    @staticmethod
    def _emit(payload: dict[str, Any]):
        _apply_payload_to_snapshot(payload)
        msg = json.dumps(payload)
        msg_type = payload.get("type", "?")

        if bridge_is_ready() and _clients:
            asyncio.run_coroutine_threadsafe(_broadcast(msg), _loop)
            _emit_stats["sent"] += 1
            logger.debug("UIBridge sent %s to %d client(s)", msg_type, len(_clients))
            return

        if _remote_ws is not None and _remote_publish_loop is not None:
            async def _send():
                await _remote_ws.send(msg)

            asyncio.run_coroutine_threadsafe(_send(), _remote_publish_loop)
            _emit_stats["remote_sent"] += 1
            logger.debug("UIBridge remote sent %s", msg_type)
            return

        if not bridge_is_ready():
            _emit_stats["dropped_no_loop"] += 1
            logger.debug("UIBridge dropped %s (bridge not ready, clients=%d)", msg_type, len(_clients))
        elif not _clients:
            _emit_stats["dropped_no_clients"] += 1
            logger.debug("UIBridge dropped %s (no UI clients connected)", msg_type)

    @classmethod
    def snapshot(cls) -> dict[str, Any]:
        return dict(_snapshot)

    @classmethod
    def set_state(cls, state: str):
        _snapshot["state"] = state
        cls._emit({"type": "state", "value": state})

    @classmethod
    def set_status(cls, text: str):
        _snapshot["status"] = text
        cls._emit({"type": "status", "text": text})

    @classmethod
    def set_transcript(cls, text: str):
        _snapshot["transcript"] = text
        cls._emit({"type": "transcript", "text": text})

    @classmethod
    def set_response(cls, text: str):
        _snapshot["response"] = text
        cls._emit({"type": "response", "text": text})

    @classmethod
    def set_ready(cls, ready: bool = True):
        _snapshot["ready"] = ready
        cls._emit({"type": "ready", "value": ready})

    @classmethod
    def set_face(cls, active: bool, status: str = "scanning", user: str | None = None, confidence: float | None = None):
        _snapshot["face"] = {
            "active": active,
            "status": status,
            "user": user,
            "confidence": confidence,
        }
        cls._emit({
            "type": "face",
            "active": active,
            "status": status,
            "user": user,
            "confidence": confidence,
        })

    @classmethod
    def set_user(cls, name: str):
        _snapshot["face"]["user"] = name
        cls._emit({"type": "user", "name": name})

    @classmethod
    def feed_audio(cls, samples: list[float]):
        cls._emit({"type": "audio", "samples": samples})

    @classmethod
    def debug_pulse(cls):
        """Emit a visible test sequence — used by ui/test_bridge.py and diagnostics."""
        cls.set_status("Bridge debug pulse")
        for state in ("listening", "thinking", "speaking", "dormant"):
            cls.set_state(state)
            time.sleep(0.35)


if __name__ == "__main__":
    logging.basicConfig(level=logging.INFO)
    ensure_bridge()
    logger.info("Open http://localhost:%d/ui/  (bridge: ws://localhost:%d)", HTTP_PORT, WS_PORT)
    logger.info("Health: http://localhost:%d/ui/api/health", HTTP_PORT)
    try:
        while True:
            time.sleep(1)
    except KeyboardInterrupt:
        pass

# Added wrapper for unified startup
def start_ui_backend(timeout: float = 15.0) -> bool:
    """Public API to start UI bridge and static server.
    Returns True if UI is ready.
    """
    return ensure_bridge(timeout)
