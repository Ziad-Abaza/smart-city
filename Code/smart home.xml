from core.config_manager import config_manager

# Fix for PyTorch 2.6 safe unpickling
from torch.serialization import add_safe_globals
add_safe_globals([XttsConfig])

# Override torch.load to force full model loading
original_torch_load = torch.load
def patched_torch_load(f, *args, **kwargs):
    kwargs["weights_only"] = False
    return original_torch_load(f, *args, **kwargs)
torch.load = patched_torch_load


class StreamingXTTS:
    def __init__(self, config_path, checkpoint_dir, device=None):
        self.device = device if device else ("cuda" if torch.cuda.is_available() else "cpu")

        # Load config
        self.config = XttsConfig()
        self.config.load_json(config_path)

        # Initialize model
        self.model = Xtts.init_from_config(self.config)
        self.model.load_checkpoint(self.config, checkpoint_dir=checkpoint_dir, eval=True)
        self.model.to(self.device)

        self.sample_rate = 24000

    @staticmethod
    def split_text_into_chunks(text, chunk_size=5):
        words = text.split()
        for i in range(0, len(words), chunk_size):
            yield " ".join(words[i:i+chunk_size])

    def synthesize_streaming(self, text, speaker_wav=None, language="en", gpt_cond_len=3):
        try:
            for idx, chunk in enumerate(self.split_text_into_chunks(text)):
                print(f"Synthesizing chunk {idx + 1}: '{chunk}'")

                outputs = self.model.synthesize(
                    chunk,
                    self.config,
                    speaker_wav=speaker_wav,
                    gpt_cond_len=gpt_cond_len,
                    language=language,
                )

                wav = outputs.get("wav")
                if wav is not None:
                    # Play chunk immediately
                    sd.play(wav, self.sample_rate)

                    duration_sec = len(wav) / self.sample_rate
                    time.sleep(duration_sec * 0.9)  # Slight overlap for smooth streaming

                else:
                    print(f"Warning: No audio generated for chunk {idx + 1}")

        except Exception as e:
            print(f"Error during synthesis streaming: {e}")


if __name__ == "__main__":
    xtts_config = config_manager.get("tts_models", {}).get("xtts", {})
    
