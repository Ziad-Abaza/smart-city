from flask import Flask, request, jsonify, Response
from core.config_manager import config_manager
from core.camera_manager import camera_manager
from face_recognition.recognizer import FaceRecognition
from face_recognition.enrollment import FaceEnrollment
from face_recognition.liveness import FakeRealFaceDetection
import cv2
import logging
import threading
import time
import mediapipe as mp

logging.basicConfig(level=logging.WARNING)
app = Flask(__name__)

# ---------------------------------------------------------------------
# Instantiate FaceRecognition ONCE at module startup.
# Re-instantiating per-request reloads MediaPipe + all face embeddings
# every call, adding 5-15s of latency before the camera even opens.
# ---------------------------------------------------------------------
try:
    _face_recognition = FaceRecognition()
    logging.info("FaceRecognition model loaded at startup.")
except Exception as _e:
    _face_recognition = None
    logging.error(f"FaceRecognition failed to initialize: {_e}")

try:
    _liveness_checker = FakeRealFaceDetection()
    logging.info("FakeRealFaceDetection loaded at startup.")
except Exception as _e:
    _liveness_checker = None
    logging.error(f"FakeRealFaceDetection failed to initialize: {_e}")

def start_face_enrollment():
    user_name = input("Enter your name for enrollment: ")
    face_enrollment = FaceEnrollment(user_name)
    face_enrollment.enroll_face()
    print(f"Enrollment for {user_name} complete.")
    return {"status": "success", "message": f"Enrollment for {user_name} complete"}

@app.route('/start_face_recognition', methods=['GET', 'POST'])
def api_start_face_recognition():
    logging.debug("Starting face recognition endpoint...")
    global _face_recognition
    try:
        if _face_recognition is None or _liveness_checker is None:
            return jsonify({"status": "error", "message": "Models not loaded"}), 500
        face_recognition = _face_recognition
        liveness_checker = _liveness_checker
        if not camera_manager.start_camera():
            logging.error("Failed to start centralized camera manager.")
            return jsonify({"status": "error", "message": "Failed to access video feed or local webcam"}), 500

        # Wait for a face with timeout
        start_time = time.time()
        fr_config = config_manager.get("face_recognition_server", {})
        timeout = fr_config.get("recognition_timeout_s", 30)
        window_size = fr_config.get("multiframe_window_size", 5)
        majority_ratio = fr_config.get("multiframe_majority_ratio", 0.7)
        required_votes = max(1, int(window_size * majority_ratio))
        
        from collections import deque
        result_buffer = deque(maxlen=window_size)
        
        face_detected = False
        frame = None
        name = "Unknown"

        while time.time() - start_time < timeout:
            frame = camera_manager.get_latest_frame()
            if frame is None:
                time.sleep(0.05)
                continue

            try:
                # Call recognize_face to check for face
                frame, name, face_detected_now = face_recognition.recognize_face(frame)
                
                if face_detected_now:
                    # Run liveness check
                    frame, liveness_label = liveness_checker.detect_fake_or_real(frame)
                    
                    if liveness_label == "Real Face":
                        result_buffer.append(name)
                        logging.debug(f"Frame recognized as {name}")
                    else:
                        result_buffer.append("Fake")
                        logging.debug("Face failed liveness check.")
                else:
                    result_buffer.append(None)
                    
                # Check for consensus
                from collections import Counter
                valid_votes = [n for n in result_buffer if n is not None and n != "Fake"]
                if len(result_buffer) == window_size:
                    vote_counts = Counter(valid_votes)
                    if vote_counts:
                        most_common_name, count = vote_counts.most_common(1)[0]
                        if count >= required_votes and most_common_name != "Unknown":
                            name = most_common_name
                            face_detected = True
                            logging.debug(f"Consensus reached for: {name}")
                            break

            except Exception as e:
                logging.error(f"Error in recognize_face: {e}")
                continue

            # Display frame for debugging
            cv2.imshow("Face Recognition", frame)
            if cv2.waitKey(100) & 0xFF == ord('q'):
                logging.info("User stopped recognition")
                break

        camera_manager.stop_camera()
        cv2.destroyAllWindows()

        if not face_detected:
            logging.warning("No face detected within timeout")
            return jsonify({"status": "failure", "message": "No face detected within timeout"}), 401

        if name and name != "Unknown":
            logging.info(f"Face recognition successful for {name}")
            return jsonify({"status": "success", "user": name})
        else:
            logging.warning("No recognized face detected")
            return jsonify({"status": "failure", "message": "No recognized face detected"}), 401

    except Exception as e:
        logging.error(f"Unexpected error: {e}")
        return jsonify({"status": "error", "message": str(e)}), 500

if __name__ == "__main__":
    if "--api" in sys.argv:
        choice = '3'
    else:
        choice = input("Choose an option:\n1. Start Face Enrollment\n2. Start Face Recognition\n3. Start API Server\nEnter choice (1/2/3): ")

    if choice == '1':
        start_face_enrollment()
    elif choice == '2':
        face_recognition = _face_recognition if _face_recognition else FaceRecognition()
        if not camera_manager.start_camera():
            print("Failed to start camera")
            sys.exit(1)
            
        while True:
            frame = camera_manager.get_latest_frame()
            if frame is None:
                time.sleep(0.05)
                continue
            frame, name, _ = face_recognition.recognize_face(frame)
            cv2.imshow("Face Recognition", frame)
            if name and face_recognition._should_announce(name):
                print(f"Hello, {name}!")
            if cv2.waitKey(1) & 0xFF == ord('q'):
                break
        camera_manager.stop_camera()
        cv2.destroyAllWindows()
    elif choice == '3':
        host = config_manager.get("face_recognition_server", {}).get("host", "0.0.0.0")
        port = config_manager.get("face_recognition_server", {}).get("port", 5001)
        app.run(host=host, port=port)
    else:
        print("Invalid choice. Exiting.")
