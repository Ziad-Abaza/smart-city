        function appendLog(rawText) {
            const time = new Date().toISOString().split('T')[1].substring(0, 12);
            const entry = document.createElement('div');
            entry.className = 'log-entry';
            
            let badgeClass = 'badge-sys';
            let badgeText = 'SYS';
            let message = rawText;

            // Parse formatted LOG: lines from Arduino
            if (rawText.startsWith('LOG:')) {
                const parts = rawText.split(':');
                if (parts[1].includes('PIR')) {
                    badgeClass = 'badge-pir';
                    badgeText = 'PIR EVENT';
                    message = `<span style="color: ${parts[2] === 'HIGH' ? 'var(--warning)' : 'var(--text-muted)'}">${parts[1]} -> ${parts[2]}</span>`;
                } else if (parts[1].includes('RELAY')) {
                    badgeClass = 'badge-relay';
                    badgeText = 'RELAY';
                    message = `<span style="color: ${parts[2] === 'ON' ? 'var(--success)' : 'var(--text-muted)'}">${parts[1]} -> ${parts[2]}</span>`;
                }
            } else if (rawText.startsWith('[CMD]')) {
                badgeText = 'API POST';
                message = `<span style="color: #cbd5e1;">${rawText.replace('[CMD]', '')}</span>`;
            } else {
                // Raw generic print
                message = `<span style="color: #cbd5e1;">${rawText}</span>`;
            }
            
            entry.innerHTML = `
                <span class="log-time">${time}</span>
                <span class="badge ${badgeClass}">${badgeText}</span>
                <span>${message}</span>
            `;
            
            terminal.appendChild(entry);
            terminal.scrollTop = terminal.scrollHeight;
        }

        // Initialize Server-Sent Events (SSE)
        const evtSource = new EventSource("/stream_logs");
        evtSource.onmessage = function(event) {
            appendLog(event.data);
        };
        evtSource.onerror = function() {
            appendLog("SSE Connection Lost. Attempting reconnect...");
        };

        // Polling for UI general status (every 5 seconds)
        setInterval(async () => {
            try {
                const res = await fetch('/api/status');
                const data = await res.json();
                document.getElementById('uptime').textContent = data.uptime;
                document.getElementById('sys-status').textContent = data.arduino_connected ? '🟢 Connected' : '🔴 Disconnected';
            } catch (e) {
                document.getElementById('sys-status').textContent = '🔴 Server Offline';
            }
        }, 5000);

        async function sendCommand(cmd) {
            appendLog(`[CMD] Firing: ${cmd}`);
            await fetch('/send_command', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ command: cmd })
            });
        }
    </script>
</body>
