bool lightStateC = false;

// Asynchronous UI Architecture State definitions
enum DisplayState {
  STATE_DASHBOARD,
  STATE_EMERGENCY_FIRE,
  STATE_EMERGENCY_GAS
};

DisplayState currentDisplayState = STATE_DASHBOARD;
DisplayState lastDisplayState = STATE_DASHBOARD;

// Environmental telemetry cache
float currentTemperature = NAN;
float currentHumidity = NAN;

// Non-blocking timer task variables (replaces delay loops)
unsigned long lastSafetyCheckTime = 0;
unsigned long lastDhtReadTime = 0;
unsigned long lastMotionCheckTime = 0;
unsigned long lastDisplayUpdateTime = 0;

const unsigned long safetyCheckInterval = 20;     // 20ms check (50Hz) for safety-critical inputs
const unsigned long dhtReadInterval = 2500;       // 2.5s update to meet DHT11 minimum specs
const unsigned long motionCheckInterval = 50;   // Rapid polling for zero-latency PIR detection
const unsigned long displayUpdateInterval = 250;  // 250ms periodic update for screen telemetry/status

// Asynchronous Buzzer State Machine
unsigned long lastBuzzerToggle = 0;
bool buzzerState = false;

// Asynchronous Servo State Machine (Zero-blocking sweep)
int targetServoAngle = 0;
int currentServoAngle = 0;
unsigned long lastServoMoveTime = 0;
const unsigned long servoMoveInterval = 15;       // 15ms per degree sweep speed

// Asynchronous Transient Toast Notification System
const char* currentToast = NULL;
unsigned long toastExpireTime = 0;

// Manual Override Warning timer
unsigned long manualWarningExpireTime = 0;

// Forward Declarations
void allLight(bool state);
void runSafetyCheck();
void runDhtRead();
void runPirCheck();
void updateServo();
void updateBuzzer();
void updateToast();
void handleStateTransition();
void resetUiCache();
void updateDashboard(bool forceRedraw);
void drawHeader(bool forceRedraw);
void drawGrid(bool forceRedraw);
void drawEnvironment(bool forceRedraw, float temp, float hum);
void drawZoneStatus(bool forceRedraw);
void displayAlert(const char* message, uint16_t color);
void setToast(const char* message, unsigned long durationMs = 2000);
void processCommand(String command);

void setup() {
  Serial.begin(9600);
  pinMode(FLAME_SENSOR_PIN, INPUT_PULLUP);
  pinMode(GAS_SENSOR_PIN, INPUT);
  pinMode(BUZZER_PIN, OUTPUT);
  pinMode(FAN_PIN, OUTPUT);
  pinMode(LIGHT_ROOM_A, OUTPUT);
  pinMode(LIGHT_ROOM_B, OUTPUT);
  pinMode(LIGHT_ROOM_C, OUTPUT);
  pinMode(PIR_ROOM_A, INPUT);
  pinMode(PIR_ROOM_B, INPUT);
  pinMode(PIR_ROOM_C, INPUT);
  
  // Attach and position servo immediately without using blocking loops
  WindowServo.attach(SERVO_WINDOW);
  WindowServo.write(0);
  currentServoAngle = 0;
  targetServoAngle = 0;

  dht.begin();
  
  // Initialize TFT in Landscape Mode (160x128)
  tft.initR(INITR_BLACKTAB);
  tft.setRotation(1); 
  tft.fillScreen(ST77XX_BLACK);
  
  allLight(RELAY_OFF);
  digitalWrite(FAN_PIN, RELAY_OFF);

  // Read initial environmental readings
  currentTemperature = dht.readTemperature();
  currentHumidity = dht.readHumidity();
  
  // Force full initial dashboard paint
  resetUiCache();
}

void loop() {
  unsigned long currentMillis = millis();

  // 1. Process incoming commands without blocking serial read
  if (Serial.available()) {
    String command = Serial.readStringUntil('\n');
    command.trim(); 
    processCommand(command);
  }

  // 2. Drive non-blocking servo sweep step
  updateServo();

  // 3. Drive non-blocking buzzer warning toggle
  updateBuzzer();

  // 4. Update status of visual toasts
  updateToast();

  // 5. Safety-critical reads (highest priority task running at 50Hz)
  if (currentMillis - lastSafetyCheckTime >= safetyCheckInterval) {
    lastSafetyCheckTime = currentMillis;
    runSafetyCheck();
  }

  // 6. PIR Motion Evaluation task (evaluates room PIR states every 1.0s)
  if (currentMillis - lastMotionCheckTime >= motionCheckInterval) {
    lastMotionCheckTime = currentMillis;
    runPirCheck();
  }

  // 7. Environmental Telemetry collection task (every 2.5s)
  if (currentMillis - lastDhtReadTime >= dhtReadInterval) {
    lastDhtReadTime = currentMillis;
    runDhtRead();
  }

  // 8. Screen state controller (transitions immediately on emergency alerts)
  handleStateTransition();

  // 9. Periodic Dashboard Rendering task (refreshes values every 250ms when idle)
  if (currentDisplayState == STATE_DASHBOARD) {
    if (currentMillis - lastDisplayUpdateTime >= displayUpdateInterval) {
      lastDisplayUpdateTime = currentMillis;
      updateDashboard(false); // Differential redraw avoids flickering
    }
  }
}

// Scans Flame and Gas pins; handles manual testing override timeouts
void runSafetyCheck() {
  bool fireActive = (digitalRead(FLAME_SENSOR_PIN) == LOW);
  bool gasActive = (digitalRead(GAS_SENSOR_PIN) == LOW);
  bool manualWarningActive = (manualWarningExpireTime > 0 && millis() < manualWarningExpireTime);

  if (fireActive) {
    currentDisplayState = STATE_EMERGENCY_FIRE;
    manualWarningExpireTime = 0; // Terminate manual test state if real hazard occurs
  } else if (gasActive) {
    currentDisplayState = STATE_EMERGENCY_GAS;
    manualWarningExpireTime = 0; // Terminate manual test state if real hazard occurs
  } else if (manualWarningActive) {
    currentDisplayState = STATE_EMERGENCY_FIRE;
  } else {
    if (manualWarningExpireTime > 0) {
      manualWarningExpireTime = 0; // Reset expired manual trigger
    }
    currentDisplayState = STATE_DASHBOARD;
  }
}

// Obtains sensor readings from DHT11
void runDhtRead() {
  float temp = dht.readTemperature();
  float hum = dht.readHumidity();

  if (!isnan(temp) && !isnan(hum)) {
    currentTemperature = temp;
    currentHumidity = hum;
  }
}

// Drives motion detection logic for rooms
void runPirCheck() {
  motion_detector(PIR_ROOM_A, LIGHT_ROOM_A, motionLastSeenA, motionStateA, lastDebounceTimeA, lastRawStateA, manualControlA, lightStateA);
  motion_detector(PIR_ROOM_B, LIGHT_ROOM_B, motionLastSeenB, motionStateB, lastDebounceTimeB, lastRawStateB, manualControlB, lightStateB);
  motion_detector(PIR_ROOM_C, LIGHT_ROOM_C, motionLastSeenC, motionStateC, lastDebounceTimeC, lastRawStateC, manualControlC, lightStateC);
}

// Non-blocking servo sweeping state machine
void updateServo() {
  if (currentServoAngle != targetServoAngle) {
    unsigned long curMillis = millis();
    if (curMillis - lastServoMoveTime >= servoMoveInterval) {
      lastServoMoveTime = curMillis;
      if (targetServoAngle > currentServoAngle) {
        currentServoAngle++;
      } else {
        currentServoAngle--;
      }
      WindowServo.write(currentServoAngle);
    }
  }
}

// Non-blocking buzzer pulsing state machine
void updateBuzzer() {
  if (currentDisplayState == STATE_EMERGENCY_FIRE || currentDisplayState == STATE_EMERGENCY_GAS) {
    unsigned long curMillis = millis();
    if (buzzerState) {
      if (curMillis - lastBuzzerToggle >= 300) { // 300ms active beep
        noTone(BUZZER_PIN);
        buzzerState = false;
        lastBuzzerToggle = curMillis;
      }
    } else {
      if (curMillis - lastBuzzerToggle >= 200) { // 200ms silent rest
        tone(BUZZER_PIN, 1000);
        buzzerState = true;
        lastBuzzerToggle = curMillis;
      }
    }
  } else {
    noTone(BUZZER_PIN);
    buzzerState = false;
  }
}

// Manages expiration and clearing of transient toast notifications
void updateToast() {
  if (currentToast != NULL && millis() >= toastExpireTime) {
    currentToast = NULL;
    lastDisplayUpdateTime = 0; // Request immediate redraw to clear the toast
  }
}

// Immediately transitions display contents between dashboard and emergency alert states
void handleStateTransition() {
  if (currentDisplayState != lastDisplayState) {
    if (currentDisplayState == STATE_EMERGENCY_FIRE) {
      displayAlert("FIRE ALERT!", ST77XX_RED);
      allLight(RELAY_OFF);
      digitalWrite(FAN_PIN, RELAY_OFF);
    } else if (currentDisplayState == STATE_EMERGENCY_GAS) {
      displayAlert("GAS ALERT!", ST77XX_YELLOW);
      allLight(RELAY_OFF);
      digitalWrite(FAN_PIN, RELAY_ON);
    } else {
      // Revert lights to ON to mirror legacy warning logic upon threat clearance
      allLight(RELAY_ON);
      lightStateA = lightStateB = lightStateC = true;
      
      tft.fillScreen(ST77XX_BLACK);
      resetUiCache();
    }
    lastDisplayState = currentDisplayState;
  }
}

void resetUiCache() {
  updateDashboard(true); // Redraw structural layout borders and static text
}

void updateDashboard(bool forceRedraw) {
  drawHeader(forceRedraw);
  drawGrid(forceRedraw);
  drawEnvironment(forceRedraw, currentTemperature, currentHumidity);
  drawZoneStatus(forceRedraw);
}

// Draws the system header or temporary toast message block
void drawHeader(bool forceRedraw) {
  static const char* lastDrawnToast = NULL;
  static bool lastDrawnWasToast = false;
  
  bool hasToast = (currentToast != NULL);
  
  if (forceRedraw || hasToast != lastDrawnWasToast || (hasToast && currentToast != lastDrawnToast)) {
