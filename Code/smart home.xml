// Room-by-room status column renderer (only refreshes mutated status characters to prevent flickering)
void drawZoneStatus(bool forceRedraw) {
  static bool lastLight[3] = {false, false, false};
  static int lastMotion[3] = {-1, -1, -1};
  static bool lastManual[3] = {false, false, false};
  
  for (int i = 0; i < 3; i++) {
    bool currentLight = (i == 0) ? lightStateA : (i == 1) ? lightStateB : lightStateC;
    int currentMotion = (i == 0) ? motionStateA : (i == 1) ? motionStateB : motionStateC;
    bool currentManual = (i == 0) ? manualControlA : (i == 1) ? manualControlB : manualControlC;
    
    if (forceRedraw || currentLight != lastLight[i] || currentMotion != lastMotion[i] || currentManual != lastManual[i]) {
      int cursorX = 6 + i * 53;
      
      if (forceRedraw) {
        tft.setCursor(cursorX, 72);
        tft.setTextSize(1);
        tft.setTextColor(COLOR_WHITE, ST77XX_BLACK);
        tft.print("ROOM ");
