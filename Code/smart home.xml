import os
import glob
from typing import Dict, Any

ALLOWED_ROOTS = [
    r"D:\coding\smart_home\voice_assistant\data",
    r"D:\Desktop\Smart city\DATA"
]

def is_path_allowed(path: str) -> bool:
    abs_path = os.path.abspath(path)
    for root in ALLOWED_ROOTS:
        abs_root = os.path.abspath(root)
        if abs_path.startswith(abs_root):
            return True
    return False

def handle_filesystem(params: Dict[str, Any]) -> Dict[str, Any]:
    action = params.get("action")
    path = params.get("path", "")
    content = params.get("content", "")
    pattern = params.get("pattern", "*")
    
    if not path and action != "search":
        return {"status": "error", "message": "Path is required."}
        
    abs_path = os.path.abspath(path) if path else ""
    
    if action in ["read", "write", "list"]:
        if not is_path_allowed(abs_path):
            return {"status": "denied", "message": f"Access to {abs_path} is denied. It is outside allowed roots."}
            
    if action == "read":
        if not os.path.exists(abs_path):
            return {"status": "error", "message": "File not found."}
        if not os.path.isfile(abs_path):
            return {"status": "error", "message": "Path is not a file."}
        # Max size check: 50KB
        if os.path.getsize(abs_path) > 50 * 1024:
            return {"status": "error", "message": "File too large to read."}
            
        try:
            with open(abs_path, "r", encoding="utf-8") as f:
                data = f.read()
            return {"status": "success", "data": {"content": data}}
        except Exception as e:
            return {"status": "error", "message": str(e)}
            
    elif action == "write":
        try:
            os.makedirs(os.path.dirname(abs_path), exist_ok=True)
            with open(abs_path, "w", encoding="utf-8") as f:
                f.write(content)
            return {"status": "success", "message": "File written successfully."}
        except Exception as e:
            return {"status": "error", "message": str(e)}
            
    elif action == "list":
        if not os.path.exists(abs_path):
            return {"status": "error", "message": "Directory not found."}
        if not os.path.isdir(abs_path):
            return {"status": "error", "message": "Path is not a directory."}
            
        try:
            entries = os.listdir(abs_path)
            return {"status": "success", "data": {"entries": entries}}
        except Exception as e:
            return {"status": "error", "message": str(e)}
            
    elif action == "search":
        # Search all allowed roots
        results = []
        for root in ALLOWED_ROOTS:
            search_path = os.path.join(root, "**", pattern)
            for match in glob.glob(search_path, recursive=True):
                results.append(match)
                if len(results) >= 50:
                    break
        return {"status": "success", "data": {"entries": results}}
        
    return {"status": "error", "message": "Invalid action."}
