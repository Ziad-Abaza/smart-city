import os
import sys
import time
import cv2
import numpy as np
from pathlib import Path

root_path = Path(__file__).resolve().parent.parent
if str(root_path) not in sys.path:
    sys.path.insert(0, str(root_path))

from face_recognition.recognizer import FaceRecognition
from core.config_manager import config_manager

def run_benchmarks():
    print("Initializing FaceRecognition system...")
    start_time = time.time()
    recognizer = FaceRecognition()
    init_time = time.time() - start_time
    print(f"System initialized in {init_time:.2f} seconds.")
    
    # 1. Latency Benchmark
    print("\n--- Latency Benchmark ---")
    # Create a synthetic white frame for worst-case MediaPipe inference
    synthetic_frame = np.ones((480, 640, 3), dtype=np.uint8) * 255
    
    # Warmup
    for _ in range(3):
        recognizer.recognize_face(synthetic_frame)
        
    latencies = []
    for _ in range(10):
        t0 = time.time()
        recognizer.recognize_face(synthetic_frame)
        latencies.append(time.time() - t0)
        
    print(f"Average single-frame recognition latency: {np.mean(latencies)*1000:.1f} ms")
    
    # 2. FAR (False Acceptance Rate) Benchmark
    print("\n--- FAR/FRR Benchmark ---")
    unknown_dir = recognizer.unknown_faces_dir
    false_accepts = 0
    total_impostor_attempts = 0
    
    if os.path.exists(unknown_dir):
        for img_name in os.listdir(unknown_dir):
            if not img_name.lower().endswith(('.png', '.jpg', '.jpeg')):
                continue
            img_path = os.path.join(unknown_dir, img_name)
            img = cv2.imread(img_path)
            if img is None:
                continue
            
            # Predict
            _, label, detected = recognizer.recognize_face(img)
            if detected:
                total_impostor_attempts += 1
                if label != "Unknown":
                    false_accepts += 1
                    
        if total_impostor_attempts > 0:
            far = (false_accepts / total_impostor_attempts) * 100
            print(f"FAR (False Acceptance Rate): {far:.2f}% ({false_accepts}/{total_impostor_attempts})")
        else:
            print("No valid impostor images found in unknown_faces directory to calculate FAR.")
            
    # 3. FRR (False Rejection Rate) Benchmark via Leave-One-Out Cross-Validation
    enrolled_dir = recognizer.enrolled_faces_dir
    false_rejects = 0
    total_genuine_attempts = 0
    
    if os.path.exists(enrolled_dir):
        people = [d for d in os.listdir(enrolled_dir) if os.path.isdir(os.path.join(enrolled_dir, d)) and d != "Unknown"]
        for person in people:
            person_dir = os.path.join(enrolled_dir, person)
            images = [f for f in os.listdir(person_dir) if f.lower().endswith(('.png', '.jpg', '.jpeg'))]
            
            for test_img_name in images:
                # Leave this image out
                test_img_path = os.path.join(person_dir, test_img_name)
                
                # Rebuild KNN without this image
                recognizer.known_embeddings = []
                recognizer.known_labels = []
                for p in people:
                    p_dir = os.path.join(enrolled_dir, p)
                    for f in os.listdir(p_dir):
                        if p == person and f == test_img_name:
                            continue # Leave out
                        # Load from cache since we just computed them
                        cache_path = os.path.join(p_dir, f) + ".npy"
                        if os.path.exists(cache_path):
                            recognizer.known_embeddings.append(np.load(cache_path))
                            recognizer.known_labels.append(p)
                            
                if len(recognizer.known_embeddings) == 0:
                    continue
                    
                n_neighbors = min(3, len(recognizer.known_embeddings))
                recognizer.nn.n_neighbors = n_neighbors
                recognizer.nn.fit(recognizer.known_embeddings)
                
                # Test
                img = cv2.imread(test_img_path)
                if img is None:
                    continue
                    
                _, label, detected = recognizer.recognize_face(img)
                if detected:
                    total_genuine_attempts += 1
                    if label != person:
                        false_rejects += 1
                        
        if total_genuine_attempts > 0:
            frr = (false_rejects / total_genuine_attempts) * 100
            print(f"FRR (False Rejection Rate): {frr:.2f}% ({false_rejects}/{total_genuine_attempts})")
        else:
            print("No valid enrolled images found to calculate FRR.")
            
    print("\nBenchmark completed.")

if __name__ == "__main__":
    run_benchmarks()
