/**
 * Ambient background — gradients, particles, depth
 */
export class BackgroundLayer {
  constructor(canvas) {
    this.canvas = canvas;
    this.ctx = canvas.getContext('2d');
    this.particles = Array.from({ length: 60 }, () => this._spawn());
    this._resize();
    window.addEventListener('resize', () => this._resize());
  }

  _spawn() {
    return {
      x: Math.random(),
      y: Math.random(),
      size: 0.5 + Math.random() * 2,
      speed: 0.00005 + Math.random() * 0.00015,
      phase: Math.random() * Math.PI * 2,
      drift: (Math.random() - 0.5) * 0.0002,
    };
  }

  _resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    this.canvas.width = window.innerWidth * dpr;
    this.canvas.height = window.innerHeight * dpr;
    this.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    this.w = window.innerWidth;
    this.h = window.innerHeight;
  }

  render(time, intensity = 0) {
    const ctx = this.ctx;
    const { w, h } = this;

    const grad = ctx.createRadialGradient(w * 0.5, h * 0.42, 0, w * 0.5, h * 0.5, Math.max(w, h) * 0.75);
    grad.addColorStop(0, `rgba(14, 28, 42, ${0.9 + intensity * 0.05})`);
    grad.addColorStop(0.45, '#060a10');
    grad.addColorStop(1, '#020304');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, w, h);

    const accent = ctx.createRadialGradient(w * 0.3, h * 0.25, 0, w * 0.3, h * 0.25, w * 0.4);
    accent.addColorStop(0, `rgba(30, 100, 160, ${0.06 + intensity * 0.04})`);
    accent.addColorStop(1, 'transparent');
    ctx.fillStyle = accent;
    ctx.fillRect(0, 0, w, h);

    for (const p of this.particles) {
      p.y -= p.speed * h;
      p.x += p.drift;
      if (p.y < -0.02) Object.assign(p, this._spawn(), { y: 1.02 });

      const alpha = (0.08 + 0.12 * Math.sin(time * 0.4 + p.phase)) * (1 + intensity * 0.3);
      ctx.beginPath();
      ctx.arc(p.x * w, p.y * h, p.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(140, 200, 255, ${alpha})`;
      ctx.fill();
    }
  }
}
