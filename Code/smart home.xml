/**
 * FFT / RMS audio analyzer — drives speaking-state blob reactivity.
 */
import { smooth } from '../core/easing.js';

export class AudioAnalyzer {
  constructor() {
    this.audioCtx = null;
    this.analyser = null;
    this.source = null;
    this.dataArray = null;
    this.timeArray = null;
    this.initialized = false;
    this.connectedElement = null;

    this.bands = { low: 0, mid: 0, high: 0, rms: 0 };
    this.smoothed = { low: 0, mid: 0, high: 0, rms: 0 };
  }

  async init() {
    if (this.audioCtx) return;
    const Ctx = window.AudioContext || window.webkitAudioContext;
    this.audioCtx = new Ctx();
    this.analyser = this.audioCtx.createAnalyser();
    this.analyser.fftSize = 512;
    this.dataArray = new Uint8Array(this.analyser.frequencyBinCount);
    this.timeArray = new Uint8Array(this.analyser.frequencyBinCount);
    this.initialized = true;
  }

  async resume() {
    if (this.audioCtx?.state === 'suspended') await this.audioCtx.resume();
  }

  connectMediaElement(element) {
    if (!this.initialized || !element) return;
    if (this.connectedElement === element) return;
    this.disconnect();
    this.source = this.audioCtx.createMediaElementSource(element);
    this.source.connect(this.analyser);
    this.analyser.connect(this.audioCtx.destination);
    this.connectedElement = element;
  }

  connectStream(stream) {
    if (!this.initialized) return;
    this.disconnect();
    this.source = this.audioCtx.createMediaStreamSource(stream);
    this.source.connect(this.analyser);
    this.connectedElement = stream;
  }

  disconnect() {
    try {
      this.source?.disconnect();
    } catch (_) { /* already disconnected */ }
    this.source = null;
    this.connectedElement = null;
  }

  /** Feed raw PCM float32 samples from backend WebSocket */
  feedPCM(samples) {
    if (!samples?.length) {
      this.bands.low = this.bands.mid = this.bands.high = this.bands.rms = 0;
      return;
    }
    let rmsSum = 0;
    for (let i = 0; i < samples.length; i++) {
      rmsSum += samples[i] * samples[i];
    }
    this.bands.rms = Math.sqrt(rmsSum / samples.length);
    // Approximate bands from RMS when no FFT available
    this.bands.low = this.bands.rms * 0.9;
    this.bands.mid = this.bands.rms * 0.6;
    this.bands.high = this.bands.rms * 0.35;
  }

  process(active = true) {
    if (!active || !this.analyser) {
      this.bands.low = this.bands.mid = this.bands.high = this.bands.rms = 0;
    } else {
      this.analyser.getByteFrequencyData(this.dataArray);
      this.analyser.getByteTimeDomainData(this.timeArray);

      let rmsSum = 0;
      for (let i = 0; i < this.timeArray.length; i++) {
        const val = (this.timeArray[i] - 128) / 128;
        rmsSum += val * val;
      }
      this.bands.rms = Math.sqrt(rmsSum / this.timeArray.length);

      const lowLimit = 8;
      const midLimit = 40;
      const highLimit = 128;
      let lowSum = 0, midSum = 0, highSum = 0;

      for (let i = 0; i < highLimit; i++) {
        const val = this.dataArray[i] / 255;
        if (i < lowLimit) lowSum += val;
        else if (i < midLimit) midSum += val;
        else highSum += val;
      }

      this.bands.low = lowSum / lowLimit;
      this.bands.mid = midSum / (midLimit - lowLimit);
      this.bands.high = highSum / (highLimit - midLimit);
    }

    this.smoothed.rms = smooth(this.smoothed.rms, this.bands.rms, 0.12);
    this.smoothed.low = smooth(this.smoothed.low, this.bands.low, 0.1);
    this.smoothed.mid = smooth(this.smoothed.mid, this.bands.mid, 0.15);
    this.smoothed.high = smooth(this.smoothed.high, this.bands.high, 0.2);
  }
}

export const audioAnalyzer = new AudioAnalyzer();
