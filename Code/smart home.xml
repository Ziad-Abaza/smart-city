import datetime

def handle_time(params: Dict[str, Any]) -> Dict[str, Any]:
    now = datetime.datetime.now().astimezone()
    return {
        "status": "success",
        "data": {
            "time": now.strftime("%H:%M:%S"),
            "timezone": str(now.tzname()),
            "utc_offset": now.strftime("%z")
        }
    }

def handle_calendar(params: Dict[str, Any]) -> Dict[str, Any]:
    op = params.get("operation", "today")
    base_date_str = params.get("base_date")
    if base_date_str:
        try:
            base_date = datetime.datetime.strptime(base_date_str, "%Y-%m-%d").date()
        except Exception:
            return {"status": "error", "message": "Invalid base_date format. Use YYYY-MM-DD"}
    else:
        base_date = datetime.date.today()
        
    result_date = base_date
    if op == "tomorrow":
        result_date = base_date + datetime.timedelta(days=1)
    elif op == "yesterday":
        result_date = base_date - datetime.timedelta(days=1)
    elif op == "add_days":
        days = params.get("days", 0)
        result_date = base_date + datetime.timedelta(days=days)
    elif op == "subtract_days":
        days = params.get("days", 0)
        result_date = base_date - datetime.timedelta(days=days)
    elif op == "days_between":
        target_str = params.get("target_date")
        if not target_str:
            return {"status": "error", "message": "Missing target_date"}
        try:
            target_date = datetime.datetime.strptime(target_str, "%Y-%m-%d").date()
        except Exception:
            return {"status": "error", "message": "Invalid target_date format. Use YYYY-MM-DD"}
        diff = (target_date - base_date).days
        return {
            "status": "success",
            "data": {
                "operation_result": diff,
                "days_between": diff
            }
        }
        
    return {
        "status": "success",
        "data": {
            "date": result_date.strftime("%Y-%m-%d"),
            "day_of_week": result_date.strftime("%A")
        }
    }

