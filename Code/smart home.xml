import os
import json
import time
import uuid
import threading
import datetime
from typing import Dict, Any, List, Optional, Callable
from voice_assistant.memory_maintenance import run_maintenance

DATA_DIR = "data"
ALARMS_FILE = os.path.join(DATA_DIR, "alarms.json")

class AssistantScheduler:
    def __init__(self, trigger_callback: Callable[[str], None]):
        self.trigger_callback = trigger_callback
        
        # Stopwatches: id -> {"status": "running"|"paused"|"stopped", "start_time": float, "elapsed": float}
        # Since the spec says "single stopwatch is sufficient", we use a fixed id "main"
        self.stopwatch = {
            "status": "stopped",
            "start_time": 0.0,
            "elapsed": 0.0
        }
        
        # Timers: dict of timer_id -> timer dict
        self.timers: Dict[str, Dict[str, Any]] = {}
        
        # Alarms: dict of alarm_id -> alarm dict
        self.alarms: Dict[str, Dict[str, Any]] = {}
        self._load_alarms()
        self.last_maintenance = time.time()
        
        self.running = True
        self.thread = threading.Thread(target=self._scheduler_loop, daemon=True, name="BackgroundScheduler")
        self.thread.start()

    def _load_alarms(self):
        os.makedirs(DATA_DIR, exist_ok=True)
        if os.path.exists(ALARMS_FILE):
            try:
                with open(ALARMS_FILE, "r", encoding="utf-8") as f:
                    self.alarms = json.load(f)
            except Exception as e:
                print(f"⚠️ Error loading alarms: {e}")
                self.alarms = {}

    def _save_alarms(self):
        try:
            with open(ALARMS_FILE, "w", encoding="utf-8") as f:
                json.dump(self.alarms, f, indent=4)
        except Exception as e:
            print(f"⚠️ Error saving alarms: {e}")

    def _scheduler_loop(self):
        while self.running:
            now_ts = time.time()
            now_dt = datetime.datetime.now()
            current_hm = now_dt.strftime("%H:%M")
            current_day = now_dt.strftime("%a")[:3] # e.g. Mon, Tue
            
            # Check timers
            expired_timers = []
            for tid, t in self.timers.items():
                if t["status"] == "running" and now_ts >= t["end_time"]:
                    expired_timers.append(tid)
                    
            for tid in expired_timers:
                t = self.timers.pop(tid)
                label = t.get("label") or "Timer"
                self.trigger_callback(f"{label} for {t['duration_seconds']} seconds is up!")
                
            # Check alarms
            expired_alarms = []
            for aid, a in self.alarms.items():
                if a["status"] == "active" and a["time"] == current_hm:
                    # check if it already fired this minute
                    last_fired = a.get("last_fired")
                    if last_fired == now_dt.strftime("%Y-%m-%d %H:%M"):
                        continue
                        
                    # check recurrence
                    rec = a.get("recurrence", "once")
                    should_fire = False
                    if rec == "once":
                        should_fire = True
                    elif isinstance(rec, list) and current_day in rec:
                        should_fire = True
                        
                    if should_fire:
                        a["last_fired"] = now_dt.strftime("%Y-%m-%d %H:%M")
                        expired_alarms.append(aid)
                        if rec == "once":
                            a["status"] = "removed"
                            
            if expired_alarms:
                self._save_alarms()
                for aid in expired_alarms:
                    self.trigger_callback(f"Alarm for {self.alarms[aid]['time']} is ringing!")

            # Memory Maintenance (run every hour)
            if now_ts - self.last_maintenance > 3600:
                try:
                    run_maintenance()
                except Exception as e:
                    print(f"⚠️ Maintenance Error: {e}")
                self.last_maintenance = now_ts

            time.sleep(1)

    # --- Stopwatch Methods ---
    def handle_stopwatch(self, action: str) -> Dict[str, Any]:
        now = time.time()
        st = self.stopwatch["status"]
        
        if action == "start":
            if st == "running":
                return {"status": "error", "message": "Stopwatch is already running."}
            self.stopwatch["status"] = "running"
            if st == "stopped":
                self.stopwatch["elapsed"] = 0.0
            self.stopwatch["start_time"] = now
            return {"status": "success", "data": {"status": "running", "elapsed_seconds": self.stopwatch["elapsed"]}}
            
        elif action == "pause":
            if st != "running":
                return {"status": "error", "message": "No stopwatch is currently running."}
            self.stopwatch["elapsed"] += (now - self.stopwatch["start_time"])
            self.stopwatch["status"] = "paused"
            return {"status": "success", "data": {"status": "paused", "elapsed_seconds": round(self.stopwatch["elapsed"])}}
            
        elif action == "resume":
            if st != "paused":
                return {"status": "error", "message": "Stopwatch is not paused."}
            self.stopwatch["status"] = "running"
            self.stopwatch["start_time"] = now
            return {"status": "success", "data": {"status": "running", "elapsed_seconds": round(self.stopwatch["elapsed"])}}
            
        elif action == "stop":
            if st == "stopped":
                return {"status": "error", "message": "No stopwatch is currently running."}
            if st == "running":
                self.stopwatch["elapsed"] += (now - self.stopwatch["start_time"])
            self.stopwatch["status"] = "stopped"
            return {"status": "success", "data": {"status": "stopped", "elapsed_seconds": round(self.stopwatch["elapsed"])}}
            
        elif action == "reset":
            self.stopwatch["status"] = "stopped"
            self.stopwatch["elapsed"] = 0.0
            return {"status": "success", "data": {"status": "stopped", "elapsed_seconds": 0}}
            
        elif action == "query":
            elap = self.stopwatch["elapsed"]
            if st == "running":
                elap += (now - self.stopwatch["start_time"])
            return {"status": "success", "data": {"status": st, "elapsed_seconds": round(elap)}}
            
        return {"status": "error", "message": "Invalid stopwatch action."}

    # --- Timer Methods ---
    def handle_timer(self, action: str, duration: int = 0, label: str = "", timer_id: str = "") -> Dict[str, Any]:
        if action == "start":
            if duration <= 0:
                return {"status": "error", "message": "Duration must be positive."}
            tid = str(uuid.uuid4())[:8]
            self.timers[tid] = {
                "id": tid,
                "label": label,
                "duration_seconds": duration,
                "end_time": time.time() + duration,
                "status": "running"
            }
            return {"status": "success", "data": self._get_timer_info(tid)}
            
        elif action == "list":
            return {"status": "success", "data": {"timers": [self._get_timer_info(t) for t in self.timers]}}
            
        elif action in ["query", "cancel"]:
            if not self.timers:
                return {"status": "error", "message": "No active timers."}
                
            tid = timer_id
            if not tid:
                # if only one timer, default to it
                if len(self.timers) == 1:
                    tid = list(self.timers.keys())[0]
                else:
                    return {"status": "error", "message": "Multiple timers exist. Please specify which one."}
                    
            if tid not in self.timers:
                return {"status": "error", "message": "Timer not found."}
                
            if action == "query":
                return {"status": "success", "data": self._get_timer_info(tid)}
            else:
                t = self.timers.pop(tid)
                t["status"] = "cancelled"
                return {"status": "success", "data": t}
                
        return {"status": "error", "message": "Invalid timer action."}

    def _get_timer_info(self, tid: str):
        t = self.timers[tid]
        rem = int(max(0, t["end_time"] - time.time()))
        return {
            "timer_id": tid,
            "label": t["label"],
            "duration_seconds": t["duration_seconds"],
            "remaining_seconds": rem,
            "status": t["status"]
        }

    # --- Alarm Methods ---
    def handle_alarm(self, action: str, time_str: str = "", recurrence: Any = "once", alarm_id: str = "") -> Dict[str, Any]:
        if action == "create":
            # validate time
            try:
                datetime.datetime.strptime(time_str, "%H:%M")
            except ValueError:
                return {"status": "error", "message": "Invalid time format. Use HH:MM."}
                
            aid = str(uuid.uuid4())[:8]
            self.alarms[aid] = {
                "id": aid,
                "time": time_str,
                "recurrence": recurrence,
                "status": "active"
            }
            self._save_alarms()
            return {"status": "success", "data": self.alarms[aid]}
            
        elif action == "list":
            return {"status": "success", "data": {"alarms": [a for a in self.alarms.values() if a["status"] == "active"]}}
            
        elif action == "remove":
            if not self.alarms:
                return {"status": "error", "message": "No active alarms."}
                
            aid = alarm_id
            if not aid:
                active = [k for k, v in self.alarms.items() if v["status"] == "active"]
                if len(active) == 1:
                    aid = active[0]
                else:
                    return {"status": "error", "message": "Multiple alarms exist. Please specify which one."}
                    
            if aid not in self.alarms or self.alarms[aid]["status"] != "active":
                return {"status": "error", "message": "Alarm not found."}
                
            self.alarms[aid]["status"] = "removed"
            self._save_alarms()
            return {"status": "success", "data": self.alarms[aid]}
            
        return {"status": "error", "message": "Invalid alarm action."}
