<file path="scripts/finetune_fastspeech2.py">
import os
import sys
from pathlib import Path

# Add project root to sys.path
root_path = Path(__file__).resolve().parent.parent
if str(root_path) not in sys.path:
    sys.path.insert(0, str(root_path))

import torch
import torchaudio
from transformers import FastSpeech2ConformerTokenizer, FastSpeech2ConformerWithHifiGan, Trainer, TrainingArguments
from datasets import Dataset
import soundfile as sf
import numpy as np
from torch.utils.data import DataLoader
from core.config_manager import config_manager

# Load tokenizer and model
tokenizer = FastSpeech2ConformerTokenizer.from_pretrained("espnet/fastspeech2_conformer")
model = FastSpeech2ConformerWithHifiGan.from_pretrained("espnet/fastspeech2_conformer_with_hifigan")
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
model = model.to(device)

# Mel-spectrogram transform
mel_transform = torchaudio.transforms.MelSpectrogram(
    sample_rate=22050,
    n_fft=1024,
    win_length=1024,
    hop_length=256,
    n_mels=80,
    f_min=0,
    f_max=8000
).to(device)

# Prepare dataset from your transcript
def load_data(audio_path=None, transcript_path=None):
    if audio_path is None:
        audio_path = config_manager.resolve_path("data/rawan_voice.wav")
    if transcript_path is None:
        transcript_path = config_manager.resolve_path("data/transcripts/transcript.txt")
    with open(transcript_path, "r") as f:
        lines = f.readlines()
    data = []
    for line in lines:
        audio_file, text = line.strip().split("|")
        audio, sr = sf.read(audio_file)
        if sr != 22050:
            raise ValueError(f"Audio sample rate must be 22050 Hz, got {sr}")
        data.append({"audio": audio.tolist(), "text": text})
    dataset = Dataset.from_list(data)
    print("Dataset before mapping:", dataset[0])
    return dataset

dataset = load_data()

# Preprocess dataset
def preprocess(example):
    try:
        print("Preprocessing input:", {k: type(v) for k, v in example.items()})
        inputs = tokenizer(example["text"], return_tensors="pt", padding=True, truncation=True, max_length=512)
        waveform = torch.tensor(example["audio"], dtype=torch.float32).to(device)
        mel_spec = mel_transform(waveform).squeeze(0).cpu().tolist()  # [n_mels, time]
        result = {
            "input_ids": inputs["input_ids"].squeeze().tolist(),
            "attention_mask": inputs["attention_mask"].squeeze().tolist(),
            "mel_targets": mel_spec,
        }
        print("Preprocessing output:", {k: type(v) for k, v in result.items()})
        return result
    except Exception as e:
        print(f"Preprocessing error: {e}")
        raise

dataset = dataset.map(preprocess, batched=False, keep_in_memory=True)
dataset = dataset.select_columns(["input_ids", "attention_mask", "mel_targets"])
print("Dataset after mapping:", {k: type(v) for k, v in dataset[0].items()})

# Custom data collator
def data_collator(features):
    print("Data collator features:", [{k: type(v) for k, v in f.items()} for f in features])
    input_ids = [torch.tensor(f["input_ids"], dtype=torch.long) for f in features]
    attention_mask = [torch.tensor(f["attention_mask"], dtype=torch.long) for f in features]
    mel_targets = [torch.tensor(f["mel_targets"], dtype=torch.float32) for f in features]
    max_len = max(len(ids) for ids in input_ids)
    input_ids = [torch.nn.functional.pad(ids, (0, max_len - len(ids))) for ids in input_ids]
    attention_mask = [torch.nn.functional.pad(mask, (0, max_len - len(mask))) for mask in attention_mask]
    max_mel_len = max(mel.shape[1] for mel in mel_targets)
    mel_targets = [torch.nn.functional.pad(mel, (0, max_mel_len - mel.shape[1])) for mel in mel_targets]
    return {
        "input_ids": torch.stack(input_ids),
        "attention_mask": torch.stack(attention_mask),
        "mel_targets": torch.stack(mel_targets)
    }

# Custom Trainer
class CustomTrainer(Trainer):
    def get_train_dataloader(self):
        return DataLoader(
            self.train_dataset,
            batch_size=self.args.per_device_train_batch_size,
            collate_fn=self.data_collator,
            shuffle=False
        )

# Training arguments
output_dir = config_manager.resolve_path("data/finetuned_fastspeech2")
training_args = TrainingArguments(
    output_dir=output_dir,
    per_device_train_batch_size=1,
    num_train_epochs=10,
    learning_rate=2e-5,
    save_steps=100,
    save_total_limit=2,
    logging_steps=10,
    fp16=True,
)

# Trainer
trainer = CustomTrainer(
    model=model,
    args=training_args,
    train_dataset=dataset,
    data_collator=data_collator,
)

# Fine-tune
trainer.train()

# Save fine-tuned model
output_dir = config_manager.resolve_path("data/finetuned_fastspeech2")
model.save_pretrained(output_dir)
tokenizer.save_pretrained(output_dir)
