import os
import sys
import time
import logging
from pathlib import Path

# Add project root to sys.path if running as a standalone script
project_root = str(Path(__file__).resolve().parent.parent.parent)
if project_root not in sys.path:
    sys.path.insert(0, project_root)

import numpy as np
import pyaudio
import soundfile as sf
import sounddevice as sd
from typing import Dict, Any, Type, Optional

from core.config_manager import config_manager
from voice_assistant.wakeword.base import BaseWakeWordEngine
from voice_assistant.wakeword.openwakeword_engine import OpenWakeWordEngine

# Configure default logging
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')

class WakeWordDetector:
    """Manages audio streaming from the microphone and coordinates wake-word inference."""
    
    # Engine registry for clean extensibility
    ENGINES = {
        "openwakeword": OpenWakeWordEngine
    }
    
    def __init__(self, engine_name: Optional[str] = None, model_name: Optional[str | list[str]] = None) -> None:
        """Initializes the wake-word detector and setup audio interfaces.
        
        If initialization of the engine or audio fails, wake-word detection is disabled
        gracefully to allow manual trigger fallback without crashing the assistant.
        """
        self.enabled = True
        self.engine: Optional[BaseWakeWordEngine] = None
        self.pa: Optional[pyaudio.PyAudio] = None
        self.audio_stream: Optional[pyaudio.Stream] = None
        
        # Load and validate configuration
        self._load_and_validate_config(engine_name, model_name)
        
        # Resolve alert sound and ensure file exists
        sound_rel_path = self.config.get("alert_sound", "data/sounds/test.wav")
        self.sound_path = config_manager.resolve_path(sound_rel_path)
        self._ensure_alert_sound()

        # 1. Initialize engine
        try:
            engine_cls = self._get_engine_class(self.engine_type)
            logging.info(f"Initializing wake-word engine: {self.engine_type} with model: {self.model_name}")
            self.engine = engine_cls(model_name=self.model_name)
            
            # Update sample rate and chunk size from engine requirements
            self.sample_rate = self.engine.get_required_sample_rate()
            self.chunk_size = self.engine.get_required_chunk_size()
        except Exception as e:
            logging.error(f"❌ Failed to load wake-word engine '{self.engine_type}': {e}", exc_info=True)
            self.enabled = False
            
        # 2. Setup audio stream if enabled
        if self.enabled:
            audio_success = self._setup_audio()
            if not audio_success:
                logging.warning("⚠️ Wake-word engine disabled due to audio initialization failure. Direct trigger fallback active.")
                self.enabled = False

    def _load_and_validate_config(self, engine_name: Optional[str], model_name: Optional[str | list[str]]) -> None:
        """Loads configuration from config_manager and performs startup validation."""
        # Config section defaults
        self.config = config_manager.get("wakeword", {})
        if not self.config:
            # Fallback to legacy path if standard structure is not present
            legacy_ww = config_manager.get("wake_word", {})
            self.config = {
                "engine": "openwakeword",
                "model": legacy_ww.get("keywords", ["jarvis"])[0] if legacy_ww.get("keywords") else "hey_jarvis",
                "threshold": 0.5,
                "sample_rate": 16000,
                "chunk_size": 1280,
                "inference_interval_ms": 80,
                "alert_sound": legacy_ww.get("alert_sound", "data/sounds/test.wav")
            }

        # Override with constructor parameters if explicitly passed
        self.engine_type = engine_name or self.config.get("engine", "openwakeword")
        self.model_name = model_name or self.config.get("model", "hey_jarvis")
        
        # Configuration Validation & Type Coercion
        try:
            self.threshold = float(self.config.get("threshold", 0.5))
            if not (0.0 <= self.threshold <= 1.0):
                logging.warning(f"Invalid threshold '{self.threshold}'. Resetting to default 0.5.")
                self.threshold = 0.5
        except (ValueError, TypeError):
            logging.warning("Invalid threshold format. Resetting to default 0.5.")
            self.threshold = 0.5

        try:
            self.sample_rate = int(self.config.get("sample_rate", 16000))
            if self.sample_rate <= 0:
                self.sample_rate = 16000
        except (ValueError, TypeError):
            self.sample_rate = 16000

        try:
            self.chunk_size = int(self.config.get("chunk_size", 1280))
            if self.chunk_size <= 0:
                self.chunk_size = 1280
        except (ValueError, TypeError):
            self.chunk_size = 1280

        try:
            self.inference_interval_ms = int(self.config.get("inference_interval_ms", 80))
            if self.inference_interval_ms <= 0:
                self.inference_interval_ms = 80
        except (ValueError, TypeError):
            self.inference_interval_ms = 80

        # Debugging option
        self.debug = self.config.get("debug", False)
        if self.debug:
            logging.getLogger().setLevel(logging.DEBUG)
            logging.debug("🔧 Debugging logging mode enabled for WakeWordDetector.")

    def _get_engine_class(self, engine_name: str) -> Type[BaseWakeWordEngine]:
        """Looks up the engine class in the registry."""
        if engine_name not in self.ENGINES:
            raise ValueError(
                f"Unsupported wake-word engine '{engine_name}'. "
                f"Available engines: {list(self.ENGINES.keys())}"
            )
        return self.ENGINES[engine_name]

    def _setup_audio(self) -> bool:
        """Initializes PyAudio and opens the input stream. Returns True on success, False otherwise."""
        try:
            self._cleanup_audio()
            
            self.pa = pyaudio.PyAudio()
            self.audio_stream = self.pa.open(
                rate=self.sample_rate,
                channels=1,
                format=pyaudio.paInt16,
                input=True,
                frames_per_buffer=self.chunk_size
            )
            logging.info("🎤 Microphone audio stream opened successfully.")
            return True
        except Exception as e:
            logging.error(f"❌ Failed to open microphone stream: {e}")
            self._cleanup_audio()
            return False

    def _cleanup_audio(self) -> None:
        """Safely terminates audio streams and PyAudio instance."""
        if self.audio_stream:
            try:
                self.audio_stream.stop_stream()
                self.audio_stream.close()
            except Exception as e:
                logging.debug(f"Error closing audio stream: {e}")
            self.audio_stream = None
            
        if self.pa:
            try:
                self.pa.terminate()
            except Exception as e:
                logging.debug(f"Error terminating PyAudio: {e}")
            self.pa = None

    def _ensure_alert_sound(self) -> None:
        """Generates a pleasant default beep sound if the alert sound file is missing."""
        if self.sound_path and not os.path.exists(self.sound_path):
            try:
                # Ensure directory exists
                os.makedirs(os.path.dirname(self.sound_path), exist_ok=True)
                
                # Generate a 0.2-second pleasant chime (double chime)
                sample_rate = 16000
                duration1 = 0.08
                duration2 = 0.15
                
                t1 = np.linspace(0, duration1, int(sample_rate * duration1), endpoint=False)
                t2 = np.linspace(0, duration2, int(sample_rate * duration2), endpoint=False)
                
                # Double chime: 880Hz (A5) followed by 1046.5Hz (C6)
                chime1 = np.sin(2 * np.pi * 880 * t1) * 0.3
                chime2 = np.sin(2 * np.pi * 1046.5 * t2) * 0.3
                
                # Apply envelope
                chime1 = chime1 * np.linspace(1.0, 0.0, len(t1))
                chime2 = chime2 * np.linspace(1.0, 0.0, len(t2))
                
                audio_data = np.concatenate([chime1, np.zeros(int(sample_rate * 0.02)), chime2])
                
                sf.write(self.sound_path, audio_data, sample_rate)
                logging.info(f"✨ Generated default chime alert sound at {self.sound_path}")
            except Exception as e:
                logging.error(f"❌ Failed to generate default alert sound: {e}")

    def play_alert_sound(self) -> None:
        """Plays the designated alert sound using sounddevice and soundfile."""
        if not self.sound_path or not os.path.exists(self.sound_path):
            logging.warning(f"⚠️ Alert sound file not found: {self.sound_path}")
            return
        try:
            data, fs = sf.read(self.sound_path, dtype='float32')
            sd.play(data, fs)
            sd.wait()
        except Exception as e:
            logging.error(f"❌ Error playing alert sound: {e}")

    def listen_for_wake_word(self) -> None:
        """Blocks execution and listens continuously for the wake word.
        
        If disabled, it falls back to waiting for a manual enter key trigger.
        Integrates automatic recovery from microphone read errors and stream disconnects.
        """
        if not self.enabled or not self.engine:
            print("\n⚠️ Wake-word engine is disabled. Press Enter to manually trigger voice assistant...")
            try:
                input()
            except (KeyboardInterrupt, EOFError):
                print("Exiting wake-word trigger.")
                raise KeyboardInterrupt
            return

        print("Listening for wake word...")
        consecutive_errors = 0
        max_consecutive_errors = 5

        while True:
            try:
                # Read raw bytes from PyAudio stream
                if not self.audio_stream:
                    raise IOError("Audio stream is not initialized.")
                    
                pcm_bytes = self.audio_stream.read(self.chunk_size, exception_on_overflow=False)
                if not pcm_bytes:
                    raise IOError("No audio frames read from source.")
                    
                # Convert bytes to numpy 1D array of 16-bit integers
                pcm_data = np.frombuffer(pcm_bytes, dtype=np.int16)
                
                # Perform inference
                predictions = self.engine.predict(pcm_data)
                consecutive_errors = 0  # reset error counter on successful prediction
                
                if self.debug:
                    logging.debug(f"Wake-word predictions: {predictions}")
                
                # Evaluate results against configured threshold
                detected = False
                for name, score in predictions.items():
                    if score >= self.threshold:
                        print(f"Wake word '{name}' detected! (Confidence: {score:.2f})")
                        detected = True
                        break
                
                if detected:
                    self.play_alert_sound()
                    break # exit to hand control over to speech recognition
                    
            except IOError as io_err:
                consecutive_errors += 1
                logging.warning(f"Audio stream error (attempt {consecutive_errors}/{max_consecutive_errors}): {io_err}")
                
                if consecutive_errors >= max_consecutive_errors:
                    logging.error("❌ High microphone failure rate detected. Attempting audio driver recovery...")
                    recovery_success = self._setup_audio()
                    if not recovery_success:
                        logging.error("❌ Audio recovery failed. Disabling wake-word module for this session.")
                        self.enabled = False
                        break
                    consecutive_errors = 0
                time.sleep(0.1)
                
            except KeyboardInterrupt:
                print("\nStopping wake-word detector...")
                raise KeyboardInterrupt
                
            except Exception as e:
                logging.error(f"Unexpected prediction loop exception: {e}", exc_info=True)
                time.sleep(0.1)

    def cleanup(self) -> None:
        """Performs cleanup of audio interfaces."""
        logging.info("Cleaning up wake-word detector resource allocation...")
        self._cleanup_audio()

    def release_microphone(self) -> None:
        """Release the PyAudio input stream so another backend can capture audio."""
        self._cleanup_audio()

    def resume_microphone(self) -> bool:
        """Re-open the PyAudio input stream after another backend is finished."""
        if not self.enabled:
            return False
        return self._setup_audio()

if __name__ == "__main__":
    # Standard local test runner for detector.py
    logging.info("Starting standalone wake-word detector test session...")
    
    # Instantiate detector
    detector = WakeWordDetector()
    
    # For test run, explicitly turn on debugging to show scores
    detector.debug = True
    logging.getLogger().setLevel(logging.DEBUG)
    
    try:
        while True:
            detector.listen_for_wake_word()
            print("\n🔔 [TEST MODE] Wake-word detected! Press Enter to re-arm...")
            input()
    except (KeyboardInterrupt, EOFError):
        print("\nExiting standalone test.")
    finally:
        detector.cleanup()
