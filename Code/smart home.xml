    @patch('voice_assistant.wakeword.detector.pyaudio.PyAudio')
    @patch('voice_assistant.wakeword.detector.WakeWordDetector._get_engine_class')
    def test_detector_failed_engine_init_graceful_fallback(self, mock_engine_cls, mock_pyaudio):
        """Verify detector handles engine initialization failure gracefully without crashing."""
        mock_engine_cls.side_ok = False
        mock_engine_cls.side_effect = Exception("Model initialization error")
        
        # Detector should not crash, but set enabled=False
        detector = WakeWordDetector()
        
        self.assertFalse(detector.enabled)
        self.assertIsNone(detector.engine)

    @patch('voice_assistant.wakeword.detector.pyaudio.PyAudio')
    @patch('voice_assistant.wakeword.detector.WakeWordDetector._get_engine_class')
    def test_detector_failed_audio_init_graceful_fallback(self, mock_engine_cls, mock_pyaudio):
        """Verify detector handles microphone connection failures gracefully."""
        mock_engine = MagicMock()
        mock_engine.get_required_sample_rate.return_value = 16000
        mock_engine.get_required_chunk_size.return_value = 1280
        mock_engine_cls.return_value = lambda model_name: mock_engine
        
        # Simulate PyAudio failing to open stream
        mock_pa = MagicMock()
        mock_pa.open.side_effect = Exception("Microphone busy or device not found")
        mock_pyaudio.return_value = mock_pa
        
        detector = WakeWordDetector()
        
        # Should remain operational, but wake-word engine is marked disabled
        self.assertFalse(detector.enabled)
        self.assertIsNone(detector.audio_stream)

    @patch('voice_assistant.wakeword.detector.pyaudio.PyAudio')
    @patch('voice_assistant.wakeword.detector.WakeWordDetector._get_engine_class')
    @patch('sounddevice.play')
    @patch('soundfile.read')
    @patch('os.path.exists')
    def test_listen_for_wake_word_trigger(self, mock_exists, mock_sf_read, mock_sd_play, mock_engine_cls, mock_pyaudio):
        """Test the detector trigger loop and threshold filtering."""
        mock_engine = MagicMock()
        mock_engine.get_required_sample_rate.return_value = 16000
        mock_engine.get_required_chunk_size.return_value = 1280
        # Trigger prediction scores
        mock_engine.predict.side_effect = [
            {"hey_jarvis": 0.10}, # Below threshold
            {"hey_jarvis": 0.75}  # Above threshold -> should trigger and exit
        ]
        mock_engine_cls.return_value = lambda model_name: mock_engine
        mock_exists.return_value = True
        mock_sf_read.return_value = (np.zeros(100), 16000)

        # Mock PyAudio stream reading
        mock_pa = MagicMock()
        mock_stream = MagicMock()
        mock_stream.read.return_value = b'\x00' * 2560 # 1280 samples of 16-bit PCM
        mock_pa.open.return_value = mock_stream
        mock_pyaudio.return_value = mock_pa

        detector = WakeWordDetector()
        detector.threshold = 0.5
        
        # Execute prediction trigger loop (should run twice then return)
        detector.listen_for_wake_word()
        
        self.assertEqual(mock_engine.predict.call_count, 2)
        mock_sd_play.assert_called_once() # Verify feedback sound played

    @patch('voice_assistant.wakeword.detector.pyaudio.PyAudio')
    @patch('voice_assistant.wakeword.detector.WakeWordDetector._get_engine_class')
    @patch('time.sleep')
    def test_audio_recovery_on_mic_error(self, mock_sleep, mock_engine_cls, mock_pyaudio):
        """Verify detector attempts microphone driver recovery upon consecutive IO errors."""
        mock_engine = MagicMock()
        mock_engine.get_required_sample_rate.return_value = 16000
        mock_engine.get_required_chunk_size.return_value = 1280
        mock_engine.predict.return_value = {"hey_jarvis": 0.0}
        mock_engine_cls.return_value = lambda model_name: mock_engine

        mock_pa = MagicMock()
        mock_stream = MagicMock()
        # Simulate consecutive read errors (IOError)
        mock_stream.read.side_effect = IOError("Mic read overflow/disconnect")
        mock_pa.open.return_value = mock_stream
        mock_pyaudio.return_value = mock_pa

        detector = WakeWordDetector()
        
        # Execute trigger loop, but limit maximum loops by forcing mock_stream setup to fail on recovery
        # so detector.enabled gets disabled.
        mock_pa.open.side_effect = Exception("Recovery opening failed")
        
        detector.listen_for_wake_word()
        
        self.assertFalse(detector.enabled)
        # Verify it called mock_pa.open to try and reinitialize the stream
        self.assertTrue(mock_pa.open.call_count >= 2)


