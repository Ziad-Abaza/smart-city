class Chatbot:
    print("🔄 Initializing Chatbot...")
    def __init__(self, recognizer, model_name="minicpm-v:latest", config_path="config/config.json"):
        self.model_name = model_name
        self.router = IntentRouter(model_name=model_name, wake_words=WAKE_WORDS)
