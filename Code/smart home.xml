import threading
import torch
import sounddevice as sd
import numpy as np
from scipy.io.wavfile import write, read
from core.config_manager import config_manager
import os
try:
    from ui.server import UIBridge
except ImportError:
    class UIBridge:
        @classmethod
        def set_state(cls, state: str): pass
        @classmethod
        def feed_audio(cls, samples: list): pass
# Import XTTS modules for TTS
from TTS.tts.configs.xtts_config import XttsConfig
from TTS.tts.models.xtts import Xtts

# ---------------------------------------------------------------------
# PyTorch Safe Unpickling Fix & Patch
# ---------------------------------------------------------------------
from torch.serialization import add_safe_globals
add_safe_globals([XttsConfig])  # Allowlist XTTS Config class

original_torch_load = torch.load
def patched_torch_load(f, *args, **kwargs):
    kwargs["weights_only"] = False  # Ensure full model loads
    return original_torch_load(f, *args, **kwargs)
torch.load = patched_torch_load

# ---------------------------------------------------------------------
# Persistent audio output stream (avoids per-chunk sd.play/sd.wait gaps)
# ---------------------------------------------------------------------
class _AudioPlayer:
  SAMPLE_RATE = 24000

  def __init__(self, sample_rate: int = SAMPLE_RATE):
    self.sample_rate = sample_rate
    self._lock = threading.Lock()
    self._stream = sd.OutputStream(
      samplerate=sample_rate,
      channels=1,
      dtype="float32",
      blocksize=2048,
    )
    self._stream.start()

  @staticmethod
  def _to_float32(wav) -> np.ndarray:
    arr = wav.detach().cpu().numpy() if torch.is_tensor(wav) else np.asarray(wav)
    return np.asarray(arr, dtype=np.float32).flatten()

  def write(self, wav) -> None:
    """Write audio samples to the open output stream (blocks until buffered)."""
    arr = self._to_float32(wav)
    if arr.size == 0:
      return
    step = max(1, len(arr) // 256)
    UIBridge.feed_audio(arr[::step].tolist())
    with self._lock:
      pos = 0
      block = 4096
      while pos < len(arr):
        self._stream.write(arr[pos : pos + block])
        pos += block

  def play(self, wav) -> None:
    """Play a complete waveform through the persistent stream."""
    self.write(wav)

  def close(self) -> None:
    with self._lock:
      if self._stream is not None:
        self._stream.stop()
        self._stream.close()
        self._stream = None


# ---------------------------------------------------------------------
# TextToSpeech Class using Coqui XTTS Model for Voice Synthesis
# ---------------------------------------------------------------------

class _AudioCache:
    """
    Pre-synthesizes known fixed phrases in a background thread so they
    play instantly (~0.05 s) instead of waiting for full XTTS inference.
    Thread-safe. Uses the same sequential GPU queue as live synthesis.
    """
    def __init__(self):
        self._cache: dict = {}       # normalized_text → wav ndarray
        self._lock  = threading.RLock()
        self._ready = threading.Event()  # set when all phrases are done
        self._pending = 0

    @staticmethod
    def _normalize(text: str) -> str:
        return " ".join(text.lower().split()).strip(" .,!?")

    def warm(self, phrases: list, synth_fn, language: str = "en"):
        """
        Submit phrases for background synthesis.
        synth_fn(text, language) → wav ndarray | None
        """
        unique = list(dict.fromkeys(p.strip() for p in phrases if p.strip()))
        self._pending = len(unique)
        if not unique:
            self._ready.set()
            return

        def _worker():
            for phrase in unique:
                key = self._normalize(phrase)
                with self._lock:
                    if key in self._cache:       # already cached
                        self._pending -= 1
                        continue
                wav = synth_fn(phrase, language)
                with self._lock:
                    if wav is not None:
                        self._cache[key] = wav
                    self._pending -= 1
            self._ready.set()
            print(f"\u2705 Audio cache ready ({len(self._cache)} phrases pre-synthesized).")

        threading.Thread(target=_worker, daemon=True, name="tts-cache-warmer").start()

    def get(self, text: str):
        key = self._normalize(text)
        with self._lock:
            return self._cache.get(key)

    def put(self, text: str, wav):
        """Add a newly synthesized phrase to the cache for future reuse."""
        with self._lock:
            self._cache[self._normalize(text)] = wav


class TextToSpeech:
    # XTTS hard character limit per synthesis call
    _XTTS_CHAR_LIMIT = 230
    SAMPLE_RATE = 24000

    def __init__(self):
