    # Pre-synthesize all known fixed responses in background.
    # The assistant is available immediately; phrases are cached one by
    # one on the GPU as the user starts interacting.
    # Cache hits play in ~0.05s instead of 5-10s synthesis time.
    # ------------------------------------------------------------------
    fixed_phrases = list({
        # Wake responses
        *WAKE_RESPONSES,
        # All fuzzy command spoken responses
        *[spoken for _, _, spoken in chatbot.router.COMMAND_PHRASES.values() if spoken],
        # Config-driven fixed answers
