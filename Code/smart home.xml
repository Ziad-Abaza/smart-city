<file path="ui/js/bridge/assistant-bridge.js">
/**
 * Production bridge — live state from clone_main.py via WebSocket.
 */
import { bus } from '../core/event-bus.js';
import { stateMachine, STATES } from '../core/state-machine.js';
import { audioAnalyzer } from '../audio/audio-analyzer.js';

const VALID_STATES = new Set(Object.values(STATES));
const DEBUG = new URLSearchParams(location.search).has('debug');

export class AssistantBridge {
  constructor(url = null) {
    this.url = url || `ws://${location.hostname}:8765`;
    this.ws = null;
    this.reconnectDelay = 2000;
    this.connected = false;
    this.backendReady = false;
    this.statusText = '';
    this.transcript = '';
    this.response = '';
    this.messageLog = [];
    this._pingTimer = null;
  }

  connect() {
    if (this.ws?.readyState === WebSocket.OPEN) return;

    this._log('connecting', { url: this.url });

    try {
      this.ws = new WebSocket(this.url);
      this.ws.onopen = () => {
        this.connected = true;
        this._log('connected', { url: this.url });
        console.info('[Bridge] Connected to', this.url);
        bus.emit('bridge:connected');
        this._startPing();
      };
      this.ws.onmessage = (e) => this._handleMessage(e.data);
      this.ws.onclose = (e) => {
        this.connected = false;
        this.backendReady = false;
        this._stopPing();
        this._log('disconnected', { code: e.code, reason: e.reason });
        bus.emit('bridge:disconnected');
        setTimeout(() => this.connect(), this.reconnectDelay);
      };
      this.ws.onerror = (e) => {
        this._log('error', { type: 'websocket' });
        console.error('[Bridge] WebSocket error on', this.url);
        this.ws?.close();
      };
    } catch (err) {
      this._log('error', { message: String(err) });
      console.error('[Bridge] Connection failed:', err);
      setTimeout(() => this.connect(), this.reconnectDelay);
    }
  }

  _startPing() {
    this._stopPing();
    this._pingTimer = setInterval(() => {
      this.send({ type: 'ping' });
    }, 10000);
  }

  _stopPing() {
    if (this._pingTimer) clearInterval(this._pingTimer);
    this._pingTimer = null;
  }

  _log(kind, detail = {}) {
    const entry = { ts: new Date().toISOString(), kind, ...detail };
    this.messageLog.unshift(entry);
    if (this.messageLog.length > 40) this.messageLog.length = 40;
    bus.emit('bridge:debug', entry);
    if (DEBUG) console.debug('[Bridge]', kind, detail);
  }

  _applySnapshot(msg) {
    this._log('snapshot', { state: msg.state, ready: msg.ready, status: msg.status });
    if (VALID_STATES.has(msg.state)) stateMachine.syncState(msg.state);
    if (msg.face) {
      stateMachine.setFaceActive(!!msg.face.active, {
        faceStatus: msg.face.status,
        user: msg.face.user,
        confidence: msg.face.confidence,
      });
    }
    if (msg.status != null) this._setStatus(msg.status);
    if (msg.transcript != null) this._setTranscript(msg.transcript);
    if (msg.response != null) this._setResponse(msg.response);
    if (msg.ready != null) this._setReady(msg.ready);
  }

  _setStatus(text) {
    this.statusText = text || '';
    this._log('status', { text });
    bus.emit('ui:status', { text: this.statusText });
  }

  _setTranscript(text) {
    this.transcript = text || '';
    this._log('transcript', { text });
    bus.emit('ui:transcript', { text: this.transcript });
  }

  _setResponse(text) {
    this.response = text || '';
    this._log('response', { text: text?.slice(0, 80) });
    bus.emit('ui:response', { text: this.response });
  }

  _setReady(ready) {
    this.backendReady = !!ready;
    this._log('ready', { ready: this.backendReady });
    bus.emit('bridge:ready', { ready: this.backendReady });
  }

  _handleMessage(raw) {
    let msg;
    try {
      msg = JSON.parse(raw);
    } catch {
      this._log('parse_error', { raw: String(raw).slice(0, 80) });
      return;
    }

    if (msg.type !== 'audio') {
      this._log('message', { type: msg.type, ...(msg.value != null ? { value: msg.value } : {}) });
    }

    switch (msg.type) {
      case 'snapshot':
        this._applySnapshot(msg);
        break;
      case 'pong':
        break;
      case 'state':
        if (VALID_STATES.has(msg.value)) stateMachine.syncState(msg.value);
        break;
      case 'status':
        this._setStatus(msg.text);
        break;
      case 'transcript':
        this._setTranscript(msg.text);
        break;
      case 'response':
        this._setResponse(msg.text);
        break;
      case 'ready':
        this._setReady(msg.value);
        break;
      case 'face':
        stateMachine.setFaceActive(!!msg.active, {
          faceStatus: msg.status,
          user: msg.user,
          confidence: msg.confidence,
        });
        if (msg.bbox) bus.emit('face:frame', msg);
        break;
      case 'audio':
        if (Array.isArray(msg.samples)) audioAnalyzer.feedPCM(msg.samples);
        break;
      case 'user':
        stateMachine.user = msg.name;
        bus.emit('face:change', { active: stateMachine.faceActive, user: msg.name });
        break;
      default:
        break;
    }
  }

  send(payload) {
    if (this.ws?.readyState === WebSocket.OPEN) {
      this.ws.send(JSON.stringify(payload));
    }
  }

  async fetchHealth() {
    try {
      const res = await fetch('/ui/api/health', { cache: 'no-store' });
      return await res.json();
    } catch (err) {
      return { error: String(err) };
    }
  }

  exposeAPI() {
    window.AssistantUI = {
      setState: (s) => VALID_STATES.has(s) && stateMachine.syncState(s),
      setFace: (active, meta = {}) => stateMachine.setFaceActive(active, meta),
      feedAudio: (samples) => audioAnalyzer.feedPCM(samples),
      getState: () => stateMachine.state,
      getBridgeLog: () => this.messageLog,
      fetchHealth: () => this.fetchHealth(),
    };
  }
}

export const bridge = new AssistantBridge();
</file>

<file path="ui/js/components/status-display.js">
/**
 * Status display — live labels and system indicators from clone_main.py
 */
import { bus } from '../core/event-bus.js';
import { STATES } from '../core/state-machine.js';

export class StatusDisplay {
  constructor(root, bridge) {
    this.root = root;
    this.bridge = bridge;
    this.app = document.querySelector('.app');
    this.primary = root.querySelector('.status-primary');
    this.secondary = root.querySelector('.status-secondary');
    this.micIndicator = root.querySelector('.indicator--mic');
    this.cameraIndicator = root.querySelector('.indicator--camera');
    this.linkIndicator = root.querySelector('.indicator--link');
    this.userBadge = document.querySelector('.user-badge');
    this.clockEl = document.querySelector('.clock');

    this._statusText = '';
    this._transcript = '';
    this._response = '';

    bus.on('state:change', ({ label, state }) => this._onStateChange(label, state));
    bus.on('face:change', ({ active, user }) => this._onFaceChange(active, user));
    bus.on('ui:status', ({ text }) => {
      this._statusText = text;
      this._refreshSecondary();
    });
    bus.on('ui:transcript', ({ text }) => {
      this._transcript = text;
      this._refreshSecondary();
    });
    bus.on('ui:response', ({ text }) => {
      this._response = text;
      this._refreshSecondary();
    });
    bus.on('bridge:connected', () => this._setBridgeState('connected'));
    bus.on('bridge:disconnected', () => {
      this._setBridgeState('offline');
      this.secondary.textContent = 'Assistant offline — start clone_main.py';
    });
    bus.on('bridge:ready', ({ ready }) => {
      if (ready) this._setBridgeState('live');
    });

    this._startClock();
    this._setBridgeState('connecting');
    this.linkIndicator?.classList.add('is-visible');
    this._refreshSecondary();
  }

  _setBridgeState(state) {
    this.app.dataset.bridge = state;
    this.linkIndicator?.classList.add('is-visible');
    this.linkIndicator?.classList.toggle('is-live', state === 'live');
    this.linkIndicator?.classList.toggle('is-offline', state === 'offline');
  }

  _onStateChange(label, state) {
    this.app.dataset.state = state;
    this.primary.classList.add('is-transitioning');
    setTimeout(() => {
      this.primary.textContent = label;
      this.primary.classList.remove('is-transitioning');
    }, 200);

    this.micIndicator?.classList.toggle('is-visible', state === STATES.LISTENING);
    this._refreshSecondary();
  }

  _onFaceChange(active, user) {
    this.app.dataset.faceActive = active ? 'true' : 'false';
    this.cameraIndicator?.classList.toggle('is-visible', active);

    if (user) {
      this.userBadge.textContent = user;
      this.userBadge.classList.add('is-visible');
    } else if (!active) {
      this.userBadge.classList.remove('is-visible');
    }
  }

  _refreshSecondary() {
    const state = this.app.dataset.state || STATES.DORMANT;
    let line = this._statusText;

    if (state === STATES.LISTENING && this._transcript) {
      line = `"${this._truncate(this._transcript, 72)}"`;
    } else if (state === STATES.THINKING && this._transcript) {
      line = this._truncate(this._transcript, 72);
    } else if (state === STATES.SPEAKING && this._response) {
      line = this._truncate(this._response, 88);
    } else if (!line && this.app.dataset.bridge === 'offline') {
      line = 'Assistant offline — start clone_main.py';
    } else if (!line && this.app.dataset.bridge === 'connecting') {
      line = 'Connecting to assistant...';
    }

    this.secondary.textContent = line || 'Voice Assistant';
  }

  _truncate(text, max) {
    const t = (text || '').trim();
    if (t.length <= max) return t;
    return `${t.slice(0, max - 1)}…`;
  }

  _startClock() {
    if (!this.clockEl) return;
    const tick = () => {
      const now = new Date();
      this.clockEl.textContent = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    };
    tick();
    setInterval(tick, 30000);
  }
}
