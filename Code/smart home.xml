from flask import Flask, request, jsonify, render_template_string, Response
import serial
import time
import os
import threading
import queue

app = Flask(__name__)
SERVER_START_TIME = time.time()

SERIAL_PORT = os.environ.get('ARDUINO_PORT', '/dev/ttyACM0')
BAUD_RATE = 9600

serial_lock = threading.Lock()
arduino = None
client_queues = []

# Try to connect to Arduino
try:
    arduino = serial.Serial(SERIAL_PORT, BAUD_RATE, timeout=0.1)
    time.sleep(2) # Wait for connection to initialize
    print(f"✅ Connected to Arduino on {SERIAL_PORT}")
except Exception as e:
    print(f"⚠️ Error connecting to Arduino on {SERIAL_PORT}: {e}")

def read_from_arduino():
    while True:
        try:
            if arduino and arduino.is_open:
                with serial_lock:
                    if arduino.in_waiting > 0:
                        line = arduino.readline().decode('utf-8', errors='ignore').strip()
                        if line:
                            # Broadcast to all connected SSE clients
                            for q in client_queues:
                                q.put(line)
            time.sleep(0.01)
        except Exception as e:
            time.sleep(1)

# Start background reading thread
thread = threading.Thread(target=read_from_arduino, daemon=True)
thread.start()

@app.route('/stream_logs')
def stream_logs():
    def event_stream():
        q = queue.Queue(maxsize=100)
        client_queues.append(q)
        try:
            while True:
                line = q.get()
                yield f"data: {line}\n\n"
        except GeneratorExit:
            client_queues.remove(q)
            
    return Response(event_stream(), mimetype='text/event-stream')

@app.route('/send_command', methods=['POST'])
def send_command():
    try:
        command = request.get_json().get('command', '') if request.is_json else request.form.get('command', '')
        if not command:
            return jsonify({"status": "error", "message": "No command provided"}), 400

        if arduino and arduino.is_open:
            with serial_lock:
                arduino.write(f"{command}\n".encode('utf-8'))
            return jsonify({"status": "success", "message": f"Command sent: {command}"}), 200
        else:
            return jsonify({"status": "simulated", "message": f"Command logged, but Arduino not connected: {command}"}), 200
    except Exception as e:
        return jsonify({"status": "error", "message": str(e)}), 500

@app.route('/api/status', methods=['GET'])
def status():
    uptime_seconds = int(time.time() - SERVER_START_TIME)
    hours, remainder = divmod(uptime_seconds, 3600)
    minutes, seconds = divmod(remainder, 60)
    return jsonify({
        "status": "running", 
        "arduino_connected": arduino is not None and arduino.is_open,
        "port": SERIAL_PORT,
        "uptime": f"{hours}h {minutes}m {seconds}s"
    })

@app.route('/')
def index():
    # Read the dashboard HTML from file
    with open('debug_dashboard.html', 'r') as f:
        return render_template_string(f.read())

if __name__ == '__main__':
    print("🚀 Starting Raspberry Pi Intermediary Server...")
    app.run(host='0.0.0.0', port=5000, debug=False, threaded=True)
