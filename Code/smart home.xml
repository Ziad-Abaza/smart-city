import cv2
import threading
import time
import base64
import platform
from core.config_manager import config_manager

class VisionManager:
    """
    Manages the camera stream for real-time vision capabilities.
    Reuses the optimized threaded capture architecture from chatbot-stream-ai.xml.
    """
    def __init__(self):
        self.camera = None
        self.camera_active = False
        self.camera_lock = threading.Lock()
        self.stop_capture = threading.Event()
        
        self._frame_data = {"frame": None, "jpeg": None}
        self.frame_lock = threading.Lock()
        
        self._encode_params = [int(cv2.IMWRITE_JPEG_QUALITY), 80]
        
        # Downscale parameters to reduce token load on the LLM
        self.analyze_w = 640
        self.analyze_h = 480
        self.capture_fps = 30
        
        self._load_config()

    def _load_config(self):
        config_data = config_manager.data
        fr_config = config_data.get("face_recognition_server", {})
        feed_val = fr_config.get("video_feed_url", 0)
        
        # Override to 0 if it was 1, as webcam index 0 is typically the default. 
        # (chatbot-stream-ai.xml used index 0).
        if feed_val == 1:
            feed_val = 0
            
        try:
            self.camera_index = int(feed_val)
        except ValueError:
            self.camera_index = feed_val

    def _init_camera(self):
        """Open the camera with a platform-appropriate backend."""
        backend_primary = cv2.CAP_DSHOW if platform.system() == "Windows" else cv2.CAP_V4L2
        backends_to_try = [backend_primary, cv2.CAP_ANY]
        if platform.system() == "Windows":
            backends_to_try.insert(1, cv2.CAP_MSMF)
            
        cam = None
        # Try preferred index first, then fallback to 0 or 1
        indices_to_try = [self.camera_index]
        if isinstance(self.camera_index, int):
            indices_to_try.extend([0, 1])
            
        for idx in indices_to_try:
            for be in backends_to_try:
                if isinstance(idx, int):
                    cam = cv2.VideoCapture(idx, be)
                else:
                    cam = cv2.VideoCapture(idx)
                    
                if cam is not None and cam.isOpened():
                    # Test if we can actually read a frame (avoids silent failures)
                    success, frame = cam.read()
                    if success and frame is not None:
                        print(f"✅ Successfully opened and verified camera feed: {idx} (backend: {be})")
                        break
                    else:
                        cam.release()
                        cam = None
                        
                if not isinstance(idx, int):
                    break # Don't try multiple backends for string URLs
                    
            if cam is not None and cam.isOpened():
                break
            
        if cam is None or not cam.isOpened():
            print(f"❌ Failed to open any camera feed. Tried indices: {indices_to_try}")
            return None
            
        # Try to set properties
        try:
            cam.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
            cam.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)
            cam.set(cv2.CAP_PROP_FPS, self.capture_fps)
            cam.set(cv2.CAP_PROP_BUFFERSIZE, 1)
        except Exception:
            pass
            
        return cam

    def start_camera(self):
        """Activates the camera in a background thread if not already running."""
        with self.camera_lock:
            if self.camera_active:
                return True
                
            print("👁️ Activating vision system...")
            self.camera = self._init_camera()
            if self.camera is None:
                return False
                
            self.camera_active = True
            self.stop_capture.clear()
            threading.Thread(target=self._capture_frames, daemon=True, name="vision_capture").start()
            
            # Wait briefly for the first frame to arrive
            start_wait = time.time()
            while time.time() - start_wait < 5.0:
                with self.frame_lock:
                    if self._frame_data["frame"] is not None:
                        break
                time.sleep(0.1)
                
            return True

    def stop_camera(self):
        """Deactivates the camera and releases resources."""
        with self.camera_lock:
            if not self.camera_active:
                return
            print("👁️ Deactivating vision system...")
            self.camera_active = False
            self.stop_capture.set()
            if self.camera is not None:
                self.camera.release()
                self.camera = None
                
        with self.frame_lock:
            self._frame_data["frame"] = None
            self._frame_data["jpeg"] = None

    def _capture_frames(self):
        """Background thread that continuously reads frames and caches the latest one."""
        interval = 1.0 / self.capture_fps
        while not self.stop_capture.is_set():
            with self.camera_lock:
                cam = self.camera
                
            if cam is None or not cam.isOpened():
                time.sleep(0.1)
                continue
                
            t0 = time.monotonic()
            success, frame = cam.read()
            
            if not success or frame is None:
                time.sleep(0.05)
                continue
                
            # Compress and encode
            ok, buf = cv2.imencode(".jpg", frame, self._encode_params)
            if not ok:
                continue
                
            with self.frame_lock:
                self._frame_data["frame"] = frame  # Store reference
                self._frame_data["jpeg"] = buf.tobytes()
                
            elapsed = time.monotonic() - t0
            sleep_time = interval - elapsed
            if sleep_time > 0:
                time.sleep(sleep_time)

    def get_latest_frame_b64(self, downscale=True):
        """Returns the latest frame encoded as a base64 JPEG string."""
        with self.frame_lock:
            frame = self._frame_data["frame"]
            
        if frame is None:
            return None
            
        if downscale:
            small = cv2.resize(frame, (self.analyze_w, self.analyze_h), interpolation=cv2.INTER_AREA)
            ok, buf = cv2.imencode(".jpg", small, self._encode_params)
        else:
            ok, buf = cv2.imencode(".jpg", frame, self._encode_params)
            
        if not ok:
            return None
            
        return base64.b64encode(buf.tobytes()).decode("utf-8")
