import cv2
import numpy as np
import math

def get_pose_angles(matrix):
    """
    Extract yaw, pitch, and roll in degrees from a 4x4 facial transformation matrix.
    """
    if matrix is None:
        return 0.0, 0.0, 0.0
        
    # Pitch (x-axis), Yaw (y-axis), Roll (z-axis)
    sy = math.sqrt(matrix[0, 0] * matrix[0, 0] + matrix[1, 0] * matrix[1, 0])
    singular = sy < 1e-6
    if not singular:
        pitch = math.atan2(matrix[2, 1], matrix[2, 2])
        yaw = math.atan2(-matrix[2, 0], sy)
        roll = math.atan2(matrix[1, 0], matrix[0, 0])
    else:
        pitch = math.atan2(-matrix[1, 2], matrix[1, 1])
        yaw = math.atan2(-matrix[2, 0], sy)
        roll = 0
    return np.degrees([yaw, pitch, roll])

def check_image_quality(frame, landmarks, face_matrix, config):
    """
    Check image quality based on size, sharpness, and pose angle.
    Returns (passed_bool, dict_of_metrics, failure_reason)
    """
    # 1. Face size
    h, w = frame.shape[:2]
    ys = [lm.y * h for lm in landmarks]
    face_height = max(ys) - min(ys)
    size_ratio = face_height / h
    
    min_size_ratio = config.get("quality_min_face_size_ratio", 0.15)
    if size_ratio < min_size_ratio:
        return False, {"size_ratio": size_ratio}, f"Face too small ({size_ratio:.2f} < {min_size_ratio})"
        
    # 2. Sharpness (Blur) on cropped face
    xs = [lm.x * w for lm in landmarks]
    x_min, x_max = max(0, int(min(xs))), min(w, int(max(xs)))
    y_min, y_max = max(0, int(min(ys))), min(h, int(max(ys)))
    
    face_crop = frame[y_min:y_max, x_min:x_max]
    if face_crop.size == 0:
        return False, {}, "Empty face crop"
        
    sharpness = cv2.Laplacian(face_crop, cv2.CV_64F).var()
    min_sharpness = config.get("quality_min_sharpness", 35.0)
    if sharpness < min_sharpness:
        return False, {"sharpness": sharpness}, f"Image too blurry ({sharpness:.1f} < {min_sharpness})"
        
    # 3. Pose angle
    yaw, pitch, roll = get_pose_angles(face_matrix)
    max_angle = config.get("quality_max_pose_angle_deg", 25.0)
    
    if abs(yaw) > max_angle or abs(pitch) > max_angle:
        return False, {"yaw": yaw, "pitch": pitch, "roll": roll}, f"Extreme pose (yaw:{yaw:.1f}, pitch:{pitch:.1f})"
        
    metrics = {
        "size_ratio": size_ratio,
        "sharpness": sharpness,
        "yaw": yaw,
        "pitch": pitch,
        "roll": roll
    }
    return True, metrics, ""
