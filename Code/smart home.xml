import numpy as np
from typing import Dict, List
from openwakeword.model import Model
from voice_assistant.wakeword.base import BaseWakeWordEngine
from voice_assistant.wakeword.models import resolve_model_path

class OpenWakeWordEngine(BaseWakeWordEngine):
    """OpenWakeWord wake-word detection engine implementation."""
    
    def __init__(self, model_name: str | list[str] = "hey_jarvis", **kwargs) -> None:
        """Initializes the OpenWakeWord model engine.
        
        Args:
            model_name: Name of the built-in model (e.g. "hey_jarvis"), path, or a list of them.
            **kwargs: Extra arguments passed to the underlying openwakeword Model class.
        """
        if isinstance(model_name, str):
            model_names = [model_name]
        else:
            model_names = model_name
            
        # Resolve the model paths or identifiers
        self.resolved_models = [resolve_model_path(m) for m in model_names]
        
        # Instantiate openwakeword Model
        inference_framework = kwargs.pop("inference_framework", "onnx")
        self.model = Model(
            wakeword_models=self.resolved_models,
            inference_framework=inference_framework,
            **kwargs
        )
        
        # Store the display names of the models
        self.model_names = list(self.model.models.keys())
        
    def predict(self, pcm: np.ndarray) -> Dict[str, float]:
        """Runs inference on a chunk of audio frames.
        
        Args:
            pcm: 1D numpy array of 16-bit PCM samples.
            
        Returns:
            A dictionary mapping model names to their detection probabilities.
        """
        # Model.predict expects a numpy array. By default it returns a dict of scores.
        # e.g., {'hey_jarvis': 0.05}
        return self.model.predict(pcm)
        
    def get_required_sample_rate(self) -> int:
        """OpenWakeWord standard sample rate is 16000 Hz."""
        return 16000
        
    def get_required_chunk_size(self) -> int:
        """OpenWakeWord operates on 80ms chunks of 16kHz audio (1280 samples)."""
        return 1280
        
    def get_model_names(self) -> List[str]:
        """Returns the list of loaded wake-word models."""
        return self.model_names
