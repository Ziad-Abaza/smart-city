.app {
  position: relative;
  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* Layer stack */
.layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.layer--bg {
  z-index: 0;
}

.layer--blob {
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--duration-slow) var(--ease-out-soft);
}

.layer--ui {
  z-index: 4;
  pointer-events: none;
}

.layer--noise {
  z-index: 5;
  opacity: 0.04;
  mix-blend-mode: overlay;
}

.layer--vignette {
  z-index: 6;
  background: radial-gradient(
    ellipse 80% 70% at 50% 45%,
    transparent 40%,
    rgba(0, 0, 0, 0.55) 100%
  );
}

/* Blob stage shifts left when face verification is active */
.app[data-face-active="true"] .layer--blob {
  transform: translateX(var(--blob-offset-face));
}

.blob-stage {
  position: relative;
  width: var(--blob-size);
  height: var(--blob-size);
  border-radius: clamp(32px, 4vw, 48px);
  background: radial-gradient(circle at 30% 30%, #14181c, #030405);
  box-shadow:
    0 20px 60px rgba(0, 0, 0, 0.8),
    inset 0 0 80px rgba(20, 180, 200, 0.08);
  overflow: hidden;
  backdrop-filter: blur(2px);
  transition:
    box-shadow var(--duration-normal) var(--ease-fluid),
    transform var(--duration-slow) var(--ease-out-soft);
}

.app[data-state="listening"] .blob-stage {
  box-shadow:
    0 24px 70px rgba(0, 0, 0, 0.75),
    inset 0 0 100px rgba(40, 200, 220, 0.12),
    var(--glow-soft);
  transform: scale(1.04);
}

.app[data-state="thinking"] .blob-stage {
  box-shadow:
    0 22px 65px rgba(0, 0, 0, 0.78),
    inset 0 0 90px rgba(30, 160, 200, 0.1);
}

.app[data-state="speaking"] .blob-stage {
  box-shadow:
    0 28px 80px rgba(0, 0, 0, 0.7),
    inset 0 0 120px rgba(50, 210, 255, 0.15),
    0 0 60px rgba(60, 185, 255, 0.12);
}

.blob-canvas {
  display: block;
  width: 100%;
  height: 100%;
}

/* Light rays */
.light-rays {
  position: absolute;
  inset: -20%;
  background: conic-gradient(
    from 200deg at 50% 50%,
    transparent 0deg,
    rgba(60, 180, 255, 0.03) 40deg,
    transparent 80deg,
    rgba(80, 200, 255, 0.02) 140deg,
    transparent 200deg
  );
  animation: rays-rotate 120s linear infinite;
  opacity: 0.6;
  transition: opacity var(--duration-normal) var(--ease-fluid);
}

.app[data-state="speaking"] .light-rays {
  opacity: 1;
  animation-duration: 60s;
}

@keyframes rays-rotate {
  to { transform: rotate(360deg); }
}

/* Center column for status */
.center-column {
  position: absolute;
  left: 50%;
  bottom: var(--space-breath);
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.25rem;
  transition: transform var(--duration-slow) var(--ease-out-soft);
  z-index: 4;
}

.app[data-face-active="true"] .center-column {
  transform: translateX(calc(var(--blob-offset-face) * 0.5));
}

@media (max-width: 900px) {
  .app[data-face-active="true"] .layer--blob,
  .app[data-face-active="true"] .center-column {
    transform: translateY(-8vh);
  }

  :root {
    --blob-size: min(85vw, 420px);
  }
}
