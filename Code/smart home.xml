import cv2
import numpy as np

# Canonical points for 112x112 output, typically used by ArcFace/SFace
# These correspond to: left eye, right eye, nose tip, mouth left, mouth right
# in the aligned image space.
_TARGET_POINTS = np.array([
    [38.2946, 51.6963],
    [73.5318, 51.6963],
    [56.0252, 71.7366],
    [41.5493, 92.3655],
    [70.7299, 92.3655]
], dtype=np.float32)

def align_face(image, face_landmarks):
    """
    Align a face to a 112x112 crop using MediaPipe face landmarks.
    Expects `image` to be the BGR frame and `face_landmarks` to be a single FaceLandmarker result.
    """
    h, w = image.shape[:2]
    
    # MediaPipe indices:
    # 33: right eye outer corner (anatomical), left side of unmirrored image
    # 263: left eye outer corner (anatomical), right side of unmirrored image
    # 1: nose tip
    # 61: right mouth corner (anatomical)
    # 291: left mouth corner (anatomical)
    
    eye_1 = np.array([face_landmarks[33].x * w, face_landmarks[33].y * h])
    eye_2 = np.array([face_landmarks[263].x * w, face_landmarks[263].y * h])
    
    # Sort left/right based on image x-coordinate so that the "left eye" (in image space) comes first
    if eye_1[0] < eye_2[0]:
        img_left_eye = eye_1
        img_right_eye = eye_2
    else:
        img_left_eye = eye_2
        img_right_eye = eye_1
        
    nose = np.array([face_landmarks[1].x * w, face_landmarks[1].y * h])
    
    mouth_1 = np.array([face_landmarks[61].x * w, face_landmarks[61].y * h])
    mouth_2 = np.array([face_landmarks[291].x * w, face_landmarks[291].y * h])
    
    if mouth_1[0] < mouth_2[0]:
        img_left_mouth = mouth_1
        img_right_mouth = mouth_2
    else:
        img_left_mouth = mouth_2
        img_right_mouth = mouth_1
        
    src_points = np.array([
        img_left_eye,
        img_right_eye,
        nose,
        img_left_mouth,
        img_right_mouth
    ], dtype=np.float32)
    
    # Estimate transform
    M, _ = cv2.estimateAffinePartial2D(src_points, _TARGET_POINTS)
    if M is None:
        return None
        
    aligned_face = cv2.warpAffine(image, M, (112, 112))
    return aligned_face
