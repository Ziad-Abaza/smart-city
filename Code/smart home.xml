import os
import sys
from pathlib import Path

# Add project root to sys.path
root_path = Path(__file__).resolve().parent.parent
if str(root_path) not in sys.path:
    sys.path.insert(0, str(root_path))

import cv2
import mediapipe as mp
from mediapipe.tasks import python
from mediapipe.tasks.python import vision
import numpy as np
from core.config_manager import config_manager

class FakeRealFaceDetection:
    def __init__(self, blur_threshold=35, confidence_threshold=0.8):
        self.blur_threshold = blur_threshold
        self.confidence_threshold = confidence_threshold
        
        fr_config = config_manager.get("face_recognition_server", {})
        model_relative_path = fr_config.get("model_path", "face_recognition/models/face_landmarker.task")
        model_absolute_path = config_manager.resolve_path(model_relative_path)
        
        det_conf = fr_config.get("detection_min_confidence", 0.6)
        trk_conf = fr_config.get("tracking_min_confidence", 0.6)

        base_options = python.BaseOptions(model_asset_path=model_absolute_path)
        options = vision.FaceLandmarkerOptions(
            base_options=base_options,
            num_faces=1,
            min_face_detection_confidence=det_conf,
            min_tracking_confidence=trk_conf
        )
        self.face_landmarker = vision.FaceLandmarker.create_from_options(options)
        self.circle_center = None
        self.circle_radius = None
        self.cam_width = 640
        self.cam_height = 480

    def detect_fake_or_real(self, frame):
        rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        mp_image = mp.Image(image_format=mp.ImageFormat.SRGB, data=rgb_frame)
        detection_result = self.face_landmarker.detect(mp_image)

        if not detection_result.face_landmarks:
            return frame, "No face detected"

        label = "No face detected"
        for face_landmarks in detection_result.face_landmarks:
            # Calculate face bounding box
            ih, iw, _ = frame.shape
            x_min = int(min([lm.x for lm in face_landmarks]) * iw)
            y_min = int(min([lm.y for lm in face_landmarks]) * ih)
            x_max = int(max([lm.x for lm in face_landmarks]) * iw)
            y_max = int(max([lm.y for lm in face_landmarks]) * ih)

            # Safeguard boundary values
            x_min, y_min = max(0, x_min), max(0, y_min)
            x_max, y_max = min(iw, x_max), min(ih, y_max)

            face = frame[y_min:y_max, x_min:x_max]
            if face.size == 0:
                continue
                
            blur_value = self.calculate_blur(face)

            if blur_value > self.blur_threshold:
                label = "Real Face"
                color = (0, 255, 0)  # Green for real
            else:
                label = "Fake Face"
                color = (0, 0, 255)  # Red for fake

            cv2.putText(frame, label, (x_min, y_min - 10), cv2.FONT_HERSHEY_SIMPLEX, 1, color, 2)
            cv2.rectangle(frame, (x_min, y_min), (x_max, y_max), color, 2)

        return frame, label

    def calculate_blur(self, face_image):
        """Calculate the blurriness of the face image using Laplacian variance."""
        return cv2.Laplacian(face_image, cv2.CV_64F).var()
