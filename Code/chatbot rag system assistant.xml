import { RetrievedChunk } from '../types/Chunk';

/**
 * ContextBuilder — Stage 5 of the RAG pipeline
 * ----------------------------------------------
 * Converts reranked chunks into a compact, high-signal context string
 * for the LLM. Deduplicates overlapping content. Adds source attribution.
 *
 * Design rules:
 *   - Use only top 3–5 chunks (configurable)
 *   - Serve content in the user's language first, then bilingual supplement
 *   - Keep total context under ~2000 tokens to preserve LLM reasoning capacity
 */
export class ContextBuilder {
  private readonly MAX_CHUNKS = 5;
  private readonly MAX_CHARS_PER_CHUNK = 600;

  public build(chunks: RetrievedChunk[], lang: 'ar' | 'en'): string {
    const selected = chunks.slice(0, this.MAX_CHUNKS);
    const deduplicated = this.deduplicate(selected, lang);

    return deduplicated
      .map((chunk, i) => {
        const primary = lang === 'ar' ? chunk.content.ar : chunk.content.en;
        const secondary = lang === 'ar' ? chunk.content.en : chunk.content.ar;
        const truncatedPrimary = primary.slice(0, this.MAX_CHARS_PER_CHUNK);
        const type = chunk.metadata.type ?? 'general';

        return `[Source ${i + 1} — ${type}]\n${truncatedPrimary}\n` +
               (secondary ? `[Supplement]\n${secondary.slice(0, 200)}` : '');
      })
      .join('\n\n---\n\n');
  }

  /**
   * Remove chunks whose primary content overlaps > 70% with an earlier chunk
   * using Jaccard similarity on token sets.
   */
  private deduplicate(chunks: RetrievedChunk[], lang: 'ar' | 'en'): RetrievedChunk[] {
    const seen: Set<string>[] = [];
    return chunks.filter(chunk => {
      const text = lang === 'ar' ? chunk.content.ar : chunk.content.en;
      const tokens = new Set(text.toLowerCase().split(/\s+/));

      for (const seenTokens of seen) {
        const intersection = [...tokens].filter(t => seenTokens.has(t)).length;
        const union = new Set([...tokens, ...seenTokens]).size;
        if (intersection / union > 0.7) return false;
      }

      seen.push(tokens);
      return true;
    });
  }
}
