import crypto from 'crypto';

class Security {
  private static blockedPatterns: RegExp[] = [
    /ignore previous instructions/i,
    /disregard all above/i,
    /forget everything/i,
    /override system/i,
    /bypass rules/i,
    /new instructions/i,
    /system prompt/i,
    /reveal your instructions/i,
    /show your prompt/i,
    /print your system message/i,
    /what are your instructions/i,
    /how are you programmed/i,
    /reveal configuration/i,
    /you are now/i,
    /act as/i,
    /pretend to be/i,
    /roleplay as/i,
    /become a/i,
    /dan mode/i,
    /developer mode/i,
    /jailbreak/i,
    /unrestricted/i,
    /no limitations/i,
    /bypass safety/i,
    /ignore safety/i,
    /what is your model/i,
    /which model are you/i,
    /show your code/i,
    /base64/i,
    /rot13/i,
    /hex encode/i,
  ];

  public static validateInput(input: string): boolean {
    if (!input || input.trim().length === 0) return false;
    if (input.length > 2000) return false;
    return !Security.blockedPatterns.some(p => p.test(input));
  }

  public static getSecurityResponse(input: string): string | null {
    if (/system prompt|reveal your instructions|show your prompt/i.test(input))
      return 'I cannot disclose my operational instructions.';
    if (/you are now|act as|pretend to be|roleplay as/i.test(input))
      return 'I maintain my designated role as BATU assistant.';
    if (/dan mode|developer mode|jailbreak|unrestricted/i.test(input))
      return 'I cannot bypass my operational protocols.';
    if (/what is your model|which model are you/i.test(input))
      return 'I cannot provide technical specifications.';
    if (/base64|rot13|hex encode/i.test(input))
      return 'I cannot process encoded instructions.';
    return null;
  }

  // In-memory rate limiter (use Redis in production via CacheLayer)
  private static rateLimits = new Map<string, { start: number; count: number }>();
  private static readonly LIMIT = 10;
  private static readonly WINDOW = 60;

  public static checkRateLimit(sessionId: string): boolean {
    const key = crypto.createHash('md5').update(sessionId).digest('hex');
    const now = Math.floor(Date.now() / 1000);
    const current = Security.rateLimits.get(key);

    if (!current || now - current.start >= Security.WINDOW) {
      Security.rateLimits.set(key, { start: now, count: 1 });
      return true;
    }

    if (current.count >= Security.LIMIT) return false;
    current.count++;
    return true;
  }

  public static sanitize(data: string | string[]): string | string[] {
    if (Array.isArray(data)) return data.map(Security.sanitize) as string[];
    return data
      .trim()
      .replace(/<[^>]*>/g, '')
      .replace(/[&<>"']/g, char => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
      }[char] ?? char));
  }
}

export default Security;
