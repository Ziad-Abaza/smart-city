// ============================================
// Chat History Storage Management
// ============================================

const MAX_CHAT_HISTORY = 5;

export function getChatsFromStorage() {
  try {
    const chats = localStorage.getItem('batu-chats');
    return chats ? JSON.parse(chats) : [];
  } catch (e) {
    console.error('Error loading chats from storage:', e);
    return [];
  }
}

export function saveChat(messageHistory, currentChatId) {
  if (messageHistory.length === 0) return;
  
  // Generate chat ID if not exists
  if (!currentChatId) {
    currentChatId = Date.now().toString();
  }
  
  // Get chat title from first user message
  const firstUserMessage = messageHistory.find(m => m.role === 'user');
  const title = firstUserMessage 
    ? (firstUserMessage.content.length > 30 
        ? firstUserMessage.content.substring(0, 30) + '...' 
        : firstUserMessage.content)
    : 'New Chat';
  
  // Get existing chats
  let chats = getChatsFromStorage();
  
  // Remove current chat if it exists (to update it)
  chats = chats.filter(c => c.id !== currentChatId);
  
  // Add current chat to the beginning
  chats.unshift({
    id: currentChatId,
    title: title,
    messages: messageHistory,
    timestamp: Date.now()
  });
  
  // Keep only max 5 chats
  if (chats.length > MAX_CHAT_HISTORY) {
    chats = chats.slice(0, MAX_CHAT_HISTORY);
  }
  
  // Save to localStorage
  try {
    localStorage.setItem('batu-chats', JSON.stringify(chats));
    return currentChatId;
  } catch (e) {
    console.error('Error saving chat to storage:', e);
    return currentChatId;
  }
}

export function performDelete(chatId) {
  // Get chats from storage
  let chats = getChatsFromStorage();
  
  // Remove the chat
  chats = chats.filter(c => c.id !== chatId);
  
  // Save updated chats
  try {
    localStorage.setItem('batu-chats', JSON.stringify(chats));
    return true;
  } catch (e) {
    console.error('Error deleting chat:', e);
    return false;
  }
}
