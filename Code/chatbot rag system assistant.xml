<file path="src/rag/QueryAnalyzer.ts">
export type Intent = 'question' | 'greeting' | 'out_of_scope' | 'command';
export type QueryType = 'factual' | 'procedural' | 'comparative';
export type Domain = 'faculty' | 'course' | 'faq' | 'policy' | 'general';

export interface QueryAnalysis {
  language: 'ar' | 'en';
  intent: Intent;
  domain: Domain;
  queryType: QueryType;
  entities: string[];
  rewrittenQuery: string;
}

/**
 * QueryAnalyzer — Stage 1 of the RAG pipeline
 * ---------------------------------------------
 * Performs:
 *   - Intent classification
 *   - Domain classification
 *   - Entity extraction
 *   - Query normalization / rewriting
 */
export class QueryAnalyzer {
  private readonly DOMAIN_SIGNALS: Record<Domain, string[]> = {
    faculty: [
      'faculty', 'college', 'department', 'كلية', 'قسم', 'تخصص',
      'industry', 'health', 'engineering', 'صناعة', 'صحة', 'هندسة',
    ],
    course: [
      'course', 'subject', 'credit', 'curriculum', 'lecture',
      'مقرر', 'مادة', 'ساعة', 'منهج', 'درس',
    ],
    faq: [
      'fee', 'tuition', 'admission', 'apply', 'location', 'contact',
      'scholarship', 'facility', 'calendar', 'international',
      'رسوم', 'قبول', 'موقع', 'تواصل', 'منحة', 'مرافق', 'تقويم', 'دولي',
    ],
    policy: [
      'policy', 'rule', 'regulation', 'conduct', 'attendance', 'exam',
      'سياسة', 'نظام', 'لائحة', 'انضباط', 'حضور', 'امتحان',
    ],
    general: [],
  };

  private readonly GREETING_PATTERNS = [
    /^(hello|hi|hey|good\s+(morning|afternoon|evening))\b/i,
    /^(مرحبا|السلام|أهلا|صباح|مساء)/,
  ];

  private readonly PROCEDURAL_KEYWORDS = [
    'how to', 'how do', 'steps', 'process', 'procedure', 'guide',
    'كيف', 'خطوات', 'إجراء', 'طريقة',
  ];

  public analyze(query: string, lang: 'ar' | 'en'): QueryAnalysis {
    const trimmed = query.trim();
    const intent = this.classifyIntent(trimmed);
    const domain = this.classifyDomain(trimmed);
    const queryType = this.classifyQueryType(trimmed);
    const entities = this.extractEntities(trimmed, lang);
    const rewrittenQuery = this.rewrite(trimmed, lang, entities);

    return { language: lang, intent, domain, queryType, entities, rewrittenQuery };
  }

  private classifyIntent(query: string): Intent {
    if (this.GREETING_PATTERNS.some(p => p.test(query))) return 'greeting';
    if (query.includes('?') || query.includes('؟')) return 'question';
    return 'question';
  }

  private classifyDomain(query: string): Domain {
    const lower = query.toLowerCase();
    let maxScore = 0;
    let bestDomain: Domain = 'general';

    for (const [domain, signals] of Object.entries(this.DOMAIN_SIGNALS) as [Domain, string[]][]) {
      const score = signals.filter(s => lower.includes(s)).length;
      if (score > maxScore) {
        maxScore = score;
        bestDomain = domain;
      }
    }

    return bestDomain;
  }

  private classifyQueryType(query: string): QueryType {
    const lower = query.toLowerCase();
    if (this.PROCEDURAL_KEYWORDS.some(k => lower.includes(k))) return 'procedural';
    return 'factual';
  }

  private extractEntities(query: string, lang: 'ar' | 'en'): string[] {
    const patterns = [
      /faculty of ([\w\s]+?)(?:\.|,|$|\?)/gi,
      /department of ([\w\s]+?)(?:\.|,|$|\?)/gi,
      /كلية ([\u0600-\u06FF\s]+?)(?:\.|،|$|\؟)/g,
      /قسم ([\u0600-\u06FF\s]+?)(?:\.|،|$|\؟)/g,
    ];

    const entities: string[] = [];
    for (const pattern of patterns) {
      let match: RegExpExecArray | null;
      while ((match = pattern.exec(query)) !== null) {
        const entity = match[1].trim();
        if (entity.length > 1) entities.push(entity);
      }
    }

    return [...new Set(entities)];
  }

  private rewrite(query: string, lang: 'ar' | 'en', entities: string[]): string {
    return query
      .trim()
      .replace(/\s+/g, ' ')
      .replace(/[؟?]+$/, '?');
  }
}
