import { Request, Response } from 'express';
import Security from '../services/Security';
import { Pipeline } from '../rag/Pipeline';

// Singleton pipeline — initialized once on first request
let pipeline: Pipeline | null = null;
let initializing: Promise<void> | null = null;

async function getPipeline(): Promise<Pipeline> {
  if (pipeline) return pipeline;

  if (!initializing) {
    const p = new Pipeline();
    initializing = p.initialize().then(() => {
      pipeline = p;
      initializing = null;
    });
  }

  await initializing;
  return pipeline!;
}

export const chatHandler = async (req: Request, res: Response): Promise<void> => {
  try {
    const { query, history = [] } = req.body;

    if (!query || typeof query !== 'string') {
      res.status(400).json({ error: 'Invalid query' });
      return;
    }

    const sanitizedQuery = Security.sanitize(query) as string;

    if (!Security.validateInput(sanitizedQuery)) {
      const securityResponse = Security.getSecurityResponse(sanitizedQuery);
      res.json({
        response: securityResponse ?? 'I maintain my designated role as BATU assistant.',
        timestamp: Math.floor(Date.now() / 1000),
      });
      return;
    }

    const sessionId = (req as any).sessionID as string
      ?? req.ip
      ?? 'default';

    if (!Security.checkRateLimit(sessionId)) {
      res.status(429).json({ error: 'Too many requests. Please wait a moment.' });
      return;
    }

    const p = await getPipeline();
    const response = await p.process(sanitizedQuery, history);

    res.json({ response, timestamp: Math.floor(Date.now() / 1000) });
  } catch (error) {
    console.error('[chatHandler] Error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
};
