### 4.2 TreeClassifier

```typescript
// src/rag/TreeClassifier.ts

interface TreeNode {
  id: string;
  signals: string[];        // keywords → this node
  children?: TreeNode[];
  chromaFilter?: Record<string, string>;  // passed to VectorStore.query()
}

const DOMAIN_TREE: TreeNode = {
  id: 'root',
  signals: [],
  children: [
    {
      id: 'faculty',
      signals: ['faculty', 'college', 'كلية', 'department', 'قسم'],
      chromaFilter: { domain: 'faculty' },
      children: [
        {
          id: 'industry_energy',
          signals: ['industry', 'energy', 'صناعة', 'طاقة', 'textile', 'food', 'railway'],
          chromaFilter: { domain: 'faculty', subCategory: 'industry_energy' },
        },
        {
          id: 'health_sciences',
          signals: ['health', 'medical', 'صحة', 'طبي', 'nursing', 'dental', 'radiology'],
          chromaFilter: { domain: 'faculty', subCategory: 'health_sciences' },
        },
      ],
    },
    {
      id: 'faq',
      signals: ['fee', 'tuition', 'admission', 'contact', 'location', 'رسوم', 'قبول', 'موقع'],
      chromaFilter: { domain: 'faq' },
    },
    {
      id: 'policy',
      signals: ['policy', 'rule', 'regulation', 'conduct', 'سياسة', 'نظام'],
      chromaFilter: { domain: 'policy' },
    },
  ],
};

export class TreeClassifier {
  public classify(query: string): Record<string, string> | undefined {
    return this.traverse(query.toLowerCase(), DOMAIN_TREE);
  }

  private traverse(
    query: string,
    node: TreeNode
  ): Record<string, string> | undefined {
    if (!node.children) return node.chromaFilter;

    for (const child of node.children) {
      if (child.signals.some(s => query.includes(s))) {
        // Recurse to narrow further
        const deeper = this.traverse(query, child);
        return deeper ?? child.chromaFilter;
      }
    }

    return node.chromaFilter; // no child matched, use this node's filter
  }
}
```

### 4.3 Integration into Pipeline

In `Pipeline.process()`, replace the hardcoded domain filter:

```typescript
// Phase 4 addition inside Pipeline.process()
const treeFilter = this.treeClassifier.classify(query);
const candidates = await this.vectorStore.query(embedding, 10, treeFilter);
```

This means a query about "health sciences nursing department" will immediately narrow the vector search to `{domain: 'faculty', subCategory: 'health_sciences'}` — searching only ~15% of the corpus instead of all chunks.

