// ── Admin Dashboard JavaScript ───────────────────────────────────

class AdminDashboard {
  constructor() {
    this.currentPage = 'dashboard';
    this.chunks = [];
    this.isAuthenticated = false;
    this.csrfToken = null;
    this.init();
  }

  // ── Authentication Methods ───────────────────────────────────────
  
  async checkAuthentication() {
    try {
      const response = await fetch('/api/admin/verify');
      if (response.ok) {
        const data = await response.json();
        this.isAuthenticated = data.authenticated;
        return this.isAuthenticated;
      }
      // 401 is expected if not logged in, don't log as error
      if (response.status === 401) {
        return false;
      }
      return false;
    } catch (error) {
      // Silently handle network errors during auth check
      console.debug('[Auth] Network error during authentication check:', error);
      return false;
    }
  }

  async login(username, password) {
    try {
      const response = await fetch('/api/admin/login', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ username, password })
      });

      const data = await response.json();

      if (response.ok) {
        this.isAuthenticated = true;
        this.showLoginScreen(false);
        this.showAdminDashboard(true);
        this.loadStats();
        this.loadChunks();
        this.showAlert('Success', 'Login successful', 'success');
        return true;
      } else {
        throw new Error(data.error || 'Login failed');
      }
    } catch (error) {
      console.error('Login error:', error);
      throw error;
    }
  }

  async logout() {
    try {
      await fetch('/api/admin/logout', {
        method: 'POST'
      });
      
      this.isAuthenticated = false;
      this.showLoginScreen(true);
      this.showAdminDashboard(false);
      this.showAlert('Success', 'Logged out successfully', 'success');
    } catch (error) {
      console.error('Logout error:', error);
      this.showAlert('Error', 'Failed to logout', 'error');
    }
  }

  getCookie(name) {
    // Get cookie value by name
    const match = document.cookie.match(new RegExp('(^|;\\s*)(' + name + ')=([^;]*)'));
    return match ? match[3] : null;
  }

  getCsrfToken() {
    // Get CSRF token from cookie
    return this.getCookie('csrf_token');
  }

  async authenticatedFetch(url, options = {}) {
    const csrfToken = this.getCsrfToken();
    const headers = {
      ...options.headers,
      'Content-Type': 'application/json'
    };

    if (csrfToken) {
      headers['X-CSRF-Token'] = csrfToken;
    }

    return fetch(url, {
      ...options,
      headers
    });
  }

  // ── Custom Dialog Methods ───────────────────────────────────────
  
  showConfirm(title, message, callback) {
    // Remove existing confirm dialog if any
    const existingConfirm = document.querySelector('.confirm-dialog');
    if (existingConfirm) {
      existingConfirm.remove();
    }

    const confirmDialog = document.createElement('div');
    confirmDialog.className = 'confirm-dialog';
    confirmDialog.innerHTML = `
      <div class="confirm-dialog-content">
        <div class="confirm-dialog-title">${this.escapeHtml(title)}</div>
        <div class="confirm-dialog-message">${this.escapeHtml(message)}</div>
        <div class="confirm-dialog-actions">
          <button class="confirm-dialog-btn secondary" data-action="cancel">Cancel</button>
          <button class="confirm-dialog-btn primary" data-action="confirm">Confirm</button>
        </div>
      </div>
    `;

    document.body.appendChild(confirmDialog);

    // Show dialog with animation
    setTimeout(() => confirmDialog.classList.add('active'), 10);

    // Handle button clicks
    const handleAction = (action) => {
      confirmDialog.classList.remove('active');
      setTimeout(() => {
        confirmDialog.remove();
        if (action === 'confirm' && callback) {
          callback();
        }
      }, 200);
    };

    confirmDialog.addEventListener('click', (e) => {
      if (e.target.classList.contains('confirm-dialog-btn')) {
        handleAction(e.target.dataset.action);
      }
    });

    // Close on overlay click
    confirmDialog.addEventListener('click', (e) => {
      if (e.target === confirmDialog) {
        handleAction('cancel');
      }
    });
  }

  showAlert(title, message, type = 'info', duration = 5000) {
    // Remove existing alert if any
    const existingAlert = document.querySelector('.alert-dialog');
    if (existingAlert) {
      existingAlert.remove();
    }

    const alertDialog = document.createElement('div');
    alertDialog.className = `alert-dialog ${type}`;
    alertDialog.innerHTML = `
      <button class="alert-dialog-close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <div class="alert-dialog-title">${this.escapeHtml(title)}</div>
      <div class="alert-dialog-message">${this.escapeHtml(message)}</div>
    `;

    document.body.appendChild(alertDialog);

    // Show alert with animation
    setTimeout(() => alertDialog.classList.add('show'), 10);

    // Handle close button
    const closeAlert = () => {
      alertDialog.classList.remove('show');
      setTimeout(() => alertDialog.remove(), 200);
    };

    alertDialog.querySelector('.alert-dialog-close').addEventListener('click', closeAlert);

    // Auto-hide after duration
    if (duration > 0) {
      setTimeout(closeAlert, duration);
    }
  }

  init() {
    // Wait for DOM to be fully loaded
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        this.bindEvents();
        this.checkAuthAndInit();
      });
    } else {
      this.bindEvents();
      this.checkAuthAndInit();
    }
  }

  async checkAuthAndInit() {
    // Initially hide both screens and show loading state
    this.showLoginScreen(false);
    this.showAdminDashboard(false);
    
    // Add loading indicator
    const loadingHtml = `
      <div id="auth-loading" style="
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #1a1a1a;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        color: white;
        font-family: Arial, sans-serif;
      ">
        <div style="text-align: center;">
          <div style="margin-bottom: 20px;">Loading...</div>
          <div style="width: 40px; height: 40px; border: 3px solid #333; border-top: 3px solid #007bff; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto;"></div>
        </div>
      </div>
      <style>
        @keyframes spin {
          0% { transform: rotate(0deg); }
          100% { transform: rotate(360deg); }
        }
      </style>
    `;
    
    // Remove any existing loading indicator
    const existingLoading = document.getElementById('auth-loading');
    if (existingLoading) {
      existingLoading.remove();
    }
    
    // Add loading indicator
    document.body.insertAdjacentHTML('beforeend', loadingHtml);
    
    try {
      // Check if user is already authenticated by checking for admin_token cookie
      const hasToken = this.getCookie('admin_token');
      console.debug('[Auth] Cookie check - admin_token present:', !!hasToken);
      
      if (hasToken) {
        const isAuth = await this.checkAuthentication();
        console.debug('[Auth] Server verification - authenticated:', isAuth);
        
        if (isAuth) {
          // Remove loading indicator
          const loadingIndicator = document.getElementById('auth-loading');
          if (loadingIndicator) {
            loadingIndicator.remove();
          }
          
          this.showLoginScreen(false);
          this.showAdminDashboard(true);
          this.loadStats();
          this.loadChunks();
          return;
        }
      }
      
      // Remove loading indicator and show login screen
      const loadingIndicator = document.getElementById('auth-loading');
      if (loadingIndicator) {
        loadingIndicator.remove();
      }
      
      console.debug('[Auth] Showing login screen');
      this.showLoginScreen(true);
      this.showAdminDashboard(false);
    } catch (error) {
      console.error('[Auth] Error during auth check:', error);
      
      // Remove loading indicator and show login screen on error
      const loadingIndicator = document.getElementById('auth-loading');
      if (loadingIndicator) {
        loadingIndicator.remove();
      }
      
      this.showLoginScreen(true);
      this.showAdminDashboard(false);
    }
  }

  showLoginScreen(show) {
    const loginScreen = document.getElementById('login-screen');
    if (loginScreen) {
      loginScreen.style.display = show ? 'flex' : 'none';
    }
  }

  showAdminDashboard(show) {
    const adminLayout = document.getElementById('admin-layout');
    if (adminLayout) {
      adminLayout.style.display = show ? 'flex' : 'none';
    }
  }

  bindEvents() {
    // Login form
    const loginForm = document.getElementById('login-form');
    if (loginForm) {
      loginForm.addEventListener('submit', (e) => this.handleLogin(e));
    }

    // Logout button
    const logoutBtn = document.getElementById('logout-btn');
    if (logoutBtn) {
      logoutBtn.addEventListener('click', () => this.logout());
    }

    // Navigation
    document.querySelectorAll('.nav-item').forEach(item => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        const page = item.dataset.page;
        this.navigateTo(page);
      });
    });

    // Menu toggle
    const menuToggle = document.getElementById('menu-toggle');
    if (menuToggle) {
      menuToggle.addEventListener('click', () => this.toggleSidebar());
    }

    // Chunk form
    const chunkForm = document.getElementById('chunk-form');
    if (chunkForm) {
      chunkForm.addEventListener('submit', (e) => this.handleChunkSubmit(e));
    }

    // Search
    const searchInput = document.getElementById('chunk-search');
    if (searchInput) {
      searchInput.addEventListener('input', (e) => this.handleSearch(e));
    }
  }

  async handleLogin(e) {
    e.preventDefault();
    const form = e.target;
    const username = form.username.value;
    const password = form.password.value;
    const loginBtn = document.getElementById('login-btn');
    const loginError = document.getElementById('login-error');
    const btnText = loginBtn.querySelector('.btn-text');
    const btnLoading = loginBtn.querySelector('.btn-loading');

    // Show loading state
    loginBtn.disabled = true;
    btnText.style.display = 'none';
    btnLoading.style.display = 'inline';
    loginError.style.display = 'none';

    try {
      await this.login(username, password);
      form.reset();
    } catch (error) {
      loginError.textContent = error.message;
      loginError.style.display = 'block';
    } finally {
      // Reset button state
      loginBtn.disabled = false;
      btnText.style.display = 'inline';
      btnLoading.style.display = 'none';
    }
  }

  navigateTo(page) {
    this.currentPage = page;

    // Update nav items
    document.querySelectorAll('.nav-item').forEach(item => {
      item.classList.remove('active');
      if (item.dataset.page === page) {
        item.classList.add('active');
      }
    });

    // Update pages
    document.querySelectorAll('.page').forEach(p => {
      p.classList.remove('active');
    });
    const targetPage = document.getElementById(`page-${page}`);
    if (targetPage) {
      targetPage.classList.add('active');
    }

    // Update title
    const titleMap = {
      dashboard: 'Dashboard',
      chunks: 'Knowledge Base',
      analytics: 'Analytics',
      settings: 'Settings'
    };
    document.getElementById('page-title').textContent = titleMap[page] || 'Dashboard';

    // Close sidebar on mobile
    if (window.innerWidth <= 768) {
      this.closeSidebar();
    }
  }

  toggleSidebar() {
    const sidebar = document.getElementById('sidebar');
    if (sidebar) {
      sidebar.classList.toggle('open');
    }
  }

  closeSidebar() {
    const sidebar = document.getElementById('sidebar');
    if (sidebar) {
      sidebar.classList.remove('open');
    }
  }

  async loadStats() {
    try {
      const response = await this.authenticatedFetch('/api/admin/stats');
      if (response.ok) {
        const stats = await response.json();
        this.updateStats(stats);
      } else if (response.status === 401) {
        // Token expired, redirect to login
        this.isAuthenticated = false;
        this.showLoginScreen(true);
        this.showAdminDashboard(false);
      } else {
        console.warn('Stats API not available, showing fallback');
        this.updateStats({
          chunks: 0,
          queries: 0,
          uptime: '0h 0m',
          health: 'Unknown'
        });
      }
    } catch (error) {
      console.error('Error loading stats:', error);
      this.updateStats({
        chunks: 0,
        queries: 0,
        uptime: '0h 0m',
        health: 'Unknown'
      });
    }
  }

  updateStats(stats) {
    const chunksEl = document.getElementById('stat-chunks');
    const queriesEl = document.getElementById('stat-queries');
    const uptimeEl = document.getElementById('stat-uptime');
    const healthEl = document.getElementById('stat-health');

    if (chunksEl) chunksEl.textContent = stats.chunks || 0;
    if (queriesEl) queriesEl.textContent = stats.queries || 0;
    
    // Format uptime display
    let uptimeText = stats.uptime || '100%';
    if (stats.uptimeHours !== undefined && stats.uptimeMinutes !== undefined) {
      uptimeText = `${stats.uptimeHours}h ${stats.uptimeMinutes}m`;
    }
    if (uptimeEl) uptimeEl.textContent = uptimeText;
    
    if (healthEl) {
      healthEl.textContent = stats.health || 'Good';
      // Update health indicator color
      const statCard = healthEl.closest('.stat-card');
      if (statCard) {
        const icon = statCard.querySelector('.stat-icon');
        if (stats.health === 'Good') {
          icon.style.background = 'var(--success)';
        } else if (stats.health === 'Degraded') {
          icon.style.background = 'var(--warning)';
        } else {
          icon.style.background = 'var(--danger)';
        }
      }
    }
  }

  refreshStats() {
    this.loadStats();
    this.addActivity('Stats refreshed');
  }

  async loadChunks() {
    try {
      const response = await this.authenticatedFetch('/api/admin/chunks');
      if (response.ok) {
        const data = await response.json();
        this.chunks = data.chunks || [];
        this.renderChunks();
      } else if (response.status === 401) {
        // Token expired, redirect to login
        this.isAuthenticated = false;
        this.showLoginScreen(true);
        this.showAdminDashboard(false);
      } else {
        console.warn('Chunks API not available, showing empty state');
        this.chunks = [];
        this.renderChunks();
      }
    } catch (error) {
      console.error('Error loading chunks:', error);
      this.chunks = [];
      this.renderChunks();
    }
  }

  renderChunks(filteredChunks = null) {
    const tbody = document.getElementById('chunks-table-body');
    if (!tbody) return;

    const chunksToRender = filteredChunks || this.chunks;

    if (chunksToRender.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="no-data">No chunks found</td></tr>';
      return;
    }

    tbody.innerHTML = chunksToRender.map(chunk => `
      <tr>
        <td><code>${this.escapeHtml(chunk.id)}</code></td>
        <td><span class="badge">${this.escapeHtml(chunk.type)}</span></td>
        <td>${this.escapeHtml(chunk.domain)}</td>
        <td>${this.escapeHtml(chunk.language)}</td>
        <td>${this.formatDate(chunk.updatedAt)}</td>
        <td>
          <button class="btn-icon" onclick="admin.editChunk('${this.escapeHtml(chunk.id)}')" title="Edit">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
            </svg>
          </button>
          <button class="btn-icon danger" onclick="admin.deleteChunk('${this.escapeHtml(chunk.id)}')" title="Delete">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="3 6 5 6 21 6"></polyline>
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
            </svg>
          </button>
        </td>
      </tr>
    `).join('');
  }

  handleSearch(e) {
    const query = e.target.value.toLowerCase();
    const filtered = this.chunks.filter(chunk =>
      chunk.id.toLowerCase().includes(query) ||
      chunk.type.toLowerCase().includes(query) ||
      chunk.domain.toLowerCase().includes(query)
    );
    this.renderChunks(filtered);
  }

  showAddChunkForm() {
    const modal = document.getElementById('chunk-modal');
    if (modal) {
      modal.classList.add('active');
    }
  }

  closeModal() {
    const modal = document.getElementById('chunk-modal');
    if (modal) {
      modal.classList.remove('active');
    }
    // Reset form
    const form = document.getElementById('chunk-form');
    if (form) {
      form.reset();
    }
  }

  async handleChunkSubmit(e) {
    e.preventDefault();
    const form = e.target;
    const formData = new FormData(form);
    const isEdit = form.dataset.mode === 'edit';
    const chunkId = form.dataset.chunkId;

    const chunkData = {
      id: formData.get('id'),
      metadata: {
        type: formData.get('type'),
        domain: formData.get('domain'),
        subCategory: formData.get('subCategory') || '',
        source: formData.get('source'),
        language: formData.get('language'),
        updatedAt: new Date().toISOString()
      },
      content: {
        en: formData.get('contentEn'),
        ar: formData.get('contentAr') || ''
      }
    };

    try {
      const response = await this.authenticatedFetch('/api/admin/chunks', {
        method: 'POST',
        body: JSON.stringify(chunkData)
      });

      if (response.ok) {
        this.addActivity(`${isEdit ? 'Updated' : 'Added'} chunk: ${chunkData.id}`);
        this.closeModal();
        this.loadChunks();
        this.loadStats();
        this.showAlert('Success', `Chunk ${isEdit ? 'updated' : 'added'} successfully`, 'success');
      } else if (response.status === 401) {
        this.isAuthenticated = false;
        this.showLoginScreen(true);
        this.showAdminDashboard(false);
      } else {
        const error = await response.json();
        this.showAlert('Error', error.message || 'Failed to save chunk', 'error');
      }
    } catch (error) {
      console.error('Error submitting chunk:', error);
      this.showAlert('Error', 'Failed to save chunk', 'error');
    }
  }

  async editChunk(id) {
    try {
      const response = await this.authenticatedFetch(`/api/admin/chunks/${id}`);
      if (!response.ok) {
        if (response.status === 401) {
          this.isAuthenticated = false;
          this.showLoginScreen(true);
          this.showAdminDashboard(false);
        }
        this.showAlert('Error', 'Failed to load chunk data', 'error');
        return;
      }

      const { chunk } = await response.json();
      this.showEditChunkForm(chunk);
    } catch (error) {
      console.error('Error loading chunk:', error);
      this.showAlert('Error', 'Failed to load chunk data', 'error');
    }
  }

  async deleteChunk(id) {
    this.showConfirm(
      'Delete Chunk',
      `Are you sure you want to delete chunk "${id}"? This action cannot be undone.`,
      async () => {
        try {
          const response = await this.authenticatedFetch(`/api/admin/chunks/${id}`, {
            method: 'DELETE'
          });

          if (response.ok) {
            this.addActivity(`Deleted chunk: ${id}`);
            this.loadChunks();
            this.loadStats();
            this.showAlert('Success', 'Chunk deleted successfully', 'success');
          } else if (response.status === 401) {
            this.isAuthenticated = false;
            this.showLoginScreen(true);
            this.showAdminDashboard(false);
          } else {
            const error = await response.json();
            this.showAlert('Error', error.error || 'Failed to delete chunk', 'error');
          }
        } catch (error) {
          console.error('Error deleting chunk:', error);
          this.showAlert('Error', 'Failed to delete chunk', 'error');
        }
      }
    );
  }

  showEditChunkForm(chunk) {
    const modal = document.getElementById('chunk-modal');
    if (!modal) return;

    // Update modal title
    const modalTitle = modal.querySelector('.modal-header h2');
    if (modalTitle) {
      modalTitle.textContent = 'Edit Knowledge Chunk';
    }

    // Fill form with chunk data
    const form = document.getElementById('chunk-form');
    if (form) {
      form.dataset.mode = 'edit';
      form.dataset.chunkId = chunk.id;

      document.getElementById('chunk-id').value = chunk.id;
      document.getElementById('chunk-type').value = chunk.metadata.type;
      document.getElementById('chunk-domain').value = chunk.metadata.domain;
      document.getElementById('chunk-subcategory').value = chunk.metadata.subCategory || '';
      document.getElementById('chunk-language').value = chunk.metadata.language;
      document.getElementById('chunk-source').value = chunk.metadata.source;
      document.getElementById('chunk-content-en').value = chunk.content.en;
      document.getElementById('chunk-content-ar').value = chunk.content.ar;

      // Make ID field readonly for edit
      document.getElementById('chunk-id').readOnly = true;
    }

    modal.classList.add('active');
  }

  showAddChunkForm() {
    const modal = document.getElementById('chunk-modal');
    if (!modal) return;

    // Update modal title
    const modalTitle = modal.querySelector('.modal-header h2');
    if (modalTitle) {
      modalTitle.textContent = 'Add Knowledge Chunk';
    }

    // Reset form
    const form = document.getElementById('chunk-form');
    if (form) {
      form.reset();
      form.dataset.mode = 'add';
      delete form.dataset.chunkId;

      // Make ID field editable for add
      document.getElementById('chunk-id').readOnly = false;
    }

    modal.classList.add('active');
  }

  addActivity(message) {
    const activityList = document.getElementById('activity-list');
    if (!activityList) return;

    const activityItem = document.createElement('div');
    activityItem.className = 'activity-item';
    activityItem.innerHTML = `
      <div class="activity-icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="16" x2="12" y2="12"></line>
          <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
      </div>
      <div class="activity-details">
        <div class="activity-title">${this.escapeHtml(message)}</div>
        <div class="activity-time">Just now</div>
      </div>
    `;

    activityList.insertBefore(activityItem, activityList.firstChild);

    // Keep only last 10 activities
    while (activityList.children.length > 10) {
      activityList.removeChild(activityList.lastChild);
    }
  }

  escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  formatDate(dateString) {
    const date = new Date(dateString);
    return date.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric'
    });
  }
}

// Initialize admin dashboard
const admin = new AdminDashboard();
// Make admin globally available for onclick handlers
window.admin = admin;
