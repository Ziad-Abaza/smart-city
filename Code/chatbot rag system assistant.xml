export type ChunkType = 'faculty' | 'course' | 'faq' | 'policy' | 'event' | 'contact';
export type DomainLevel1 = 'faculty' | 'course' | 'faq' | 'policy' | 'general';
export type Language = 'bilingual';

export interface BilingualContent {
  ar: string;
  en: string;
}

export interface ChunkMetadata {
  type: ChunkType;
  source: string;
  language: Language;
  domain: DomainLevel1;
  subCategory?: string;
  ttl?: number;           // seconds
  updatedAt: string;      // ISO 8601
}

export interface ChunkDocument {
  id: string;
  content: BilingualContent;
  metadata: ChunkMetadata;
}

export interface RetrievedChunk {
  id: string;
  content: BilingualContent;
  metadata: Record<string, string>;
  score: number;
}
