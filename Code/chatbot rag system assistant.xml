import axios, { AxiosInstance } from 'axios';
import Config from '../config/Config';

interface Message {
  role: 'system' | 'user' | 'assistant';
  content: string;
}

class GroqClient {
  private client: AxiosInstance;
  private apiKey: string;
  private apiUrl: string;
  private model: string;

  constructor() {
    const config = Config.getInstance();
    this.apiKey = config.get('GROQ_API_KEY');
    this.apiUrl = config.get('GROQ_API_URL', 'https://api.groq.com/openai/v1/chat/completions');
    this.model = config.get('GROQ_MODEL', 'mixtral-8x7b-32768');

    this.client = axios.create({
      headers: {
        Authorization: `Bearer ${this.apiKey}`,
        'Content-Type': 'application/json',
      },
      timeout: 30_000,
    });
  }

  public async generateResponse(messages: Message[], temperature = 0.3): Promise<string> {
    try {
      const response = await this.client.post(this.apiUrl, {
        model: this.model,
        messages,
        temperature,
        max_tokens: 1024,
      });
      return response.data.choices?.[0]?.message?.content ?? 'I cannot confirm this.';
    } catch (error) {
      console.error('[GroqClient] API error:', error);
      return 'I cannot confirm this based on available information.';
    }
  }

  public async ping(): Promise<boolean> {
    try {
      await this.generateResponse([
        { role: 'user', content: 'ping' },
      ]);
      return true;
    } catch {
      return false;
    }
  }
}

export default GroqClient;
