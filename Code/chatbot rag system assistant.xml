import crypto from 'crypto';
import Config from '../config/Config';

interface CacheEntry {
  value: string;
  expiresAt: number;
}

/**
 * CacheLayer
 * ----------
 * Redis-backed response cache with in-memory LRU fallback.
 * Domain-aware TTL prevents stale responses for time-sensitive content.
 */
export class CacheLayer {
  private memory = new Map<string, CacheEntry>();
  private redis: { get(k: string): Promise<string | null>; set(k: string, v: string, ex: number): Promise<void>; } | null = null;
  private readonly MAX_MEMORY = 1000;

  constructor() {
    this.initRedis().catch(() => {
      console.warn('[CacheLayer] Redis unavailable — using in-memory cache');
    });
  }

  private async initRedis(): Promise<void> {
    const url = Config.getInstance().get('REDIS_URL', '');
    if (!url) return;

    // Dynamic import so Redis is optional
    try {
      const { default: Redis } = await import('ioredis') as unknown as { default: new (url: string) => { get(k: string): Promise<string | null>; set(k: string, v: string, px: string, ex: number): Promise<void>; ping(): Promise<string>; on(event: string, handler: (err: Error) => void): void; } };
      const client = new Redis(url);
      client.on('error', (err) => {
        // Silently handle connection errors - fallback to memory cache
      });
      await client.ping();
      this.redis = {
        get: (k) => client.get(k),
        set: (k, v, ex) => client.set(k, v, 'EX', ex) as unknown as Promise<void>,
      };
      console.log('[CacheLayer] Connected to Redis');
    } catch {
      // Redis stays null, memory fallback used
    }
  }

  private makeKey(query: string, lang: string): string {
    return crypto.createHash('sha256').update(`${lang}|${query.trim().toLowerCase()}`).digest('hex');
  }

  public async get(query: string, lang: string): Promise<string | null> {
    const key = this.makeKey(query, lang);

    if (this.redis) {
      return this.redis.get(key);
    }

    const entry = this.memory.get(key);
    if (!entry) return null;
    if (Date.now() > entry.expiresAt) {
      this.memory.delete(key);
      return null;
    }
    return entry.value;
  }

  public async set(query: string, lang: string, value: string, ttlSeconds: number): Promise<void> {
    const key = this.makeKey(query, lang);

    if (this.redis) {
      await this.redis.set(key, value, ttlSeconds);
      return;
    }

    // Evict oldest entry if at capacity
    if (this.memory.size >= this.MAX_MEMORY) {
      const firstKey = this.memory.keys().next().value;
      if (firstKey) this.memory.delete(firstKey);
    }

    this.memory.set(key, {
      value,
      expiresAt: Date.now() + ttlSeconds * 1000,
    });
  }

  /** TTL strategy based on content domain */
  public static ttlForDomain(domain: string): number {
    const ttlMap: Record<string, number> = {
      faq:     7 * 24 * 3600,  // 7 days
      faculty: 24 * 3600,      // 24 hours
      course:  12 * 3600,      // 12 hours
      policy:  24 * 3600,      // 24 hours
      event:   1 * 3600,       // 1 hour
      general: 6 * 3600,       // 6 hours
    };
    return ttlMap[domain] ?? 3600;
  }
}
</file>

<file path="src/services/EmbeddingService.ts">
import axios from 'axios';
import Config from '../config/Config';

export interface EmbeddingResult {
  embedding: number[];
  model: string;
  dimensions: number;
}

/**
 * EmbeddingService
 * ----------------
 * Generates vector embeddings for text.
 *
 * Provider priority:
 *   EMBEDDING_PROVIDER=ollama → local Nomic Embed (free, fast, multilingual)
 *   EMBEDDING_PROVIDER=voyage → Voyage AI cloud (higher quality)
 *
 * Automatically falls back to a deterministic pseudo-embedding
 * (TF-IDF hash) if no provider is reachable, keeping Phase 1 alive.
 */
export class EmbeddingService {
  private provider: 'voyage' | 'ollama';
  private ollamaUrl: string;

  constructor() {
    const config = Config.getInstance();
    this.provider = config.get('EMBEDDING_PROVIDER', 'ollama') as 'voyage' | 'ollama';
    this.ollamaUrl = config.get('OLLAMA_URL', 'http://localhost:11434');
  }

  public async embed(text: string): Promise<EmbeddingResult> {
    const maxRetries = 3;
    const baseDelay = 1000; // 1 second

    for (let attempt = 1; attempt <= maxRetries; attempt++) {
      try {
        if (this.provider === 'voyage') {
          return await this.embedVoyage(text);
        }
        return await this.embedOllama(text);
      } catch (err) {
        if (attempt === maxRetries) {
          console.warn('[EmbeddingService] Provider unavailable after retries, using fallback hash embedding');
          console.error('[EmbeddingService] Last error:', err);
          return this.hashFallback(text);
        }
        const delay = baseDelay * Math.pow(2, attempt - 1);
        console.warn(`[EmbeddingService] Provider unavailable (attempt ${attempt}/${maxRetries}), retrying in ${delay}ms...`);
        console.error('[EmbeddingService] Error:', err);
        await new Promise(resolve => setTimeout(resolve, delay));
      }
    }
    return this.hashFallback(text); // Should never reach here
  }

  public async ping(): Promise<boolean> {
    try {
      await this.embed('ping');
      return true;
    } catch {
      return false;
    }
  }

  // ── Providers ────────────────────────────────────────────────

  private async embedOllama(text: string): Promise<EmbeddingResult> {
    const res = await axios.post(
      `${this.ollamaUrl}/api/embeddings`,
      { model: 'nomic-embed-text', prompt: text },
      { timeout: 60_000 } // Increased to 60s for model loading
    );
    const embedding: number[] = res.data.embedding;
    return { embedding, model: 'nomic-embed-text', dimensions: embedding.length };
  }

  private async embedVoyage(text: string): Promise<EmbeddingResult> {
    const config = Config.getInstance();
    const res = await axios.post(
      'https://api.voyageai.com/v1/embeddings',
      { model: 'voyage-large-2', input: text },
      {
        headers: {
          Authorization: `Bearer ${config.get('VOYAGE_API_KEY')}`,
          'Content-Type': 'application/json',
        },
        timeout: 15_000,
      }
    );
    const embedding: number[] = res.data.data[0].embedding;
    return { embedding, model: 'voyage-large-2', dimensions: embedding.length };
  }

  /**
   * Deterministic 384-dim pseudo-embedding via FNV-1a hashing.
   * Quality is poor — used only when no embedding service is reachable.
   */
  private hashFallback(text: string): EmbeddingResult {
    const DIM = 384;
    const embedding = new Array<number>(DIM).fill(0);
    const words = text.toLowerCase().split(/\s+/);
    for (const word of words) {
      let hash = 2166136261;
      for (let i = 0; i < word.length; i++) {
        hash ^= word.charCodeAt(i);
        hash = (hash * 16777619) >>> 0;
      }
      const idx = hash % DIM;
      embedding[idx] += 1;
    }
    // L2 normalize
    const norm = Math.sqrt(embedding.reduce((s, v) => s + v * v, 0)) || 1;
    return {
      embedding: embedding.map(v => v / norm),
      model: 'hash-fallback',
      dimensions: DIM,
    };
  }
}
</file>

