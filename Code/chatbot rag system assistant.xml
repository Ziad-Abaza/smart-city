## Phase 3 — Multi-Stage Retrieval Pipeline

**Goal:** Replace the current `Router → Retriever → Processor` chain with a proper five-stage pipeline.

### 3.1 Stage Breakdown

```
Stage 1: QueryAnalyzer
  - Language detection (existing LanguageHandler)
  - Intent classification: question | command | greeting | out-of-scope
  - Entity extraction: faculty name, course code, topic keywords
  - Query type: factual | procedural | comparative

Stage 2: EmbeddingService.embed(query)
  - For Arabic queries: embed Arabic text directly (Nomic handles Arabic well)
  - For English: embed English text

Stage 3: VectorStore.query(embedding, topK=10, metadataFilter)
  - Apply domain filter from Stage 1 classification

Stage 4: Reranker
  - Score each retrieved chunk against original query
  - Cross-encoder: query × chunk → relevance score
  - Fallback: BM25 score as secondary signal

Stage 5: ContextBuilder
  - Pick top 3–5 reranked chunks
  - Format bilingual context for LLM prompt
  - Deduplicate overlapping content
```

### 3.2 QueryAnalyzer

```typescript
// src/rag/QueryAnalyzer.ts

export type Intent = 'question' | 'greeting' | 'out_of_scope' | 'command';
export type QueryType = 'factual' | 'procedural' | 'comparative';
export type Domain = 'faculty' | 'course' | 'faq' | 'policy' | 'general';

export interface QueryAnalysis {
  language: 'ar' | 'en';
  intent: Intent;
  domain: Domain;
  queryType: QueryType;
  entities: string[];
  rewrittenQuery: string;
}

export class QueryAnalyzer {
  private readonly DOMAIN_SIGNALS: Record<Domain, string[]> = {
    faculty: ['faculty', 'college', 'department', 'كلية', 'قسم', 'تخصص'],
    course: ['course', 'subject', 'credit', 'مقرر', 'مادة', 'ساعة'],
    faq: ['fee', 'admission', 'location', 'contact', 'رسوم', 'قبول', 'موقع'],
    policy: ['policy', 'rule', 'regulation', 'سياسة', 'نظام', 'لائحة'],
    general: [],
  };

  public analyze(query: string, lang: 'ar' | 'en'): QueryAnalysis {
    const domain = this.classifyDomain(query);
    const intent = this.classifyIntent(query, lang);
    const entities = this.extractEntities(query, lang);
    const queryType = this.classifyQueryType(query, lang);

    return {
      language: lang,
      intent,
      domain,
      queryType,
      entities,
      rewrittenQuery: this.rewrite(query, lang, entities),
    };
  }

  private classifyDomain(query: string): Domain {
    const lower = query.toLowerCase();
    for (const [domain, signals] of Object.entries(this.DOMAIN_SIGNALS) as [Domain, string[]][]) {
      if (signals.some(s => lower.includes(s))) return domain;
    }
    return 'general';
  }

  private classifyIntent(query: string, lang: 'ar' | 'en'): Intent {
    const greetings = ['hello', 'hi', 'hey', 'مرحبا', 'السلام', 'أهلا'];
    const lower = query.toLowerCase();
    if (greetings.some(g => lower.includes(g))) return 'greeting';
    if (query.includes('?') || query.includes('؟')) return 'question';
    return 'question';
  }

  private extractEntities(query: string, lang: 'ar' | 'en'): string[] {
    // Faculty names, course codes, department names
    const facultyPatterns = [
      /faculty of (\w+(?: \w+)*)/gi,
      /department of (\w+(?: \w+)*)/gi,
      /كلية ([\u0600-\u06FF ]+)/g,
      /قسم ([\u0600-\u06FF ]+)/g,
    ];
    const entities: string[] = [];
    for (const pattern of facultyPatterns) {
      let match;
      while ((match = pattern.exec(query)) !== null) {
        entities.push(match[1].trim());
      }
    }
    return entities;
  }

  private classifyQueryType(query: string, lang: 'ar' | 'en'): QueryType {
    const proceduralKeywords = ['how to', 'how do', 'steps', 'process', 'كيف', 'خطوات'];
    const lower = query.toLowerCase();
    if (proceduralKeywords.some(k => lower.includes(k))) return 'procedural';
    return 'factual';
  }

  private rewrite(query: string, lang: 'ar' | 'en', entities: string[]): string {
    // Normalize and expand query
    return query.trim()
      .replace(/\s+/g, ' ')
      .replace(/[؟?]+$/, '?');
  }
}
```

### 3.3 Reranker

```typescript
// src/rag/Reranker.ts
// Cross-encoder reranking using Cohere Rerank (free tier: 1000 calls/month)
// Fallback: BM25 keyword overlap scoring

import axios from 'axios';
import Config from '../config/Config';

export interface RankedChunk {
  id: string;
  content: { en: string; ar: string };
  metadata: Record<string, string>;
  score: number;
}

export class Reranker {
  private config = Config.getInstance();
  private cohereKey = this.config.get('COHERE_API_KEY', '');

  public async rerank(
    query: string,
    candidates: RankedChunk[],
    topN: number = 5
  ): Promise<RankedChunk[]> {
    if (this.cohereKey && candidates.length > 0) {
      try {
        return await this.cohereRerank(query, candidates, topN);
      } catch {
        console.warn('[Reranker] Cohere unavailable, falling back to BM25');
      }
    }
    return this.bm25Rerank(query, candidates, topN);
  }

  private async cohereRerank(
    query: string,
    candidates: RankedChunk[],
    topN: number
  ): Promise<RankedChunk[]> {
    const docs = candidates.map(c => `${c.content.en}\n${c.content.ar}`);
    const res = await axios.post(
      'https://api.cohere.ai/v1/rerank',
      { query, documents: docs, top_n: topN, model: 'rerank-multilingual-v3.0' },
      { headers: { Authorization: `Bearer ${this.cohereKey}` } }
    );

    return res.data.results.map((r: { index: number; relevance_score: number }) => ({
      ...candidates[r.index],
      score: r.relevance_score,
    }));
  }

  private bm25Rerank(query: string, candidates: RankedChunk[], topN: number): RankedChunk[] {
    const queryTerms = query.toLowerCase().split(/\s+/);
    const scored = candidates.map(c => {
      const text = `${c.content.en} ${c.content.ar}`.toLowerCase();
      const termFreq = queryTerms.reduce((acc, t) => {
        const count = (text.match(new RegExp(t, 'g')) ?? []).length;
        return acc + (count > 0 ? 1 + Math.log(count) : 0);
      }, 0);
      return { ...c, score: c.score * 0.5 + termFreq * 0.5 };
    });
    return scored.sort((a, b) => b.score - a.score).slice(0, topN);
  }
}
```

### 3.4 Updated Pipeline.ts

```typescript
// src/rag/Pipeline.ts (Phase 3 version)
import { QueryAnalyzer } from './QueryAnalyzer';
import { VectorStore } from '../services/VectorStore';
import { EmbeddingService } from '../services/EmbeddingService';
import { Reranker, RankedChunk } from './Reranker';
import { ContextBuilder } from './ContextBuilder';
import { CacheLayer } from '../services/CacheLayer';
import GroqClient from '../services/GroqClient';
import LanguageHandler from '../services/LanguageHandler';

export class Pipeline {
  private analyzer = new QueryAnalyzer();
  private embedder = new EmbeddingService();
  private vectorStore = new VectorStore();
  private reranker = new Reranker();
  private contextBuilder = new ContextBuilder();
  private cache = new CacheLayer();
  private groq = new GroqClient();

  public async initialize(): Promise<void> {
    await this.vectorStore.initialize();
  }

  public async process(query: string): Promise<string> {
    const lang = LanguageHandler.detect(query);

    // Stage 0: Cache check
    const cached = await this.cache.get(query, lang);
    if (cached) return cached;

    // Stage 1: Query analysis
    const analysis = this.analyzer.analyze(query, lang);

    // Short-circuit greetings
    if (analysis.intent === 'greeting') {
      const reply = lang === 'ar'
        ? 'مرحباً! كيف يمكنني مساعدتك في جامعة BATU؟'
        : 'Hello! How can I help you with BATU today?';
      await this.cache.set(query, lang, reply, 3600);
      return reply;
    }

    // Stage 2: Embedding
    const { embedding } = await this.embedder.embed(analysis.rewrittenQuery);

    // Stage 3: Vector search with domain filter
    const whereFilter = analysis.domain !== 'general'
      ? { domain: analysis.domain }
      : undefined;
    const candidates = await this.vectorStore.query(embedding, 10, whereFilter);

    // Stage 4: Rerank
    const reranked = await this.reranker.rerank(
      analysis.rewrittenQuery,
      candidates as RankedChunk[],
      5
    );

    // Stage 5: Context construction
    const context = this.contextBuilder.build(reranked, lang);

    // Stage 6: Generation
    const response = await this.groq.generateResponse([
      { role: 'system', content: this.getSystemPrompt(lang) },
      { role: 'user', content: `Context:\n${context}\n\nQuery: ${analysis.rewrittenQuery}` },
    ]);

    // Cache with TTL based on domain
    const ttl = analysis.domain === 'faq' ? 604800 : analysis.domain === 'faculty' ? 86400 : 3600;
    await this.cache.set(query, lang, response, ttl);

    return response;
  }

  private getSystemPrompt(lang: 'ar' | 'en'): string {
    // ... (same as current, with language instruction)
    return `You are the official AI assistant for Burj Al Arab Technological University (BATU).
    STRICT RULES:
    - Only answer using the provided context.
    - If the context does not contain the answer, say so explicitly.
    - Never fabricate facts, names, or data.
    - ${lang === 'ar' ? 'استجب باللغة العربية فقط.' : 'Respond ONLY in English.'}`;
  }
}
```

