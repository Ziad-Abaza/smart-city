import { Request, Response } from 'express';
import { VectorStore } from '../services/VectorStore';
import { ChunkDocument } from '../types/Chunk';
import { v4 as uuidv4 } from 'uuid';
import AuthService from '../services/AuthService';

// Singleton pipeline — initialized once on first request
let vectorStore: VectorStore | null = null;
let initializing: Promise<void> | null = null;

// ── Login Handler ─────────────────────────────────────────────────
export const loginHandler = async (req: Request, res: Response): Promise<void> => {
  try {
    const { username, password } = req.body;
    const authService = AuthService.getInstance();
    const ip = (req as any).clientIp || req.ip || 'unknown';

    // Validate input
    const validation = authService.validateCredentials(username, password);
    if (!validation.valid) {
      res.status(400).json({ error: validation.error });
      return;
    }

    // Check if account is locked
    const identifier = `${ip}_${username}`;
    if (authService.isAccountLocked(identifier)) {
      const remainingTime = Math.ceil(authService.getRemainingLockTime(identifier) / 1000);
      res.status(429).json({ 
        error: 'Account temporarily locked due to too many failed attempts',
        code: 'ACCOUNT_LOCKED',
        remainingTime
      });
      return;
    }

    // Check credentials
    const isValid = await authService.checkAdminCredentials(username, password);
    if (!isValid) {
      authService.recordFailedAttempt(identifier);
      authService.logSecurityEvent('FAILED_LOGIN_ATTEMPT', { 
        username, 
        ip,
        timestamp: new Date().toISOString()
      });
      res.status(401).json({ 
        error: 'Invalid username or password',
        code: 'INVALID_CREDENTIALS'
      });
      return;
    }

    // Generate token
    const token = authService.generateToken(username);
    
    // Record successful attempt
    authService.recordSuccessfulAttempt(identifier);
    
    // Log successful login
    authService.logSecurityEvent('SUCCESSFUL_LOGIN', { 
      username, 
      ip,
      timestamp: new Date().toISOString()
    });

    // Set token in HTTP-only cookie
    res.cookie('admin_token', token, {
      httpOnly: true,
      secure: process.env.NODE_ENV === 'production',
      sameSite: 'strict',
      path: '/',
      maxAge: 24 * 60 * 60 * 1000 // 24 hours
    });

    res.json({ 
      success: true, 
      token,
      username,
      message: 'Login successful'
    });
  } catch (error) {
    console.error('[loginHandler] Error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
};

// ── Logout Handler ────────────────────────────────────────────────
export const logoutHandler = async (req: Request, res: Response): Promise<void> => {
  try {
    // Clear token cookie
    res.clearCookie('admin_token', { path: '/' });
    res.clearCookie('csrf_token', { path: '/' });
    
    res.json({ success: true, message: 'Logout successful' });
  } catch (error) {
    console.error('[logoutHandler] Error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
};

// ── Verify Auth Handler ────────────────────────────────────────────
export const verifyAuthHandler = async (req: Request, res: Response): Promise<void> => {
  try {
    // If we reach here, authentication middleware has already verified the token
    res.json({ 
      authenticated: true,
      username: req.user?.username
    });
  } catch (error) {
    console.error('[verifyAuthHandler] Error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
};

// ── Optional Verify Auth Handler (for frontend check) ───────────────
export const optionalVerifyAuthHandler = async (req: Request, res: Response): Promise<void> => {
  try {
    // Get token from Authorization header or cookie
    const authHeader = req.headers.authorization;
    const tokenFromHeader = authHeader?.startsWith('Bearer ') 
      ? authHeader.substring(7) 
      : null;
    
    const tokenFromCookie = req.cookies?.admin_token;
    const token = tokenFromHeader || tokenFromCookie;

    console.debug('[Auth] Verify request - token from header:', !!tokenFromHeader, 'token from cookie:', !!tokenFromCookie);

    if (!token) {
      console.debug('[Auth] No token found');
      res.json({ authenticated: false });
      return;
    }

    const authService = AuthService.getInstance();
    const payload = authService.verifyToken(token);
    
    if (payload) {
      console.debug('[Auth] Token verification successful for user:', payload.username);
      res.json({ 
        authenticated: true,
        username: payload.username
      });
    } else {
      console.debug('[Auth] Token verification failed');
      res.json({ authenticated: false });
    }
  } catch (error) {
    console.error('[optionalVerifyAuthHandler] Error:', error);
    res.json({ authenticated: false });
  }
};

async function getVectorStore(): Promise<VectorStore> {
  if (vectorStore) return vectorStore;

  if (!initializing) {
    vectorStore = new VectorStore();
    initializing = vectorStore.initialize().then(() => {
      initializing = null;
    });
  }

  await initializing;
  return vectorStore!;
}

// ── Stats Handler ───────────────────────────────────────────────
export const statsHandler = async (req: Request, res: Response): Promise<void> => {
  try {
    const vs = await getVectorStore();
    
    // Get real stats from ChromaDB
    const isHealthy = await vs.ping();
    const chunkCount = await vs.getChunkCount();
    
    // Calculate uptime (simplified - would use process.uptime() in production)
    const uptime = process.uptime();
    const uptimeHours = Math.floor(uptime / 3600);
    const uptimeMinutes = Math.floor((uptime % 3600) / 60);
    const uptimePercent = uptime > 0 ? '100%' : '0%';
    
    const stats = {
      chunks: chunkCount,
      queries: 0, // This would come from query logging in production
      uptime: uptimePercent,
      health: isHealthy ? 'Good' : 'Degraded',
      uptimeHours,
      uptimeMinutes
    };

    res.json(stats);
  } catch (error) {
    console.error('[statsHandler] Error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
};

// ── List Chunks Handler ───────────────────────────────────────────
export const listChunksHandler = async (req: Request, res: Response): Promise<void> => {
  try {
    const vs = await getVectorStore();
    
    // Get real chunks from ChromaDB
    const chunks = await vs.getAllChunks();

    res.json({ chunks });
  } catch (error) {
    console.error('[listChunksHandler] Error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
};

// ── Add Chunk Handler ─────────────────────────────────────────────
export const addChunkHandler = async (req: Request, res: Response): Promise<void> => {
  try {
    const { id, metadata, content } = req.body;

    if (!id || !metadata || !content) {
      res.status(400).json({ error: 'Missing required fields' });
      return;
    }

    if (!content.en || !content.ar) {
      res.status(400).json({ error: 'Content must include both English and Arabic' });
      return;
    }

    const chunk: ChunkDocument = {
      id: id || `chunk_${uuidv4()}`,
      content: {
        en: content.en,
        ar: content.ar
      },
      metadata: {
        type: metadata.type || 'unknown',
        source: metadata.source || 'admin',
        language: metadata.language || 'bilingual',
        domain: metadata.domain || 'general',
        subCategory: metadata.subCategory,
        updatedAt: metadata.updatedAt || new Date().toISOString()
      }
    };

    const vs = await getVectorStore();
    await vs.upsertChunks([chunk]);

    res.json({ success: true, chunkId: chunk.id });
  } catch (error) {
    console.error('[addChunkHandler] Error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
};

// ── Delete Chunk Handler ──────────────────────────────────────────
export const deleteChunkHandler = async (req: Request, res: Response): Promise<void> => {
  try {
    const { id } = req.params;

    if (!id) {
      res.status(400).json({ error: 'Missing chunk ID' });
      return;
    }

    const vs = await getVectorStore();
    const success = await vs.deleteChunk(id);

    if (success) {
      res.json({ success: true, message: 'Chunk deleted successfully' });
    } else {
      res.status(404).json({ error: 'Chunk not found or deletion failed' });
    }
  } catch (error) {
    console.error('[deleteChunkHandler] Error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
};

// ── Get Chunk Handler ─────────────────────────────────────────────
export const getChunkHandler = async (req: Request, res: Response): Promise<void> => {
  try {
    const { id } = req.params;

    if (!id) {
      res.status(400).json({ error: 'Missing chunk ID' });
      return;
    }

    const vs = await getVectorStore();
    const chunk = await vs.getChunkById(id);

    if (chunk) {
      res.json({ chunk });
    } else {
      res.status(404).json({ error: 'Chunk not found' });
    }
  } catch (error) {
    console.error('[getChunkHandler] Error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
};
