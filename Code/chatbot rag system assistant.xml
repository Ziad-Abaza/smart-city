<file path="src/services/VectorStore.ts">
import Config from '../config/Config';
import { ChunkDocument, RetrievedChunk, ChunkMetadata } from '../types/Chunk';
import { EmbeddingService } from './EmbeddingService';

/**
 * VectorStore
 * -----------
 * Wraps ChromaDB for semantic chunk storage and retrieval.
 *
 * Falls back to in-memory cosine similarity (over pre-computed embeddings)
 * when ChromaDB is not reachable — ensures the system works in dev
 * without running Docker.
 */
export class VectorStore {
  private embedder: EmbeddingService;
  private chromaUrl: string;
  private readonly COLLECTION = 'batu_knowledge';

  // In-memory fallback store
  private memoryStore: Array<{
    id: string;
    embedding: number[];
    content: { en: string; ar: string };
    metadata: Record<string, string>;
  }> = [];

  private useMemory = false;
  private collectionId: string | null = null;

  constructor() {
    this.embedder = new EmbeddingService();
    this.chromaUrl = Config.getInstance().get('CHROMA_URL', 'http://localhost:8000');
  }

  public async initialize(): Promise<void> {
    const maxRetries = 5;
    const baseDelay = 2000; // 2 seconds

    for (let attempt = 1; attempt <= maxRetries; attempt++) {
      try {
        const res = await fetch(`${this.chromaUrl}/api/v2/heartbeat`, {
          method: 'GET',
          headers: { 'Accept': 'application/json' },
        });
        if (!res.ok) {
          console.error(`[VectorStore] Heartbeat failed: ${res.status} ${res.statusText}`);
          throw new Error('ChromaDB not reachable');
        }
        await this.ensureCollection();
        await this.getCollectionId();
        console.log('[VectorStore] Connected to ChromaDB at', this.chromaUrl);
        return;
      } catch (err) {
        if (attempt === maxRetries) {
          console.warn('[VectorStore] ChromaDB unavailable after retries — using in-memory fallback');
          console.error('[VectorStore] Last error:', err);
          this.useMemory = true;
          return;
        }
        const delay = baseDelay * Math.pow(2, attempt - 1);
        console.warn(`[VectorStore] ChromaDB unavailable (attempt ${attempt}/${maxRetries}), retrying in ${delay}ms...`);
        console.error('[VectorStore] Error:', err);
        await new Promise(resolve => setTimeout(resolve, delay));
      }
    }
  }

  public async upsertChunks(chunks: ChunkDocument[]): Promise<void> {
    for (const chunk of chunks) {
      const combined = `${chunk.content.en}\n${chunk.content.ar}`;
      const { embedding } = await this.embedder.embed(combined);

      if (this.useMemory) {
        this.memoryStore.push({
          id: chunk.id,
          embedding,
          content: chunk.content,
          metadata: {
            type: chunk.metadata.type,
            domain: chunk.metadata.domain,
            subCategory: chunk.metadata.subCategory ?? '',
            source: chunk.metadata.source,
            language: chunk.metadata.language,
            updatedAt: chunk.metadata.updatedAt,
          },
        });
      } else {
        await this.chromaUpsert(chunk, embedding);
      }
    }
    console.log(`[VectorStore] Upserted ${chunks.length} chunks`);
  }

  public async query(
    queryEmbedding: number[],
    topK = 10,
    where?: Record<string, string>
  ): Promise<RetrievedChunk[]> {
    if (this.useMemory) {
      return this.memoryQuery(queryEmbedding, topK, where);
    }
    return this.chromaQuery(queryEmbedding, topK, where);
  }

  public async ping(): Promise<boolean> {
    if (this.useMemory) return true;
    try {
      const res = await fetch(`${this.chromaUrl}/api/v2/heartbeat`);
      return res.ok;
    } catch {
      return false;
    }
  }

  // ── ChromaDB calls ───────────────────────────────────────────

  private async getCollectionId(): Promise<void> {
    const res = await fetch(
      `${this.chromaUrl}/api/v2/tenants/default_tenant/databases/default_database/collections/${this.COLLECTION}?name=${this.COLLECTION}`
    );
    if (res.ok) {
      const data = await res.json() as { id: string };
      this.collectionId = data.id;
    } else {
      throw new Error('Failed to get collection ID');
    }
  }

  private async ensureCollection(): Promise<void> {
    await fetch(`${this.chromaUrl}/api/v2/tenants/default_tenant/databases/default_database/collections`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: this.COLLECTION,
        metadata: { 'hnsw:space': 'cosine' },
      }),
    });
    // 409 Conflict = already exists, which is fine
  }

  private async chromaUpsert(chunk: ChunkDocument, embedding: number[]): Promise<void> {
    await fetch(`${this.chromaUrl}/api/v2/tenants/default_tenant/databases/default_database/collections/${this.collectionId}/upsert`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        ids: [chunk.id],
        embeddings: [embedding],
        documents: [JSON.stringify(chunk.content)],
        metadatas: [{
          type: chunk.metadata.type,
          domain: chunk.metadata.domain,
          subCategory: chunk.metadata.subCategory ?? '',
          source: chunk.metadata.source,
          language: chunk.metadata.language,
          updatedAt: chunk.metadata.updatedAt,
        }],
      }),
    });
  }

  private async chromaQuery(
    queryEmbedding: number[],
    topK: number,
    where?: Record<string, string>
  ): Promise<RetrievedChunk[]> {
    const body: Record<string, unknown> = {
      query_embeddings: [queryEmbedding],
      n_results: topK,
      include: ['documents', 'metadatas', 'distances'],
    };
    if (where && Object.keys(where).length > 0) {
      // ChromaDB where clause — all values must match
      body.where = Object.fromEntries(
        Object.entries(where).map(([k, v]) => [k, { $eq: v }])
      );
    }
    const res = await fetch(
      `${this.chromaUrl}/api/v2/tenants/default_tenant/databases/default_database/collections/${this.collectionId}/query`,
      {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      }
    );

    if (!res.ok) {
      const text = await res.text();
      console.error('[VectorStore] Query failed:', res.status, text);
      throw new Error(`ChromaDB query failed: ${res.status}`);
    }

    const data = await res.json() as {
      ids: string[][];
      documents: string[][];
      metadatas: Record<string, string>[][];
      distances: number[][];
    };

    return (data.ids[0] ?? []).map((id, i) => ({
      id,
      content: JSON.parse(data.documents[0][i] ?? '{}') as { en: string; ar: string },
      score: 1 - (data.distances?.[0]?.[i] ?? 1),
      metadata: data.metadatas[0][i] ?? {},
    }));
  }

  // ── In-memory fallback ───────────────────────────────────────

  private memoryQuery(
    queryEmbedding: number[],
    topK: number,
    where?: Record<string, string>
  ): RetrievedChunk[] {
    let candidates = this.memoryStore;

    if (where) {
      candidates = candidates.filter(c =>
        Object.entries(where).every(([k, v]) => c.metadata[k] === v)
      );
    }

    return candidates
      .map(c => ({
        id: c.id,
        content: c.content,
        metadata: c.metadata,
        score: this.cosineSimilarity(queryEmbedding, c.embedding),
      }))
      .sort((a, b) => b.score - a.score)
      .slice(0, topK);
  }

  private cosineSimilarity(a: number[], b: number[]): number {
    if (a.length !== b.length) return 0;
    let dot = 0, normA = 0, normB = 0;
    for (let i = 0; i < a.length; i++) {
      dot += a[i] * b[i];
      normA += a[i] * a[i];
      normB += b[i] * b[i];
    }
    return dot / (Math.sqrt(normA) * Math.sqrt(normB) || 1);
  }

  // ── Admin Methods ───────────────────────────────────────────────

  public async getAllChunks(): Promise<Array<{
    id: string;
    type: string;
    domain: string;
    language: string;
    updatedAt: string;
  }>> {
    if (this.useMemory) {
      return this.memoryStore.map(c => ({
        id: c.id,
        type: c.metadata.type,
        domain: c.metadata.domain,
        language: c.metadata.language,
        updatedAt: c.metadata.updatedAt
      }));
    }

    try {
      // Get all documents from collection
      const res = await fetch(
        `${this.chromaUrl}/api/v2/tenants/default_tenant/databases/default_database/collections/${this.collectionId}/get`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            limit: 1000, // Get up to 1000 chunks
            include: ['metadatas']
          }),
        }
      );

      if (!res.ok) {
        console.error('[VectorStore] Get all chunks failed:', res.status);
        return [];
      }

      const data = await res.json() as {
        ids: string[];
        metadatas: Record<string, string>[];
      };

      return (data.ids ?? []).map((id, i) => ({
        id,
        type: data.metadatas[i]?.type || 'unknown',
        domain: data.metadatas[i]?.domain || 'unknown',
        language: data.metadatas[i]?.language || 'unknown',
        updatedAt: data.metadatas[i]?.updatedAt || new Date().toISOString()
      }));
    } catch (error) {
      console.error('[VectorStore] Error getting all chunks:', error);
      return [];
    }
  }

  public async getChunkCount(): Promise<number> {
    if (this.useMemory) {
      return this.memoryStore.length;
    }

    try {
      // Get collection count
      const res = await fetch(
        `${this.chromaUrl}/api/v2/tenants/default_tenant/databases/default_database/collections/${this.collectionId}/count`,
        {
          method: 'GET',
          headers: { 'Accept': 'application/json' },
        }
      );

      if (!res.ok) {
        console.error('[VectorStore] Get count failed:', res.status);
        return 0;
      }

      const data = await res.json() as { count: number };
      return data.count || 0;
    } catch (error) {
      console.error('[VectorStore] Error getting count:', error);
      return 0;
    }
  }

  public async deleteChunk(id: string): Promise<boolean> {
    if (this.useMemory) {
      const index = this.memoryStore.findIndex(c => c.id === id);
      if (index !== -1) {
        this.memoryStore.splice(index, 1);
        return true;
      }
      return false;
    }

    try {
      // Delete from ChromaDB
      const res = await fetch(
        `${this.chromaUrl}/api/v2/tenants/default_tenant/databases/default_database/collections/${this.collectionId}/delete`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            ids: [id]
          }),
        }
      );

      if (!res.ok) {
        console.error('[VectorStore] Delete chunk failed:', res.status);
        return false;
      }

      return true;
    } catch (error) {
      console.error('[VectorStore] Error deleting chunk:', error);
      return false;
    }
  }

  public async getChunkById(id: string): Promise<ChunkDocument | null> {
    if (this.useMemory) {
      const chunk = this.memoryStore.find(c => c.id === id);
      if (chunk) {
        return {
          id: chunk.id,
          content: chunk.content,
          metadata: chunk.metadata as unknown as ChunkMetadata
        };
      }
      return null;
    }

    try {
      // Get specific chunk from ChromaDB
      const res = await fetch(
        `${this.chromaUrl}/api/v2/tenants/default_tenant/databases/default_database/collections/${this.collectionId}/get`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            ids: [id],
            include: ['documents', 'metadatas']
          }),
        }
      );

      if (!res.ok) {
        console.error('[VectorStore] Get chunk by ID failed:', res.status);
        return null;
      }

      const data = await res.json() as {
        ids: string[];
        documents: string[];
        metadatas: Record<string, string>[];
      };

      if (data.ids.length === 0) {
        return null;
      }

      const metadata = data.metadatas[0] || {};
      
      // Ensure required metadata fields exist
      const chunkMetadata: ChunkMetadata = {
        type: (metadata.type as any) || 'faq',
        source: metadata.source || 'unknown',
        language: (metadata.language as any) || 'bilingual',
        domain: (metadata.domain as any) || 'general',
        subCategory: metadata.subCategory,
        ttl: metadata.ttl ? parseInt(metadata.ttl) : undefined,
        updatedAt: metadata.updatedAt || new Date().toISOString()
      };

      return {
        id: data.ids[0],
        content: JSON.parse(data.documents[0] || '{}') as { en: string; ar: string },
        metadata: chunkMetadata
      };
    } catch (error) {
      console.error('[VectorStore] Error getting chunk by ID:', error);
      return null;
    }
  }
}
