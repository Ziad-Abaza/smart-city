import { Request, Response, NextFunction } from 'express';
import AuthService from '../services/AuthService';
import crypto from 'crypto';

// CSRF Token Middleware
export const csrfProtection = (req: Request, res: Response, next: NextFunction): void => {
  const authService = AuthService.getInstance();

  // Skip CSRF for GET requests and login endpoint
  if (req.method === 'GET' || req.path === '/api/admin/login') {
    next();
    return;
  }

  // Get CSRF token from header
  const csrfToken = req.headers['x-csrf-token'] as string;
  
  // Get expected CSRF token from cookie
  const expectedCsrfToken = req.cookies?.csrf_token;

  if (!csrfToken || !expectedCsrfToken || csrfToken !== expectedCsrfToken) {
    console.warn('[CSRF] Invalid or missing CSRF token from IP:', req.ip);
    res.status(403).json({ 
      error: 'Invalid CSRF token',
      code: 'INVALID_CSRF_TOKEN'
    });
    return;
  }

  next();
};

// Generate CSRF Token
export const generateCsrfToken = (req: Request, res: Response, next: NextFunction): void => {
  try {
    const authService = AuthService.getInstance();
    const csrfToken = authService.generateCSRFToken();
    
    // Set CSRF token in HTTP-only cookie
    res.cookie('csrf_token', csrfToken, {
      httpOnly: false, // Must be accessible by JavaScript for AJAX
      secure: process.env.NODE_ENV === 'production',
      sameSite: 'strict',
      path: '/',
      maxAge: 24 * 60 * 60 * 1000 // 24 hours
    });

    // Also send it in response header for initial requests
    res.setHeader('X-CSRF-Token', csrfToken);
    
    next();
  } catch (error) {
    console.error('[CSRF] Error generating token:', error);
    next();
  }
};

// Security Headers Middleware
export const securityHeaders = (req: Request, res: Response, next: NextFunction): void => {
  const authService = AuthService.getInstance();
  const headers = authService.getSecurityHeaders();

  Object.entries(headers).forEach(([key, value]) => {
    res.setHeader(key, value);
  });

  // Additional Content Security Policy
  const csp = [
    "default-src 'self'",
    "script-src 'self' 'unsafe-inline' 'unsafe-eval'",
    "style-src 'self' 'unsafe-inline'",
    "img-src 'self' data: blob: https:",
    "font-src 'self' data:",
    "connect-src 'self'",
    "frame-ancestors 'none'",
    "form-action 'self'",
    "base-uri 'self'"
  ].join('; ');

  res.setHeader('Content-Security-Policy', csp);

  next();
};

// Input Sanitization Middleware
export const sanitizeInput = (req: Request, res: Response, next: NextFunction): void => {
  const authService = AuthService.getInstance();

  // Sanitize body
  if (req.body) {
    req.body = sanitizeObject(req.body, authService);
  }

  // Sanitize query params
  if (req.query) {
    req.query = sanitizeObject(req.query, authService);
  }

  // Sanitize params
  if (req.params) {
    req.params = sanitizeObject(req.params, authService);
  }

  next();
};

function sanitizeObject(obj: any, authService: AuthService): any {
  if (typeof obj !== 'object' || obj === null) {
    return obj;
  }

  const sanitized: any = Array.isArray(obj) ? [] : {};

  for (const key in obj) {
    if (obj.hasOwnProperty(key)) {
      const value = obj[key];
      
      if (typeof value === 'string') {
        sanitized[key] = authService.sanitizeInput(value);
      } else if (typeof value === 'object') {
        sanitized[key] = sanitizeObject(value, authService);
      } else {
        sanitized[key] = value;
      }
    }
  }

  return sanitized;
}

// IP Whitelist/Blacklist Middleware
export const ipFilter = (req: Request, res: Response, next: NextFunction): void => {
  const authService = AuthService.getInstance();
  const ip = req.ip || req.socket.remoteAddress || 'unknown';

  // Validate IP format
  if (!authService.isValidIP(ip) && ip !== '::1' && ip !== 'unknown') {
    console.warn('[IP Filter] Invalid IP format:', ip);
    res.status(400).json({ error: 'Invalid IP address' });
    return;
  }

  // Store IP in a custom property for logging
  (req as any).clientIp = ip;
  next();
};

// Request Logging Middleware
export const requestLogger = (req: Request, res: Response, next: NextFunction): void => {
  const startTime = Date.now();
  const ip = (req as any).clientIp || req.ip || 'unknown';

  // Log request
  console.log(`[Request] ${new Date().toISOString()} - ${req.method} ${req.path} - IP: ${ip}`);

  // Log response
  res.on('finish', () => {
    const duration = Date.now() - startTime;
    const level = res.statusCode >= 400 ? 'warn' : 'info';
    console.log(`[Response] ${new Date().toISOString()} - ${req.method} ${req.path} - Status: ${res.statusCode} - Duration: ${duration}ms - IP: ${ip}`);
  });

  next();
};

// Prevent Clickjacking
export const preventClickjacking = (req: Request, res: Response, next: NextFunction): void => {
  res.setHeader('X-Frame-Options', 'DENY');
  res.setHeader('Content-Security-Policy', "frame-ancestors 'none'");
  next();
};

// HSTS Middleware (HTTPS only in production)
export const hsts = (req: Request, res: Response, next: NextFunction): void => {
  if (process.env.NODE_ENV === 'production') {
    res.setHeader('Strict-Transport-Security', 'max-age=31536000; includeSubDomains; preload');
  }
  next();
};
</file>

