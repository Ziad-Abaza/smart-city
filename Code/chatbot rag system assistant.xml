/**
 * scripts/index.ts
 * ----------------
 * One-time (and re-runnable) script to index all chunks into ChromaDB.
 *
 * Usage:
 *   tsx scripts/index.ts
 *
 * Safe to re-run — uses upsert so existing chunks are updated, not duplicated.
 */

import { ChunkLoader } from '../src/data/ChunkLoader';
import { VectorStore } from '../src/services/VectorStore';
import { SEED_CHUNKS } from '../src/data/SeedChunks';

async function main() {
  console.log('[index] Starting chunk indexing...\n');

  // 1. Load existing chunks from disk, or use seed data
  const loader = new ChunkLoader();
  let chunks = loader.loadAll();

  if (chunks.length === 0) {
    console.log('[index] No disk chunks found — using seed data');
    chunks = SEED_CHUNKS;
    loader.save(chunks);
  }

  console.log(`[index] Found ${chunks.length} chunks to index`);

  // 2. Initialize vector store
  const vectorStore = new VectorStore();
  await vectorStore.initialize();

  // 3. Upsert chunks (includes embedding generation)
  console.log('[index] Generating embeddings and upserting...');
  const batchSize = 5;
  for (let i = 0; i < chunks.length; i += batchSize) {
    const batch = chunks.slice(i, i + batchSize);
    await vectorStore.upsertChunks(batch);
    console.log(`[index] Progress: ${Math.min(i + batchSize, chunks.length)}/${chunks.length}`);
  }

  console.log('\n[index] ✅ Indexing complete');
  process.exit(0);
}

main().catch(err => {
  console.error('[index] Fatal error:', err);
  process.exit(1);
});
