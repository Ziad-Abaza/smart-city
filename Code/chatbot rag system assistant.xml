## Core Data Schema

Every piece of knowledge — whether a faculty description, course, FAQ, or policy — becomes a **ChunkDocument**:

```typescript
// src/types/Chunk.ts

export type ChunkType = 'faculty' | 'course' | 'faq' | 'policy' | 'event' | 'contact';
export type DomainLevel1 = 'faculty' | 'course' | 'faq' | 'policy';
export type Language = 'bilingual';

export interface BilingualContent {
  ar: string;
  en: string;
}

export interface ChunkMetadata {
  type: ChunkType;
  source: string;          // e.g. "faculties_seed", "faq_seed", "admin_upload"
  language: Language;
  domain: DomainLevel1;
  subCategory?: string;    // e.g. "health_sciences", "industry_energy"
  ttl?: number;            // seconds; used by cache layer
  updatedAt: string;       // ISO 8601
}

export interface ChunkDocument {
  id: string;              // UUID v4
  content: BilingualContent;
  metadata: ChunkMetadata;
  embedding?: number[];    // populated after embed step
}
```

