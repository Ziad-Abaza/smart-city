import { Request, Response } from 'express';
import { VectorStore } from '../services/VectorStore';
import { EmbeddingService } from '../services/EmbeddingService';

const vectorStore = new VectorStore();
const embedder = new EmbeddingService();

export const healthHandler = async (_req: Request, res: Response): Promise<void> => {
  const [vs, em] = await Promise.allSettled([
    vectorStore.ping(),
    embedder.ping(),
  ]);

  const checks = {
    vectorStore: vs.status === 'fulfilled' && vs.value,
    embedder: em.status === 'fulfilled' && em.value,
    uptime: process.uptime(),
    memory: process.memoryUsage().heapUsed,
  };

  const healthy = checks.vectorStore && checks.embedder;
  res.status(healthy ? 200 : 503).json({
    status: healthy ? 'ok' : 'degraded',
    checks,
    timestamp: new Date().toISOString(),
  });
};
