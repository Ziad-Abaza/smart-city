import express, { Request, Response } from 'express';
import cors from 'cors';
import path from 'path';
import cookieParser from 'cookie-parser';
import Config from './config/Config';
import { chatHandler } from './routes/chat';
import { healthHandler } from './routes/health';
import { 
  statsHandler, 
  listChunksHandler, 
  addChunkHandler, 
  deleteChunkHandler,
  getChunkHandler,
  loginHandler,
  logoutHandler,
  verifyAuthHandler,
  optionalVerifyAuthHandler
} from './routes/admin';
import { authenticateAdmin } from './middleware/auth';
import { 
  generalRateLimiter, 
  loginRateLimiter,
  sensitiveOperationRateLimiter 
} from './middleware/rateLimit';
import {
  securityHeaders,
  csrfProtection,
  generateCsrfToken,
  sanitizeInput,
  ipFilter,
  requestLogger,
  preventClickjacking,
  hsts
} from './middleware/security';

const app = express();
const config = Config.getInstance();
const PORT = config.getPort();

// ── Middleware ────────────────────────────────────────────────
app.use(cors({
  origin: process.env.NODE_ENV === 'production' ? false : true,
  credentials: true
}));
app.use(express.json({ limit: '1mb' }));
app.use(express.urlencoded({ extended: true, limit: '1mb' }));
app.use(cookieParser());

// Security middleware
app.use(ipFilter);
app.use(securityHeaders);
app.use(preventClickjacking);
app.use(hsts);
app.use(sanitizeInput);
app.use(requestLogger);
app.use(generalRateLimiter);

// Generate CSRF token for all requests
app.use(generateCsrfToken);

// ── API Routes ────────────────────────────────────────────────
app.post('/api/chat', chatHandler);
app.get('/api/health', healthHandler);

// Admin Authentication Routes (no auth required)
app.post('/api/admin/login', loginRateLimiter, loginHandler);
app.post('/api/admin/logout', logoutHandler);
app.get('/api/admin/verify', optionalVerifyAuthHandler);
app.get('/api/admin/verify-auth', authenticateAdmin, verifyAuthHandler);

// Admin Protected Routes (require authentication)
app.get('/api/admin/stats', authenticateAdmin, csrfProtection, statsHandler);
app.get('/api/admin/chunks', authenticateAdmin, csrfProtection, listChunksHandler);
app.post('/api/admin/chunks', authenticateAdmin, csrfProtection, sensitiveOperationRateLimiter, addChunkHandler);
app.get('/api/admin/chunks/:id', authenticateAdmin, csrfProtection, getChunkHandler);
app.delete('/api/admin/chunks/:id', authenticateAdmin, csrfProtection, sensitiveOperationRateLimiter, deleteChunkHandler);

// ── Static / SPA ──────────────────────────────────────────────
app.use(express.static(path.join(process.cwd(), 'public')));

app.get('*', (req: Request, res: Response) => {
  if (req.path.startsWith('/api')) {
    res.status(404).json({ error: 'API endpoint not found' });
    return;
  }
  res.sendFile(path.join(process.cwd(), 'public', 'index.html'));
});

// ── Start ─────────────────────────────────────────────────────
app.listen(PORT, () => {
  console.log(`\nBAT Chatbot RAG v2 running on port ${PORT}`);
  console.log(`Environment: ${config.get('APP_ENV', 'development')}`);
  console.log(`Debug: ${config.isDebug()}`);
  console.log(`Embedding provider: ${config.get('EMBEDDING_PROVIDER', 'ollama')}`);
  console.log(`ChromaDB: ${config.get('CHROMA_URL', 'http://localhost:8000')}\n`);
});

export default app;
</file>

