import fs from 'fs';
import path from 'path';
import { ChunkDocument } from '../types/Chunk';
import { SEED_CHUNKS } from './SeedChunks';

/**
 * ChunkLoader
 * -----------
 * Loads ChunkDocuments from disk (data/chunks/*.json).
 * Falls back to SEED_CHUNKS if no chunks directory exists yet.
 *
 * Phase 1 dependency only — Phase 2+ uses VectorStore directly.
 */
export class ChunkLoader {
  private chunksDir: string;

  constructor() {
    this.chunksDir = path.join(process.cwd(), 'data', 'chunks');
    if (!fs.existsSync(this.chunksDir)) {
      fs.mkdirSync(this.chunksDir, { recursive: true });
    }
  }

  public loadAll(): ChunkDocument[] {
    const files = fs
      .readdirSync(this.chunksDir)
      .filter(f => f.endsWith('.json'));

    if (files.length === 0) {
      console.warn('[ChunkLoader] No chunk files found — using seed data');
      return SEED_CHUNKS;
    }

    return files.flatMap(f => {
      try {
        const raw = fs.readFileSync(path.join(this.chunksDir, f), 'utf-8');
        return JSON.parse(raw) as ChunkDocument[];
      } catch (err) {
        console.error(`[ChunkLoader] Failed to parse ${f}:`, err);
        return [];
      }
    });
  }

  public save(chunks: ChunkDocument[]): void {
    const file = path.join(this.chunksDir, `chunks_${Date.now()}.json`);
    fs.writeFileSync(file, JSON.stringify(chunks, null, 2));
    console.log(`[ChunkLoader] Saved ${chunks.length} chunks to ${file}`);
  }
}
</file>

