// ============================================
// Chat Operations
// ============================================

import { detectLanguage, parseMarkdown, escapeHtml, copyMessage } from './utils.js';
import { getChatsFromStorage } from './storage.js';

export class ChatManager {
  constructor(messagesContainer, userInput, welcomeScreen) {
    this.messagesContainer = messagesContainer;
    this.userInput = userInput;
    this.welcomeScreen = welcomeScreen;
    this.messageHistory = [];
    this.currentChatId = null;
  }

  addMessage(role, content, parseContent = true) {
    const messageEl = document.createElement("div");
    messageEl.className = `message ${role} slide-up`;

    const time = new Date().toLocaleTimeString("en-US", {
      hour: "2-digit",
      minute: "2-digit",
    });

    const avatarContent = role === "user" 
      ? '<span class="user-avatar-text">U</span>'
      : '<img src="assets/images/avatar.png" alt="BATU Avatar" class="message-avatar-img">';
    const parsedContent =
      role === "assistant" && parseContent
        ? parseMarkdown(content)
        : escapeHtml(content);

    // Detect language and set lang attribute
    const detectedLang = detectLanguage(content);

    // Check if message is short and might overlap with avatar
    const isShortMessage = content.trim().length < 10 && !content.includes('\n') && !content.includes(' ');
    const bubbleClass = isShortMessage ? 'message-bubble short-message' : 'message-bubble';

    messageEl.innerHTML = `
      <div class="message-avatar">${avatarContent}</div>
      <div class="message-content">
        <div class="${bubbleClass}" lang="${detectedLang}">${parsedContent}</div>
        <div class="message-meta">
          <span>${time}</span>
          ${
            role === "assistant"
              ? `<button class="copy-msg-btn" onclick="chat.copyMessage(this)" title="Copy message">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>`
              : ""
          }
        </div>
      </div>
    `;

    this.messagesContainer.appendChild(messageEl);

    // Save to history
    this.messageHistory.push({ role, content, time, lang: detectedLang });
    
    return detectedLang;
  }

  loadHistory() {
    const historyList = document.getElementById("history-list");
    if (historyList) {
      const chats = getChatsFromStorage();
      
      if (chats.length === 0) {
        historyList.innerHTML = '<div class="history-empty">No recent chats</div>';
        return;
      }

      historyList.innerHTML = chats
        .map(
          (chat) => `
            <div class="history-item ${chat.id === this.currentChatId ? "active" : ""}">
              <div class="history-content" onclick="chat.loadChat('${chat.id}')">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <span>${escapeHtml(chat.title)}</span>
              </div>
              <button class="delete-chat-btn" onclick="chat.deleteChat('${chat.id}', event)" title="Delete chat">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m3 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6h14zM10 11v6M14 11v6"/></svg>
              </button>
            </div>
          `,
        )
        .join("");
    }
  }

  loadChat(id) {
    const chats = getChatsFromStorage();
    const chatToLoad = chats.find(c => c.id === id);
    
    if (chatToLoad) {
      this.currentChatId = id;
      this.messagesContainer.innerHTML = "";
      this.messageHistory = chatToLoad.messages;
      
      // Hide welcome screen
      if (this.welcomeScreen) {
        this.welcomeScreen.classList.add("hidden");
      }
      
      // Render messages
      chatToLoad.messages.forEach(msg => {
        const messageEl = document.createElement("div");
        messageEl.className = `message ${msg.role}`;

        const avatarContent = msg.role === "user" 
          ? '<span class="user-avatar-text">U</span>'
          : '<img src="assets/images/avatar.png" alt="BATU Avatar" class="message-avatar-img">';
        const parsedContent =
          msg.role === "assistant"
            ? parseMarkdown(msg.content)
            : escapeHtml(msg.content);

        // Check if message is short and might overlap with avatar
        const isShortMessage = msg.content.trim().length < 10 && !msg.content.includes('\n') && !msg.content.includes(' ');
        const bubbleClass = isShortMessage ? 'message-bubble short-message' : 'message-bubble';

        messageEl.innerHTML = `
          <div class="message-avatar">${avatarContent}</div>
          <div class="message-content">
            <div class="${bubbleClass}" lang="${msg.lang || 'en'}">${parsedContent}</div>
            <div class="message-meta">
              <span>${msg.time}</span>
              ${
                msg.role === "assistant"
                  ? `<button class="copy-msg-btn" onclick="chat.copyMessage(this)" title="Copy message">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  </button>`
                  : ""
              }
            </div>
          </div>
        `;

        this.messagesContainer.appendChild(messageEl);
      });
      
      return true;
    }
    
    return false;
  }

  newChat() {
    // Clear current chat
    this.messagesContainer.innerHTML = "";
    this.messageHistory = [];
    this.currentChatId = null;
    if (this.welcomeScreen) {
      this.welcomeScreen.classList.remove("hidden");
    }
    this.userInput.value = "";
    this.userInput.style.height = "auto";
  }

  usePrompt(text) {
    this.userInput.value = text;
    this.userInput.focus();
    // Auto-resize will be handled by input event
  }

  // Expose copyMessage for onclick handlers
  copyMessage(btn) {
    copyMessage(btn);
  }
}
