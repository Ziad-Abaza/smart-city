### 2.3 VectorStore

```typescript
// src/services/VectorStore.ts
import { ChromaClient, Collection } from 'chromadb';
import { ChunkDocument } from '../types/Chunk';
import { EmbeddingService } from './EmbeddingService';

export class VectorStore {
  private client: ChromaClient;
  private embedder: EmbeddingService;
  private collection!: Collection;
  private readonly COLLECTION_NAME = 'batu_knowledge';

  constructor() {
    this.client = new ChromaClient({ path: 'http://localhost:8000' });
    this.embedder = new EmbeddingService();
  }

  public async initialize(): Promise<void> {
    this.collection = await this.client.getOrCreateCollection({
      name: this.COLLECTION_NAME,
      metadata: { 'hnsw:space': 'cosine' },
    });
  }

  public async upsertChunks(chunks: ChunkDocument[]): Promise<void> {
    const ids: string[] = [];
    const embeddings: number[][] = [];
    const documents: string[] = [];
    const metadatas: Record<string, string>[] = [];

    for (const chunk of chunks) {
      // Embed bilingual concatenation for cross-lingual retrieval
      const combined = `${chunk.content.en}\n${chunk.content.ar}`;
      const { embedding } = await this.embedder.embed(combined);

      ids.push(chunk.id);
      embeddings.push(embedding);
      // Store the full bilingual JSON as the document
      documents.push(JSON.stringify(chunk.content));
      metadatas.push({
        type: chunk.metadata.type,
        domain: chunk.metadata.domain,
        subCategory: chunk.metadata.subCategory ?? '',
        source: chunk.metadata.source,
        language: chunk.metadata.language,
        updatedAt: chunk.metadata.updatedAt,
      });
    }

    await this.collection.upsert({ ids, embeddings, documents, metadatas });
  }

  public async query(
    queryEmbedding: number[],
    topK: number = 10,
    where?: Record<string, string>
  ): Promise<{ id: string; content: { en: string; ar: string }; score: number; metadata: Record<string, string> }[]> {
    const results = await this.collection.query({
      queryEmbeddings: [queryEmbedding],
      nResults: topK,
      where,
    });

    return (results.ids[0] ?? []).map((id, i) => ({
      id,
      content: JSON.parse(results.documents[0][i] ?? '{}'),
      score: 1 - (results.distances?.[0]?.[i] ?? 1),  // cosine → similarity
      metadata: results.metadatas[0][i] as Record<string, string>,
    }));
  }
}
```

