import rateLimit from 'express-rate-limit';
import Config from '../config/Config';

// General rate limiter for all requests
export const generalRateLimiter = rateLimit({
  windowMs: parseInt(Config.getInstance().get('RATE_LIMIT_WINDOW', '900000')), // 15 minutes
  max: parseInt(Config.getInstance().get('RATE_LIMIT_MAX_REQUESTS', '100')),
  message: {
    error: 'Too many requests from this IP, please try again later',
    code: 'RATE_LIMIT_EXCEEDED'
  },
  standardHeaders: true,
  legacyHeaders: false,
  handler: (req, res) => {
    console.warn(`[Rate Limit] IP ${req.ip} exceeded rate limit`);
    res.status(429).json({
      error: 'Too many requests from this IP, please try again later',
      code: 'RATE_LIMIT_EXCEEDED'
    });
  }
});

// Stricter rate limiter for login attempts
export const loginRateLimiter = rateLimit({
  windowMs: 15 * 60 * 1000, // 15 minutes
  max: 5, // 5 login attempts per 15 minutes
  message: {
    error: 'Too many login attempts, please try again later',
    code: 'LOGIN_RATE_LIMIT_EXCEEDED'
  },
  standardHeaders: true,
  legacyHeaders: false,
  skipSuccessfulRequests: true,
  handler: (req, res) => {
    console.warn(`[Rate Limit] IP ${req.ip} exceeded login rate limit`);
    res.status(429).json({
      error: 'Too many login attempts, please try again later',
      code: 'LOGIN_RATE_LIMIT_EXCEEDED'
    });
  }
});

// Rate limiter for sensitive operations (delete, update)
export const sensitiveOperationRateLimiter = rateLimit({
  windowMs: 60 * 1000, // 1 minute
  max: 10, // 10 sensitive operations per minute
  message: {
    error: 'Too many sensitive operations, please slow down',
    code: 'SENSITIVE_OP_RATE_LIMIT_EXCEEDED'
  },
  standardHeaders: true,
  legacyHeaders: false,
  handler: (req, res) => {
    console.warn(`[Rate Limit] IP ${req.ip} exceeded sensitive operation rate limit`);
    res.status(429).json({
      error: 'Too many sensitive operations, please slow down',
      code: 'SENSITIVE_OP_RATE_LIMIT_EXCEEDED'
    });
  }
});
