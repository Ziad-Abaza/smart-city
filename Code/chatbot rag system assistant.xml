import axios from 'axios';
import Config from '../config/Config';
import { RetrievedChunk } from '../types/Chunk';

/**
 * Reranker — Stage 4 of the RAG pipeline
 * ----------------------------------------
 * Reorders retrieved chunks by cross-encoder relevance.
 *
 * Primary: Cohere Rerank v3 multilingual (free tier: 1000 calls/month)
 * Fallback: BM25-inspired overlap scoring — no external call needed
 */
export class Reranker {
  private cohereKey: string;

  constructor() {
    this.cohereKey = Config.getInstance().get('COHERE_API_KEY', '');
  }

  public async rerank(
    query: string,
    candidates: RetrievedChunk[],
    topN = 5
  ): Promise<RetrievedChunk[]> {
    if (candidates.length === 0) return [];
    if (candidates.length <= topN) return this.bm25Rerank(query, candidates, topN);

    if (this.cohereKey) {
      try {
        return await this.cohereRerank(query, candidates, topN);
      } catch (err) {
        console.warn('[Reranker] Cohere unavailable, falling back to BM25:', (err as Error).message);
      }
    }

    return this.bm25Rerank(query, candidates, topN);
  }

  // ── Cohere cross-encoder ─────────────────────────────────────

  private async cohereRerank(
    query: string,
    candidates: RetrievedChunk[],
    topN: number
  ): Promise<RetrievedChunk[]> {
    const documents = candidates.map(c => `${c.content.en}\n${c.content.ar}`);

    const res = await axios.post(
      'https://api.cohere.ai/v1/rerank',
      {
        model: 'rerank-multilingual-v3.0',
        query,
        documents,
        top_n: topN,
        return_documents: false,
      },
      {
        headers: {
          Authorization: `Bearer ${this.cohereKey}`,
          'Content-Type': 'application/json',
        },
        timeout: 10_000,
      }
    );

    return res.data.results.map((r: { index: number; relevance_score: number }) => ({
      ...candidates[r.index],
      score: r.relevance_score,
    }));
  }

  // ── BM25-inspired fallback ───────────────────────────────────

  private bm25Rerank(
    query: string,
    candidates: RetrievedChunk[],
    topN: number
  ): RetrievedChunk[] {
    const queryTerms = this.tokenize(query);
    const avgDocLen = candidates.reduce(
      (sum, c) => sum + this.tokenize(`${c.content.en} ${c.content.ar}`).length,
      0
    ) / candidates.length;

    const K1 = 1.5;
    const B = 0.75;

    const scored = candidates.map(c => {
      const docText = `${c.content.en} ${c.content.ar}`;
      const tokens = this.tokenize(docText);
      const docLen = tokens.length;

      const bm25 = queryTerms.reduce((score, term) => {
        const tf = tokens.filter(t => t === term).length;
        if (tf === 0) return score;
        const idf = Math.log(1 + (candidates.length - candidates.filter(x =>
          `${x.content.en} ${x.content.ar}`.toLowerCase().includes(term)
        ).length + 0.5) / (candidates.filter(x =>
          `${x.content.en} ${x.content.ar}`.toLowerCase().includes(term)
        ).length + 0.5));
        return score + idf * ((tf * (K1 + 1)) / (tf + K1 * (1 - B + B * docLen / avgDocLen)));
      }, 0);

      // Blend vector score (40%) with BM25 (60%)
      return { ...c, score: c.score * 0.4 + bm25 * 0.6 };
    });

    return scored.sort((a, b) => b.score - a.score).slice(0, topN);
  }

  private tokenize(text: string): string[] {
    return text.toLowerCase().split(/[\s\u0600-\u06FF\W]+/).filter(t => t.length > 1);
  }
}
</file>

<file path="src/rag/TreeClassifier.ts">
/**
 * TreeClassifier — Phase 4 Advanced Retrieval
 * --------------------------------------------
 * Navigates a three-level domain hierarchy to produce a metadata filter
 * that narrows the ChromaDB vector search before embedding similarity runs.
 *
 * Level 1: Domain (faculty | course | faq | policy)
 * Level 2: Sub-category (industry_energy | health_sciences | admissions | …)
 * Level 3: Leaf department / topic (information_technology | nursing | …)
 *
 * Returns a ChromaDB `where` filter or undefined (no filtering = search all).
 */

interface TreeNode {
  id: string;
  signals: string[];
  filter?: Record<string, string>;   // ChromaDB metadata filter for this node
  children?: TreeNode[];
}

const DOMAIN_TREE: TreeNode = {
  id: 'root',
  signals: [],
  children: [
    {
      id: 'faculty',
      signals: ['faculty', 'college', 'كلية', 'department', 'قسم', 'تخصص'],
      filter: { domain: 'faculty' },
      children: [
        {
          id: 'industry_energy',
          signals: [
            'industry', 'energy', 'صناعة', 'طاقة',
            'textile', 'نسيج', 'food', 'أغذية',
            'railway', 'سكك', 'agricultural', 'زراعي', 'tractor',
          ],
          filter: { domain: 'faculty', subCategory: 'industry_energy' },
          children: [
            {
              id: 'it',
              signals: ['information technology', 'تكنولوجيا المعلومات', 'software', 'network', 'cyber'],
              filter: { domain: 'faculty', subCategory: 'industry_energy' },
            },
            {
              id: 'railway',
              signals: ['railway', 'سكك حديدية', 'train'],
              filter: { domain: 'faculty', subCategory: 'industry_energy' },
            },
          ],
        },
        {
          id: 'health_sciences',
          signals: [
            'health', 'medical', 'صحة', 'طبي',
            'nursing', 'تمريض', 'dental', 'أسنان',
            'radiology', 'أشعة', 'respiratory', 'تنفسية', 'laboratory', 'مختبر',
          ],
          filter: { domain: 'faculty', subCategory: 'health_sciences' },
          children: [
            {
              id: 'nursing',
              signals: ['nursing', 'تمريض', 'nurse'],
              filter: { domain: 'faculty', subCategory: 'health_sciences' },
            },
            {
              id: 'radiology',
              signals: ['radiology', 'imaging', 'أشعة', 'تصوير'],
              filter: { domain: 'faculty', subCategory: 'health_sciences' },
            },
          ],
        },
      ],
    },
    {
      id: 'faq',
      signals: [
        'fee', 'tuition', 'admission', 'apply', 'location', 'contact', 'address',
        'scholarship', 'facility', 'calendar', 'international', 'where', 'how much',
        'رسوم', 'قبول', 'موقع', 'تواصل', 'منحة', 'مرافق', 'تقويم', 'دولي', 'كيف', 'كم',
      ],
      filter: { domain: 'faq' },
      children: [
        {
          id: 'admissions',
          signals: ['admission', 'apply', 'requirement', 'enroll', 'قبول', 'تسجيل', 'متطلبات'],
          filter: { domain: 'faq', subCategory: 'admissions' },
        },
        {
          id: 'fees',
          signals: ['fee', 'tuition', 'cost', 'scholarship', 'رسوم', 'تكلفة', 'منحة'],
          filter: { domain: 'faq', subCategory: 'fees' },
        },
        {
          id: 'contact',
          signals: ['contact', 'email', 'phone', 'address', 'location', 'تواصل', 'بريد', 'عنوان', 'موقع'],
          filter: { domain: 'faq', subCategory: 'contact' },
        },
        {
          id: 'facilities',
          signals: ['facility', 'lab', 'library', 'gym', 'housing', 'مرافق', 'مختبر', 'مكتبة', 'سكن'],
          filter: { domain: 'faq', subCategory: 'facilities' },
        },
      ],
    },
    {
      id: 'policy',
      signals: ['policy', 'rule', 'regulation', 'conduct', 'سياسة', 'نظام', 'لائحة', 'انضباط'],
      filter: { domain: 'policy' },
    },
    {
      id: 'course',
      signals: ['course', 'subject', 'credit', 'curriculum', 'مقرر', 'مادة', 'ساعة', 'منهج'],
      filter: { domain: 'course' },
    },
  ],
};

export class TreeClassifier {
  /**
   * Returns a ChromaDB metadata filter for the deepest matching tree node.
   * Returns undefined if no node matches (no metadata filtering applied).
   */
  public classify(query: string): Record<string, string> | undefined {
    const lower = query.toLowerCase();
    return this.traverse(lower, DOMAIN_TREE);
  }

  private traverse(
    query: string,
    node: TreeNode
  ): Record<string, string> | undefined {
    if (!node.children || node.children.length === 0) {
      return node.filter;
    }

    for (const child of node.children) {
      if (child.signals.some(s => query.includes(s))) {
        const deeper = this.traverse(query, child);
        // Use the deepest match found, else this child's filter
        return deeper ?? child.filter;
      }
    }

    // No child matched — return this node's filter (broader category)
    return node.filter;
  }
}
