// ============================================
// BATU AI Assistant - Main Entry Point
// ============================================

import { UIManager } from './ui.js';
import { ChatManager } from './chat.js';
import { sendMessage } from './api.js';
import { saveChat, performDelete } from './storage.js';
import { detectLanguage, copyCode } from './utils.js';

class BatuChat {
  constructor() {
    this.messagesContainer = document.getElementById("messages-container");
    this.userInput = document.getElementById("user-input");
    this.chatForm = document.getElementById("chat-form");
    this.welcomeScreen = document.getElementById("welcome-screen");
    this.isTyping = false;

    // Initialize managers
    this.ui = new UIManager();
    this.chatManager = new ChatManager(
      this.messagesContainer,
      this.userInput,
      this.welcomeScreen
    );

    this.init();
  }

  init() {
    // Event listeners
    this.chatForm.addEventListener("submit", (e) => this.handleSubmit(e));
    this.userInput.addEventListener("input", () => {
      this.autoResize();
      this.updateInputLanguage();
    });
    this.userInput.addEventListener("keydown", (e) => this.handleKeydown(e));

    // Theme initialization
    this.ui.initTheme();

    // Auto-focus input
    this.userInput.focus();

    // Load chat history
    this.chatManager.loadHistory();
  }

  // UI Methods - delegated to UIManager
  toggleTheme() {
    this.ui.toggleTheme();
  }

  toggleSidebar() {
    this.ui.toggleSidebar();
  }

  closeSidebar() {
    this.ui.closeSidebar();
  }

  autoResize() {
    this.userInput.style.height = "auto";
    const newHeight = Math.min(this.userInput.scrollHeight, 200);
    this.userInput.style.height = newHeight + "px";
  }

  handleKeydown(e) {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      this.chatForm.dispatchEvent(new Event("submit"));
    }
  }

  detectLanguage(text) {
    return detectLanguage(text);
  }

  updateInputLanguage() {
    const text = this.userInput.value;
    const detectedLang = this.detectLanguage(text);
    this.userInput.setAttribute('lang', detectedLang);
  }

  async handleSubmit(e) {
    e.preventDefault();
    const message = this.userInput.value.trim();
    if (!message || this.isTyping) return;

    // Hide welcome screen and suggested prompts on first message
    if (
      this.welcomeScreen &&
      !this.welcomeScreen.classList.contains("hidden")
    ) {
      this.welcomeScreen.classList.add("hidden");
      // Also hide suggested prompts
      const suggestedPrompts = this.welcomeScreen.querySelector(".suggested-prompts");
      if (suggestedPrompts) {
        suggestedPrompts.classList.add("hidden");
      }
    }

    // Add user message
    this.chatManager.addMessage("user", message);
    this.userInput.value = "";
    this.userInput.style.height = "auto";

    // Show typing indicator
    this.isTyping = true;
    this.ui.showTyping(this.messagesContainer);

    // Call API for response
    const result = await sendMessage(message, this.chatManager.messageHistory);
    
    this.isTyping = false;
    this.ui.hideTyping();

    if (result.success) {
      this.chatManager.addMessage("assistant", result.response);
    } else {
      this.chatManager.addMessage("assistant", result.error);
    }

    // Auto-save chat after adding message
    this.saveChat();
  }

  // Chat Methods - delegated to ChatManager
  addMessage(role, content) {
    return this.chatManager.addMessage(role, content);
  }

  loadHistory() {
    this.chatManager.loadHistory();
  }

  loadChat(id) {
    // Save current chat if it has messages and is different from the one being loaded
    if (this.chatManager.messageHistory.length > 0 && this.chatManager.currentChatId !== id) {
      this.saveChat();
    }
    
    const loaded = this.chatManager.loadChat(id);
    if (loaded) {
      this.ui.scrollToBottom(this.messagesContainer);
    }
    
    this.ui.closeSidebar();
    this.chatManager.loadHistory();
  }

  newChat() {
    // Save current chat if it has messages
    if (this.chatManager.messageHistory.length > 0) {
      this.saveChat();
    }
    
    this.chatManager.newChat();
    this.ui.closeSidebar();
    this.chatManager.loadHistory();
    
    // Show suggested prompts again when starting new chat
    if (this.welcomeScreen) {
      const suggestedPrompts = this.welcomeScreen.querySelector(".suggested-prompts");
      if (suggestedPrompts) {
        suggestedPrompts.classList.remove("hidden");
      }
    }
  }

  usePrompt(text) {
    this.chatManager.usePrompt(text);
    this.autoResize();
  }

  // Storage Methods
  saveChat() {
    this.chatManager.currentChatId = saveChat(
      this.chatManager.messageHistory,
      this.chatManager.currentChatId
    );
    this.chatManager.loadHistory();
  }

  deleteChat(id, event) {
    event.stopPropagation();
    this.ui.showDeleteConfirm(id, (chatId) => this.performDelete(chatId));
  }

  performDelete(chatId) {
    performDelete(chatId);
    
    // If deleting current chat, clear it
    if (chatId === this.chatManager.currentChatId) {
      this.newChat();
    } else {
      this.chatManager.loadHistory();
    }
  }

  // Utility Methods - exposed for onclick handlers
  copyCode(btn) {
    copyCode(btn);
  }

  copyMessage(btn) {
    this.chatManager.copyMessage(btn);
  }
}

// Initialize
const chat = new BatuChat();

// Make chat globally available for onclick handlers
window.chat = chat;
