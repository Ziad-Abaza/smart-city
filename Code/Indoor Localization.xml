from flask import Flask, request, jsonify, render_template
import random

app = Flask(__name__)

# Fixed ESP32 locations (manually set)
fixed_esp32s = {
    "tower_1": (0, 0),
    "tower_2": (5, 0),
    "tower_3": (2, 4),
    "tower_4": (4, 3)
}

# Function to estimate mobile ESP32 location (Simple Weighted Average)
def estimate_location(scan_data):
    x, y, weight_sum = 0, 0, 0
    for tower, rssi in scan_data.items():
        if tower in fixed_esp32s:
            weight = 100 + rssi  # Convert RSSI (-dB) to positive weight
            weight_sum += weight
            x += fixed_esp32s[tower][0] * weight
            y += fixed_esp32s[tower][1] * weight
    
    if weight_sum == 0:
        return None  # Avoid division by zero
    
    return (x / weight_sum, y / weight_sum)

# API to receive scan data from ESP32
@app.route('/locate', methods=['POST'])
def locate():
    data = request.json
    scan_data = data.get("scan_data", {})
    estimated_pos = estimate_location(scan_data)
    print(f"Received scan data: {scan_data}, estimated position: {estimated_pos}")
    if estimated_pos:
        return jsonify({"x": estimated_pos[0], "y": estimated_pos[1]})
    else:
        return jsonify({"error": "No valid data"}), 400

# Serve the front-end map
@app.route('/')
def home():
    return render_template("map.html")

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000, debug=True)
