    <title>ESP Localization Grid</title>
    <style>
        body { font-family: Arial, sans-serif; text-align: center; }
        .grid-container {
            display: grid;
            grid-template-columns: repeat(7, 50px);
            grid-template-rows: repeat(7, 50px);
            gap: 5px;
            justify-content: center;
            margin-top: 20px;
        }
        .grid-item {
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid black;
            background-color: lightgray;
            font-size: 14px;
        }
        .fixed-esp { background-color: blue; color: white; }
        .mobile-esp { background-color: red; color: white; }
    </style>
</head>
<body>
    <h2>ESP32 Localization Grid</h2>
    <div class="grid-container" id="grid"></div>
    
    <script>
        const gridSize = 7; // 7x7 for a 6x6 grid (0-6 index)
        const fixedESPPositions = { 
            "x0y6": true, "x6y6": true, "x6y0": true, "x0y0": true 
        }; // Fixed ESP positions

        function createGrid() {
            const grid = document.getElementById("grid");
            grid.innerHTML = "";

            // Iterate from top (6) to bottom (0)
            for (let y = gridSize - 1; y >= 0; y--) {
                for (let x = 0; x < gridSize; x++) {
                    let cell = document.createElement("div");
                    cell.classList.add("grid-item");
                    cell.id = `x${x}y${y}`;

                    if (fixedESPPositions[cell.id]) {
                        cell.classList.add("fixed-esp");
                        cell.innerText = "📡"; // Fixed ESP
                    }
                    grid.appendChild(cell);
                }
            }
        }

        async function updateMobileESP() {
            try {
                let response = await fetch("/locate", { 
                    method: "POST", 
                    headers: { "Content-Type": "application/json" }, 
                    body: JSON.stringify({ /* Replace with real scan data */ }) 
                });
                let data = await response.json();
                
                if (data.location) {
                    document.querySelectorAll(".mobile-esp").forEach(el => {
                        el.classList.remove("mobile-esp");
                        el.innerText = "";
                    });

                    let mobileESP = document.getElementById(data.location);
                    if (mobileESP) {
                        mobileESP.classList.add("mobile-esp");
                        mobileESP.innerText = "📍"; // Mobile ESP
                    }
                }
            } catch (error) {
                console.error("Error fetching location:", error);
            }
        }
        
        createGrid();
        setInterval(updateMobileESP, 2000);
    </script>
</body>
